<PAGE IMAGENAME="0004_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="854" Y="509" WIDTH="47" HEIGHT="386" CONF="0.842" ORDER="0" STRING="本間宗久翁小傳" />
  <LINE TYPE="本文" X="730" Y="284" WIDTH="17" HEIGHT="19" CONF="0.302" ORDER="1" STRING="本" />
<LINE TYPE="本文" X="778" Y="325" WIDTH="46" HEIGHT="1008" CONF="0.888" ORDER="2" STRING="翁通稱古作、出羽富豪本間氏之族也、本間氏者以大農鳴於海内者也、翁後年" />
  <LINE TYPE="本文" X="729" Y="330" WIDTH="45" HEIGHT="1000" CONF="0.886" ORDER="3" STRING="卜居江戸根岸、以故世人稱之根岸本間氏云、翁資性敏活、着眼奇警、巧察商界" />
  <LINE TYPE="本文" X="680" Y="334" WIDTH="45" HEIGHT="999" CONF="0.911" ORDER="4" STRING="機徴、進退馳驅未曾誤毫厘以故賣買米穀、獲得巨萬利盆、今日本間家得以富" />
  <LINE TYPE="本文" X="630" Y="324" WIDTH="47" HEIGHT="1013" CONF="0.888" ORDER="5" STRING="冠于全国者。雖因其中興之祖四郎三郎大努増殖、抑亦不翁之輔弼之功不居一" />
  <LINE TYPE="本文" X="581" Y="330" WIDTH="45" HEIGHT="888" CONF="0.854" ORDER="6" STRING="多焉、今欲叙翁之畧歴、則先不可不溯宗家本間氏致富之所由來也。" />
  <LINE TYPE="本文" X="532" Y="321" WIDTH="46" HEIGHT="1018" CONF="0.885" ORDER="7" STRING="本間氏本姓佐藤、其先久四郎君、佐渡人也、距今二百五十餘年前落魂來于酒田、" />
  <LINE TYPE="本文" X="484" Y="340" WIDTH="44" HEIGHT="993" CONF="0.892" ORDER="8" STRING="爲本間某家僕、某世々住酒田、以海船問屋爲業、稱爲酒田名家、久四郎君資性" />
  <LINE TYPE="本文" X="435" Y="339" WIDTH="43" HEIGHT="997" CONF="0.901" ORDER="9" STRING="敏活、忠実盡于其職、大爲主所信用、無幾登用主管、會本間某以事見繋獄、託" />
  <LINE TYPE="本文" X="386" Y="341" WIDTH="44" HEIGHT="998" CONF="0.891" ORDER="10" STRING="後事于君、君恐背其委託。勞思勵精、自全舗之監督、至顧客之應接、一以身任。" />
  <LINE TYPE="本文" X="337" Y="340" WIDTH="43" HEIGHT="1001" CONF="0.888" ORDER="11" STRING="之、遂不墜家聲也。已本間氏之寃解歸家、見其資産不減而内外信用如舊也、大" />
  <LINE TYPE="本文" X="287" Y="340" WIDTH="45" HEIGHT="1003" CONF="0.819" ORDER="12" STRING="喜、謝其勞、與本間氏之稱、設支店而令主之、即今之富豪本間家之始祖也、此歳" />
  </PAGE>

</OCRDATASET>