  <LINE TYPE="本文" X="1806" Y="101" WIDTH="31" HEIGHT="1306" CONF="0.427" ORDER="0" STRING="}" />
  <LINE TYPE="本文" X="1768" Y="378" WIDTH="24" HEIGHT="46" CONF="0.399" ORDER="1" STRING="十一" />
  <LINE TYPE="本文" X="1740" Y="1105" WIDTH="24" HEIGHT="50" CONF="0.392" ORDER="2" STRING="一〇二" />
  <LINE TYPE="本文" X="1701" Y="321" WIDTH="32" HEIGHT="629" CONF="0.735" ORDER="3" STRING="景気克く出る時は、其翌月に天井直段が出ると心得るがよい。" />
  <LINE TYPE="本文" X="1639" Y="339" WIDTH="37" HEIGHT="980" CONF="0.398" ORDER="5" STRING="第七章急に儲く可しと思ふ時心尋の事" />
  <LINE TYPE="本文" X="1629" Y="473" WIDTH="37" HEIGHT="547" CONF="0.801" ORDER="6" STRING="第七章急に儲く可しと思ふ時心得の事" />
  <LINE TYPE="本文" X="1536" Y="253" WIDTH="18" HEIGHT="20" CONF="0.398" ORDER="7" STRING="宗" />
  <LINE TYPE="本文" X="1503" Y="253" WIDTH="18" HEIGHT="20" CONF="0.404" ORDER="9" STRING="久" />
  <LINE TYPE="本文" X="1438" Y="253" WIDTH="19" HEIGHT="19" CONF="0.351" ORDER="10" STRING="相" />
  <LINE TYPE="本文" X="1469" Y="253" WIDTH="18" HEIGHT="20" CONF="0.381" ORDER="11" STRING="翁" />
  <LINE TYPE="本文" X="1276" Y="251" WIDTH="16" HEIGHT="17" CONF="0.305" ORDER="12" STRING="眷" />
  <LINE TYPE="本文" X="1567" Y="313" WIDTH="34" HEIGHT="1002" CONF="0.867" ORDER="13" STRING="一急に儲くべしと、商を急ぐ時は、日々の高下に迷ふ故、相塲を追掛け〳〵商致す故、其度毎に損出" />
  <LINE TYPE="本文" X="1523" Y="309" WIDTH="35" HEIGHT="1004" CONF="0.884" ORDER="14" STRING="る也。新米は、上方諸方順氣作合能々相考へ、天井底を考へ、三位の傳に引合せ、買方に付き、始終" />
  <LINE TYPE="本文" X="1481" Y="308" WIDTH="35" HEIGHT="1001" CONF="0.896" ORDER="15" STRING="強氣立拔く可し。春夏の米も、右の順也。附出し大切也、幾月も見合せ、底を見極ると第一也。商仕" />
  <LINE TYPE="本文" X="1442" Y="304" WIDTH="29" HEIGHT="578" CONF="0.829" ORDER="16" STRING="當る時は、見切大切也。商仕舞、四五十日休むと肝要也。" />
  <LINE TYPE="本文" X="1394" Y="314" WIDTH="35" HEIGHT="998" CONF="0.867" ORDER="17" STRING="(釋)急に儲け様と思つて、商内を急ぐ時は、相塲の直幅を大きく見て、相場の跡を追かけ、上げ" />
  <LINE TYPE="本文" X="1352" Y="323" WIDTH="33" HEIGHT="986" CONF="0.891" ORDER="18" STRING="つめてもはや、下げに向はふとする時に買方となり、亦、下げつめて最早上げよふとする處に賣込" />
  <LINE TYPE="本文" X="1308" Y="321" WIDTH="34" HEIGHT="991" CONF="0.907" ORDER="19" STRING="み、あつちに頭をぶつゝけ、此方に頭をぶつゝけ、ドデン〳〵で賣たり買たりするから、其商の度" />
  <LINE TYPE="本文" X="1265" Y="321" WIDTH="33" HEIGHT="991" CONF="0.876" ORDER="20" STRING="毎に、損となる者である。相塲は、天井賣底買の大見込みを立てゝ商すべき者で、中間の小相塲は、" />
  <LINE TYPE="本文" X="1221" Y="322" WIDTH="33" HEIGHT="988" CONF="0.894" ORDER="21" STRING="必勝の要訣と云ふ者はない者である。諸國の作合、順氣の如何、人氣の模樣、在米出米の如何等を" />
  <LINE TYPE="本文" X="1177" Y="323" WIDTH="35" HEIGHT="987" CONF="0.898" ORDER="22" STRING="推理し、天井と底とに意を注ぎ、天井を見付けたら、賣一方、底を見付けたらば買一方に、立派を" />
  <LINE TYPE="本文" X="1133" Y="316" WIDTH="36" HEIGHT="1006" CONF="0.883" ORDER="23" STRING="極めて賣買すべき者で、其商内の踏出しは、尤も大切だから、何百何十日も克く見合せて、天井底一" />
  <LINE TYPE="本文" X="1090" Y="320" WIDTH="34" HEIGHT="991" CONF="0.859" ORDER="24" STRING="の出るのを待つて、商内を仕かけ、そして、利盆は、七八分の處で見切つて利喰をなし、偖四五十" />
  <LINE TYPE="本文" X="911" Y="311" WIDTH="29" HEIGHT="776" CONF="0.868" ORDER="25" STRING="日休んで、靜に相塲の成行を考へ見て、再び商内を付け出すべき者である。" />
  <LINE TYPE="本文" X="842" Y="471" WIDTH="33" HEIGHT="450" CONF="0.839" ORDER="26" STRING="第八章高下の本は作の善惡の事" />
  <LINE TYPE="本文" X="781" Y="309" WIDTH="31" HEIGHT="999" CONF="0.881" ORDER="27" STRING="一作の善惡、高下の本也。其年々、九州、上方、當地近國、並に古米等多少の考、第一也。三位の傳" />
  <LINE TYPE="本文" X="737" Y="299" WIDTH="32" HEIGHT="1015" CONF="0.827" ORDER="28" STRING="と雖も、高下を知る術にはあらず、三位の節に到つて、何等のと出來て、可上の節を知るの術也、深" />
  <LINE TYPE="本文" X="695" Y="300" WIDTH="24" HEIGHT="172" CONF="0.837" ORDER="29" STRING="く考ふ可き者也。" />
  <LINE TYPE="本文" X="652" Y="321" WIDTH="31" HEIGHT="985" CONF="0.888" ORDER="30" STRING="(釋)作柄の善惡、即ち收穫高の多少は、相塲高下の根本であるから、前年よりの餘剩米と、其年" />
  <LINE TYPE="本文" X="608" Y="321" WIDTH="31" HEIGHT="953" CONF="0.862" ORDER="31" STRING="の作柄を考察せよと云ふので、意味は、明瞭ではあるが、疑義のあるのは、三位と云ふ言葉である" />
  <LINE TYPE="本文" X="565" Y="314" WIDTH="31" HEIGHT="925" CONF="0.837" ORDER="32" STRING="併し、此三位と云ふ字は、前章にも屡々説てある術語であるが、此解釋に就ては、三説ある。" />
  <LINE TYPE="本文" X="522" Y="329" WIDTH="30" HEIGHT="835" CONF="0.881" ORDER="33" STRING="第一、三位と云ふ語を、天井の位置、底の位置、又中直の位置と解するのが一説、" />
  <LINE TYPE="本文" X="479" Y="341" WIDTH="26" HEIGHT="510" CONF="0.823" ORDER="34" STRING="第二、は三位を、三年西塞甲月と解するのが一説、" />
  <LINE TYPE="本文" X="435" Y="345" WIDTH="31" HEIGHT="965" CONF="0.891" ORDER="35" STRING="第三、は葛岡翁三位間答の説で、三位と云ふのは、三昧の略であつて、三位の傳と云へば、禪心" />
  <LINE TYPE="本文" X="392" Y="362" WIDTH="32" HEIGHT="945" CONF="0.891" ORDER="36" STRING="を以て、位付の書を以て、相塲の位置を観察し、相塲高下の琴線に觸るゝことゝ、解釋を下し" />
  <LINE TYPE="本文" X="349" Y="364" WIDTH="33" HEIGHT="945" CONF="0.886" ORDER="37" STRING="た。併し、葛岡翁は、右の前兩説も、存立を認めて居つて、告朔の臨羊として居る。重ねて簡" />
  <LINE TYPE="本文" X="303" Y="349" WIDTH="33" HEIGHT="962" CONF="0.827" ORDER="38" STRING="、短に、本章の意味を設けば、相塲高下の原因たる前の數條を計校して、能々考へ、幾月も相待" />
  <LINE TYPE="本文" X="271" Y="1100" WIDTH="21" HEIGHT="51" CONF="0.548" ORDER="39" STRING="一〇三" />
  </PAGE>

