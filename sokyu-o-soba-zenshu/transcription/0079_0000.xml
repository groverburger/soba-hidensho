  <LINE TYPE="本文" X="1684" Y="478" WIDTH="30" HEIGHT="452" CONF="0.880" ORDER="4" STRING="第四十三章大阪相塲五ケ條の事" />
  <LINE TYPE="本文" X="1533" Y="258" WIDTH="16" HEIGHT="20" CONF="0.488" ORDER="5" STRING="宗" />
  <LINE TYPE="本文" X="1500" Y="259" WIDTH="16" HEIGHT="21" CONF="0.505" ORDER="6" STRING="久" />
  <LINE TYPE="本文" X="1468" Y="258" WIDTH="17" HEIGHT="21" CONF="0.527" ORDER="7" STRING="翁" />
  <LINE TYPE="本文" X="1436" Y="257" WIDTH="17" HEIGHT="21" CONF="0.504" ORDER="9" STRING="相" />
  <LINE TYPE="本文" X="1405" Y="256" WIDTH="15" HEIGHT="21" CONF="0.469" ORDER="10" STRING="場" />
  <LINE TYPE="本文" X="1339" Y="258" WIDTH="16" HEIGHT="19" CONF="0.495" ORDER="11" STRING="集" />
  <LINE TYPE="本文" X="1371" Y="259" WIDTH="16" HEIGHT="17" CONF="0.467" ORDER="12" STRING="全" />
