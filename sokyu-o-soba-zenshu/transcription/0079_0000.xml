  <LINE TYPE="本文" X="1274" Y="257" WIDTH="16" HEIGHT="20" CONF="0.498" ORDER="14" STRING="卷" />
  <LINE TYPE="本文" X="1622" Y="307" WIDTH="26" HEIGHT="702" CONF="0.876" ORDER="15" STRING="一大阪九月廿七八日頃の相塲は、東國筋作合、大概相知れ申來る也。" />
  <LINE TYPE="本文" X="1577" Y="308" WIDTH="29" HEIGHT="835" CONF="0.872" ORDER="16" STRING="一大阪十月十七日立代り也、二十日頃迄の相塲申來る故、十一月六日頃着する也。" />
  <LINE TYPE="本文" X="1535" Y="313" WIDTH="27" HEIGHT="598" CONF="0.806" ORDER="17" STRING="一大阪十二月十一日大調べ相場は、十二月廿七八日頃着也。" />
  <LINE TYPE="本文" X="1493" Y="311" WIDTH="25" HEIGHT="554" CONF="0.884" ORDER="18" STRING="一大阪越年米、并に四日初相塲、正月廿四五日頃着也。" />
  <LINE TYPE="本文" X="1448" Y="306" WIDTH="28" HEIGHT="761" CONF="0.840" ORDER="19" STRING="一大阪五月七日立代り也、十日頃迄の相場申來る故、五月廿三四日頃着也。" />
  <LINE TYPE="本文" X="1403" Y="321" WIDTH="30" HEIGHT="999" CONF="0.889" ORDER="20" STRING="(釋)右の各條は、大阪相塲の酒田へ到着する日數を調べて書いた者である。翁當時の交通機關は" />
  <LINE TYPE="本文" X="1360" Y="316" WIDTH="30" HEIGHT="1011" CONF="0.869" ORDER="21" STRING="未だ今日の様に發達をせず、左れば、相場を通知するにも、総て飛脚に書面を持たせて通信をした" />
  <LINE TYPE="本文" X="1317" Y="327" WIDTH="30" HEIGHT="989" CONF="0.841" ORDER="22" STRING="のである。右の本文で見ると、大阪の相塲が。酒田へ知れる迄には、十六日乃至廿日位の時日を要" />
  <LINE TYPE="本文" X="1278" Y="334" WIDTH="22" HEIGHT="141" CONF="0.845" ORDER="23" STRING="したのである。" />
  <LINE TYPE="本文" X="1206" Y="478" WIDTH="30" HEIGHT="389" CONF="0.855" ORDER="24" STRING="第四十四章肥後米立物の事" />
  <LINE TYPE="本文" X="1143" Y="307" WIDTH="29" HEIGHT="1012" CONF="0.785" ORDER="25" STRING="一肥後米立物になる年は、高下荒く、大方上げ勝也。登り詰むる時は、其返し至りて早し、油断なら" />
  <LINE TYPE="本文" X="1102" Y="309" WIDTH="23" HEIGHT="102" CONF="0.847" ORDER="26" STRING="ざる米也。" />
  <LINE TYPE="本文" X="910" Y="476" WIDTH="38" HEIGHT="685" CONF="0.840" ORDER="27" STRING="第四十五章米金差繰易き人並に不自由なる人の事" />
  <LINE TYPE="本文" X="847" Y="305" WIDTH="37" HEIGHT="993" CONF="0.846" ORDER="28" STRING="一米金差繰易き人、買方に向く也。米金不自由なる人は、毎度賣方に向く也。夫故、少しの上にも、" />
  <LINE TYPE="本文" X="804" Y="307" WIDTH="24" HEIGHT="171" CONF="0.851" ORDER="29" STRING="買返しに騒ぐ也。" />
  <LINE TYPE="本文" X="764" Y="328" WIDTH="33" HEIGHT="988" CONF="0.869" ORDER="30" STRING="(釋)米金自由とは、莊内地方の商習慣で、或期限を定めて、米と金との貸借をなし、其期限迄の" />
  <LINE TYPE="本文" X="719" Y="325" WIDTH="35" HEIGHT="994" CONF="0.851" ORDER="31" STRING="間、一方は米を自由にし、一方は金を自由にし、其期限に至つて、互に米と金とを各々元通りに返" />
  <LINE TYPE="本文" X="676" Y="332" WIDTH="24" HEIGHT="171" CONF="0.847" ORDER="32" STRING="濟するのである。" />
  <LINE TYPE="本文" X="633" Y="331" WIDTH="33" HEIGHT="980" CONF="0.886" ORDER="33" STRING="本章の意は。右米金の差繰り易い人、即ち金の自由になる人は、買方に向ひ易い者で、米金の不自" />
  <LINE TYPE="本文" X="587" Y="320" WIDTH="36" HEIGHT="993" CONF="0.867" ORDER="34" STRING="由なる人は、賣方に與みし易い者である。夫故、少しの上にも狼狽して。買戻しに騒ぐ者である。" />
  <LINE TYPE="本文" X="519" Y="482" WIDTH="32" HEIGHT="390" CONF="0.891" ORDER="35" STRING="第四十六章金澤山成時の事" />
  <LINE TYPE="本文" X="458" Y="316" WIDTH="33" HEIGHT="986" CONF="0.871" ORDER="36" STRING="一金澤山なる時は、米安き方也。是米に思入なく、歩金に出る也。金不足の時は、米高き者也。是、" />
  <LINE TYPE="本文" X="416" Y="314" WIDTH="23" HEIGHT="194" CONF="0.777" ORDER="37" STRING="米に思入多き故也。" />
  <LINE TYPE="本文" X="373" Y="321" WIDTH="34" HEIGHT="999" CONF="0.851" ORDER="38" STRING="今日の樣に、金融機關の發達した世の中では、通用貨幣の澤山だ時は、物價が騰貴するのは" />
  <LINE TYPE="本文" X="330" Y="320" WIDTH="33" HEIGHT="1001" CONF="0.819" ORDER="39" STRING="分り切つた理屈ではあるが、本章は、封建時代と云ひ、特に庄内地方てふ極狹い一地方で觀察推理" />
  <LINE TYPE="本文" X="299" Y="1110" WIDTH="21" HEIGHT="52" CONF="0.417" ORDER="40" STRING="一二九" />
