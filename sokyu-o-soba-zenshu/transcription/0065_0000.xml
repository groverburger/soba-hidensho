  <LINE TYPE="本文" X="1817" Y="111" WIDTH="29" HEIGHT="1265" CONF="0.369" ORDER="0" STRING="}" />
  <LINE TYPE="本文" X="1751" Y="1094" WIDTH="24" HEIGHT="51" CONF="0.478" ORDER="1" STRING="一〇〇" />
  <LINE TYPE="本文" X="1682" Y="463" WIDTH="31" HEIGHT="540" CONF="0.864" ORDER="2" STRING="第五章三年塞西の方へ廻る年心得の事" />
  <LINE TYPE="本文" X="1539" Y="243" WIDTH="16" HEIGHT="23" CONF="0.378" ORDER="3" STRING="宗" />
  <LINE TYPE="本文" X="1505" Y="246" WIDTH="17" HEIGHT="20" CONF="0.412" ORDER="4" STRING="久" />
  <LINE TYPE="本文" X="1473" Y="245" WIDTH="17" HEIGHT="22" CONF="0.406" ORDER="5" STRING="鰕" />
  <LINE TYPE="本文" X="1440" Y="246" WIDTH="18" HEIGHT="22" CONF="0.400" ORDER="6" STRING="相" />
  <LINE TYPE="本文" X="1405" Y="246" WIDTH="16" HEIGHT="18" CONF="0.375" ORDER="7" STRING="場" />
  <LINE TYPE="本文" X="1372" Y="246" WIDTH="17" HEIGHT="18" CONF="0.391" ORDER="8" STRING="全" />
  <LINE TYPE="本文" X="1341" Y="246" WIDTH="16" HEIGHT="19" CONF="0.396" ORDER="9" STRING="集" />
  <LINE TYPE="本文" X="1308" Y="246" WIDTH="16" HEIGHT="18" CONF="0.355" ORDER="10" STRING="下" />
  <LINE TYPE="本文" X="1276" Y="247" WIDTH="16" HEIGHT="18" CONF="0.379" ORDER="11" STRING="卷" />
  <LINE TYPE="本文" X="1619" Y="297" WIDTH="31" HEIGHT="1011" CONF="0.875" ORDER="12" STRING="一三年寒西の方へ廻る年は、米大に上る者也。但し、此事相違なし、夫共、御蔵米滯、又は札方申分" />
  <LINE TYPE="本文" X="1576" Y="295" WIDTH="31" HEIGHT="1008" CONF="0.893" ORDER="13" STRING="出て、又数年上作續き、米澤山極安廻りの節、見合せ深く思入立つべからず。右變なく、日本中並に" />
  <LINE TYPE="本文" X="1532" Y="290" WIDTH="30" HEIGHT="1014" CONF="0.874" ORDER="14" STRING="当地上作年にて、年柄より見越し安直段に候はゞ、隨分買入るべし。此三年塞に廻る年は、九州上方" />
  <LINE TYPE="本文" X="1489" Y="285" WIDTH="30" HEIGHT="1033" CONF="0.876" ORDER="15" STRING="当地共に天災ある年也、疑ふ可からず。冬中天井直段出る後、少々引下げ居り、其後十一月正月三月甲" />
  <LINE TYPE="本文" X="1446" Y="296" WIDTH="30" HEIGHT="1014" CONF="0.878" ORDER="16" STRING="に廻る故、此時五六十俵上ある也、疑ふべからず。此事、七月甲に廻る年、日本當地共上作にても見" />
  <LINE TYPE="本文" X="1406" Y="292" WIDTH="24" HEIGHT="425" CONF="0.834" ORDER="17" STRING="合せなく、六月より油斷なく買入るべし。" />
  <LINE TYPE="本文" X="1360" Y="313" WIDTH="30" HEIGHT="967" CONF="0.879" ORDER="18" STRING="(釋)本章は、必らずしも信ずべきことではないが、茲には、翁の本文通りに、解釋を下さう。" />
  <LINE TYPE="本文" X="1315" Y="316" WIDTH="31" HEIGHT="975" CONF="0.874" ORDER="19" STRING="偖卷末の繰方にある、西三年の塞、即ち亥子丑の三ヶ年は、相場が大に上げる者である。此事は、" />
  <LINE TYPE="本文" X="1272" Y="317" WIDTH="30" HEIGHT="984" CONF="0.904" ORDER="20" STRING="是迄の經驗に因ると、十中の八九は間違はないが、夫でも、建米たる券米が、空札發行で不渡だと" />
  <LINE TYPE="本文" X="1229" Y="311" WIDTH="31" HEIGHT="1004" CONF="0.908" ORDER="21" STRING="か、又は、数年來の上作続きで、余剰米が澤山市場に溢れて居ると云ふ樣な年であれば、假令、此" />
  <LINE TYPE="本文" X="1186" Y="318" WIDTH="31" HEIGHT="988" CONF="0.873" ORDER="22" STRING="西三年寒に當る年でも、餘り上げはない者であるから、思惑を立てゝはならない、若し、右の樣な" />
  <LINE TYPE="本文" X="1142" Y="319" WIDTH="31" HEIGHT="982" CONF="0.896" ORDER="23" STRING="事情もなく、日本國中、就中當地方が上作であつて、作柄に比べて割安ならば、十分に買思惑をし" />
  <LINE TYPE="本文" X="1099" Y="321" WIDTH="30" HEIGHT="977" CONF="0.884" ORDER="24" STRING="ても宜しい。此三年寒に廻る年は、是迄の例に依ると、天災ある廻り合せの順になつて居る、此際、" />
  <LINE TYPE="本文" X="761" Y="247" WIDTH="16" HEIGHT="21" CONF="0.336" ORDER="25" STRING="第" />
  <LINE TYPE="本文" X="934" Y="317" WIDTH="32" HEIGHT="985" CONF="0.852" ORDER="26" STRING="冬天井を出した跡に、少し引下げて居る内、十一月甲正月甲三月甲となるから、此時、各五六十俵" />
  <LINE TYPE="本文" X="893" Y="322" WIDTH="23" HEIGHT="214" CONF="0.811" ORDER="27" STRING="の上となる者である。" />
  <LINE TYPE="本文" X="848" Y="319" WIDTH="31" HEIGHT="984" CONF="0.864" ORDER="28" STRING="前に説いた大上の事は、月々干支の繰方で七月甲に回り合せた年は、六月から、油断なく買方に回" />
  <LINE TYPE="本文" X="804" Y="319" WIDTH="31" HEIGHT="985" CONF="0.863" ORDER="29" STRING="るべきである。本文但し書の中に、御蔵米滯りとあるのは、在米の堆積して減らないのを指すの" />
  <LINE TYPE="本文" X="766" Y="323" WIDTH="22" HEIGHT="38" CONF="0.660" ORDER="30" STRING="だ。" />
  <LINE TYPE="本文" X="681" Y="248" WIDTH="16" HEIGHT="20" CONF="0.362" ORDER="31" STRING="天" />
  <LINE TYPE="本文" X="693" Y="471" WIDTH="30" HEIGHT="335" CONF="0.876" ORDER="32" STRING="第六章天一天上日の事" />
  <LINE TYPE="本文" X="602" Y="250" WIDTH="15" HEIGHT="18" CONF="0.308" ORDER="33" STRING="上" />
<LINE TYPE="本文" X="569" Y="251" WIDTH="14" HEIGHT="17" CONF="0.324" ORDER="34" STRING="日" />
  <LINE TYPE="本文" X="536" Y="250" WIDTH="15" HEIGHT="17" CONF="0.319" ORDER="35" STRING="の" />
  <LINE TYPE="本文" X="503" Y="250" WIDTH="16" HEIGHT="18" CONF="0.386" ORDER="36" STRING="事" />
  <LINE TYPE="本文" X="632" Y="304" WIDTH="26" HEIGHT="374" CONF="0.879" ORDER="37" STRING="一天一天上、八専入、丑日、不成日、" />
  <LINE TYPE="本文" X="588" Y="303" WIDTH="30" HEIGHT="1001" CONF="0.884" ORDER="38" STRING="右、米、段々上げ、百俵近く成り、此日に當つて高直段出る時は、是即ち年中行附天井直段也。此後、" />
  <LINE TYPE="本文" X="544" Y="293" WIDTH="30" HEIGHT="1013" CONF="0.852" ORDER="39" STRING="是より高直出ることなし、右三年寒の年、七月甲に廻る年、决して此日天井也。但し、通例の年にても、" />
  <LINE TYPE="本文" X="501" Y="291" WIDTH="31" HEIGHT="1027" CONF="0.862" ORDER="40" STRING="此日天井出るとあれども、多くは稀也、唯の日天井出る也。米段々上げ、百俵近く成り、廿九日晦日" />
  <LINE TYPE="本文" X="459" Y="295" WIDTH="28" HEIGHT="745" CONF="0.895" ORDER="41" STRING="兩日、一二分方も景氣克く出る時は、其次月、天井直段出ると心得べし。" />
  <LINE TYPE="本文" X="415" Y="317" WIDTH="30" HEIGHT="991" CONF="0.879" ORDER="42" STRING="(釋)本章は、三年西塞、七月甲に當る年の經驗を記した者で、西塞の七月甲年は、上げ詰る時は、" />
  <LINE TYPE="本文" X="371" Y="319" WIDTH="31" HEIGHT="987" CONF="0.870" ORDER="43" STRING="斷じて、右の中の一つに當る日、天井を打つ者であるが、其他の年は、極りはなく、右に當らない、" />
  <LINE TYPE="本文" X="328" Y="320" WIDTH="31" HEIGHT="982" CONF="0.854" ORDER="44" STRING="唯の日に、天井を打つ者だ。そして其天井の見樣は、段々と數ケ月上げて來て、晦日頃の内氣配が" />
  <LINE TYPE="本文" X="292" Y="1101" WIDTH="22" HEIGHT="51" CONF="0.502" ORDER="45" STRING="一〇一" />
  </PAGE>

