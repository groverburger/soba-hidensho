  <LINE TYPE="本文" X="1869" Y="66" WIDTH="35" HEIGHT="1276" CONF="0.322" ORDER="1" STRING="…………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………" />
  <LINE TYPE="本文" X="1824" Y="1132" WIDTH="22" HEIGHT="53" CONF="0.379" ORDER="2" STRING="一四四" />
  <LINE TYPE="本文" X="1749" Y="505" WIDTH="32" HEIGHT="447" CONF="0.871" ORDER="3" STRING="第六十五章商急ぐ可からざる事" />
  <LINE TYPE="本文" X="1687" Y="339" WIDTH="32" HEIGHT="1011" CONF="0.877" ORDER="4" STRING="一商進み急ぐ可からず、賣買共に思入進み候時は、今日より外、商塲なき樣に思ふ者なれども、是は" />
  <LINE TYPE="本文" X="1645" Y="337" WIDTH="34" HEIGHT="1023" CONF="0.866" ORDER="5" STRING="功者なき故也。幾月も見合せ、通を考へ、慥なる處にて可仕掛也。無理に、天井直段底直段の考へ" />
  <LINE TYPE="本文" X="1596" Y="284" WIDTH="18" HEIGHT="20" CONF="0.402" ORDER="6" STRING="宗" />
  <LINE TYPE="本文" X="1533" Y="285" WIDTH="17" HEIGHT="20" CONF="0.394" ORDER="7" STRING="翁" />
  <LINE TYPE="本文" X="1564" Y="285" WIDTH="17" HEIGHT="18" CONF="0.403" ORDER="8" STRING="久" />
  <LINE TYPE="本文" X="1500" Y="285" WIDTH="18" HEIGHT="20" CONF="0.376" ORDER="9" STRING="相" />
  <LINE TYPE="本文" X="1467" Y="285" WIDTH="18" HEIGHT="20" CONF="0.376" ORDER="10" STRING="塲" />
  <LINE TYPE="本文" X="1436" Y="286" WIDTH="17" HEIGHT="20" CONF="0.363" ORDER="11" STRING="全" />
  <LINE TYPE="本文" X="1404" Y="286" WIDTH="16" HEIGHT="22" CONF="0.387" ORDER="12" STRING="集" />
  <LINE TYPE="本文" X="1373" Y="286" WIDTH="15" HEIGHT="21" CONF="0.345" ORDER="13" STRING="下" />
  <LINE TYPE="本文" X="1339" Y="287" WIDTH="16" HEIGHT="20" CONF="0.447" ORDER="14" STRING="卷" />
  <LINE TYPE="本文" X="1602" Y="333" WIDTH="26" HEIGHT="463" CONF="0.817" ORDER="15" STRING="なく仕掛る故、手違になる也、是れ急ぐ故也、" />
  <LINE TYPE="本文" X="1558" Y="341" WIDTH="30" HEIGHT="864" CONF="0.845" ORDER="16" STRING="(釋)本章は、上卷第一章の異文である。意味は、已に説てあるから、茲に略する。" />
  <LINE TYPE="本文" X="1487" Y="505" WIDTH="35" HEIGHT="562" CONF="0.807" ORDER="17" STRING="第六十六章心易き人にも賣買進め間敷事" />
  <LINE TYPE="本文" X="1426" Y="340" WIDTH="33" HEIGHT="1010" CONF="0.902" ORDER="18" STRING="一何程心易き人にも、賣買進め申間敷也。若し了簡違ふ時は、恨みを得る也。總て、相塲高下の論致" />
  <LINE TYPE="本文" X="1383" Y="338" WIDTH="32" HEIGHT="1009" CONF="0.892" ORDER="19" STRING="まじき也、此道を心得る人は、我了簡を立てず、人の了簡にて商する人はなき筈也。少々にても圖に" />
  <LINE TYPE="本文" X="1340" Y="336" WIDTH="33" HEIGHT="1012" CONF="0.897" ORDER="20" STRING="当る時は、募り、了簡を立たがる者也。是第一可愼處也。勿論、慥なる高下を見定め打明け人に語り" />
  <LINE TYPE="本文" X="1296" Y="325" WIDTH="34" HEIGHT="1034" CONF="0.887" ORDER="21" STRING="進むる時は、人も其気になる故、二三俵方も利を得る人は、一俵方ならで利運ならざる者也、慥なる" />
  <LINE TYPE="本文" X="1253" Y="342" WIDTH="34" HEIGHT="1005" CONF="0.872" ORDER="22" STRING="處を見据へ候はゞ、人々に拘はらずして、賣買可致候。尤も世の中に隨ひ、諸國作合、豐作凶作、上" />
  <LINE TYPE="本文" X="1209" Y="325" WIDTH="35" HEIGHT="1029" CONF="0.839" ORDER="23" STRING="方相場、九州様子、聞合せ随分宜しき也。存念は、決して人に語る可からず、是大極意也。常々専ら" />
  <LINE TYPE="本文" X="1163" Y="340" WIDTH="28" HEIGHT="104" CONF="0.845" ORDER="24" STRING="慎むべし。" />
  </PAGE>

