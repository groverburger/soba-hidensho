  <LINE TYPE="本文" X="1714" Y="318" WIDTH="18" HEIGHT="34" CONF="0.432" ORDER="9" STRING="る。" />
  <LINE TYPE="本文" X="1752" Y="1088" WIDTH="20" HEIGHT="38" CONF="0.489" ORDER="10" STRING="七四" />
  <LINE TYPE="本文" X="1663" Y="314" WIDTH="30" HEIGHT="990" CONF="0.820" ORDER="11" STRING="其外、七八月天井となるべき年を擧げれば、六月頃不順て、前途に不作の案じある時に出る者で、此不" />
  <LINE TYPE="本文" X="1619" Y="316" WIDTH="31" HEIGHT="985" CONF="0.859" ORDER="12" STRING="作の案じある年は、酒田米會所の商習慣で、新米商六月から發會を延期するの例であるから、三十" />
  <LINE TYPE="本文" X="1576" Y="316" WIDTH="30" HEIGHT="984" CONF="0.893" ORDER="13" STRING="俵臺の相塲であるならば、五六月の相場の安い内に買入れて置き、正米ならば、變質桝減り杯の恐" />
  <LINE TYPE="本文" X="1533" Y="315" WIDTH="30" HEIGHT="983" CONF="0.888" ORDER="14" STRING="れがあり、又賣方に仕拂ふ可き利足等、夫等の見積りを二三十俵と見込み、夫を歩金(歩金とは米" />
  <LINE TYPE="本文" X="1489" Y="307" WIDTH="31" HEIGHT="1003" CONF="0.883" ORDER="15" STRING="券を抵當にして金を借ると猶質入と云ふが如し)杯にして、八月の上を待つべきである。尤も、七" />
  <LINE TYPE="本文" X="1445" Y="314" WIDTH="31" HEIGHT="984" CONF="0.887" ORDER="16" STRING="月に格外の高直が出だら、八月を待たずに利喰するがよい。是は余が、嚮きに已に述べた、五月下" />
  <LINE TYPE="本文" X="1402" Y="312" WIDTH="30" HEIGHT="983" CONF="0.864" ORDER="17" STRING="る時は六月急上也と云ふ意味と同じ事で、通例の年、三四月から五六月迄夏上げの年は、決して八" />
  <LINE TYPE="本文" X="1363" Y="310" WIDTH="23" HEIGHT="314" CONF="0.910" ORDER="18" STRING="月上げがないと心得るが宜い。" />
  <LINE TYPE="本文" X="1290" Y="458" WIDTH="31" HEIGHT="567" CONF="0.859" ORDER="19" STRING="第五十二章冬より春迄金拂底大崩しの事" />
  <LINE TYPE="本文" X="1230" Y="284" WIDTH="27" HEIGHT="654" CONF="0.912" ORDER="20" STRING="一冬中より春迄も金拂底の年は、思入買多き故、金不足する也。" />
  <LINE TYPE="本文" X="1185" Y="289" WIDTH="31" HEIGHT="1003" CONF="0.842" ORDER="21" STRING="此年、五月迄に下らざる時は、六月廿日頃に大崩れ疑なし。左様の年、七月甲に廻らば、七月六七十" />
  <LINE TYPE="本文" X="1141" Y="290" WIDTH="32" HEIGHT="1000" CONF="0.877" ORDER="22" STRING="俵上るべし。明和五年、天井直段より百六七十俵下にて、此上の下げ稀也。寛政十一年、百五十俵下、" />
  <LINE TYPE="本文" X="1099" Y="291" WIDTH="30" HEIGHT="1004" CONF="0.869" ORDER="23" STRING="同十二申六月十三日百俵下也。底直段三年続也。七月甲に廻る時は、下に向かば油断なく賣付け、十" />
  <LINE TYPE="本文" X="951" Y="292" WIDTH="27" HEIGHT="606" CONF="0.874" ORDER="24" STRING="二三日も見計らい、百俵下を的にして、買返し買過すべし。" />
  <LINE TYPE="本文" X="907" Y="299" WIDTH="36" HEIGHT="1020" CONF="0.905" ORDER="25" STRING="宗久翁當時に在ては、金融機關が、今日の樣に發達しないて、資金を下すの途も、今日の如" />
  <LINE TYPE="本文" X="864" Y="313" WIDTH="34" HEIGHT="996" CONF="0.882" ORDER="26" STRING="くに多くないのである。故に、我莊内地方も、資本の用途は米を思惑するとか、亦は他の商品を思" />
  <LINE TYPE="本文" X="821" Y="316" WIDTH="33" HEIGHT="986" CONF="0.904" ORDER="27" STRING="惑するとかに留まつた者で、其處で、此理由からして推考へて見ると、冬中より春頃迄も、市塲に" />
  <LINE TYPE="本文" X="778" Y="320" WIDTH="33" HEIGHT="977" CONF="0.907" ORDER="28" STRING="通用金が拂底である年は、米に思入買の多い證據であつて、ケ樣な年は、五月比迄に下らない時は、" />
  <LINE TYPE="本文" X="735" Y="315" WIDTH="34" HEIGHT="989" CONF="0.875" ORDER="29" STRING="六月下旬頃迄に、必らず大崩れをする者で、此年七月甲に當れば、七月に六七十俵も上るだらう。" />
  <LINE TYPE="本文" X="691" Y="314" WIDTH="33" HEIGHT="996" CONF="0.888" ORDER="30" STRING="「下げに向たならば、油斷なく賣付けよ、第一の天井は中々見付け惡い故、十二三日も見計つて、第" />
  <LINE TYPE="本文" X="649" Y="321" WIDTH="32" HEIGHT="984" CONF="0.876" ORDER="31" STRING="二の天井を油斷なく賣付け、百俵下げを標凖として、其時の人氣を見て、早速に利喰し、時として" />
  <LINE TYPE="本文" X="605" Y="315" WIDTH="23" HEIGHT="198" CONF="0.818" ORDER="32" STRING="一買過すべきである。" />
  <LINE TYPE="本文" X="537" Y="475" WIDTH="32" HEIGHT="562" CONF="0.849" ORDER="33" STRING="第五十三章天井直段底直段三年續きの事" />
  <LINE TYPE="本文" X="475" Y="314" WIDTH="31" HEIGHT="991" CONF="0.863" ORDER="34" STRING="一天井直段、底直段、三ケ年續く者とあり。此事、天井直段計りと思ふ可からず。底直段も三年續く" />
  <LINE TYPE="本文" X="431" Y="302" WIDTH="28" HEIGHT="488" CONF="0.883" ORDER="35" STRING="也。常の年にも有るなれば、能々気を付くべし。" />
  <LINE TYPE="本文" X="387" Y="319" WIDTH="34" HEIGHT="992" CONF="0.867" ORDER="36" STRING="(釋)葛岡倉の三位間答には、之を高廻り三年續けば、安廻りが又三ケ年續く者で、其間には、高" />
  <LINE TYPE="本文" X="343" Y="311" WIDTH="33" HEIGHT="1007" CONF="0.832" ORDER="37" STRING="廻りとも安廻りとも付かない中の年があるから、三年宛循環して、殆んど拾年毎に、大高廻りと云" />
  <LINE TYPE="本文" X="309" Y="1101" WIDTH="22" HEIGHT="38" CONF="0.497" ORDER="38" STRING="七五" />
