  <LINE TYPE="本文" X="1775" Y="329" WIDTH="23" HEIGHT="1124" CONF="0.301" ORDER="0" STRING="…………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………" />
<LINE TYPE="本文" X="1531" Y="282" WIDTH="15" HEIGHT="19" CONF="0.407" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1337" Y="282" WIDTH="17" HEIGHT="17" CONF="0.331" ORDER="2" STRING="塲" />
  <LINE TYPE="本文" X="1385" Y="282" WIDTH="17" HEIGHT="18" CONF="0.351" ORDER="3" STRING="相" />
  <LINE TYPE="本文" X="1481" Y="282" WIDTH="16" HEIGHT="19" CONF="0.364" ORDER="4" STRING="久" />
  <LINE TYPE="本文" X="1434" Y="282" WIDTH="16" HEIGHT="18" CONF="0.376" ORDER="5" STRING="翁" />
  <LINE TYPE="本文" X="1672" Y="332" WIDTH="35" HEIGHT="992" CONF="0.864" ORDER="6" STRING="庄内之地連年豊饒、米價大賤、久四郎君竊以爲、雖今以田大稔米價大賤也。秋" />
  <LINE TYPE="本文" X="1622" Y="331" WIDTH="35" HEIGHT="990" CONF="0.880" ORDER="7" STRING="去冬來、有人爭買則米價昂騰可レ知而已、則擧全力買収正米、果然諸國商人聞" />
  <LINE TYPE="本文" X="1573" Y="332" WIDTH="35" HEIGHT="994" CONF="0.898" ORDER="8" STRING="庄内米價特賤、爭先來買、是以需要超二于供給、米價俄騰、君乘機賣會所買正米、" />
  <LINE TYPE="本文" X="1523" Y="320" WIDTH="36" HEIGHT="1013" CONF="0.893" ORDER="9" STRING="一擧得于金之利矣、君自後連年従事米穀之売買、頻収利益、久四郎君沒子某君一" />
  <LINE TYPE="本文" X="1475" Y="326" WIDTH="33" HEIGHT="962" CONF="0.885" ORDER="10" STRING="嗣、早世、其子四郎三郎君承後、四郎三郎號宗善、實爲本間家中興之偉人也。" />
  <LINE TYPE="本文" X="1426" Y="323" WIDTH="33" HEIGHT="994" CONF="0.899" ORDER="11" STRING="宗久翁以亨保二年生于出羽國田川郡新堀村、幼爲本間氏二世之猶子、娶其" />
  <LINE TYPE="本文" X="1376" Y="326" WIDTH="35" HEIGHT="995" CONF="0.899" ORDER="12" STRING="女二世卒、四郎三郎君尚幼、翁以其叔父、權掘家政、居于下藏、下藏酒田船塲町" />
  <LINE TYPE="本文" X="1326" Y="319" WIDTH="36" HEIGHT="1007" CONF="0.904" ORDER="13" STRING="之一隅、而本間家倉庫之所在也、翁謂夫欲以商業致富者、不可不擇其販路廣" />
  <LINE TYPE="本文" X="1277" Y="325" WIDTH="35" HEIGHT="987" CONF="0.884" ORDER="14" STRING="而賣買之圓滑者也、抑兩羽之地、美田沃野亘數十里、古來以産米聞于世矣、" />
  <LINE TYPE="本文" X="1227" Y="325" WIDTH="36" HEIGHT="992" CONF="0.910" ORDER="15" STRING="加之有最上川廻漕之便、有佳良港灣、運漕之利甚多矣、且酒田有米會所之設、" />
  <LINE TYPE="本文" X="1178" Y="327" WIDTH="35" HEIGHT="990" CONF="0.917" ORDER="16" STRING="有大圓滑賣買者夫吾所可從事者其米賈也乎、從是潜心于米價高底之理、放" />
  <LINE TYPE="本文" X="1129" Y="331" WIDTH="36" HEIGHT="984" CONF="0.907" ORDER="17" STRING="眼觀察人氣之變遷、數年于茲、一旦豁然有所悟焉、爾後從米穀之賣買、賣則賤、" />
  <LINE TYPE="本文" X="1080" Y="327" WIDTH="35" HEIGHT="987" CONF="0.870" ORDER="18" STRING="買則騰、莫所爲不有利、忽羸得數萬金會四郎三郎君自播州歸酒田、翁擧其" />
  <LINE TYPE="本文" X="887" Y="311" WIDTH="45" HEIGHT="992" CONF="0.871" ORDER="19" STRING="利益分附之、携妻妻学遊子大阪、大阪古來以米市場絶全国、所謂米商之本" />
  <LINE TYPE="本文" X="837" Y="315" WIDTH="47" HEIGHT="987" CONF="0.900" ORDER="20" STRING="塲者也、翁亦投此、常制機先、其手腕之妙使數世市賈瞠若于後、於是復得巨萬" />
  <LINE TYPE="本文" X="789" Y="311" WIDTH="45" HEIGHT="994" CONF="0.903" ORDER="21" STRING="之利矣、還至江戸、方此時翁已富累巨萬、謂米賈非子孫之計、欲仕上野輪王" />
  <LINE TYPE="本文" X="738" Y="301" WIDTH="48" HEIGHT="1011" CONF="0.899" ORDER="22" STRING="一寺宮而未得其途也、會寛水寺鑄大鐘、鐘成甚重、雑懸于鐘楼、翁乃建言運米" />
  <LINE TYPE="本文" X="690" Y="301" WIDTH="46" HEIGHT="1007" CONF="0.912" ORDER="23" STRING="一苞山積鐘樓之側、緩勾配、推轉巨鐘、令逹其項、因得不勞而懸之矣、宮聞之、" />
  <LINE TYPE="本文" X="641" Y="305" WIDTH="45" HEIGHT="997" CONF="0.896" ORDER="24" STRING="謂警敏可用、召任相摸守、乃搆邸宅于根岸居焉、翁老譲家于養子猪四郎君、" />
  <LINE TYPE="本文" X="591" Y="297" WIDTH="45" HEIGHT="1019" CONF="0.913" ORDER="25" STRING="以享和三年八月晦卒于根岸邸、享年八十七。葬于下谷坂本町隨徳寺、法名曰。" />
  <LINE TYPE="本文" X="541" Y="308" WIDTH="44" HEIGHT="1000" CONF="0.884" ORDER="26" STRING="光信院釋宗久、翁之進事不多傳、唯云翁尚在酒田住于下藏也、酒田中町有搗" />
  <LINE TYPE="本文" X="493" Y="310" WIDTH="43" HEIGHT="998" CONF="0.911" ORDER="27" STRING="米者善兵衞者、世々爲本間家所眷顧、曾機暮年買米、失算殆蕩盡家産、尚負" />
  <LINE TYPE="本文" X="444" Y="314" WIDTH="44" HEIGHT="996" CONF="0.894" ORDER="28" STRING="債三百金也、翁使入候其状、還報曰渠裸體體掲米、流汗淋漓、翁聞之以爲繻子可" />
  <LINE TYPE="本文" X="394" Y="316" WIDTH="45" HEIGHT="998" CONF="0.914" ORDER="29" STRING="助矣、召之問曰、聞汝負債数百金、而日搗米二白若三臼、安得恢復之乎、善兵答" />
  <LINE TYPE="本文" X="344" Y="312" WIDTH="46" HEIGHT="1006" CONF="0.888" ORDER="30" STRING="曰、誠如貴言、然奴有妻子在、不可令以一日泣飢寒也、搗米聊資生計耳、若夫" />
  <LINE TYPE="本文" X="294" Y="320" WIDTH="46" HEIGHT="990" CONF="0.865" ORDER="31" STRING="恢復之方、則別有所期于後日也、翁曰聞汝買焉而失矣、今若有資金。欲賣買孰" />
  <LINE TYPE="本文" X="268" Y="1117" WIDTH="22" HEIGHT="24" CONF="0.347" ORDER="32" STRING="三" />
  </PAGE>

