<PAGE IMAGENAME="0046_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1809" Y="100" WIDTH="22" HEIGHT="1182" CONF="0.314" ORDER="0" STRING="}" />
  <LINE TYPE="本文" X="1511" Y="264" WIDTH="16" HEIGHT="20" CONF="0.371" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1480" Y="266" WIDTH="15" HEIGHT="17" CONF="0.313" ORDER="2" STRING="久" />
<LINE TYPE="本文" X="1728" Y="1104" WIDTH="25" HEIGHT="42" CONF="0.437" ORDER="3" STRING="六二" />
  <LINE TYPE="本文" X="1683" Y="333" WIDTH="32" HEIGHT="989" CONF="0.881" ORDER="4" STRING="偖、毎年新米の出初る頃は、其年の作柄の如何を考へ、前々よりの罫線表に照して、直段の程合を" />
  <LINE TYPE="本文" X="1638" Y="332" WIDTH="34" HEIGHT="991" CONF="0.903" ORDER="5" STRING="考へ置く可きである。一體、秋の米と云ふ者は、買に利のあつて賣に利のない者である。何故と云" />
  <LINE TYPE="本文" X="1594" Y="322" WIDTH="35" HEIGHT="993" CONF="0.876" ORDER="6" STRING="・ふに、其年順氣がよくつて上作なれば、直段は夫丈下位になつて居て、賣るの餘地はなし、亦、鎌" />
  <LINE TYPE="本文" X="1551" Y="321" WIDTH="33" HEIGHT="891" CONF="0.874" ORDER="7" STRING="入不足、秋日和の不良杯を唱へて上げ勝の者だからである。故に翁も、其心得に就て、" />
  <LINE TYPE="本文" X="1508" Y="333" WIDTH="31" HEIGHT="609" CONF="0.847" ORDER="8" STRING="◎夏中天災有之時、六七月より油断なく買入るべし、云々。" />
  <LINE TYPE="本文" X="1465" Y="328" WIDTH="34" HEIGHT="993" CONF="0.887" ORDER="9" STRING="◎六七月、順気克く旱続き上作の取沙汰、一分の見聞にも上作と見ゆる年買急かず、八九月専ら年の" />
  <LINE TYPE="本文" X="1423" Y="361" WIDTH="23" HEIGHT="143" CONF="0.882" ORDER="10" STRING="買塲也、云々。" />
  <LINE TYPE="本文" X="1380" Y="339" WIDTH="32" HEIGHT="983" CONF="0.855" ORDER="11" STRING="◎六月末七月中旬迄も、何十年にもなき上作と沙汰しても、河等のと出來て、多少に限らず違作に" />
  <LINE TYPE="本文" X="1337" Y="361" WIDTH="24" HEIGHT="166" CONF="0.863" ORDER="12" STRING="なる者也、云々。" />
  <LINE TYPE="本文" X="1295" Y="343" WIDTH="31" HEIGHT="979" CONF="0.875" ORDER="13" STRING="い買方は、數月の利拂上の程知れず、甚た買惡き者なれ共、利運に向く時は、利米は風前の塵にて" />
  <LINE TYPE="本文" X="1250" Y="350" WIDTH="30" HEIGHT="650" CONF="0.808" ORDER="14" STRING="苦にならず、且多少に限らず秋米は上らずと云ふとなし、云々。" />
  <LINE TYPE="本文" X="1207" Y="338" WIDTH="32" HEIGHT="986" CONF="0.904" ORDER="15" STRING="抔、色々に注意を與へて居る。右に説く如く、秋相塲と云ふ者は、八九分上勝の者であるから、少" />
  <LINE TYPE="本文" X="1162" Y="341" WIDTH="34" HEIGHT="984" CONF="0.900" ORDER="16" STRING="し自分の心に叶はなくとも、買方に廻るべきである。併し、克々買氣になれぬならば、商を休むが" />
  <LINE TYPE="本文" X="1120" Y="337" WIDTH="32" HEIGHT="989" CONF="0.874" ORDER="17" STRING="よい。秋相場の天井直段の出ない内は、險呑だから決して賣てはならぬ。買方針を忘れぬ機に、心" />
  <LINE TYPE="本文" X="1075" Y="334" WIDTH="34" HEIGHT="992" CONF="0.875" ORDER="18" STRING="掛けるがよい。眞正の賣塲と云ふのは、上げ過し天井を出し、各地の相塲と比較して、割高になつ" />
  <LINE TYPE="本文" X="928" Y="330" WIDTH="29" HEIGHT="985" CONF="0.834" ORDER="19" STRING="た塲合の外ない者である。其外、持合相塲の時賣に廻る時は、損に極まつて居る樣な者だ。又、底か" />
  <LINE TYPE="本文" X="885" Y="335" WIDTH="31" HEIGHT="988" CONF="0.880" ORDER="20" STRING="ら少し宛ツクリ〳〵と下る米は、上げとなると通ひなしに臺替りとなつて上るから、恐ろしい者て" />
  <LINE TYPE="本文" X="844" Y="335" WIDTH="29" HEIGHT="985" CONF="0.885" ORDER="21" STRING="ある。其譯は、相塲が弱々しく見へる爲め、強弱共賣込て空賣が多いから、一旦上に向くと、一度" />
  <LINE TYPE="本文" X="803" Y="333" WIDTH="25" HEIGHT="575" CONF="0.888" ORDER="22" STRING="に買戻しに騒くから、勘定なしに急上げになる故てある。" />
  <LINE TYPE="本文" X="732" Y="482" WIDTH="30" HEIGHT="419" CONF="0.856" ORDER="23" STRING="第四十七章売方駈引六ケ敷事" />
  <LINE TYPE="本文" X="530" Y="262" WIDTH="16" HEIGHT="20" CONF="0.316" ORDER="24" STRING="夥" />
  <LINE TYPE="本文" X="669" Y="316" WIDTH="29" HEIGHT="1012" CONF="0.855" ORDER="25" STRING="一一ヶ年の内、上げ一度、下げ一度の外は大高下なしとす。上の内にも少々の下、下の内にも少々の上" />
  <LINE TYPE="本文" X="626" Y="314" WIDTH="31" HEIGHT="1012" CONF="0.866" ORDER="26" STRING="あり。是は、通相塲にて天井底を見る相塲にあらず。通の高下に迷ふべからず。總べて踏出しは大切" />
  <LINE TYPE="本文" X="582" Y="312" WIDTH="31" HEIGHT="1007" CONF="0.886" ORDER="27" STRING="也。買出候は、思やみなる者なれども、利運に向く時、少しも苦身なき者也。賣方は、心易き者なれ" />
  <LINE TYPE="本文" X="539" Y="315" WIDTH="30" HEIGHT="999" CONF="0.866" ORDER="28" STRING="ども、甚だ駈引六ケ敷者也。下げかゝる時は、何程下るも知れぬ樣になり、買返し後るゝ者也。下の" />
  <LINE TYPE="本文" X="499" Y="311" WIDTH="25" HEIGHT="537" CONF="0.903" ORDER="29" STRING="調子、人の騒ぎに乗らず、欲を離れ買返すと第一也。" />
  <LINE TYPE="本文" X="453" Y="327" WIDTH="30" HEIGHT="993" CONF="0.864" ORDER="30" STRING="本章は、賣方駈引の心得を述べた者である。偖、大抵一年の内、其前後の違はあるが、天井" />
  <LINE TYPE="本文" X="409" Y="327" WIDTH="31" HEIGHT="991" CONF="0.903" ORDER="31" STRING="一迄の上げ一度、又天井より底迄の下げ一度の外はない者で、併し、其上げる内にも少々の下け、又" />
  <LINE TYPE="本文" X="367" Y="328" WIDTH="31" HEIGHT="992" CONF="0.892" ORDER="32" STRING="下げの内にも少々上げるとがあるが、是は上の内の通下け、又下の内の通上げてあつて、直ぐに底" />
  <LINE TYPE="本文" X="322" Y="332" WIDTH="31" HEIGHT="983" CONF="0.802" ORDER="33" STRING="よりの上相塲、又天井よりの下相塲ではないから、其通相塲に迷ふてはならぬ。總べて、商内の付" />
  <LINE TYPE="本文" X="284" Y="1102" WIDTH="21" HEIGHT="44" CONF="0.544" ORDER="34" STRING="六三" />
  </PAGE>

