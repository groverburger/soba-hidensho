          ]
        ],
        "id": 16,
        "isVertical": "true",
        "text": "定めて下る也。下相場の竇付は、一ケ月切に仕舞ふ者也。夫共に、極引上げ乗米なしの處にて二三ケ",
        "isTextline": "true",
        "confidence": 0.887
