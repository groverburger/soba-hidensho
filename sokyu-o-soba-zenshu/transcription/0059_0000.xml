  <LINE TYPE="本文" X="1822" Y="317" WIDTH="22" HEIGHT="1104" CONF="0.307" ORDER="0" STRING="一" />
  <LINE TYPE="本文" X="1396" Y="244" WIDTH="16" HEIGHT="20" CONF="0.405" ORDER="1" STRING="金" />
  <LINE TYPE="本文" X="1427" Y="244" WIDTH="20" HEIGHT="21" CONF="0.368" ORDER="2" STRING="場" />
  <LINE TYPE="本文" X="1459" Y="245" WIDTH="21" HEIGHT="21" CONF="0.379" ORDER="3" STRING="相" />
  <LINE TYPE="本文" X="1493" Y="246" WIDTH="17" HEIGHT="19" CONF="0.372" ORDER="4" STRING="鍋" />
  <LINE TYPE="本文" X="1525" Y="246" WIDTH="17" HEIGHT="19" CONF="0.395" ORDER="5" STRING="次" />
  <LINE TYPE="本文" X="1557" Y="246" WIDTH="19" HEIGHT="21" CONF="0.420" ORDER="6" STRING="宗" />
  <LINE TYPE="本文" X="1363" Y="244" WIDTH="17" HEIGHT="20" CONF="0.437" ORDER="7" STRING="集" />
  <LINE TYPE="本文" X="1331" Y="245" WIDTH="17" HEIGHT="18" CONF="0.457" ORDER="8" STRING="上" />
  <LINE TYPE="本文" X="1298" Y="242" WIDTH="17" HEIGHT="21" CONF="0.487" ORDER="9" STRING="卷" />
  <LINE TYPE="本文" X="1759" Y="1095" WIDTH="22" HEIGHT="41" CONF="0.461" ORDER="10" STRING="廿八" />
  <LINE TYPE="本文" X="1718" Y="311" WIDTH="36" HEIGHT="993" CONF="0.850" ORDER="11" STRING="例へば、此米は大體上げの米ではあるが、少し上げは後れるであらう、まだ云々の弱原因があるか" />
  <LINE TYPE="本文" X="1673" Y="294" WIDTH="38" HEIGHT="1023" CONF="0.906" ORDER="12" STRING="ら、目先」と下げするであらう。其處を買掬はふ抔と、一寸賣つて見るとある者だが、是は决して" />
  <LINE TYPE="本文" X="1630" Y="304" WIDTH="36" HEIGHT="1008" CONF="0.873" ORDER="13" STRING="すべきとてはない。果して、下げと思ふ頃から反對に上る者である。人間と云ふ者は、我慢心の強" />
  <LINE TYPE="本文" X="1587" Y="305" WIDTH="36" HEIGHT="1004" CONF="0.887" ORDER="14" STRING="い者で、自分が、是非下げるだらうと賣付る時に、見込の反對に上げられると、尚々其處で買兼ね、" />
  <LINE TYPE="本文" X="1546" Y="293" WIDTH="36" HEIGHT="1025" CONF="0.898" ORDER="15" STRING="踏跟因循して居る内に買後れて、遂には燒を起して、買入るべき月に、却て賣る樣になる者で、大" />
  <LINE TYPE="本文" X="1503" Y="302" WIDTH="36" HEIGHT="1006" CONF="0.858" ORDER="16" STRING="の損をする者であるから、大に愼むべく、若し、來月上ると見込んだなら、押目の買塲を待つべきで" />
  <LINE TYPE="本文" X="1473" Y="305" WIDTH="20" HEIGHT="75" CONF="0.682" ORDER="17" STRING="ある。" />
  <LINE TYPE="本文" X="1469" Y="303" WIDTH="28" HEIGHT="67" CONF="0.372" ORDER="18" STRING="ある。" />
  <LINE TYPE="本文" X="1394" Y="452" WIDTH="36" HEIGHT="582" CONF="0.862" ORDER="19" STRING="第六十七章一分の存念にて賣買無用の事" />
  <LINE TYPE="本文" X="1330" Y="308" WIDTH="34" HEIGHT="991" CONF="0.876" ORDER="20" STRING="一我一分の了簡にて、賣買决して致し間敷也。三位の傳を表にし、立羽を極め、賣買の内立拔く可し" />
  <LINE TYPE="本文" X="1287" Y="314" WIDTH="35" HEIGHT="984" CONF="0.901" ORDER="21" STRING="本文に我一分の了簡にて商すべからずとあつて、自分の了簡て商してはならぬと、檢束する" />
  <LINE TYPE="本文" X="1243" Y="314" WIDTH="36" HEIGHT="985" CONF="0.898" ORDER="22" STRING="者とすれば、我見込て商してはならぬと云樣に聞へて、大に反對を唱へたくなるが、我一分のと云" />
  <LINE TYPE="本文" X="1198" Y="314" WIDTH="38" HEIGHT="987" CONF="0.881" ORDER="23" STRING="ふ三字が目の附け處で、天井底の位取の考もなく、又賣主義買主義の定りもなく、輕忽に賣買する" />
  <LINE TYPE="本文" X="1156" Y="313" WIDTH="34" HEIGHT="987" CONF="0.887" ORDER="24" STRING="とを訓戒した者で、翁の意は、月の十干を繰り合せ、又上下の月數俵數を位付の書を見て覺り、賞" />
  <LINE TYPE="本文" X="1115" Y="310" WIDTH="32" HEIGHT="894" CONF="0.861" ORDER="25" STRING="なら賣、買なら買と、一定の主義が定まつた後に、始めて商内を付出せと云ふのである。" />
  <LINE TYPE="本文" X="471" Y="238" WIDTH="449" HEIGHT="38" CONF="0.303" ORDER="26" STRING="を傳の位三章九十六第事候れ連に下高くなも羽立章八十六年" />
<LINE TYPE="本文" X="896" Y="401" WIDTH="41" HEIGHT="599" CONF="0.874" ORDER="27" STRING="第六十八章立羽もなく高下に連れ候事" />
  <LINE TYPE="本文" X="834" Y="288" WIDTH="44" HEIGHT="1030" CONF="0.899" ORDER="28" STRING="一来の高下に連れ、立端もなく、上くべし下く可しと商致し、五六日も過ぎ、米の動きに連れ、弱気" />
  <LINE TYPE="本文" X="793" Y="296" WIDTH="41" HEIGHT="1008" CONF="0.876" ORDER="29" STRING="になり、其節賣過致し、十四五日も過ぎ、又々買氣になり、其度毎に損出る也。是は、商を急ぎ、是" />
  <LINE TYPE="本文" X="749" Y="297" WIDTH="40" HEIGHT="1007" CONF="0.870" ORDER="30" STRING="非共取る心にて致す故違ふ也。欲を離れ、天井底を見定め、上ならば上、下ならば下と、立羽を極" />
  <LINE TYPE="本文" X="705" Y="292" WIDTH="32" HEIGHT="511" CONF="0.862" ORDER="31" STRING="め、三位傳に引合せ、賣なり買なりと立拔く可し。" />
  <LINE TYPE="本文" X="663" Y="314" WIDTH="41" HEIGHT="984" CONF="0.903" ORDER="32" STRING="(釋)本章は、主義なき商内の損失に終る理由を明かにした者で、買主義とか、又賣主義とか、一" />
  <LINE TYPE="本文" X="619" Y="318" WIDTH="42" HEIGHT="982" CONF="0.899" ORDER="33" STRING="定の立派がない時には、相場弱く見へると賣方となり、ドテン賣し、又少し上るとドテンして買方" />
  <LINE TYPE="本文" X="577" Y="317" WIDTH="41" HEIGHT="987" CONF="0.891" ORDER="34" STRING="に變るから、其決算の度毎に、損となる者である。是は、主として勝を急ぐから起るので、かゝる" />
  <LINE TYPE="本文" X="535" Y="318" WIDTH="40" HEIGHT="983" CONF="0.904" ORDER="35" STRING="商内は、見込のないのに、無理に見込を付けるから、必らず損となるものである。故に、欲心を離" />
  <LINE TYPE="本文" X="489" Y="317" WIDTH="43" HEIGHT="989" CONF="0.876" ORDER="36" STRING="れ、上げ下げ通ひ等を残らず取る心にならずに、賣なり買なり、一定の主義を立てゝ、上か下か、" />
  <LINE TYPE="本文" X="448" Y="324" WIDTH="28" HEIGHT="368" CONF="0.873" ORDER="37" STRING="一方の高下を取る工夫をするがよい。" />
  <LINE TYPE="本文" X="377" Y="469" WIDTH="41" HEIGHT="570" CONF="0.838" ORDER="38" STRING="第六十九章三位の傳を以て上下鍛練の事" />
  <LINE TYPE="本文" X="314" Y="301" WIDTH="45" HEIGHT="1002" CONF="0.792" ORDER="39" STRING="一此商三位の傳を以て。一體の上下を見極め、二つの内、何程の下げ、何程迄上げ、何程にて止まる" />
  <LINE TYPE="本文" X="295" Y="1096" WIDTH="18" HEIGHT="35" CONF="0.527" ORDER="41" STRING="八九" />
  </PAGE>

