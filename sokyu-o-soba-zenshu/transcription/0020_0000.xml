  <LINE TYPE="本文" X="1769" Y="309" WIDTH="26" HEIGHT="1127" CONF="0.374" ORDER="0" STRING="…………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………" />
  <LINE TYPE="本文" X="1488" Y="246" WIDTH="18" HEIGHT="21" CONF="0.433" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1457" Y="247" WIDTH="16" HEIGHT="19" CONF="0.374" ORDER="2" STRING="久" />
  <LINE TYPE="本文" X="1423" Y="246" WIDTH="18" HEIGHT="21" CONF="0.409" ORDER="3" STRING="翁" />
  <LINE TYPE="本文" X="1390" Y="246" WIDTH="18" HEIGHT="19" CONF="0.396" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1293" Y="247" WIDTH="17" HEIGHT="18" CONF="0.425" ORDER="5" STRING="集" />
  <LINE TYPE="本文" X="1324" Y="247" WIDTH="18" HEIGHT="18" CONF="0.427" ORDER="6" STRING="全" />
  <LINE TYPE="本文" X="1357" Y="246" WIDTH="17" HEIGHT="18" CONF="0.411" ORDER="7" STRING="場" />
  <LINE TYPE="本文" X="1228" Y="246" WIDTH="18" HEIGHT="18" CONF="0.360" ORDER="8" STRING="巻" />
  <LINE TYPE="本文" X="1260" Y="247" WIDTH="18" HEIGHT="18" CONF="0.339" ORDER="9" STRING="上" />
  <LINE TYPE="本文" X="1704" Y="1096" WIDTH="24" HEIGHT="34" CONF="0.372" ORDER="10" STRING="〇〇〇" />
  <LINE TYPE="本文" X="1658" Y="321" WIDTH="31" HEIGHT="978" CONF="0.846" ORDER="11" STRING="月數と割合とを繰り、且社會外圍の事情とを考へ合せて、買を決心するが善い、是等を買時機と云" />
  <LINE TYPE="本文" X="1614" Y="309" WIDTH="33" HEIGHT="1007" CONF="0.909" ORDER="12" STRING="ふのである。何故かと云ふに斯る平穩無事の年柄には、已に前に下くべき丈けの安直を出し盡した" />
  <LINE TYPE="本文" X="1571" Y="317" WIDTH="32" HEIGHT="996" CONF="0.884" ORDER="13" STRING="揚句てあるから、彼岸下げと云ふ下ぐべき時機にも下げず、少しでも日和悪い時は、利喰急ぎの買" />
  <LINE TYPE="本文" X="1527" Y="317" WIDTH="32" HEIGHT="995" CONF="0.904" ORDER="14" STRING="物等が出て、段々と引上げ、其上へ六月頃植付の時季に差迫つて、天候が面白くない時には、賣方" />
  <LINE TYPE="本文" X="1484" Y="317" WIDTH="31" HEIGHT="989" CONF="0.894" ORDER="15" STRING="の買戻し、新買等が出て、意外の高直を見せるとある者である。此時一ト天井となるとがあるから、" />
  <LINE TYPE="本文" X="1441" Y="315" WIDTH="27" HEIGHT="647" CONF="0.864" ORDER="16" STRING="月數と割合とを推究して、天井直段か否かを見極むべきである。" />
  <LINE TYPE="本文" X="1371" Y="468" WIDTH="31" HEIGHT="476" CONF="0.831" ORDER="17" STRING="第六章急に下げ急に上る相塲の事" />
  <LINE TYPE="本文" X="1309" Y="309" WIDTH="31" HEIGHT="986" CONF="0.848" ORDER="18" STRING="一急に下げ、急に上る相塲は、天井底の日限定まらず、見計らひ取仕廻ふべし。其節二ツ仕廻、三ツ" />
  <LINE TYPE="本文" X="1267" Y="295" WIDTH="25" HEIGHT="403" CONF="0.867" ORDER="19" STRING="十分、四ツ轉ジ、是れ三位の秘傳なり。" />
  <LINE TYPE="本文" X="1222" Y="313" WIDTH="31" HEIGHT="996" CONF="0.876" ORDER="20" STRING="(釋)天井底を决する最良の標準は、月數と、割合の熟不熟を見るとであるが、併し、茲に例外の塲" />
  <LINE TYPE="本文" X="1177" Y="314" WIDTH="33" HEIGHT="997" CONF="0.892" ORDER="21" STRING="合がある。即ち、本章説く所の、急に上げ又は急に下る相塲である。是は、早熟相塲と云ふ者であ" />
  <LINE TYPE="本文" X="1135" Y="316" WIDTH="34" HEIGHT="995" CONF="0.879" ORDER="22" STRING="つて、月數日數には拘はらず、天井を極め、亦底を極める者であるから、利のある商内ならば、善" />
  <LINE TYPE="本文" X="1090" Y="318" WIDTH="35" HEIGHT="989" CONF="0.885" ORDER="23" STRING="い加減に、手仕廻するがよい、そして、之に對する心得は、二ツ仕廻、三ツ十分、四ツ轉じの呼吸" />
  <LINE TYPE="本文" X="1047" Y="306" WIDTH="36" HEIGHT="1010" CONF="0.852" ORDER="24" STRING="を忘れないで、我玉を手放して、虞心平氣に相塲の十分するを窺ひ、宜しく相塲の反を打つべきであ" />
  <LINE TYPE="本文" X="877" Y="312" WIDTH="20" HEIGHT="37" CONF="0.520" ORDER="25" STRING="る。" />
  <LINE TYPE="本文" X="830" Y="305" WIDTH="37" HEIGHT="579" CONF="0.823" ORDER="26" STRING="本章は、月数の例外相場に対する心得を説ひた者である。" />
  <LINE TYPE="本文" X="761" Y="457" WIDTH="44" HEIGHT="596" CONF="0.797" ORDER="28" STRING="第七章冬より正月迄天井直段の米見様の事" />
  <LINE TYPE="本文" X="712" Y="244" WIDTH="14" HEIGHT="19" CONF="0.365" ORDER="29" STRING="四" />
  <LINE TYPE="本文" X="692" Y="242" WIDTH="16" HEIGHT="21" CONF="0.407" ORDER="30" STRING="第" />
  <LINE TYPE="本文" X="650" Y="243" WIDTH="15" HEIGHT="19" CONF="0.443" ORDER="31" STRING="章" />
  <LINE TYPE="本文" X="628" Y="244" WIDTH="14" HEIGHT="19" CONF="0.387" ORDER="32" STRING="冬" />
  <LINE TYPE="本文" X="697" Y="294" WIDTH="37" HEIGHT="511" CONF="0.859" ORDER="33" STRING="一冬中正月頃迄、底直段の米は、五六月上るべし。" />
  <LINE TYPE="本文" X="658" Y="290" WIDTH="43" HEIGHT="1019" CONF="0.875" ORDER="34" STRING="冬中より、正月二月頃迄天井直段の米は、五六月下る可し。五月十分に下る時は、六月急上也。五月" />
  <LINE TYPE="本文" X="613" Y="288" WIDTH="33" HEIGHT="454" CONF="0.874" ORDER="35" STRING="下らざれば、六月決して崩る可し、疑なし。" />
  <LINE TYPE="本文" X="568" Y="294" WIDTH="37" HEIGHT="614" CONF="0.859" ORDER="36" STRING="七八九十月迄も、底直段の米は、十二月迄に上ると心得べし。" />
  <LINE TYPE="本文" X="527" Y="312" WIDTH="43" HEIGHT="995" CONF="0.869" ORDER="37" STRING="本章、之を三節に分て見るがよい。第一節は、前章に於て已に詳解したから、直に第二節に" />
  <LINE TYPE="本文" X="483" Y="321" WIDTH="24" HEIGHT="127" CONF="0.839" ORDER="38" STRING="就て説かう。" />
  <LINE TYPE="本文" X="442" Y="318" WIDTH="42" HEIGHT="990" CONF="0.873" ORDER="39" STRING="不作の爲め前年より上を續け、十二月正月頃迄の間に天井直段となつた米は、其后、供給地の正米" />
  <LINE TYPE="本文" X="398" Y="321" WIDTH="42" HEIGHT="986" CONF="0.899" ORDER="40" STRING="が定期の高足に誘はれて、相應に出廻つた塲合と雖も、人氣は、前年の不作覺へて買慕ふて居るか" />
  <LINE TYPE="本文" X="354" Y="322" WIDTH="43" HEIGHT="987" CONF="0.900" ORDER="41" STRING="ら、容易に崩れないものである。併し、斯る際は、不作に伴ふ天井保合として、賣方針を忘れては" />
  <LINE TYPE="本文" X="311" Y="322" WIDTH="42" HEIGHT="988" CONF="0.885" ORDER="42" STRING="ならぬ。何故かとなれば、此る買慕へは、何時迄も續く者でない。五月頃になつて、麥作も平作で、" />
  <LINE TYPE="本文" X="264" Y="320" WIDTH="45" HEIGHT="993" CONF="0.874" ORDER="43" STRING="天候も惡くなく、且前年不作年の惡米は、暖氣に品痛みの恐れがあるから、米持の賣急ぎ杯で大崩れ" />
  <LINE TYPE="本文" X="245" Y="1106" WIDTH="23" HEIGHT="37" CONF="0.450" ORDER="45" STRING="十一" />
  </PAGE>

