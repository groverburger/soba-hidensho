<PAGE IMAGENAME="0076_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1712" Y="303" WIDTH="25" HEIGHT="380" CONF="0.883" ORDER="0" STRING="食ある年は、是迄大小となく不作也。" />
  <LINE TYPE="本文" X="1749" Y="1108" WIDTH="20" HEIGHT="51" CONF="0.484" ORDER="1" STRING="一三" />
  <LINE TYPE="本文" X="1640" Y="476" WIDTH="30" HEIGHT="305" CONF="0.869" ORDER="2" STRING="第三十三章厄日の事" />
  <LINE TYPE="本文" X="1579" Y="310" WIDTH="27" HEIGHT="595" CONF="0.866" ORDER="3" STRING="一厄日は、八十八夜無難なれば、二百十日無難なりと云ふ。" />
  <LINE TYPE="本文" X="1542" Y="254" WIDTH="18" HEIGHT="23" CONF="0.382" ORDER="4" STRING="宗" />
  <LINE TYPE="本文" X="1511" Y="252" WIDTH="17" HEIGHT="21" CONF="0.349" ORDER="5" STRING="久" />
  <LINE TYPE="本文" X="1477" Y="253" WIDTH="17" HEIGHT="20" CONF="0.353" ORDER="6" STRING="病" />
  <LINE TYPE="本文" X="1533" Y="292" WIDTH="29" HEIGHT="1032" CONF="0.815" ORDER="7" STRING="但し、二百十日無難にても、三日目酉の日有れば此日大風也、此事違なし。寛政九年、三日目酉の日" />
  <LINE TYPE="本文" X="1496" Y="307" WIDTH="24" HEIGHT="78" CONF="0.837" ORDER="8" STRING="大風也。" />
  <LINE TYPE="本文" X="1412" Y="252" WIDTH="18" HEIGHT="20" CONF="0.410" ORDER="9" STRING="塲" />
  <LINE TYPE="本文" X="1444" Y="253" WIDTH="18" HEIGHT="22" CONF="0.365" ORDER="10" STRING="相" />
  <LINE TYPE="本文" X="1381" Y="252" WIDTH="16" HEIGHT="19" CONF="0.447" ORDER="11" STRING="全" />
  <LINE TYPE="本文" X="1348" Y="251" WIDTH="15" HEIGHT="20" CONF="0.493" ORDER="12" STRING="集" />
  <LINE TYPE="本文" X="1317" Y="251" WIDTH="15" HEIGHT="19" CONF="0.506" ORDER="13" STRING="下" />
  <LINE TYPE="本文" X="1422" Y="475" WIDTH="31" HEIGHT="302" CONF="0.833" ORDER="14" STRING="第三十四章三木の事" />
  <LINE TYPE="本文" X="1364" Y="304" WIDTH="24" HEIGHT="419" CONF="0.889" ORDER="15" STRING="一甲乙三ヶ月續く時は、大風吹くべし。" />
  <LINE TYPE="本文" X="1319" Y="305" WIDTH="25" HEIGHT="372" CONF="0.867" ORDER="16" STRING="一丙丁三ヶ月續く時は、旱すべし。" />
  <LINE TYPE="本文" X="1283" Y="250" WIDTH="17" HEIGHT="18" CONF="0.479" ORDER="17" STRING="卷" />
  <LINE TYPE="本文" X="1274" Y="299" WIDTH="27" HEIGHT="492" CONF="0.871" ORDER="18" STRING="一戊己三ヶ月續く時は、米穀高しと知るべし。" />
  <LINE TYPE="本文" X="1232" Y="301" WIDTH="25" HEIGHT="445" CONF="0.921" ORDER="19" STRING="一庚辛三ケ月續く時は、米穀不足論あり。" />
  <LINE TYPE="本文" X="1189" Y="302" WIDTH="25" HEIGHT="466" CONF="0.867" ORDER="20" STRING="一壬癸三ヶ月續く時は、米高ふして人死す。" />
  <LINE TYPE="本文" X="1143" Y="296" WIDTH="29" HEIGHT="632" CONF="0.880" ORDER="21" STRING="右、春夏秋冬時に寄て、大風、米穀、日旱等の義、考ふべし。" />
  <LINE TYPE="本文" X="1094" Y="293" WIDTH="38" HEIGHT="1010" CONF="0.779" ORDER="22" STRING="天明六年、九月朔日より庚丑、十月朔日庚未、閏十月朔日辛未、三ケ月続く。此年、二十六俵八分、" />
  <LINE TYPE="本文" X="918" Y="292" WIDTH="29" HEIGHT="591" CONF="0.844" ORDER="23" STRING="十月十六日十六俵四分天井也。此年、彼岸八月廿八日也。" />
  <LINE TYPE="本文" X="876" Y="302" WIDTH="33" HEIGHT="1016" CONF="0.828" ORDER="24" STRING="(釋)甲乙三ケ月續く時とあるのは、朔日に、甲乙三ケ月續く時はと云ふ意味で、丙丁云々も、之一" />
  <LINE TYPE="本文" X="832" Y="319" WIDTH="25" HEIGHT="264" CONF="0.859" ORDER="25" STRING="に準じて知るべしである。" />
  <LINE TYPE="本文" X="400" Y="236" WIDTH="404" HEIGHT="46" CONF="0.412" ORDER="28" STRING="一章七十一年七十三年" />
  <LINE TYPE="本文" X="763" Y="472" WIDTH="32" HEIGHT="505" CONF="0.858" ORDER="29" STRING="第三十五章朔日火木三つ四つ續く事" />
  <LINE TYPE="本文" X="699" Y="303" WIDTH="27" HEIGHT="378" CONF="0.876" ORDER="30" STRING="一朔日火四つ續く時は、其年旱す。" />
  <LINE TYPE="本文" X="655" Y="302" WIDTH="28" HEIGHT="468" CONF="0.843" ORDER="31" STRING="一同木三つ續く時は、其年度々大風あり。" />
  <LINE TYPE="本文" X="613" Y="304" WIDTH="31" HEIGHT="775" CONF="0.874" ORDER="32" STRING="一何れの月にても、水五つ續く時は、五水種を失ふとて、度々洪水すとなり。" />
  <LINE TYPE="本文" X="568" Y="302" WIDTH="27" HEIGHT="333" CONF="0.851" ORDER="33" STRING="但し、此事掟木ならず考ふべし。" />
  <LINE TYPE="本文" X="679" Y="1174" WIDTH="26" HEIGHT="28" CONF="0.409" ORDER="34" STRING="船" />
  <LINE TYPE="本文" X="500" Y="474" WIDTH="32" HEIGHT="425" CONF="0.852" ORDER="35" STRING="第三十六章丑の日辰の日の事" />
  <LINE TYPE="本文" X="438" Y="301" WIDTH="33" HEIGHT="1007" CONF="0.796" ORDER="36" STRING="一丑の日、辰の日、米安き日也。但し、丑の日底直段天井直段出る日也。天井底の節、氣を付くべし。" />
  <LINE TYPE="本文" X="369" Y="478" WIDTH="32" HEIGHT="420" CONF="0.830" ORDER="37" STRING="第三十七章一つ目二つと申事" />
  <LINE TYPE="本文" X="312" Y="303" WIDTH="30" HEIGHT="722" CONF="0.815" ORDER="38" STRING="一一つ目、二つと高下なしと云事は、位付の書の目のと也、心得べし。" />
  <LINE TYPE="本文" X="282" Y="1107" WIDTH="20" HEIGHT="50" CONF="0.536" ORDER="39" STRING="一二三" />
  </PAGE>

