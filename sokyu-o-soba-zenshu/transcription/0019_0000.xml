  <LINE TYPE="本文" X="1722" Y="1112" WIDTH="25" HEIGHT="24" CONF="0.325" ORDER="0" STRING="武" />
  <LINE TYPE="本文" X="1776" Y="88" WIDTH="29" HEIGHT="1222" CONF="0.318" ORDER="1" STRING="一" />
  <LINE TYPE="本文" X="1662" Y="467" WIDTH="32" HEIGHT="661" CONF="0.728" ORDER="2" STRING="第四章人も同じ見込の節海中へ飛入る心持の事" />
  <LINE TYPE="本文" X="1514" Y="251" WIDTH="16" HEIGHT="20" CONF="0.479" ORDER="3" STRING="宗" />
  <LINE TYPE="本文" X="1483" Y="251" WIDTH="14" HEIGHT="18" CONF="0.461" ORDER="4" STRING="久" />
  <LINE TYPE="本文" X="1449" Y="250" WIDTH="17" HEIGHT="19" CONF="0.435" ORDER="5" STRING="翁" />
  <LINE TYPE="本文" X="1415" Y="250" WIDTH="18" HEIGHT="18" CONF="0.431" ORDER="6" STRING="相" />
  <LINE TYPE="本文" X="1352" Y="250" WIDTH="17" HEIGHT="18" CONF="0.304" ORDER="7" STRING="全" />
<LINE TYPE="本文" X="1383" Y="250" WIDTH="17" HEIGHT="18" CONF="0.327" ORDER="8" STRING="場" />
  <LINE TYPE="本文" X="1288" Y="251" WIDTH="14" HEIGHT="17" CONF="0.349" ORDER="9" STRING="上" />
  <LINE TYPE="本文" X="1318" Y="250" WIDTH="17" HEIGHT="18" CONF="0.346" ORDER="10" STRING="集" />
  <LINE TYPE="本文" X="1254" Y="251" WIDTH="16" HEIGHT="17" CONF="0.417" ORDER="11" STRING="卷" />
  <LINE TYPE="本文" X="1599" Y="300" WIDTH="31" HEIGHT="1012" CONF="0.858" ORDER="12" STRING="一米、段々下げ、上方相塲無替事諸國並に最上拂物澤山の風聞、人氣も揃ひ弱く、何程下るも知れ" />
  <LINE TYPE="本文" X="1554" Y="300" WIDTH="32" HEIGHT="1009" CONF="0.873" ORDER="13" STRING="難く、我が考も弱かるべしと思ふ節、心を轉じ買入る可き也。此思切、海中へ飛入心持、甚だ成悪き" />
  <LINE TYPE="本文" X="1511" Y="301" WIDTH="31" HEIGHT="1005" CONF="0.880" ORDER="14" STRING="者なれとも、其節疑の氣を生せず買べし、極めて利運也。下と見込む時、思入の通り下る者なれば心" />
  <LINE TYPE="本文" X="1469" Y="300" WIDTH="29" HEIGHT="1003" CONF="0.818" ORDER="15" STRING="易き者なれども、人氣下ると片寄る時、却て上る者故、考に及ばざる也。上も同断、即ち海中に飛込" />
  <LINE TYPE="本文" X="1428" Y="304" WIDTH="24" HEIGHT="149" CONF="0.853" ORDER="16" STRING="心持、極意也。" />
  <LINE TYPE="本文" X="1382" Y="317" WIDTH="30" HEIGHT="987" CONF="0.860" ORDER="17" STRING="(釋)最上は、今の村山最上郡一圓の總稱、拂物は、諸藩の御拂米のとて、總て酒田港に輸し來つ" />
  <LINE TYPE="本文" X="1341" Y="317" WIDTH="25" HEIGHT="561" CONF="0.814" ORDER="18" STRING="て販売するを例とせるとは、已に巻首に述べて置ひた。" />
  <LINE TYPE="本文" X="1295" Y="320" WIDTH="31" HEIGHT="985" CONF="0.857" ORDER="19" STRING="前章には、人気買に片寄つた時の賣を説いたが、本章には、人気が賣に偏した時の買を説いた者で" />
  <LINE TYPE="本文" X="1256" Y="328" WIDTH="20" HEIGHT="56" CONF="0.714" ORDER="20" STRING="ある。" />
  <LINE TYPE="本文" X="1207" Y="318" WIDTH="32" HEIGHT="978" CONF="0.868" ORDER="21" STRING="人氣が、賣一方に傾向ひて居つて、自分も賣賛成の時には、決して憂てはならぬ。斯んな時には、" />
  <LINE TYPE="本文" X="1162" Y="308" WIDTH="35" HEIGHT="1004" CONF="0.891" ORDER="22" STRING="宜しく海中へ飛込底の大勇猛の心を以て、買方に廻るべきである。何故と云ふに、此人気売一偏の" />
  <LINE TYPE="本文" X="1119" Y="320" WIDTH="34" HEIGHT="984" CONF="0.869" ORDER="23" STRING="現象は、一面から見れば、賣方が、手一杯賣つた極點の時季であつて、最早、利喰の出づべき時に" />
  <LINE TYPE="本文" X="1073" Y="319" WIDTH="37" HEIGHT="985" CONF="0.864" ORDER="24" STRING="迫つて居るのである一)。又衆人が、猫も杓子も賣に偏した結果はして居る" />
  <LINE TYPE="本文" X="902" Y="324" WIDTH="42" HEIGHT="987" CONF="0.858" ORDER="25" STRING="のて、最早反動の上に向ふて居る機微である(二)からてある。併し翁が斯く誨ゆるのは、月數も熟" />
  <LINE TYPE="本文" X="859" Y="319" WIDTH="40" HEIGHT="988" CONF="0.825" ORDER="26" STRING="し、直段も熟した塲合を指すのて、月數日數若い塲合に應用してはならぬ。慈実務も、斯ふ云ふて" />
  <LINE TYPE="本文" X="815" Y="324" WIDTH="22" HEIGHT="59" CONF="0.730" ORDER="27" STRING="居る。" />
  <LINE TYPE="本文" X="771" Y="340" WIDTH="27" HEIGHT="278" CONF="0.858" ORDER="28" STRING="高下共、五分一割に隨ふて、" />
  <LINE TYPE="本文" X="728" Y="392" WIDTH="27" HEIGHT="236" CONF="0.874" ORDER="29" STRING="二割三割逆ふ理と知れ。" />
  <LINE TYPE="本文" X="684" Y="328" WIDTH="28" HEIGHT="315" CONF="0.898" ORDER="30" STRING="高下共、五分一割は乘がよし" />
  <LINE TYPE="本文" X="642" Y="387" WIDTH="29" HEIGHT="266" CONF="0.872" ORDER="31" STRING="中墨過ぎて、乘は馬鹿也。" />
  <LINE TYPE="本文" X="597" Y="324" WIDTH="29" HEIGHT="377" CONF="0.886" ORDER="32" STRING="本章と共に、良い訓戒だろふと思ふ。" />
  <LINE TYPE="本文" X="531" Y="473" WIDTH="37" HEIGHT="512" CONF="0.870" ORDER="33" STRING="第五章冬より正二月迄持合ふ米の事" />
  <LINE TYPE="本文" X="465" Y="314" WIDTH="37" HEIGHT="832" CONF="0.798" ORDER="34" STRING="一冬中より、正二月頃迄底直段にて持合ふ米は、三四月より、五六月、决して上る也。" />
  <LINE TYPE="本文" X="422" Y="309" WIDTH="40" HEIGHT="1022" CONF="0.877" ORDER="35" STRING="前年高直あつて、翌年一月頃迄、三ヶ月以上の下げとなつた米は、前年豊作であつて、秋揚" />
  <LINE TYPE="本文" X="379" Y="323" WIDTH="38" HEIGHT="996" CONF="0.891" ORDER="36" STRING="げも十分等、弱氣のダラ〳〵を、唱へ盡して、下落した相塲であるから、目先に別段強材料もなく、" />
  <LINE TYPE="本文" X="336" Y="325" WIDTH="38" HEIGHT="991" CONF="0.893" ORDER="37" STRING="特に冬中の氣候申分ない時には、早くも、彼岸日和の良いのを見越して、賣人も出るから、暫く安直を" />
  <LINE TYPE="本文" X="293" Y="322" WIDTH="38" HEIGHT="995" CONF="0.843" ORDER="38" STRING="見するであろふ。そして此安直が、多く一年中の底直段となるとが多いから、宜しく罫線表にて、" />
  <LINE TYPE="本文" X="263" Y="1105" WIDTH="23" HEIGHT="22" CONF="0.424" ORDER="39" STRING="九" />
  </PAGE>

