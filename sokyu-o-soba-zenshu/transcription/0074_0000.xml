  <LINE TYPE="本文" X="1732" Y="309" WIDTH="33" HEIGHT="999" CONF="0.847" ORDER="10" STRING="共に殘る年は、新古共、七月迄上げなし。左樣の年は、霜月限八九十月より段々自然と引上げ、十二" />
  <LINE TYPE="本文" X="1688" Y="309" WIDTH="34" HEIGHT="1003" CONF="0.902" ORDER="11" STRING="月か正月迄に天井直段出ると心得べし。六月より急ぐ可からず。見合可申也。猶能々考ふ可し。其年" />
  <LINE TYPE="本文" X="1645" Y="307" WIDTH="33" HEIGHT="1009" CONF="0.876" ORDER="12" STRING="の古米の多少、作の善悪、人気の差別あり。年々、夫故一様ならず。然れども、遅くも早くも、此年" />
  <LINE TYPE="本文" X="1609" Y="303" WIDTH="23" HEIGHT="216" CONF="0.866" ORDER="13" STRING="上らずと云ふとなし。" />
  <LINE TYPE="本文" X="1559" Y="313" WIDTH="32" HEIGHT="999" CONF="0.833" ORDER="14" STRING="七月甲に廻る年の駈引は、上卷第五十一章に精しく説いてあるが、茲には、一層簡短に述べ" />
  <LINE TYPE="本文" X="1525" Y="328" WIDTH="20" HEIGHT="76" CONF="0.811" ORDER="15" STRING="たのだ。" />
  <LINE TYPE="本文" X="1475" Y="319" WIDTH="31" HEIGHT="996" CONF="0.826" ORDER="16" STRING="偖、七月甲に廻つて天災ある年の相塲は、七月頃から段々五六ケ月も上る者である。併し、其年順" />
  <LINE TYPE="本文" X="1430" Y="319" WIDTH="32" HEIGHT="992" CONF="0.866" ORDER="17" STRING="気が克く、且在米澤山の時は、遲れて八月か九月頃から上る者である。左れど、其年の古米の多少、" />
  <LINE TYPE="本文" X="1387" Y="315" WIDTH="32" HEIGHT="994" CONF="0.859" ORDER="18" STRING="作柄の善悪、人氣の如何に依て、上に早晩の差別あるから、夫等を考へて、駈引をせよと云ふので" />
  <LINE TYPE="本文" X="1355" Y="327" WIDTH="20" HEIGHT="58" CONF="0.712" ORDER="19" STRING="ある。" />
  <LINE TYPE="本文" X="1278" Y="473" WIDTH="31" HEIGHT="421" CONF="0.779" ORDER="20" STRING="第二十五章上方相塲位附の事" />
  <LINE TYPE="本文" X="1222" Y="306" WIDTH="24" HEIGHT="347" CONF="0.869" ORDER="21" STRING="一肥後米より筑前米は、四匁位落。" />
  <LINE TYPE="本文" X="1177" Y="306" WIDTH="25" HEIGHT="346" CONF="0.875" ORDER="22" STRING="一筑前米より加賀米は、五匁位落。" />
  <LINE TYPE="本文" X="1133" Y="307" WIDTH="26" HEIGHT="323" CONF="0.895" ORDER="23" STRING="一同米より中國米は、九匁位落。" />
  <LINE TYPE="本文" X="930" Y="302" WIDTH="25" HEIGHT="331" CONF="0.853" ORDER="24" STRING="一同米より莊内米は、七匁位落。" />
  <LINE TYPE="本文" X="886" Y="298" WIDTH="24" HEIGHT="238" CONF="0.887" ORDER="25" STRING="右、累年右位の釣合也。" />
  <LINE TYPE="本文" X="843" Y="311" WIDTH="25" HEIGHT="580" CONF="0.845" ORDER="26" STRING="(釋)右の四ケ條は、大阪に於ける當時の格附表である。" />
  <LINE TYPE="本文" X="773" Y="468" WIDTH="30" HEIGHT="389" CONF="0.768" ORDER="27" STRING="第二十六章月切商仕様の事" />
  <LINE TYPE="本文" X="713" Y="300" WIDTH="25" HEIGHT="524" CONF="0.854" ORDER="28" STRING="一一ヶ月切の商は、見計ひ少々宛の利を取留る者也。" />
  <LINE TYPE="本文" X="668" Y="308" WIDTH="29" HEIGHT="990" CONF="0.814" ORDER="29" STRING="(釋)仕かけて置た商内、當月切となつた時は、假令少々見込があつても、大抵見切りを付けて、" />
  <LINE TYPE="本文" X="627" Y="317" WIDTH="24" HEIGHT="397" CONF="0.882" ORDER="30" STRING="少し計りの利でも取留むべき者である。" />
  <LINE TYPE="本文" X="554" Y="477" WIDTH="32" HEIGHT="585" CONF="0.804" ORDER="31" STRING="第二十七章土用入并に節替り陰陽繰方の事" />
  <LINE TYPE="本文" X="494" Y="301" WIDTH="25" HEIGHT="480" CONF="0.835" ORDER="32" STRING="一土用入節替りの節、陰に入陽に入を知る繰方。" />
