  <LINE TYPE="本文" X="1779" Y="1119" WIDTH="18" HEIGHT="51" CONF="0.346" ORDER="0" STRING="一三二" />
<LINE TYPE="本文" X="1731" Y="346" WIDTH="30" HEIGHT="986" CONF="0.809" ORDER="1" STRING="してはならぬ、宜しく、心機を一轉すべしと云ふのである。此調子を覺るのは、相塲師の必要事で" />
  <LINE TYPE="本文" X="1690" Y="338" WIDTH="25" HEIGHT="474" CONF="0.887" ORDER="2" STRING="あるから、呉々も、此心得を忘れてはならぬ。" />
  <LINE TYPE="本文" X="1620" Y="489" WIDTH="31" HEIGHT="453" CONF="0.892" ORDER="3" STRING="第四十九章霜月限買入秘伝の事" />
  <LINE TYPE="本文" X="1556" Y="270" WIDTH="17" HEIGHT="24" CONF="0.485" ORDER="4" STRING="宗" />
  <LINE TYPE="本文" X="1558" Y="322" WIDTH="30" HEIGHT="1006" CONF="0.871" ORDER="5" STRING="一霜月限、大方、六月初まる也。偖、新米、七月節入日より中の日の間にて買入甚だ宜き也。决して、" />
  <LINE TYPE="本文" X="1524" Y="270" WIDTH="15" HEIGHT="21" CONF="0.421" ORDER="6" STRING="久" />
  <LINE TYPE="本文" X="1492" Y="269" WIDTH="16" HEIGHT="20" CONF="0.433" ORDER="7" STRING="翁" />
  <LINE TYPE="本文" X="1458" Y="269" WIDTH="17" HEIGHT="20" CONF="0.432" ORDER="8" STRING="相" />
  <LINE TYPE="本文" X="1426" Y="268" WIDTH="17" HEIGHT="21" CONF="0.448" ORDER="9" STRING="場" />
  <LINE TYPE="本文" X="1515" Y="322" WIDTH="31" HEIGHT="1014" CONF="0.837" ORDER="10" STRING="此間底直段出る者也。尤も、此月の丑の日底直段出る時は、急に引上る者也。七月中の日の末より利" />
  <LINE TYPE="本文" X="1472" Y="301" WIDTH="30" HEIGHT="876" CONF="0.823" ORDER="11" STRING="運に向く時は、油斷なく買入るゝ者也。此間の新米買入置き、不利運と云ふとなし。" />
  <LINE TYPE="本文" X="1428" Y="312" WIDTH="31" HEIGHT="1029" CONF="0.851" ORDER="12" STRING="但し、古米夏中天井直より百俵下げに氣を付くべきなり、其年により、百三四十俵も引下げ、新米商" />
  <LINE TYPE="本文" X="1297" Y="259" WIDTH="16" HEIGHT="29" CONF="0.417" ORDER="13" STRING="一卷" />
  <LINE TYPE="本文" X="1330" Y="268" WIDTH="16" HEIGHT="19" CONF="0.432" ORDER="14" STRING="下" />
  <LINE TYPE="本文" X="1362" Y="268" WIDTH="16" HEIGHT="19" CONF="0.435" ORDER="15" STRING="集" />
  <LINE TYPE="本文" X="1394" Y="269" WIDTH="16" HEIGHT="18" CONF="0.451" ORDER="16" STRING="全" />
  <LINE TYPE="本文" X="1385" Y="311" WIDTH="28" HEIGHT="734" CONF="0.867" ORDER="17" STRING="出る事あり。其節は、極めて底直故、上に掛る時甚だ厳敷也。可急也。" />
  <LINE TYPE="本文" X="1341" Y="328" WIDTH="30" HEIGHT="1000" CONF="0.887" ORDER="18" STRING="但し、此教、国々上作唱へ、七月節に入日より七月中の日迄の間、丑の日有之底直出る時は、一筋" />
  <LINE TYPE="本文" X="1298" Y="339" WIDTH="30" HEIGHT="988" CONF="0.882" ORDER="19" STRING="に可買入也。若し、六月の節前より作難出で、中の節頃迄に三十四十俵も上る時は、急に買ふ可" />
  <LINE TYPE="本文" X="1253" Y="340" WIDTH="31" HEIGHT="989" CONF="0.897" ORDER="20" STRING="からず。七八月の中に天井出るか、亦十一月迄すわりになるか、難計也。若し、其年六七月も無照、" />
  <LINE TYPE="本文" X="1210" Y="329" WIDTH="32" HEIGHT="997" CONF="0.889" ORDER="21" STRING="雨又虫付なる時は、四十俵上にても可買也。七月節に入日より中の日の間さへ買へば、高直の米に" />
  <LINE TYPE="本文" X="1167" Y="330" WIDTH="30" HEIGHT="938" CONF="0.858" ORDER="22" STRING="ても利有りと、決して思ふべからず。若し心得違の時は、損するとあるべし、考ふ可き也。" />
  <LINE TYPE="本文" X="1121" Y="340" WIDTH="33" HEIGHT="986" CONF="0.820" ORDER="23" STRING="(釋)酒田米會所の霜月限、即ち十一月限は、大抵毎年六月から發會して、七月節入頃から、中の節" />
  <LINE TYPE="本文" X="901" Y="333" WIDTH="33" HEIGHT="974" CONF="0.881" ORDER="24" STRING="頃迄に、土用中照込み強く上順氣を唱へると、人氣が皆弱氣に赴き、底直段を出す者であるから、" />
  <LINE TYPE="本文" X="858" Y="331" WIDTH="32" HEIGHT="985" CONF="0.902" ORDER="25" STRING="其底に注意して買て置けば、必らず利の乘る者である。併し、古米の天井直段と新米の産れ直の鞘" />
  <LINE TYPE="本文" X="815" Y="322" WIDTH="34" HEIGHT="1009" CONF="0.906" ORDER="26" STRING="の、百俵下に注意すべしである。百俵は大抵底となる者だが、其年によつて、百三四十俵の下鞘に" />
  <LINE TYPE="本文" X="773" Y="329" WIDTH="32" HEIGHT="994" CONF="0.894" ORDER="27" STRING="商出るとあるが、是は屹度底であるから、大に買入るべき米で、こんな大底を出した上は、必らず" />
  <LINE TYPE="本文" X="730" Y="331" WIDTH="31" HEIGHT="988" CONF="0.909" ORDER="28" STRING="急に上る者である。併し、注意して置かねばならぬとは、各國並に當地も上作の唱へで、七月の土" />
  <LINE TYPE="本文" X="687" Y="322" WIDTH="32" HEIGHT="1008" CONF="0.910" ORDER="29" STRING="用前後に底直らしい安直があつたら、面も振らず買てもよいが、若し、其前方の六月頃から故障が" />
  <LINE TYPE="本文" X="643" Y="332" WIDTH="32" HEIGHT="988" CONF="0.895" ORDER="30" STRING="出て、三四十俵方も底から上げて居る相塲は、餘程考へ者で、作難丈けは、已に上げて居るのだか" />
  <LINE TYPE="本文" X="600" Y="331" WIDTH="32" HEIGHT="991" CONF="0.903" ORDER="31" STRING="ら好順氣が續けば、其邊が天井となるし、又一好一不の順氣でも、十一月迄高直持合となるが、と" />
  <LINE TYPE="本文" X="556" Y="333" WIDTH="33" HEIGHT="988" CONF="0.901" ORDER="32" STRING="ちらとも云はれぬから、餘り買急いではならぬ。又、其年、六七月の照り込むべき季節にも、雨天" />
  <LINE TYPE="本文" X="514" Y="331" WIDTH="31" HEIGHT="988" CONF="0.861" ORDER="33" STRING="計りであるとか、又は虫害抔の難事が出れば、四十俵上でも買てもよいのである。此区別あるとも" />
  <LINE TYPE="本文" X="470" Y="332" WIDTH="31" HEIGHT="977" CONF="0.870" ORDER="34" STRING="知らずに、唯七月節から中の節の間で買ひさへすれば、高直の米でも、必ず利分あると思ふては、" />
  <LINE TYPE="本文" X="429" Y="336" WIDTH="21" HEIGHT="123" CONF="0.847" ORDER="35" STRING="ならぬことだ。" />
  <LINE TYPE="本文" X="357" Y="480" WIDTH="32" HEIGHT="579" CONF="0.869" ORDER="36" STRING="第五十章買米有之相塲引上の節心得の事一" />
  <LINE TYPE="本文" X="296" Y="311" WIDTH="30" HEIGHT="999" CONF="0.788" ORDER="37" STRING="一買米有之強氣の處、相塲引上る時は、上留りの考もなく、猶々買募り、至りて高直の處買重ね、不" />
  <LINE TYPE="本文" X="263" Y="1112" WIDTH="21" HEIGHT="53" CONF="0.472" ORDER="38" STRING="一三三" />
  <LINE TYPE="本文" X="211" Y="99" WIDTH="26" HEIGHT="1336" CONF="0.418" ORDER="39" STRING="}" />
  </PAGE>

