<PAGE IMAGENAME="0031_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1784" Y="63" WIDTH="35" HEIGHT="1399" CONF="0.381" ORDER="0" STRING="}" />
  <LINE TYPE="本文" X="1514" Y="270" WIDTH="17" HEIGHT="22" CONF="0.315" ORDER="1" STRING="宗" />
<LINE TYPE="本文" X="1321" Y="267" WIDTH="17" HEIGHT="19" CONF="0.330" ORDER="2" STRING="集" />
  <LINE TYPE="本文" X="1290" Y="268" WIDTH="15" HEIGHT="17" CONF="0.332" ORDER="3" STRING="上" />
  <LINE TYPE="本文" X="1256" Y="267" WIDTH="17" HEIGHT="18" CONF="0.382" ORDER="4" STRING="卷" />
  <LINE TYPE="本文" X="1681" Y="347" WIDTH="24" HEIGHT="195" CONF="0.872" ORDER="5" STRING="就て述べて見よう。" />
  <LINE TYPE="本文" X="1718" Y="1118" WIDTH="21" HEIGHT="38" CONF="0.419" ORDER="6" STRING="三二" />
  <LINE TYPE="本文" X="1632" Y="363" WIDTH="29" HEIGHT="970" CONF="0.785" ORDER="7" STRING="一、原因の性質で、是は、其高下の原因が、一種なるとあり。又二種以上の原因が相集つて、高" />
  <LINE TYPE="本文" X="1595" Y="384" WIDTH="23" HEIGHT="268" CONF="0.877" ORDER="8" STRING="下の原因となるとがある。" />
  <LINE TYPE="本文" X="1546" Y="358" WIDTH="30" HEIGHT="826" CONF="0.864" ORDER="9" STRING="二、原因の數量で、是は、其大小強弱に因て、相塲に影響するとも違ふ譯である。" />
  <LINE TYPE="本文" X="1502" Y="368" WIDTH="31" HEIGHT="966" CONF="0.865" ORDER="10" STRING="三、原因の影響する間の時間て、原因が出ると、直に相塲に影響するとあり。亦遙か後に、影響" />
  <LINE TYPE="本文" X="1462" Y="378" WIDTH="27" HEIGHT="522" CONF="0.888" ORDER="11" STRING="するとあり。亦全然、相塲に影響せざることもある。" />
  <LINE TYPE="本文" X="1416" Y="339" WIDTH="31" HEIGHT="988" CONF="0.882" ORDER="12" STRING="だからして、相場の高下を推測するには、以上の三範疇に就て、取調べなければならないのであつ" />
  <LINE TYPE="本文" X="1372" Y="339" WIDTH="33" HEIGHT="989" CONF="0.868" ORDER="13" STRING="て、之を取調べて高下の斷案を下すには、必ず、多少の經驗を要する。此經驗なくして、迂濶に斷" />
  <LINE TYPE="本文" X="1330" Y="339" WIDTH="32" HEIGHT="992" CONF="0.855" ORDER="14" STRING="案を下して商内を仕掛け樣ものなら、屹度失敗の破目に陷る。是即ち、翁が、此道不案内の人は、" />
  <LINE TYPE="本文" X="1286" Y="336" WIDTH="31" HEIGHT="536" CONF="0.863" ORDER="15" STRING="決して米相場をしてはならぬと、訓戒した譯である。" />
  <LINE TYPE="本文" X="1218" Y="486" WIDTH="34" HEIGHT="452" CONF="0.831" ORDER="16" STRING="第十六章天井直段後通相塲の事" />
  <LINE TYPE="本文" X="1153" Y="326" WIDTH="35" HEIGHT="1005" CONF="0.837" ORDER="17" STRING="一天井直段後、通にて下相塲は、月頭に上げ、月末には、廿九日晦日迄に、二三十俵三四十俵宛、定" />
  <LINE TYPE="本文" X="1120" Y="316" WIDTH="24" HEIGHT="242" CONF="0.777" ORDER="18" STRING="めて下る者也、疑なし。" />
  <LINE TYPE="本文" X="1063" Y="331" WIDTH="38" HEIGHT="989" CONF="0.788" ORDER="19" STRING="(釋)天井直段後の下相塲と云ふ者は、月の上旬には、前月の高直覺への爲めに買慕ひ多く、何と" />
  <LINE TYPE="本文" X="917" Y="344" WIDTH="36" HEIGHT="983" CONF="0.895" ORDER="20" STRING="なく上向く者であるけれ共、唯夫丈けの者であつて、四囲の事情、別に高材料もなく、却つて正米" />
  <LINE TYPE="本文" X="873" Y="349" WIDTH="38" HEIGHT="978" CONF="0.897" ORDER="21" STRING="の輸入あつたとか、産地が安いとか、亦は氣候が好順だとか、安材料の爲めに、自然と買人なく、" />
  <LINE TYPE="本文" X="830" Y="345" WIDTH="37" HEIGHT="989" CONF="0.868" ORDER="22" STRING="投物等顕はれて、月の中旬乃至下旬には、屹度下る者であるから、罫線表を見て、天井後の通上げ" />
  <LINE TYPE="本文" X="784" Y="341" WIDTH="32" HEIGHT="465" CONF="0.911" ORDER="23" STRING="と云ふことを見定め、売方針を立てべきである。" />
  <LINE TYPE="本文" X="717" Y="493" WIDTH="36" HEIGHT="538" CONF="0.861" ORDER="24" STRING="第十七章七八月天井五六ケ月引下の事" />
  <LINE TYPE="本文" X="655" Y="328" WIDTH="36" HEIGHT="992" CONF="0.867" ORDER="25" STRING="一七、八、兩月天井直段出る時は、十二月迄下る者也。正月少々上れ共、春中不景氣なる者也。其節、" />
  <LINE TYPE="本文" X="610" Y="325" WIDTH="31" HEIGHT="483" CONF="0.825" ORDER="26" STRING="過分引下る時は、五六月の内、極めて上る者也。" />
  <LINE TYPE="本文" X="569" Y="340" WIDTH="36" HEIGHT="994" CONF="0.894" ORDER="27" STRING="(糯)七八月頃の天井直段と云ふ者は、多くは、風雨洪水等の爲めに、其天井になる程の高直を出" />
  <LINE TYPE="本文" X="525" Y="337" WIDTH="37" HEIGHT="1004" CONF="0.902" ORDER="28" STRING="した者であるから、其後に至り、気候が本順に復し、作柄も見直した時には、段々十二月頃迄も五" />
  <LINE TYPE="本文" X="483" Y="349" WIDTH="35" HEIGHT="983" CONF="0.884" ORDER="29" STRING="六ケ月も引續き下る者である。正月頃になつては、利喰の買物も出るであらうし、天井よりは可な" />
  <LINE TYPE="本文" X="440" Y="351" WIDTH="35" HEIGHT="981" CONF="0.900" ORDER="30" STRING="り下がつたと云つて、思惑買等も出る爲に、多少上る者であるけれども、何しろ、豊作尻の米と云ひ、" />
  <LINE TYPE="本文" X="396" Y="340" WIDTH="37" HEIGHT="1005" CONF="0.891" ORDER="31" STRING="買方も前年の例もあり旁々、無暗に買進まないから、相塲は、春中は容易く引立たず、下直に保合" />
  <LINE TYPE="本文" X="353" Y="351" WIDTH="35" HEIGHT="987" CONF="0.878" ORDER="32" STRING="ふ者である。併し、四五月頃になつては、産地の出過ぎ、乃至は麥作の不良等を申唱へて、ぢり" />
  <LINE TYPE="本文" X="309" Y="345" WIDTH="29" HEIGHT="499" CONF="0.856" ORDER="33" STRING="〳〵、五六月頃迄上げを續けることある者である。" />
  <LINE TYPE="本文" X="279" Y="1124" WIDTH="21" HEIGHT="36" CONF="0.488" ORDER="34" STRING="三三" />
  </PAGE>

