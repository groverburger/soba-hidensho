<LINE TYPE="本文" X="1760" Y="338" WIDTH="21" HEIGHT="1105" CONF="0.339" ORDER="1" STRING="…………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………" />
  <LINE TYPE="本文" X="1667" Y="328" WIDTH="33" HEIGHT="1007" CONF="0.851" ORDER="2" STRING="右衛門なる者、家老兼郡代たり、奮て藩の財政を改革し、酒田鶴岡の兩地に藩廳の倉庫を設置し、毎" />
  <LINE TYPE="本文" X="1526" Y="273" WIDTH="15" HEIGHT="21" CONF="0.488" ORDER="3" STRING="宗" />
  <LINE TYPE="本文" X="1477" Y="273" WIDTH="15" HEIGHT="20" CONF="0.415" ORDER="4" STRING="久" />
  <LINE TYPE="本文" X="1429" Y="271" WIDTH="16" HEIGHT="21" CONF="0.360" ORDER="5" STRING="翁" />
  <LINE TYPE="本文" X="1380" Y="271" WIDTH="17" HEIGHT="20" CONF="0.320" ORDER="6" STRING="相" />
  <LINE TYPE="本文" X="1333" Y="271" WIDTH="16" HEIGHT="20" CONF="0.320" ORDER="7" STRING="場" />
  <LINE TYPE="本文" X="1236" Y="269" WIDTH="15" HEIGHT="19" CONF="0.361" ORDER="8" STRING="集" />
  <LINE TYPE="本文" X="1623" Y="327" WIDTH="34" HEIGHT="1009" CONF="0.910" ORDER="9" STRING="年十月を期して領内の貢米を此兩倉庫に納入せしめ、之に對して其組の代官兩名づゝの名儀にて、預" />
  <LINE TYPE="本文" X="1581" Y="320" WIDTH="34" HEIGHT="1023" CONF="0.909" ORDER="10" STRING="り米札を發行し、藩士の祿は、凡て此米札を以て給與するの制を定め、且商賈に拂下ぐる御拂米なる" />
  <LINE TYPE="本文" X="1538" Y="322" WIDTH="33" HEIGHT="1011" CONF="0.873" ORDER="11" STRING="者も、又總べて此米札を以てし、倉庫に至り、何時にても正米と引替ふるを得るとゝせり。而して、" />
  <LINE TYPE="本文" X="1495" Y="317" WIDTH="34" HEIGHT="1019" CONF="0.876" ORDER="12" STRING="藩廳に於て其監督を嚴密にすると同時に、隨意に市塲に賣買轉々せしむると、正米と同様に之を許可" />
  <LINE TYPE="本文" X="1453" Y="313" WIDTH="33" HEIGHT="961" CONF="0.871" ORDER="13" STRING="せるが故に、士民、特に米商の如きは、大なる便宜を得、賣買年を逐ふて昌盛に趣きたり。" />
  <LINE TYPE="本文" X="1409" Y="305" WIDTH="35" HEIGHT="1029" CONF="0.817" ORDER="14" STRING="▲酒田米會所(歩坐方)の創立は實に源を此米札の賣" />
  <LINE TYPE="本文" X="1368" Y="318" WIDTH="33" HEIGHT="1013" CONF="0.899" ORDER="15" STRING="米なるが故に、其品質の好良なると。(第二)感出しの期限は、翌年の十月にして、其間は何時にても" />
  <LINE TYPE="本文" X="1324" Y="307" WIDTH="35" HEIGHT="1029" CONF="0.907" ORDER="16" STRING="正米と引替藏出するを得ると。(第三)受渡しは、米札の受授を以て足り、且品質一定し居るが故に、" />
  <LINE TYPE="本文" X="1281" Y="316" WIDTH="34" HEIGHT="1010" CONF="0.884" ORDER="17" STRING="其都度米質を檢査するの煩なく、且度々桝廻し藏移し等の手數を要せざると、等の特點を有するを以" />
  <LINE TYPE="本文" X="1239" Y="318" WIDTH="34" HEIGHT="1010" CONF="0.911" ORDER="18" STRING="て、酒田水舶の各国の商船は、問屋を介して購入する者甚だ多數にして、中には、直段の安き時に購" />
  <LINE TYPE="本文" X="1195" Y="309" WIDTH="36" HEIGHT="1027" CONF="0.908" ORDER="19" STRING="入し置き、相場の上れる時之を賣放し其差を利せんとする思惑人も出て来りて、追々賣買の隆昌を来" />
  <LINE TYPE="本文" X="1153" Y="315" WIDTH="34" HEIGHT="1013" CONF="0.882" ORDER="20" STRING="すに連れ、各問屋、互に申合せて一の取引市塲を設け、各々附屬の仲買人を毎夕刻より茲に出場しめ" />
  <LINE TYPE="本文" X="1110" Y="315" WIDTH="35" HEIGHT="1009" CONF="0.866" ORDER="21" STRING="期月を定めて右札米の賣買をなさしめ、期月に至り受渡には總べて此米札を用ひたり、是が即ち酒田" />
  <LINE TYPE="本文" X="1076" Y="316" WIDTH="25" HEIGHT="199" CONF="0.872" ORDER="22" STRING="米会所の根源なり。" />
  <LINE TYPE="本文" X="766" Y="274" WIDTH="17" HEIGHT="20" CONF="0.355" ORDER="23" STRING="酒" />
  <LINE TYPE="本文" X="729" Y="274" WIDTH="16" HEIGHT="19" CONF="0.415" ORDER="24" STRING="田" />
  <LINE TYPE="本文" X="692" Y="274" WIDTH="15" HEIGHT="19" CONF="0.392" ORDER="25" STRING="米" />
  <LINE TYPE="本文" X="654" Y="274" WIDTH="14" HEIGHT="18" CONF="0.359" ORDER="26" STRING="會" />
  <LINE TYPE="本文" X="616" Y="272" WIDTH="17" HEIGHT="20" CONF="0.406" ORDER="27" STRING="所" />
  <LINE TYPE="本文" X="579" Y="271" WIDTH="15" HEIGHT="19" CONF="0.323" ORDER="28" STRING="の" />
  <LINE TYPE="本文" X="541" Y="272" WIDTH="15" HEIGHT="20" CONF="0.409" ORDER="29" STRING="商" />
  <LINE TYPE="本文" X="507" Y="272" WIDTH="16" HEIGHT="19" CONF="0.419" ORDER="30" STRING="習" />
  <LINE TYPE="本文" X="469" Y="270" WIDTH="17" HEIGHT="21" CONF="0.438" ORDER="31" STRING="慣" />
  <LINE TYPE="本文" X="913" Y="322" WIDTH="30" HEIGHT="796" CONF="0.822" ORDER="32" STRING="▲霜月限又新商十一月期のことにして、建米は新米なり發會は大概六月中なり" />
  <LINE TYPE="本文" X="868" Y="326" WIDTH="33" HEIGHT="1003" CONF="0.869" ORDER="33" STRING="▲何俵上げ又何俵下げ藩の制、米の相塲を立つるに、拾兩に付五斗入何俵何分と稱す。故に會所に" />
  <LINE TYPE="本文" X="827" Y="322" WIDTH="31" HEIGHT="1007" CONF="0.896" ORDER="34" STRING="於ても其唱へに隨ひ、拾兩に付何程と相塲を立て、百兩分を一つ即ち一枚と定む。故に千兩分と云へ" />
  <LINE TYPE="本文" X="784" Y="322" WIDTH="31" HEIGHT="1012" CONF="0.877" ORDER="35" STRING="ば十枚、百枚は一萬兩分なりとす。左れば、四十俵上げ乃至百七八十俵上げ抔と云ふは、百兩分に就" />
  <LINE TYPE="本文" X="743" Y="321" WIDTH="25" HEIGHT="469" CONF="0.869" ORDER="36" STRING="て之を云ふなり。下げとあるも同斷なりとす。" />
  <LINE TYPE="本文" X="695" Y="322" WIDTH="32" HEIGHT="1007" CONF="0.899" ORDER="37" STRING="▲落引又は連れ落及緊落引とは、簡短に之を説明すれば、指金落切のどなり。尤も往時は差札と稱" />
  <LINE TYPE="本文" X="654" Y="322" WIDTH="32" HEIGHT="1007" CONF="0.905" ORDER="38" STRING="し、米札即ち今の所謂米券を以て、證據金に代用するの慣例なりき。但し、其落引の額は、時々規約" />
  <LINE TYPE="本文" X="610" Y="321" WIDTH="31" HEIGHT="1010" CONF="0.855" ORDER="39" STRING="の改正に因り、二十俵高下落引、乃至四十俵高下落引等一定せず。而して、商内は(落引及泣きの場" />
  <LINE TYPE="本文" X="566" Y="322" WIDTH="30" HEIGHT="1006" CONF="0.895" ORDER="40" STRING="合を除き)限月迄損益を差引勘定するを得ざる仕組故、賣埋又は買埋して、賣買の已に濟み居る商と" />
  <LINE TYPE="本文" X="525" Y="324" WIDTH="29" HEIGHT="1004" CONF="0.890" ORDER="41" STRING="雖も、限月迄の間は、賣は賣、買は買と各別に見做す故、相塲の高下に依り、其賣玉或は其買玉に對" />
  <LINE TYPE="本文" X="485" Y="322" WIDTH="25" HEIGHT="521" CONF="0.867" ORDER="42" STRING="して、落斷りを得ると、尋常新規賣買の商内に同じ。" />
  <LINE TYPE="本文" X="439" Y="333" WIDTH="31" HEIGHT="997" CONF="0.901" ORDER="43" STRING="例へば、二十一俵の相塲にて、甲仲買乙仲買より十枚即ち百兩分を買受け證據金として双方より證" />
  <LINE TYPE="本文" X="396" Y="326" WIDTH="31" HEIGHT="1012" CONF="0.893" ORDER="44" STRING="據金を取引所に指入れ置きたるに、其相場騰貴して、十九俵となる時、(二十俵落引の塲合を以て云" />
  <LINE TYPE="本文" X="353" Y="330" WIDTH="30" HEIGHT="973" CONF="0.804" ORDER="45" STRING="ふ)甲は乙に對して、落引に掛りし旨を通知し、(落引を見るには、平均直段を以てす)二俵指落切" />
  <LINE TYPE="本文" X="312" Y="333" WIDTH="28" HEIGHT="860" CONF="0.835" ORDER="46" STRING="にするか、或は今一ト追敷を入れて、商内を繋ぐかを照會する也、之を落斷りと云ふ。" />
  <LINE TYPE="本文" X="275" Y="1113" WIDTH="21" HEIGHT="23" CONF="0.435" ORDER="47" STRING="二一" />
  </PAGE>

