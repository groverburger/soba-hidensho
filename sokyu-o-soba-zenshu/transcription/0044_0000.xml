  <LINE TYPE="本文" X="1509" Y="278" WIDTH="15" HEIGHT="19" CONF="0.389" ORDER="0" STRING="宗" />
  <LINE TYPE="本文" X="1444" Y="277" WIDTH="15" HEIGHT="19" CONF="0.350" ORDER="1" STRING="編" />
  <LINE TYPE="本文" X="1475" Y="278" WIDTH="16" HEIGHT="18" CONF="0.372" ORDER="2" STRING="久" />
  <LINE TYPE="本文" X="1412" Y="276" WIDTH="15" HEIGHT="21" CONF="0.353" ORDER="3" STRING="相" />
  <LINE TYPE="本文" X="1379" Y="275" WIDTH="16" HEIGHT="22" CONF="0.316" ORDER="4" STRING="場" />
  <LINE TYPE="本文" X="1315" Y="274" WIDTH="15" HEIGHT="21" CONF="0.313" ORDER="5" STRING="集" />
<LINE TYPE="本文" X="1283" Y="276" WIDTH="14" HEIGHT="19" CONF="0.326" ORDER="6" STRING="上" />
  <LINE TYPE="本文" X="1250" Y="275" WIDTH="16" HEIGHT="19" CONF="0.384" ORDER="7" STRING="卷" />
  <LINE TYPE="本文" X="1723" Y="1124" WIDTH="18" HEIGHT="35" CONF="0.372" ORDER="8" STRING="五八" />
  <LINE TYPE="本文" X="1678" Y="352" WIDTH="30" HEIGHT="983" CONF="0.877" ORDER="9" STRING="の出るとの四件である。一體、賣方は數ケ月勝利し來つた勢に乘つて、手の及ぶ丈玉數を殖やし賣叩" />
  <LINE TYPE="本文" X="1635" Y="350" WIDTH="31" HEIGHT="991" CONF="0.875" ORDER="10" STRING="いたる結果、此底を出した者である。已に、此上玉数を殖やすとが出來なければ、勢ひ利喰買埋し" />
  <LINE TYPE="本文" X="1591" Y="349" WIDTH="31" HEIGHT="988" CONF="0.893" ORDER="11" STRING="なくつちやならない。そして、右利喰の爲め相塲が少し引返すと、偖は先きの安直は底であつたか" />
  <LINE TYPE="本文" X="1548" Y="350" WIDTH="30" HEIGHT="985" CONF="0.905" ORDER="12" STRING="と云ふて、利喰を急ぐ者もあれば、其内、或る上の原因抔を申唱へて新買等も出て、時として利喰" />
  <LINE TYPE="本文" X="1507" Y="344" WIDTH="26" HEIGHT="605" CONF="0.887" ORDER="13" STRING="急ぎの為め、米売りの米上げと云ふ結果を生ずるとがある。" />
  <LINE TYPE="本文" X="1462" Y="347" WIDTH="30" HEIGHT="982" CONF="0.896" ORDER="14" STRING="以上に説いた處ろは、陰陽轉還の道理の學術的説明であるが、古人は此道理をば克く説明せずに、" />
  <LINE TYPE="本文" X="1419" Y="350" WIDTH="30" HEIGHT="987" CONF="0.899" ORDER="15" STRING="或は神秘的に、或は不可思議的に記述した者も少くない様だ。彼の猛虎軒慈雲齋の如き、此部に屬" />
  <LINE TYPE="本文" X="1378" Y="345" WIDTH="27" HEIGHT="639" CONF="0.901" ORDER="16" STRING="する者であるが、所謂英雄人を欺くの類であらう。慈雲齋曰く、" />
  <LINE TYPE="本文" X="1335" Y="362" WIDTH="27" HEIGHT="609" CONF="0.911" ORDER="17" STRING="理と非との、中に籠もれる理外の理、米の高下の源と知れ。" />
  <LINE TYPE="本文" X="1292" Y="362" WIDTH="25" HEIGHT="561" CONF="0.896" ORDER="18" STRING="高安の理は空理にて目に見へず、影も形もなき者が體。" />
  <LINE TYPE="本文" X="1251" Y="349" WIDTH="22" HEIGHT="125" CONF="0.841" ORDER="19" STRING="と歌ひ、又、" />
  <LINE TYPE="本文" X="1202" Y="358" WIDTH="32" HEIGHT="974" CONF="0.850" ORDER="20" STRING="大極動きて陽を生じ、動くと極りて靜なり、静にして陰を生ず。靜なると極りて亦動く、一動一" />
  <LINE TYPE="本文" X="1163" Y="364" WIDTH="23" HEIGHT="216" CONF="0.844" ORDER="21" STRING="靜あるに其根となる。" />
  <LINE TYPE="本文" X="1119" Y="348" WIDTH="24" HEIGHT="260" CONF="0.794" ORDER="22" STRING="と云ふた。猛虎軒は、又、" />
  <LINE TYPE="本文" X="1071" Y="356" WIDTH="31" HEIGHT="975" CONF="0.827" ORDER="23" STRING="人の気分、陽に上り詰めたる時は、陰来つて陰に趣き下る者也。又、陰に下り詰る時は、陽来の" />
  <LINE TYPE="本文" X="916" Y="364" WIDTH="21" HEIGHT="123" CONF="0.809" ORDER="24" STRING="て上る者也。" />
  <LINE TYPE="本文" X="869" Y="338" WIDTH="30" HEIGHT="990" CONF="0.862" ORDER="25" STRING="抔と、勿體をつけたが、以上の如く學術的に解釋をすれば、何でもない話である。併し、陰陽轉還" />
  <LINE TYPE="本文" X="826" Y="328" WIDTH="31" HEIGHT="991" CONF="0.871" ORDER="26" STRING="は、唯に相場界のみならず、宇宙間の眞理であるから、吾人は、决して之をさみする譯ではないが、" />
  <LINE TYPE="本文" X="783" Y="328" WIDTH="29" HEIGHT="915" CONF="0.882" ORDER="27" STRING="其説明の、餘り宗教的ぢみて居る爲め、後進を誤らんとを恐れ、茲に一言する譯である。" />
  <LINE TYPE="本文" X="714" Y="483" WIDTH="31" HEIGHT="481" CONF="0.872" ORDER="28" STRING="第四十三章霜月限買入心得方の事" />
  <LINE TYPE="本文" X="651" Y="318" WIDTH="31" HEIGHT="1010" CONF="0.898" ORDER="29" STRING="一霜月限、六七月より買入候ては、退屈致し利運遠し。其年の模樣を考へ、八九月の内に買入れてよ" />
  <LINE TYPE="本文" X="609" Y="311" WIDTH="28" HEIGHT="814" CONF="0.818" ORDER="30" STRING="べし。作無難の年は、如此心得べし。不作年には、六月より買入るゝと第一也。" />
  <LINE TYPE="本文" X="564" Y="328" WIDTH="31" HEIGHT="1002" CONF="0.882" ORDER="31" STRING="(釋)本章は、新米買思惑の時機を示めした者で、例令ひ、相塲が下直に居つても、氣候が本順で" />
  <LINE TYPE="本文" X="522" Y="338" WIDTH="29" HEIGHT="974" CONF="0.868" ORDER="32" STRING="ある年柄は、六七月早々から買ふて置くに及ばぬ。或は、順氣下げで好買塲が出ぬとも限らない。" />
  <LINE TYPE="本文" X="479" Y="330" WIDTH="28" HEIGHT="856" CONF="0.831" ORDER="33" STRING="併し、気候が不順で不作と見へる年柄は、六月から買入れるとを心がけねばならぬ。" />
  <LINE TYPE="本文" X="408" Y="484" WIDTH="33" HEIGHT="543" CONF="0.838" ORDER="34" STRING="第四十四章上相塲にて利運心得方の事" />
  <LINE TYPE="本文" X="347" Y="325" WIDTH="30" HEIGHT="1003" CONF="0.872" ORDER="35" STRING="一上相塲にて利運落引の節、底直を考へ賣返さゞる者也。底の買落にならば、尚々買重ねてもよき也。" />
  <LINE TYPE="本文" X="303" Y="315" WIDTH="31" HEIGHT="1019" CONF="0.832" ORDER="36" STRING="百俵上を考へ上げかゝる米は、二位落る者故、此處考へ取留る者也。夫共に、百俵上近き時は、早" />
  <LINE TYPE="本文" X="267" Y="1111" WIDTH="19" HEIGHT="39" CONF="0.508" ORDER="37" STRING="五九" />
  </PAGE>

