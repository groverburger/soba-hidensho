  <LINE TYPE="本文" X="1491" Y="268" WIDTH="16" HEIGHT="19" CONF="0.314" ORDER="0" STRING="久" />
<LINE TYPE="本文" X="1459" Y="267" WIDTH="17" HEIGHT="18" CONF="0.344" ORDER="1" STRING="探" />
  <LINE TYPE="本文" X="1426" Y="267" WIDTH="16" HEIGHT="19" CONF="0.340" ORDER="2" STRING="相" />
  <LINE TYPE="本文" X="1395" Y="266" WIDTH="17" HEIGHT="19" CONF="0.359" ORDER="3" STRING="場" />
  <LINE TYPE="本文" X="1330" Y="266" WIDTH="16" HEIGHT="18" CONF="0.362" ORDER="4" STRING="集" />
  <LINE TYPE="本文" X="1362" Y="267" WIDTH="17" HEIGHT="18" CONF="0.364" ORDER="5" STRING="全" />
  <LINE TYPE="本文" X="1299" Y="266" WIDTH="14" HEIGHT="18" CONF="0.316" ORDER="6" STRING="上" />
  <LINE TYPE="本文" X="1266" Y="264" WIDTH="16" HEIGHT="20" CONF="0.336" ORDER="7" STRING="卷" />
  <LINE TYPE="本文" X="1730" Y="1113" WIDTH="19" HEIGHT="40" CONF="0.450" ORDER="8" STRING="四〇" />
  <LINE TYPE="本文" X="1684" Y="326" WIDTH="33" HEIGHT="1002" CONF="0.864" ORDER="9" STRING="月上る者也。一と目高下と心得べし。尤も、潜相塲に氣を付くべし。此兩月は、高下なき月故、賣買" />
  <LINE TYPE="本文" X="1640" Y="327" WIDTH="33" HEIGHT="1001" CONF="0.887" ORDER="10" STRING="共退屈氣を變する月也。其節、天井直段底直段を考ふると第一也。尤も、三月は相塲強き月也。崩れ" />
  <LINE TYPE="本文" X="1604" Y="323" WIDTH="25" HEIGHT="350" CONF="0.857" ORDER="11" STRING="は、四、五、六、此三ケ月の者也。" />
  <LINE TYPE="本文" X="1554" Y="337" WIDTH="32" HEIGHT="985" CONF="0.880" ORDER="12" STRING="(釋)正二兩月の相塲は、大高下のない月で、多く持合相場であるから少しドチラかへ動き出すと、" />
  <LINE TYPE="本文" X="1510" Y="340" WIDTH="32" HEIGHT="984" CONF="0.902" ORDER="13" STRING="そら來たかと云ふ鹽梅で、人氣は雷同附和するが、別段其材料がない爲に、跡は直に伸力がなくな" />
  <LINE TYPE="本文" X="1467" Y="339" WIDTH="32" HEIGHT="984" CONF="0.905" ORDER="14" STRING="る者である。正月上げれば二月下げ、正月下なければ二月上げると云ふのは、詰り此人気の作用を" />
  <LINE TYPE="本文" X="1422" Y="331" WIDTH="34" HEIGHT="1004" CONF="0.903" ORDER="15" STRING="云ふた者である。併し、是は汎論であつて定式でないから、「尤も潜相塲に氣を付くべし、」と鳴破し" />
  <LINE TYPE="本文" X="1380" Y="341" WIDTH="33" HEIGHT="983" CONF="0.883" ORDER="16" STRING="て注意を與へた。潜相塲と云ふのは、持合の、孰れにか解くれんとする塲合て、所謂、山雨来らん" />
  <LINE TYPE="本文" X="1337" Y="341" WIDTH="33" HEIGHT="979" CONF="0.902" ORDER="17" STRING="として風樓に滿つ、と云ふ樣に、變發の氣を十分に含んで居る塲合を指すのである。之を察するに" />
  <LINE TYPE="本文" X="1293" Y="334" WIDTH="34" HEIGHT="998" CONF="0.904" ORDER="18" STRING="は、其時の相場が、天井直段の位置なるが、又底直段の位置ではないか、將亦、中直の保合相塲で、" />
  <LINE TYPE="本文" X="1250" Y="338" WIDTH="33" HEIGHT="988" CONF="0.855" ORDER="19" STRING="あるかと云ふとを考ふるがよい。要するに、相塲の常勢から云へば、正二兩月は、小高下の月だか" />
  <LINE TYPE="本文" X="1206" Y="327" WIDTH="33" HEIGHT="1003" CONF="0.843" ORDER="20" STRING="ら、賣方買方双方共、心を総ずる月である。又三月は、相塲の強い月である。又、四五六月は、多" />
  <LINE TYPE="本文" X="1171" Y="334" WIDTH="23" HEIGHT="309" CONF="0.910" ORDER="21" STRING="く相塲の崩れとなる月である。" />
  <LINE TYPE="本文" X="1096" Y="482" WIDTH="31" HEIGHT="420" CONF="0.819" ORDER="22" STRING="第二十八章霜月限底天井の事" />
  <LINE TYPE="本文" X="728" Y="266" WIDTH="16" HEIGHT="18" CONF="0.326" ORDER="23" STRING="第" />
  <LINE TYPE="本文" X="903" Y="321" WIDTH="40" HEIGHT="1009" CONF="0.898" ORDER="24" STRING="一新霜月、初つて、四十五六俵五十俵位底にて起き上る米は、作合少々申分出る時は、天井直段、百" />
  <LINE TYPE="本文" X="859" Y="309" WIDTH="42" HEIGHT="1009" CONF="0.845" ORDER="25" STRING="俵上に限らず、時に寄り百六拾俵百八十俵も上る者と心得べし。六七月、三十四五俵より起き上る米" />
  <LINE TYPE="本文" X="816" Y="308" WIDTH="40" HEIGHT="976" CONF="0.819" ORDER="26" STRING="は假令此方作合相應にて、又は大坂相塲、引上げ乘米有之候ても、百俵上げは天井と心得べし。" />
  <LINE TYPE="本文" X="772" Y="318" WIDTH="42" HEIGHT="1021" CONF="0.891" ORDER="27" STRING="五十俵位の大底より起上る相場は、少しく作合が違ふ時は、百俵上げ處ではなく、百六十俵" />
  <LINE TYPE="本文" X="730" Y="332" WIDTH="39" HEIGHT="997" CONF="0.872" ORDER="28" STRING="乃至百八十俵上位も上げて、天井となる者であるが、中底の位置より起き出した米は、百俵上がつ" />
  <LINE TYPE="本文" X="689" Y="337" WIDTH="26" HEIGHT="351" CONF="0.891" ORDER="29" STRING="たらば、先づ天井と心得るがよい。" />
  <LINE TYPE="本文" X="692" Y="1027" WIDTH="23" HEIGHT="21" CONF="0.378" ORDER="30" STRING="出来る" />
  <LINE TYPE="本文" X="645" Y="343" WIDTH="40" HEIGHT="981" CONF="0.898" ORDER="31" STRING="本章は、中直の位置から上け出した相場は、天井迄上の割合少いけれ共、底の位から上げ出した相" />
  <LINE TYPE="本文" X="601" Y="340" WIDTH="40" HEIGHT="989" CONF="0.904" ORDER="32" STRING="塲は、直數の割合、夫丈多く上げる者だと云ふことを、説明した者である。一例を擧げれば、中直の位" />
  <LINE TYPE="本文" X="556" Y="340" WIDTH="41" HEIGHT="996" CONF="0.884" ORDER="33" STRING="からの上を、一割五分とすれば、太底から上げ出す時は、三割位も上げるとがあると云ふ意味であ" />
  <LINE TYPE="本文" X="518" Y="349" WIDTH="19" HEIGHT="35" CONF="0.674" ORDER="35" STRING="る。" />
  <LINE TYPE="本文" X="446" Y="494" WIDTH="36" HEIGHT="475" CONF="0.823" ORDER="36" STRING="第二十九章大高下過通ひ相塲の事" />
  <LINE TYPE="本文" X="385" Y="322" WIDTH="39" HEIGHT="1013" CONF="0.886" ORDER="37" STRING="一大高下も過ぎ、天井直段後、相塲持合、上か下か見合の時、何となく上方相塲抔含み、少々景氣付" />
  <LINE TYPE="本文" X="342" Y="325" WIDTH="38" HEIGHT="1006" CONF="0.883" ORDER="38" STRING="候時は、人々買氣になり、騒ぎ立程上る者也。其節決して賣塲也。是は、通相場にて、上ては下げ" />
  <LINE TYPE="本文" X="298" Y="321" WIDTH="40" HEIGHT="1011" CONF="0.809" ORDER="39" STRING="下ては上げ、過分の高下もなく、幾度も通ふ者也。右人氣と通ひの相塲に心を動かさず、天井と底と" />
  <LINE TYPE="本文" X="273" Y="1119" WIDTH="20" HEIGHT="34" CONF="0.484" ORDER="40" STRING="四一" />
  </PAGE>

