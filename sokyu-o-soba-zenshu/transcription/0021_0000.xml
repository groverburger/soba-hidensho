  <LINE TYPE="本文" X="1777" Y="83" WIDTH="34" HEIGHT="1341" CONF="0.440" ORDER="0" STRING="}" />
  <LINE TYPE="本文" X="1744" Y="821" WIDTH="24" HEIGHT="20" CONF="0.390" ORDER="1" STRING="七" />
  <LINE TYPE="本文" X="1726" Y="1098" WIDTH="22" HEIGHT="36" CONF="0.423" ORDER="2" STRING="三" />
  <LINE TYPE="本文" X="1682" Y="319" WIDTH="30" HEIGHT="993" CONF="0.856" ORDER="3" STRING="となる者である。併し、餘りに下る時は、其反動として、六月にかけて急上げとなるともあるから、" />
  <LINE TYPE="本文" X="1508" Y="245" WIDTH="19" HEIGHT="21" CONF="0.355" ORDER="4" STRING="宗" />
  <LINE TYPE="本文" X="1477" Y="246" WIDTH="16" HEIGHT="18" CONF="0.365" ORDER="5" STRING="久" />
  <LINE TYPE="本文" X="1445" Y="244" WIDTH="17" HEIGHT="21" CONF="0.351" ORDER="6" STRING="翁" />
  <LINE TYPE="本文" X="1413" Y="244" WIDTH="16" HEIGHT="20" CONF="0.348" ORDER="7" STRING="相" />
  <LINE TYPE="本文" X="1380" Y="243" WIDTH="17" HEIGHT="21" CONF="0.312" ORDER="8" STRING="塲" />
  <LINE TYPE="本文" X="1349" Y="242" WIDTH="16" HEIGHT="21" CONF="0.309" ORDER="9" STRING="全" />
  <LINE TYPE="本文" X="1316" Y="244" WIDTH="15" HEIGHT="20" CONF="0.326" ORDER="10" STRING="集" />
  <LINE TYPE="本文" X="1283" Y="244" WIDTH="17" HEIGHT="20" CONF="0.349" ORDER="11" STRING="上" />
  <LINE TYPE="本文" X="1251" Y="243" WIDTH="17" HEIGHT="22" CONF="0.396" ORDER="12" STRING="巻" />
  <LINE TYPE="本文" X="1640" Y="317" WIDTH="24" HEIGHT="402" CONF="0.832" ORDER="13" STRING="注意するがよい、次に第三節を説かう。" />
  <LINE TYPE="本文" X="1595" Y="319" WIDTH="30" HEIGHT="990" CONF="0.842" ORDER="14" STRING="八九月の底直は、春來氣候に申分なく、麥作も豊作の唱で、段々の安直を顯はし、折には一二縣洪" />
  <LINE TYPE="本文" X="1552" Y="310" WIDTH="30" HEIGHT="1007" CONF="0.842" ORDER="15" STRING="水抔の噂で、相塲の小戻りを見せるとあるけれ共、概して云へば、植付后の天候が良好で、且土用" />
  <LINE TYPE="本文" X="1530" Y="491" WIDTH="29" HEIGHT="425" CONF="0.554" ORDER="16" STRING="八百十八石四毛斃馬死" />
  <LINE TYPE="本文" X="1508" Y="317" WIDTH="33" HEIGHT="984" CONF="0.864" ORDER="17" STRING="中の照込も申分なく、農家も安心して持米を賣出し、商人も、又買控の方針て、容易く買進まない" />
  <LINE TYPE="本文" X="1465" Y="319" WIDTH="30" HEIGHT="980" CONF="0.891" ORDER="18" STRING="故、盆〻安氣配となり、豐年萬作を見越して、人も我も弱氣のダラ〳〵を唱和するから、一年中の" />
  <LINE TYPE="本文" X="1421" Y="313" WIDTH="31" HEIGHT="994" CONF="0.899" ORDER="19" STRING="底直段となるとがある。斯る塲合には、極めて買ふべしてある。人氣の弱氣に片寄つて居る時であ" />
  <LINE TYPE="本文" X="1378" Y="315" WIDTH="30" HEIGHT="988" CONF="0.851" ORDER="20" STRING="るから、度数の弱い暴風警報位ぢや、格別人気に障らんが、そうして居る中に、近県に虫害の噂で" />
  <LINE TYPE="本文" X="1333" Y="316" WIDTH="31" HEIGHT="983" CONF="0.889" ORDER="21" STRING="も出るか、亦暴風が障つたとか、早冷だとか、僅かのとが動機となつて、段々高直に進み、追々十" />
  <LINE TYPE="本文" X="1291" Y="318" WIDTH="31" HEIGHT="980" CONF="0.899" ORDER="22" STRING="一月頃になると、鎌入不足だとか、秋揚日和が不順だとか云つて、相場は、愈々段々高直に運びお" />
  <LINE TYPE="本文" X="1247" Y="315" WIDTH="32" HEIGHT="987" CONF="0.859" ORDER="23" STRING="まけにヤレ産地と不引合の、産地賣惜みのと、種々の事情が集つて來て、相塲は引締る一方である" />
  <LINE TYPE="本文" X="1201" Y="314" WIDTH="34" HEIGHT="988" CONF="0.859" ORDER="24" STRING="から、賣方の煎米、強氣の買煽りて、十一十二月頃迄、自然と上に向く著てある。併し、前述の事情" />
  <LINE TYPE="本文" X="1157" Y="318" WIDTH="36" HEIGHT="977" CONF="0.848" ORDER="25" STRING="で上げた相塲は、多く、十二月一月頃に至つて、一旦天井となる者であるから、大に注意を要する。" />
  <LINE TYPE="本文" X="1089" Y="467" WIDTH="35" HEIGHT="634" CONF="0.729" ORDER="26" STRING="第八章七、八、九、十月天井及夏下げの事" />
  <LINE TYPE="本文" X="473" Y="267" WIDTH="17" HEIGHT="17" CONF="0.361" ORDER="27" STRING="事" />
  <LINE TYPE="本文" X="505" Y="268" WIDTH="15" HEIGHT="16" CONF="0.362" ORDER="28" STRING="の" />
  <LINE TYPE="本文" X="539" Y="267" WIDTH="15" HEIGHT="18" CONF="0.377" ORDER="29" STRING="引" />
  <LINE TYPE="本文" X="569" Y="266" WIDTH="18" HEIGHT="18" CONF="0.375" ORDER="30" STRING="駈" />
  <LINE TYPE="本文" X="597" Y="267" WIDTH="15" HEIGHT="17" CONF="0.318" ORDER="31" STRING="年" />
  <LINE TYPE="本文" X="679" Y="267" WIDTH="14" HEIGHT="17" CONF="0.337" ORDER="32" STRING="章" />
  <LINE TYPE="本文" X="651" Y="267" WIDTH="16" HEIGHT="18" CONF="0.305" ORDER="33" STRING="不" />
<LINE TYPE="本文" X="907" Y="322" WIDTH="37" HEIGHT="998" CONF="0.882" ORDER="34" STRING="一七、八、九、十月天井直段の米は、十二月迄に下ると心得べし。思入多き年は、决して夏下げ也。" />
  <LINE TYPE="本文" X="863" Y="329" WIDTH="37" HEIGHT="1000" CONF="0.874" ORDER="35" STRING="(釋)一體、七、八、九、十月の天井直段なる者は、多くは、夏中に風雨洪水等の天災あつた結果" />
  <LINE TYPE="本文" X="820" Y="332" WIDTH="36" HEIGHT="997" CONF="0.902" ORDER="36" STRING="か、又は端境品かすれの爲めに、一時此高直を現したのであるから、其后、天候恢復して作柄も見" />
  <LINE TYPE="本文" X="777" Y="336" WIDTH="36" HEIGHT="989" CONF="0.900" ORDER="37" STRING="直され、加へて、先きの高直で、各地の正米を吸集した結果に連れて、期米も段々安直となり、其" />
  <LINE TYPE="本文" X="734" Y="333" WIDTH="36" HEIGHT="997" CONF="0.875" ORDER="38" STRING="後收獲前となつて、新米の取入充分と云ふ見込の付く時は、地方の農家では、商人に對し、新米を" />
  <LINE TYPE="本文" X="691" Y="334" WIDTH="36" HEIGHT="995" CONF="0.897" ORDER="39" STRING="安直で賣る豫約等をする者が多いから、各地の正米先づ低落し、其結果定期に影響して、買方の投" />
  <LINE TYPE="本文" X="647" Y="338" WIDTH="37" HEIGHT="988" CONF="0.870" ORDER="40" STRING="米抔が出て、意外の低落を見る者である。次の思入多き年は、決して夏下也云々。は前章、第二節" />
  <LINE TYPE="本文" X="603" Y="343" WIDTH="24" HEIGHT="146" CONF="0.867" ORDER="41" STRING="と同意である。" />
  <LINE TYPE="本文" X="535" Y="486" WIDTH="32" HEIGHT="331" CONF="0.863" ORDER="42" STRING="第九章不作年駈引の事" />
  <LINE TYPE="本文" X="473" Y="320" WIDTH="35" HEIGHT="1011" CONF="0.882" ORDER="43" STRING="一當地、六七月雨勝凉敷、時候冷々敷、天氣稀なる年は、此方近國共極めて不作也。又九州、西國、" />
  <LINE TYPE="本文" X="428" Y="315" WIDTH="38" HEIGHT="1026" CONF="0.851" ORDER="44" STRING="中國、五畿内、東海道、奥筋共、天気作合年々不同也。北国上作、西國不作、又西國上作、關東不作、" />
  <LINE TYPE="本文" X="385" Y="317" WIDTH="33" HEIGHT="647" CONF="0.858" ORDER="45" STRING="其年々大概当国に順すると雖も、其違あるなり、能々考ふべし。" />
  <LINE TYPE="本文" X="343" Y="335" WIDTH="36" HEIGHT="1000" CONF="0.893" ORDER="46" STRING="(釋)本章、之を敷節に分けるとが出來る。本節は、其觀測地の作柄を以て、全国の作柄を大観す" />
  <LINE TYPE="本文" X="299" Y="324" WIDTH="37" HEIGHT="1012" CONF="0.836" ORDER="47" STRING="るの方法を述べたもので、茲には、荘内地方を基点として、之を説明した者であるから、當地と云" />
  <LINE TYPE="本文" X="271" Y="1124" WIDTH="20" HEIGHT="32" CONF="0.452" ORDER="48" STRING="一三" />
  <LINE TYPE="本文" X="235" Y="828" WIDTH="25" HEIGHT="22" CONF="0.418" ORDER="49" STRING="一一" />
