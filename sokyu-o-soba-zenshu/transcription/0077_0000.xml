<PAGE IMAGENAME="0077_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1761" Y="1101" WIDTH="22" HEIGHT="53" CONF="0.439" ORDER="0" STRING="一二四" />
  <LINE TYPE="本文" X="1718" Y="316" WIDTH="30" HEIGHT="992" CONF="0.810" ORDER="1" STRING="(釋)本章の一つ目に就ては、上卷、第廿七章の正二月の相塲は、正" />
  <LINE TYPE="本文" X="1675" Y="316" WIDTH="28" HEIGHT="743" CONF="0.876" ORDER="2" STRING="月上れば二月下げ、正月下れば二月上る者也、と云處を參照するがよい。" />
  <LINE TYPE="本文" X="1606" Y="471" WIDTH="29" HEIGHT="507" CONF="0.844" ORDER="3" STRING="第三十八章朔日より四五日頃迄の事" />
  <LINE TYPE="本文" X="1549" Y="248" WIDTH="17" HEIGHT="21" CONF="0.459" ORDER="4" STRING="宗" />
  <LINE TYPE="本文" X="1516" Y="248" WIDTH="17" HEIGHT="18" CONF="0.457" ORDER="5" STRING="久" />
  <LINE TYPE="本文" X="1485" Y="248" WIDTH="17" HEIGHT="18" CONF="0.449" ORDER="6" STRING="翁" />
  <LINE TYPE="本文" X="1421" Y="247" WIDTH="16" HEIGHT="16" CONF="0.422" ORDER="7" STRING="塲" />
  <LINE TYPE="本文" X="1453" Y="248" WIDTH="16" HEIGHT="17" CONF="0.443" ORDER="8" STRING="相" />
  <LINE TYPE="本文" X="1389" Y="247" WIDTH="15" HEIGHT="17" CONF="0.421" ORDER="9" STRING="全" />
  <LINE TYPE="本文" X="1356" Y="246" WIDTH="16" HEIGHT="18" CONF="0.450" ORDER="10" STRING="集" />
  <LINE TYPE="本文" X="1325" Y="245" WIDTH="16" HEIGHT="18" CONF="0.423" ORDER="11" STRING="下" />
  <LINE TYPE="本文" X="1292" Y="245" WIDTH="16" HEIGHT="18" CONF="0.471" ORDER="12" STRING="巻" />
  <LINE TYPE="本文" X="1544" Y="301" WIDTH="29" HEIGHT="1011" CONF="0.873" ORDER="13" STRING="一朔日より四日五日頃迄、一つ目二つ目潜る米は、通の内の買相塲とあり。是は、前に記す天井後の下" />
  <LINE TYPE="本文" X="1503" Y="305" WIDTH="27" HEIGHT="764" CONF="0.789" ORDER="14" STRING="相塲の時、前月より其月初めに高き時は、其月上ると云事なり、心得べし。" />
  <LINE TYPE="本文" X="1458" Y="314" WIDTH="30" HEIGHT="999" CONF="0.875" ORDER="15" STRING="(釋)已に説てある如く、天井後の下相塲と云者は、二三ケ月或は五六ケ月の間、毎月々初めに高" />
  <LINE TYPE="本文" X="1415" Y="314" WIDTH="30" HEIGHT="993" CONF="0.869" ORDER="16" STRING="く月末に安い者であるが、若し、此法規を破て、前月の月末からかけて、其月の初めに高直を出す" />
  <LINE TYPE="本文" X="1374" Y="310" WIDTH="26" HEIGHT="883" CONF="0.849" ORDER="17" STRING="様な景況の時は、通上となつて、其月中に高くなる者であるから、心得て置くが宜い。" />
  <LINE TYPE="本文" X="1304" Y="464" WIDTH="29" HEIGHT="394" CONF="0.860" ORDER="18" STRING="第三十九章米商心得方の事" />
  <LINE TYPE="本文" X="1243" Y="297" WIDTH="27" HEIGHT="606" CONF="0.887" ORDER="19" STRING="一二つ仕舞、三つ十分、四つ轉じの事は、前に記し置く也。" />
  <LINE TYPE="本文" X="1198" Y="297" WIDTH="30" HEIGHT="1014" CONF="0.905" ORDER="20" STRING="右米商は、上げ下げ二つより出で、心の道の多きと絲筋の如し、此商を心掛る人は、前條の趣意、常" />
  <LINE TYPE="本文" X="1154" Y="294" WIDTH="31" HEIGHT="1010" CONF="0.856" ORDER="21" STRING="々無油断見明らめ、考ふべし。悉く見極むる時は、自然と米の強弱を知る也。此書を能々見明らめ" />
  <LINE TYPE="本文" X="1110" Y="295" WIDTH="31" HEIGHT="1008" CONF="0.854" ORDER="22" STRING="賣買を致す時は、假令、其年天災不時、作の豊凶、米の多少、買船の多少、人気を以て何程相塲動き" />
  <LINE TYPE="本文" X="550" Y="252" WIDTH="15" HEIGHT="19" CONF="0.316" ORDER="23" STRING="得" />
<LINE TYPE="本文" X="502" Y="253" WIDTH="16" HEIGHT="18" CONF="0.349" ORDER="24" STRING="の" />
  <LINE TYPE="本文" X="477" Y="255" WIDTH="16" HEIGHT="20" CONF="0.376" ORDER="25" STRING="事" />
  <LINE TYPE="本文" X="912" Y="296" WIDTH="38" HEIGHT="720" CONF="0.864" ORDER="26" STRING="ても、利を得ずと云ふことなし、必らず〳〵、他見無用、専ら慎むべし。" />
  <LINE TYPE="本文" X="869" Y="293" WIDTH="46" HEIGHT="1028" CONF="0.900" ORDER="27" STRING="此二つ仕廻、三つ十分、四つ轉じと云事は、定期賣買の極意であつて、期米と株米と株式とを問ふ" />
  <LINE TYPE="本文" X="828" Y="315" WIDTH="41" HEIGHT="993" CONF="0.874" ORDER="28" STRING="ず、警貴の駈引は、此一句に籠つて居ると云つてもよい金言で、隨つて、其應用の意味も、種々の" />
  <LINE TYPE="本文" X="786" Y="318" WIDTH="40" HEIGHT="988" CONF="0.901" ORDER="29" STRING="方面より解釋せられるのである。或は、本書の一節なる、天井月より二三ケ月は慥かに下る也、四" />
  <LINE TYPE="本文" X="744" Y="322" WIDTH="41" HEIGHT="989" CONF="0.908" ORDER="30" STRING="ケ月目は品に寄り上る事あり、賣方すべからず、と云ふ言に據て、二三月迄相塲に付て、四ヶ月目" />
  <LINE TYPE="本文" X="700" Y="319" WIDTH="41" HEIGHT="994" CONF="0.900" ORDER="31" STRING="には變ずるの意味に解し。或は、利喰は、七八分にて手仕廻し、十分上滿るのを俟て、扨心を轉じ" />
  <LINE TYPE="本文" X="657" Y="318" WIDTH="40" HEIGHT="995" CONF="0.898" ORDER="32" STRING="て、是迄買て収た者なら、反對に賣方となり、亦、賣方で取た者なら、今度は反對に買方となるべ" />
  <LINE TYPE="本文" X="614" Y="324" WIDTH="41" HEIGHT="988" CONF="0.889" ORDER="33" STRING="しと云ふ意味であると。或は曰く、是は相塲の呼吸を云ふた者て、云心は、利に乘つた米は、一ト" />
  <LINE TYPE="本文" X="570" Y="321" WIDTH="40" HEIGHT="996" CONF="0.886" ORDER="34" STRING="調子から二調子の處で手仕廻をして、十分に待つて相塲上下げの極點を見定め、夫から相塲の反を" />
  <LINE TYPE="本文" X="526" Y="322" WIDTH="40" HEIGHT="997" CONF="0.904" ORDER="35" STRING="打つの意味であると。要するに、何れの解釋から見ても、此事は、相場駈引の奥儀であつて、相場" />
  <LINE TYPE="本文" X="481" Y="315" WIDTH="44" HEIGHT="999" CONF="0.891" ORDER="36" STRING="の秘訣と云ふのは、此外にないのである。特に、但し書の、「相場は、上げ下げ二つより出て心の道" />
  <LINE TYPE="本文" X="440" Y="327" WIDTH="40" HEIGHT="957" CONF="0.891" ORDER="37" STRING="の多きと糸筋の如し。」と説いたのは、東西に亘り、古今に通じて、是より上の金言はなからう。" />
  <LINE TYPE="本文" X="397" Y="324" WIDTH="40" HEIGHT="995" CONF="0.900" ORDER="38" STRING="意ろは、夫れ米相塲と云者は、上下原因の甚だ複雑な者で、其複雑な原因が、人心に感應して相塲" />
  <LINE TYPE="本文" X="354" Y="325" WIDTH="40" HEIGHT="999" CONF="0.904" ORDER="39" STRING="となつて顯はれるのである。萬人の心が集つて立つ相塲であるから、其心の道の多いと、丁度糸筋" />
  <LINE TYPE="本文" X="310" Y="325" WIDTH="40" HEIGHT="993" CONF="0.886" ORDER="40" STRING="の榛ではあるが、詰る處、糸筋に兩端ある如くで、上と下との二途の外にはないので、云ひ換ゆれ" />
  <LINE TYPE="本文" X="286" Y="1107" WIDTH="20" HEIGHT="51" CONF="0.546" ORDER="41" STRING="一二五" />
  </PAGE>

