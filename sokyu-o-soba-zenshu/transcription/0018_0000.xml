<PAGE IMAGENAME="0018_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1669" Y="297" WIDTH="38" HEIGHT="985" CONF="0.847" ORDER="0" STRING="時に因て、中旬の初めより廿一二日頃迄に、高直を見するともあるが、下相塲の常態は大抵は月初" />
  <LINE TYPE="本文" X="1723" Y="1088" WIDTH="23" HEIGHT="23" CONF="0.313" ORDER="1" STRING="六" />
<LINE TYPE="本文" X="1494" Y="228" WIDTH="19" HEIGHT="20" CONF="0.455" ORDER="2" STRING="宗" />
  <LINE TYPE="本文" X="1625" Y="298" WIDTH="25" HEIGHT="240" CONF="0.869" ORDER="3" STRING="高の月末安を例とする。" />
  <LINE TYPE="本文" X="1582" Y="293" WIDTH="38" HEIGHT="1000" CONF="0.872" ORDER="4" STRING="併し、一言注意して置き度い事は、此様に二三ヶ月の間、月始高月末安、月始高月末安と続いた後" />
  <LINE TYPE="本文" X="1539" Y="296" WIDTH="37" HEIGHT="995" CONF="0.895" ORDER="5" STRING="で、月末に安直なく、反對に月末高と出た時である。斯る相塲は、時として此月の安直は、一時又" />
  <LINE TYPE="本文" X="1495" Y="289" WIDTH="37" HEIGHT="1008" CONF="0.880" ORDER="6" STRING="は一年中の底直となつて、翌月より早速月節を拔て上げに向ふと屡あるから、宜敷注意を加ふべき" />
  <LINE TYPE="本文" X="1463" Y="229" WIDTH="17" HEIGHT="19" CONF="0.431" ORDER="7" STRING="久" />
  <LINE TYPE="本文" X="1429" Y="227" WIDTH="18" HEIGHT="21" CONF="0.395" ORDER="8" STRING="翁" />
  <LINE TYPE="本文" X="1398" Y="229" WIDTH="18" HEIGHT="20" CONF="0.383" ORDER="9" STRING="相" />
  <LINE TYPE="本文" X="1364" Y="228" WIDTH="19" HEIGHT="21" CONF="0.354" ORDER="10" STRING="塲" />
  <LINE TYPE="本文" X="1333" Y="231" WIDTH="16" HEIGHT="18" CONF="0.384" ORDER="11" STRING="全" />
  <LINE TYPE="本文" X="1301" Y="230" WIDTH="16" HEIGHT="19" CONF="0.428" ORDER="12" STRING="録" />
  <LINE TYPE="本文" X="1268" Y="231" WIDTH="17" HEIGHT="18" CONF="0.387" ORDER="13" STRING="上" />
  <LINE TYPE="本文" X="1451" Y="302" WIDTH="23" HEIGHT="80" CONF="0.795" ORDER="14" STRING="てある。" />
  <LINE TYPE="本文" X="1382" Y="450" WIDTH="37" HEIGHT="619" CONF="0.831" ORDER="15" STRING="第三章引上げ大騒の節火中へ飛込む心持の事" />
  <LINE TYPE="本文" X="1319" Y="268" WIDTH="40" HEIGHT="1031" CONF="0.875" ORDER="16" STRING="一来、段々上る時、諸国不時申出し、大坂相場も加へ、跡も引上候沙汰、御蔵米抔申立、猶々上げ、" />
  <LINE TYPE="本文" X="1276" Y="281" WIDTH="39" HEIGHT="1007" CONF="0.868" ORDER="17" STRING="人氣も強く、我も買氣に付候節、心を轉じ賣方に附候事肝要也、是即ち火中へ飛入思切、一統騷立節" />
  <LINE TYPE="本文" X="1232" Y="262" WIDTH="40" HEIGHT="1034" CONF="0.862" ORDER="18" STRING="は、人々西に走らば、我は東に向ふ時は、極めて利運也。人の戻る頃、後れ馳に西に向ふては、何時" />
  <LINE TYPE="本文" X="1189" Y="275" WIDTH="39" HEIGHT="969" CONF="0.868" ORDER="19" STRING="も利を得るとなし。二ツ仕舞、三ツ十分、四ツ轉じ、是れ第一三位の秘傳也。忘るべからず。" />
  <LINE TYPE="本文" X="1145" Y="281" WIDTH="41" HEIGHT="1010" CONF="0.831" ORDER="20" STRING="不時とは、臨時の時變を云ふのである。御藏米抔申立は、藩廳の備荒貯蓄米抔を吹聽すると" />
  <LINE TYPE="本文" X="1103" Y="306" WIDTH="24" HEIGHT="81" CONF="0.650" ORDER="21" STRING="てある。" />
  <LINE TYPE="本文" X="1058" Y="302" WIDTH="44" HEIGHT="997" CONF="0.830" ORDER="22" STRING="本章は、人気の狂奔に雷同附和せず、却て心機を一轉して、人氣の反對に廻るべしとの訓飛である。" />
  <LINE TYPE="本文" X="898" Y="312" WIDTH="39" HEIGHT="988" CONF="0.898" ORDER="23" STRING="偖、二三ケ月も段々引上る時、諸國の不時天災等を風聞し、且大阪も上げて來たとか、跡も高いと" />
  <LINE TYPE="本文" X="854" Y="315" WIDTH="40" HEIGHT="983" CONF="0.912" ORDER="24" STRING="か、又御用米の買上げあるとか唱へ、弱材料は隱れて仕廻つて、見聞する處、一として強氣の材料" />
  <LINE TYPE="本文" X="810" Y="316" WIDTH="41" HEIGHT="982" CONF="0.911" ORDER="25" STRING="ならざるなく、盆上げ、何時下がるとも見へないものである。併し、此相塲も強く、人氣も強く、" />
  <LINE TYPE="本文" X="767" Y="315" WIDTH="40" HEIGHT="989" CONF="0.901" ORDER="26" STRING="我も買氣の節は、最早相塲極點の印であるから、决して買ふ可からざるのみならず、宜しく火中に" />
  <LINE TYPE="本文" X="723" Y="316" WIDTH="40" HEIGHT="989" CONF="0.916" ORDER="27" STRING="飛入心持を以て、人氣の反對に、大決心を以て賣叩くべきである。全體人氣が賣とか買とか、一方に" />
  <LINE TYPE="本文" X="678" Y="318" WIDTH="43" HEIGHT="990" CONF="0.899" ORDER="28" STRING="揃ふて騒立時は、諸人西に走らば、我は東に向ふ時は、極めて大勝利である。然るを、人の戻る頃" />
  <LINE TYPE="本文" X="634" Y="313" WIDTH="44" HEIGHT="998" CONF="0.884" ORDER="29" STRING="後れ馳に、西に向つては、相塲の後を追掛け歩行計りて、何時も損計りである。何しろ相塲節は、" />
  <LINE TYPE="本文" X="593" Y="320" WIDTH="39" HEIGHT="985" CONF="0.873" ORDER="30" STRING="衆人の資に夢中になつて居る中でも、買を忘れてはならぬ。又世間中買熟に浮かされて居る時でも、" />
  <LINE TYPE="本文" X="549" Y="319" WIDTH="34" HEIGHT="719" CONF="0.870" ORDER="31" STRING="賣を忘れてはならぬ。序に本章の訓戒として、三位の秘訣を説かうか、" />
  <LINE TYPE="本文" X="506" Y="372" WIDTH="27" HEIGHT="315" CONF="0.868" ORDER="32" STRING="二ツ仕廻三ツ十分四ツ轉ジ" />
  <LINE TYPE="本文" X="462" Y="319" WIDTH="40" HEIGHT="996" CONF="0.896" ORDER="33" STRING="此意味は、二ツ仕廻とは、相場の上下する勢ひを云ふた者で、三ツ十分とは、天井又底の行當りを" />
  <LINE TYPE="本文" X="419" Y="322" WIDTH="40" HEIGHT="984" CONF="0.884" ORDER="34" STRING="云ひ、四ツ轉じとは、滿ちたる者は欠くると云ふ意味で、行當り相塲の反動の調子を云ふた者であ" />
  <LINE TYPE="本文" X="374" Y="306" WIDTH="42" HEIGHT="998" CONF="0.857" ORDER="35" STRING="る。五六ケ月も、上け詰め、月數直數の充實したる塲合には、决して此格言を忘れてはならぬ。一" />
  <LINE TYPE="本文" X="275" Y="1118" WIDTH="20" HEIGHT="23" CONF="0.434" ORDER="36" STRING="土" />
  </PAGE>

