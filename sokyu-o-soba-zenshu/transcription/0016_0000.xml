  <LINE TYPE="本文" X="1772" Y="113" WIDTH="19" HEIGHT="635" CONF="0.318" ORDER="0" STRING="…………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………" />
  <LINE TYPE="本文" X="1484" Y="256" WIDTH="18" HEIGHT="24" CONF="0.355" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1453" Y="257" WIDTH="17" HEIGHT="22" CONF="0.385" ORDER="2" STRING="久" />
  <LINE TYPE="本文" X="1421" Y="257" WIDTH="16" HEIGHT="21" CONF="0.356" ORDER="3" STRING="翁" />
  <LINE TYPE="本文" X="1388" Y="256" WIDTH="18" HEIGHT="23" CONF="0.327" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1355" Y="255" WIDTH="19" HEIGHT="24" CONF="0.301" ORDER="5" STRING="場" />
<LINE TYPE="本文" X="1323" Y="258" WIDTH="17" HEIGHT="21" CONF="0.313" ORDER="6" STRING="全" />
  <LINE TYPE="本文" X="1291" Y="257" WIDTH="17" HEIGHT="21" CONF="0.362" ORDER="7" STRING="集" />
  <LINE TYPE="本文" X="1257" Y="259" WIDTH="19" HEIGHT="20" CONF="0.337" ORDER="8" STRING="上" />
  <LINE TYPE="本文" X="1226" Y="257" WIDTH="17" HEIGHT="21" CONF="0.386" ORDER="9" STRING="巻" />
  <LINE TYPE="本文" X="1659" Y="333" WIDTH="30" HEIGHT="974" CONF="0.809" ORDER="10" STRING="出の大切なるとは、損盆の機、凡て付出しに繋ると、云ふた程の者である。偖商内を付出すは、つ" />
  <LINE TYPE="本文" X="1615" Y="322" WIDTH="32" HEIGHT="1003" CONF="0.894" ORDER="11" STRING="まり見込を定めるより始まるとであるが、此見込を付けるには、極めて、心を虚ふし、気を平にす" />
  <LINE TYPE="本文" X="1571" Y="332" WIDTH="32" HEIGHT="987" CONF="0.887" ORDER="12" STRING="るとが、最も必要で、之が為に宗久翁は、禪室を屋後に築いて、三味に入つたと云ふが、我々相場" />
  <LINE TYPE="本文" X="1528" Y="320" WIDTH="31" HEIGHT="1005" CONF="0.868" ORDER="13" STRING="師が、相塲の見込を定めんとするに當り、見込其者よりも、先入主となり、吾々の相塲の判斷鏡を" />
  <LINE TYPE="本文" X="1486" Y="324" WIDTH="26" HEIGHT="608" CONF="0.915" ORDER="14" STRING="味まさんとする、悪魔がある。悪魔とは何ぞ急ぐ心である。" />
  <LINE TYPE="本文" X="1441" Y="347" WIDTH="32" HEIGHT="966" CONF="0.843" ORDER="15" STRING="(一)早く儲けねばならぬとて、儲け急ぎすると、假令へば、高利の金を借入れて、其金を返濟" />
  <LINE TYPE="本文" X="1398" Y="358" WIDTH="30" HEIGHT="959" CONF="0.854" ORDER="16" STRING="せんが為に、其期限なる何月何日迄に、必らず儲けねばならぬ抔と、見込なきに強て見込みを" />
  <LINE TYPE="本文" X="1356" Y="366" WIDTH="25" HEIGHT="517" CONF="0.892" ORDER="17" STRING="付け、仕掛くる商内是は無論、損に極まつて居る。" />
  <LINE TYPE="本文" X="1311" Y="359" WIDTH="31" HEIGHT="959" CONF="0.810" ORDER="18" STRING="(二)は、儲けたる人の商内を羨ましく思ふて、仕掛け急ぐとである。所謂、けなり賣、けなり" />
  <LINE TYPE="本文" X="1268" Y="355" WIDTH="30" HEIGHT="772" CONF="0.823" ORDER="19" STRING="買なる者に屬する者であるが、是も見込を立つる爲めには、大惡魔である。" />
  <LINE TYPE="本文" X="1223" Y="354" WIDTH="32" HEIGHT="957" CONF="0.879" ORDER="20" STRING="(三)は、自分の商内不首尾續きの爲め、燒けとなり、腹立の餘り、主義もなく賣買する商内で" />
  <LINE TYPE="本文" X="1181" Y="351" WIDTH="31" HEIGHT="828" CONF="0.825" ORDER="21" STRING="ある、是の如き、狂的の奴は、宜しく坐禪でもして、此大惡魔を追出すがよい。" />
  <LINE TYPE="本文" X="1135" Y="345" WIDTH="35" HEIGHT="993" CONF="0.857" ORDER="22" STRING="は、商内を付出すべき好機會は、今日より外なしと心進立場合である。是は中々、悪魔所" />
  <LINE TYPE="本文" X="1092" Y="364" WIDTH="36" HEIGHT="954" CONF="0.865" ORDER="23" STRING="ぢやない、至極尤ものとてあるが、マテ併し、如此進み急ぐ心を以て、観破した好機會なる者" />
  <LINE TYPE="本文" X="1048" Y="368" WIDTH="38" HEIGHT="944" CONF="0.820" ORDER="24" STRING="は是迄の例に因ると、吾々が、眞正の機會と信じた機會は、假面を被つた假裝の好機會であつ" />
  <LINE TYPE="本文" X="741" Y="266" WIDTH="16" HEIGHT="17" CONF="0.380" ORDER="25" STRING="第" />
  <LINE TYPE="本文" X="605" Y="266" WIDTH="15" HEIGHT="18" CONF="0.309" ORDER="26" STRING="踏" />
  <LINE TYPE="本文" X="582" Y="267" WIDTH="14" HEIGHT="17" CONF="0.353" ORDER="27" STRING="出" />
  <LINE TYPE="本文" X="557" Y="267" WIDTH="15" HEIGHT="17" CONF="0.398" ORDER="28" STRING="大" />
  <LINE TYPE="本文" X="534" Y="267" WIDTH="15" HEIGHT="17" CONF="0.441" ORDER="29" STRING="切" />
  <LINE TYPE="本文" X="510" Y="267" WIDTH="13" HEIGHT="17" CONF="0.440" ORDER="30" STRING="の" />
  <LINE TYPE="本文" X="484" Y="267" WIDTH="15" HEIGHT="17" CONF="0.415" ORDER="31" STRING="事" />
  <LINE TYPE="本文" X="908" Y="364" WIDTH="36" HEIGHT="974" CONF="0.892" ORDER="32" STRING="た例が多いから、ソー云はず、三日間待が宜しい、三時間でも宜しい、是は余の發明したる補" />
  <LINE TYPE="本文" X="865" Y="376" WIDTH="37" HEIGHT="951" CONF="0.899" ORDER="33" STRING="一塲の秘訣である。此進み急ぐ心を押へ付け、氣を落付けて、偖此相塲は、二伸し相場歟、保合相" />
  <LINE TYPE="本文" X="821" Y="378" WIDTH="36" HEIGHT="950" CONF="0.912" ORDER="34" STRING="塲歟、將た通相塲歟、と云ふとを考へ、而して連年の作柄、古米の多少、麥作の豊凶、大手の" />
  <LINE TYPE="本文" X="778" Y="379" WIDTH="36" HEIGHT="949" CONF="0.904" ORDER="35" STRING="動静等、の外団の事情より打算して、時の相場、天井の位にあるか、底直の位にあるか、將又" />
  <LINE TYPE="本文" X="736" Y="377" WIDTH="35" HEIGHT="953" CONF="0.892" ORDER="36" STRING="中直の位にあるか、を見定め、愈我胸にヒシと引合ひたる上、商を附出すも、決して晩からぬ" />
  <LINE TYPE="本文" X="692" Y="378" WIDTH="35" HEIGHT="949" CONF="0.908" ORDER="37" STRING="譯である。然るに、多くの人は、儲け急ぎをする爲めに、我氣と、相塲の機との契合を待つと" />
  <LINE TYPE="本文" X="650" Y="380" WIDTH="34" HEIGHT="941" CONF="0.912" ORDER="38" STRING="能はず、唯々商内の附出しを急ひて、損する人の多いのは、誠に悲むべきてある、要するに、" />
  <LINE TYPE="本文" X="606" Y="378" WIDTH="35" HEIGHT="951" CONF="0.871" ORDER="39" STRING="相塲の要訣は、天井に賣り、底直に買ふにあるので、底天井出ざる内は、幾月も見合せ、天井" />
  <LINE TYPE="本文" X="564" Y="377" WIDTH="27" HEIGHT="472" CONF="0.892" ORDER="40" STRING="底の時機に到つて、商内を付出すべきである。" />
  <LINE TYPE="本文" X="519" Y="325" WIDTH="35" HEIGHT="1012" CONF="0.873" ORDER="41" STRING="商急ぐ可からずとは、天井直段底直段を見るとなり。踏出し大切とは、考の外のと出る者なれば也。" />
  <LINE TYPE="本文" X="476" Y="318" WIDTH="36" HEIGHT="1019" CONF="0.861" ORDER="42" STRING="天井底を知る時は、利運にして損なきの理也。利運の米は、強欲を思はず、百俵上げを見切り。商仕" />
  <LINE TYPE="本文" X="432" Y="320" WIDTH="36" HEIGHT="998" CONF="0.780" ORDER="43" STRING="廻、四五十日休むべし。休むと云ふは、底直段を見るの理也。前後能々考へ。受用すべし。" />
  <LINE TYPE="本文" X="389" Y="339" WIDTH="36" HEIGHT="993" CONF="0.910" ORDER="44" STRING="(釋)本節には、再び、商内は、踏出しを急ぐ可からざる理由を詳説したものである。前段に述べ" />
  <LINE TYPE="本文" X="345" Y="331" WIDTH="37" HEIGHT="1003" CONF="0.901" ORDER="45" STRING="たる如く、急ぎ立つ心を去り、氣を落付けて、天井直段底直段を見定めると、至極大切である。又" />
  <LINE TYPE="本文" X="301" Y="337" WIDTH="37" HEIGHT="1000" CONF="0.860" ORDER="46" STRING="踏出し大切と説いたのは、吾人の考へたる尋常原因の外、上げ下げすべき理外の理を、発見すると" />
  </PAGE>

</OCRDATASET>