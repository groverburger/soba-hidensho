  <LINE TYPE="本文" X="1730" Y="1115" WIDTH="19" HEIGHT="39" CONF="0.516" ORDER="0" STRING="四四" />
  <LINE TYPE="本文" X="1662" Y="484" WIDTH="35" HEIGHT="635" CONF="0.777" ORDER="1" STRING="第三十二章二三ケ月必至〳〵と引上候時の事" />
  <LINE TYPE="本文" X="1528" Y="266" WIDTH="15" HEIGHT="18" CONF="0.425" ORDER="2" STRING="宗" />
  <LINE TYPE="本文" X="1496" Y="266" WIDTH="14" HEIGHT="16" CONF="0.394" ORDER="3" STRING="久" />
  <LINE TYPE="本文" X="1365" Y="264" WIDTH="16" HEIGHT="17" CONF="0.390" ORDER="4" STRING="全" />
  <LINE TYPE="本文" X="1429" Y="264" WIDTH="16" HEIGHT="18" CONF="0.393" ORDER="5" STRING="相" />
  <LINE TYPE="本文" X="1462" Y="265" WIDTH="15" HEIGHT="18" CONF="0.390" ORDER="6" STRING="翁" />
  <LINE TYPE="本文" X="1397" Y="263" WIDTH="16" HEIGHT="19" CONF="0.380" ORDER="7" STRING="塲" />
<LINE TYPE="本文" X="1300" Y="262" WIDTH="19" HEIGHT="19" CONF="0.392" ORDER="8" STRING="上" />
  <LINE TYPE="本文" X="1332" Y="261" WIDTH="16" HEIGHT="20" CONF="0.400" ORDER="9" STRING="集" />
  <LINE TYPE="本文" X="1268" Y="260" WIDTH="16" HEIGHT="21" CONF="0.430" ORDER="10" STRING="巻" />
  <LINE TYPE="本文" X="1599" Y="322" WIDTH="35" HEIGHT="1007" CONF="0.838" ORDER="11" STRING="一二三ケ月も必至〳〵と上げ詰め、急に一と落位も下る事あり、是極めて買ふべし、又々上る也、其" />
  <LINE TYPE="本文" X="1561" Y="318" WIDTH="31" HEIGHT="553" CONF="0.868" ORDER="12" STRING="節早速仕廻ふ可し。是第一の駈引にて甚だ成惡き者也。" />
  <LINE TYPE="本文" X="1513" Y="330" WIDTH="35" HEIGHT="981" CONF="0.886" ORDER="13" STRING="(釋)二三ケ月も勢克く、ヒス〳〵と上げ詰めて、急に三四俵方(一落位)も暴落するとあるが、" />
  <LINE TYPE="本文" X="1470" Y="332" WIDTH="35" HEIGHT="990" CONF="0.899" ORDER="14" STRING="此様の急に下るのは通相塲だから、必らず、多少は引返す者であるから、買ふが宜しい。併し相塲は、" />
  <LINE TYPE="本文" X="1426" Y="334" WIDTH="36" HEIGHT="988" CONF="0.886" ORDER="15" STRING="二三ケ月で上げ留るか、亦此通ひを付けて、再び四五ケ月も引續き上るかは、跡を見なければ不明て" />
  <LINE TYPE="本文" X="1384" Y="336" WIDTH="34" HEIGHT="983" CONF="0.892" ORDER="16" STRING="あるから、早速利喰して、更に付出すを上策とする、但し、少し利の乘る時は、人間の弱點として" />
  <LINE TYPE="本文" X="1344" Y="323" WIDTH="33" HEIGHT="659" CONF="0.852" ORDER="17" STRING="図にのる者であるから、此様の駈引は、甚だ仕にくい者である。" />
  <LINE TYPE="本文" X="1273" Y="476" WIDTH="33" HEIGHT="487" CONF="0.838" ORDER="18" STRING="第三十三章商仕舞四五十日休の事" />
  <LINE TYPE="本文" X="1210" Y="311" WIDTH="34" HEIGHT="1007" CONF="0.905" ORDER="19" STRING="一米上くべしと買入置き、最初の思入より上げ越し十分仕當る時、上げ詰め行當る時は、意地惡敷高" />
  <LINE TYPE="本文" X="1166" Y="309" WIDTH="36" HEIGHT="1006" CONF="0.883" ORDER="20" STRING="下する者也。其節商仕舞、四五十日休むべし。右休みの内、見抜候程の商塲有りとも、決してせざる" />
  <LINE TYPE="本文" X="1123" Y="312" WIDTH="36" HEIGHT="1002" CONF="0.846" ORDER="21" STRING="者也。乘米の多少、船手買入に不搆、十分仕當る商は、右の處にて仕廻、四五十日得と米の強弱を考" />
  <LINE TYPE="本文" X="1082" Y="304" WIDTH="32" HEIGHT="825" CONF="0.816" ORDER="22" STRING="へ、三位の伝に引合せ、立羽を極め賣買すべし。賣方にて仕當考時も、同斷の事。" />
  <LINE TYPE="本文" X="923" Y="328" WIDTH="29" HEIGHT="824" CONF="0.816" ORDER="23" STRING="本章は、商仕當る時、圖に乘つて長追ひすべからざるを訓戒した者である。" />
  <LINE TYPE="本文" X="880" Y="319" WIDTH="33" HEIGHT="1026" CONF="0.888" ORDER="24" STRING="偖上相塲に際して、我見込十分に當り、相場上け詰め行當る時は、乱高下をする者であつて、我見" />
  <LINE TYPE="本文" X="837" Y="336" WIDTH="32" HEIGHT="992" CONF="0.907" ORDER="25" STRING="込みが當つて居るから、商を仕舞ひ度くなくなり、何處迄も圖に乘るものだが、斯る時は、商を悉" />
  <LINE TYPE="本文" X="795" Y="337" WIDTH="32" HEIGHT="989" CONF="0.901" ORDER="26" STRING="皆利喰して、四五十日間も休むべきである。商を手仕廻して、局外中立の眼から見るから、高下は" />
  <LINE TYPE="本文" X="751" Y="326" WIDTH="33" HEIGHT="1016" CONF="0.909" ORDER="27" STRING="克く見へる者であるが、右休んで居る内は、決して商内をしない者である。各地との直鞘が充分付" />
  <LINE TYPE="本文" X="708" Y="338" WIDTH="33" HEIGHT="989" CONF="0.898" ORDER="28" STRING="て居るとか、他處からも、買註文入込んで買ふとか、云ふ事情には一切搆はず、十分に利の付た商" />
  <LINE TYPE="本文" X="665" Y="339" WIDTH="33" HEIGHT="976" CONF="0.901" ORDER="29" STRING="内は、右の塲合で皆な利喰して、一二ヶ月間は商を休み、得と相塲の摸様と人氣の趨向とを考へ、" />
  <LINE TYPE="本文" X="621" Y="337" WIDTH="34" HEIGHT="992" CONF="0.870" ORDER="30" STRING="虚心平気に方針を定めて、夫から商内を付け出すべきである。賣方で仕當てた時も、右の様に心得" />
  <LINE TYPE="本文" X="580" Y="344" WIDTH="21" HEIGHT="122" CONF="0.848" ORDER="31" STRING="るが宜しい。" />
  <LINE TYPE="本文" X="511" Y="479" WIDTH="32" HEIGHT="601" CONF="0.695" ORDER="32" STRING="第三十四章霜月限買入利分付候時心得の事" />
  <LINE TYPE="本文" X="450" Y="320" WIDTH="30" HEIGHT="1015" CONF="0.845" ORDER="33" STRING="一霜月限、底を見極め買付餘程の利分付候節、相塲、保合候か、又少々引下るとあり。其節利足勘定" />
  <LINE TYPE="本文" X="406" Y="306" WIDTH="32" HEIGHT="1038" CONF="0.853" ORDER="34" STRING="等致し、先達上の節賣返さゞるを思ふとあり。甚だ心得違也。底を買出す時は、落引なき前に、決し" />
  <LINE TYPE="本文" X="363" Y="312" WIDTH="29" HEIGHT="724" CONF="0.859" ORDER="35" STRING="て売らざる者也。底の買引上げ、落になる迄買重ぬる者也、心得べし。" />
  <LINE TYPE="本文" X="320" Y="324" WIDTH="30" HEIGHT="1004" CONF="0.806" ORDER="36" STRING="(釋)利足勘定と云ふのは、酒田米會所の商習慣で、商内を其仕掛けた月の内に仕廻はないて、翌" />
  <LINE TYPE="本文" X="285" Y="1114" WIDTH="20" HEIGHT="38" CONF="0.499" ORDER="37" STRING="四五" />
  </PAGE>

