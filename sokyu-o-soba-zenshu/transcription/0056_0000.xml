<PAGE IMAGENAME="0056_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1754" Y="1092" WIDTH="23" HEIGHT="37" CONF="0.368" ORDER="0" STRING="八二" />
  <LINE TYPE="本文" X="1708" Y="308" WIDTH="32" HEIGHT="993" CONF="0.836" ORDER="1" STRING="變の措置を要する者で、前者が善いの、後者がよいのと、定規に宛て篏めた樣なとは云へない、何" />
  <LINE TYPE="本文" X="1663" Y="316" WIDTH="33" HEIGHT="992" CONF="0.884" ORDER="2" STRING="時も前者の駈引計りを採ると、大儲けは出來ないし、左れば迚、何時も慾張つて、利盆を十二分も" />
  <LINE TYPE="本文" X="1620" Y="317" WIDTH="32" HEIGHT="983" CONF="0.887" ORDER="3" STRING="取らうと計りすると、其内に相場の反動に遇つて、折角付いた利盆を、取逃がす様なとになるから、" />
  <LINE TYPE="本文" X="1577" Y="321" WIDTH="32" HEIGHT="980" CONF="0.888" ORDER="4" STRING="克々相塲の大勢と、人氣の滿欠とを考へ、臨機の所置をすべきである。本章の大意は、詰商利運の" />
  <LINE TYPE="本文" X="1534" Y="317" WIDTH="26" HEIGHT="466" CONF="0.882" ORDER="5" STRING="時は、七八分で手仕廻せよと云ふとに歸する。" />
  <LINE TYPE="本文" X="1465" Y="469" WIDTH="31" HEIGHT="512" CONF="0.852" ORDER="6" STRING="第六十章毎日の相塲に氣を付可申事" />
  <LINE TYPE="本文" X="1404" Y="303" WIDTH="30" HEIGHT="999" CONF="0.869" ORDER="7" STRING="一極意は、毎日の相塲に氣を付、米の通ひを以て賣買すべき也。右の通ひ運びと申すは、秘傳也。此" />
  <LINE TYPE="本文" X="1360" Y="293" WIDTH="26" HEIGHT="584" CONF="0.918" ORDER="8" STRING="見様黒白の違ひあり、一毛違ふて千里をする心、第一也。" />
  <LINE TYPE="本文" X="1316" Y="313" WIDTH="30" HEIGHT="845" CONF="0.834" ORDER="9" STRING="本文にある通ひとは、通相塲のとて、又運ひとは、ノシ相塲を指すのである。" />
  <LINE TYPE="本文" X="1272" Y="313" WIDTH="32" HEIGHT="986" CONF="0.881" ORDER="10" STRING="偖米商の極意は、毎日の相塲に注意し、其時の相塲は、幾度も通ひつゝ持合ふ相塲であるか、又は、" />
  <LINE TYPE="本文" X="1228" Y="304" WIDTH="34" HEIGHT="1002" CONF="0.900" ORDER="11" STRING="是なりに上運びし、或は瓦落する伸相塲であるかの判定を付けて、賣買を試むべきである。但し、" />
  <LINE TYPE="本文" X="1185" Y="311" WIDTH="32" HEIGHT="990" CONF="0.874" ORDER="12" STRING="此運び相塲、伸相塲の區別の付け方は、甚だ六ケ敷い者て、少しでも見樣が違ふと、身代にも拘は" />
  <LINE TYPE="本文" X="1140" Y="309" WIDTH="32" HEIGHT="1001" CONF="0.869" ORDER="13" STRING="るとが出来るから、此觀察に就ては、注意の上にも注意を加へねばならぬ。就ては、茲に、翁の説" />
  <LINE TYPE="本文" X="1099" Y="321" WIDTH="26" HEIGHT="550" CONF="0.888" ORDER="14" STRING="を綜合して、通伸の兩相塲に付て、少く述べて置かう。" />
  <LINE TYPE="本文" X="942" Y="318" WIDTH="32" HEIGHT="982" CONF="0.880" ORDER="15" STRING="伸相場とは、底直から段々と上運び、又は天井から瓦落する大相塲と云ふ意味で、其標準は月節で" />
  <LINE TYPE="本文" X="898" Y="318" WIDTH="33" HEIGHT="983" CONF="0.882" ORDER="16" STRING="あつて、即ち前の月の月節を越して上げかゝり、又下げかゝる相塲で、上相塲では、月頭に下げ月" />
  <LINE TYPE="本文" X="854" Y="310" WIDTH="33" HEIGHT="995" CONF="0.858" ORDER="17" STRING="末に上げ、又下相塲では、月頭に上げ月未に下げて、二ケ月以上、六ケ月跨位迄上下する相場を云" />
  <LINE TYPE="本文" X="811" Y="312" WIDTH="30" HEIGHT="869" CONF="0.863" ORDER="18" STRING="ふので、其観察法に付ては、本書上巻第二章及第十四章第四十章等を參考するがよい。" />
  <LINE TYPE="本文" X="769" Y="314" WIDTH="27" HEIGHT="473" CONF="0.869" ORDER="19" STRING="又、通相塲と云ふのは、其塲合が澤山あつて、" />
  <LINE TYPE="本文" X="726" Y="341" WIDTH="25" HEIGHT="374" CONF="0.925" ORDER="20" STRING="一底から天井迄上の内の通ひ下げ、" />
  <LINE TYPE="本文" X="683" Y="341" WIDTH="24" HEIGHT="373" CONF="0.893" ORDER="21" STRING="二天井から底迄下の内の通ひ上げ、" />
  <LINE TYPE="本文" X="640" Y="335" WIDTH="25" HEIGHT="514" CONF="0.857" ORDER="22" STRING="三は小高下持合相塲の内の通ひ上げ及通ひ下げ、" />
  <LINE TYPE="本文" X="595" Y="317" WIDTH="28" HEIGHT="848" CONF="0.872" ORDER="23" STRING="抔である。此通ひ相塲の見方に付ても、上卷第十章通ひ相塲の處に詳く説て置いた。" />
  <LINE TYPE="本文" X="538" Y="246" WIDTH="15" HEIGHT="19" CONF="0.308" ORDER="24" STRING="の" />
<LINE TYPE="本文" X="514" Y="245" WIDTH="18" HEIGHT="21" CONF="0.331" ORDER="25" STRING="事" />
  <LINE TYPE="本文" X="524" Y="402" WIDTH="32" HEIGHT="544" CONF="0.814" ORDER="26" STRING="第六十一章米人我三つ揃候時の事" />
  <LINE TYPE="本文" X="462" Y="304" WIDTH="31" HEIGHT="1013" CONF="0.892" ORDER="27" STRING="一米も弱く、人氣も揃ひ、我思入も弱き節、其後是非上る者也。人々の氣も強く上ると志ざし候米一" />
  <LINE TYPE="本文" X="419" Y="297" WIDTH="31" HEIGHT="1014" CONF="0.840" ORDER="28" STRING="は、決して下る也。兎角、百俵上げの米は、下ると計りと考ふべし。タワヒもなく弱き米は、上ると一" />
  <LINE TYPE="本文" X="376" Y="296" WIDTH="25" HEIGHT="286" CONF="0.859" ORDER="29" STRING="計りと考へ可申事、肝要也。" />
  <LINE TYPE="本文" X="333" Y="319" WIDTH="29" HEIGHT="982" CONF="0.827" ORDER="30" STRING="(釋)本章の意は、天井底の間際になると、強弱共、誰人も一方に片寄る者で、我も其人氣に馬鹿" />
  <LINE TYPE="本文" X="298" Y="1094" WIDTH="20" HEIGHT="35" CONF="0.521" ORDER="31" STRING="八三" />
  <LINE TYPE="本文" X="208" Y="81" WIDTH="31" HEIGHT="1332" CONF="0.355" ORDER="32" STRING="同百二十一日" />
  </PAGE>

