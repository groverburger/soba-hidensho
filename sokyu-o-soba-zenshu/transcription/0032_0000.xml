<PAGE IMAGENAME="0032_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1491" Y="281" WIDTH="16" HEIGHT="18" CONF="0.311" ORDER="0" STRING="久" />
<LINE TYPE="本文" X="1523" Y="279" WIDTH="16" HEIGHT="19" CONF="0.355" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1734" Y="1129" WIDTH="21" HEIGHT="36" CONF="0.411" ORDER="2" STRING="三四" />
  <LINE TYPE="本文" X="1663" Y="501" WIDTH="33" HEIGHT="597" CONF="0.751" ORDER="3" STRING="第十八章十一十二正月頃迄下直夏引上の事" />
  <LINE TYPE="本文" X="1602" Y="339" WIDTH="29" HEIGHT="888" CONF="0.723" ORDER="4" STRING="一十一、十二、正月頃迄下直の米は、夏上と知る可し、心得べし。七月頃迄も上る者也。" />
  <LINE TYPE="本文" X="1557" Y="345" WIDTH="31" HEIGHT="998" CONF="0.871" ORDER="5" STRING="前章に、七八両月天井直段の米は、十一二月頃迄下るの理由を説いたが、前年豊年豊年萬作を唱" />
  <LINE TYPE="本文" X="1515" Y="350" WIDTH="31" HEIGHT="987" CONF="0.899" ORDER="6" STRING="へた餘勢、及正米の壓迫抔で十一月頃から、正月一杯も、下げるとがあるが、斯る相場は、弱氣の" />
  <LINE TYPE="本文" X="1472" Y="346" WIDTH="31" HEIGHT="994" CONF="0.869" ORDER="7" STRING="有丈けを唱へ盡して、下げられる丈け下げを盡した者であるから、其反動の上げを引起すと無論で、" />
  <LINE TYPE="本文" X="1428" Y="338" WIDTH="31" HEIGHT="1007" CONF="0.854" ORDER="8" STRING="特に、餘り譽め盡した揚句と云ふ者は、動もすれば、高材料が持上る者で、且春中麥作に何かの故" />
  <LINE TYPE="本文" X="1386" Y="345" WIDTH="29" HEIGHT="845" CONF="0.863" ORDER="9" STRING="障を申唱へる時は、時として、五月から六月一杯の上げとなることも、ある者である。" />
  <LINE TYPE="本文" X="1315" Y="499" WIDTH="32" HEIGHT="598" CONF="0.806" ORDER="10" STRING="第十九章七八兩月応十二正月迄大上けの事" />
  <LINE TYPE="本文" X="1256" Y="334" WIDTH="27" HEIGHT="570" CONF="0.853" ORDER="11" STRING="一七八兩月底直段の米は、十二月正月迄に大上なるべし。" />
  <LINE TYPE="本文" X="1210" Y="345" WIDTH="32" HEIGHT="992" CONF="0.897" ORDER="12" STRING="七八月の底直段の米と云ふ者は、畢竟、前年の豊作に、麥作の良好等が加勢して、下げて來た" />
  <LINE TYPE="本文" X="1166" Y="336" WIDTH="33" HEIGHT="1011" CONF="0.903" ORDER="13" STRING="處へ、土用前后の順氣譽め、作柄も非常に好い爲めに、豊年萬作を見越して、弱氣の有丈を唱へ盡" />
  <LINE TYPE="本文" X="1123" Y="347" WIDTH="33" HEIGHT="989" CONF="0.872" ORDER="14" STRING="して下げたる結果である。併し、相場の率としても、其反動が出來るし其内、天災も出て來るし、" />
  <LINE TYPE="本文" X="1079" Y="335" WIDTH="33" HEIGHT="1012" CONF="0.836" ORDER="15" STRING="鎌入不足抔も唱へ出すし、初めに譽め過した丈け、夫丈け、其反動の上も急激なる者である。此上。" />
  <LINE TYPE="本文" X="924" Y="344" WIDTH="25" HEIGHT="420" CONF="0.846" ORDER="16" STRING="げは、時として、正月頃迄繼く者である。" />
  <LINE TYPE="本文" X="855" Y="495" WIDTH="31" HEIGHT="448" CONF="0.855" ORDER="17" STRING="第二十章底より起き上り月の事" />
  <LINE TYPE="本文" X="793" Y="324" WIDTH="30" HEIGHT="826" CONF="0.836" ORDER="18" STRING="一九、十、十一、此三ケ月は、極めて天井直段なき月也、底より起き上がる月也。" />
  <LINE TYPE="本文" X="752" Y="334" WIDTH="29" HEIGHT="743" CONF="0.896" ORDER="19" STRING="但し、如此あれども、八九十月、天井出る年折々有るなり、考ふべし。" />
  <LINE TYPE="本文" X="708" Y="342" WIDTH="32" HEIGHT="994" CONF="0.885" ORDER="20" STRING="(釋)前各章の、天井及底月略測法に説いた處に據ると、九十一の三ケ月は、丁度其中程に當る" />
  <LINE TYPE="本文" X="666" Y="345" WIDTH="31" HEIGHT="991" CONF="0.899" ORDER="21" STRING="から、汎く論じて恁ふ云ふた者である。併し、前の各章に述べた例は、皆月数六ヶ月跨りの例であ" />
  <LINE TYPE="本文" X="623" Y="339" WIDTH="31" HEIGHT="1002" CONF="0.888" ORDER="22" STRING="るから、若し、三ヶ月以上五ケ月跨りになると、右三ヶ月亦天井直段を出す月に當るので、一概に" />
  <LINE TYPE="本文" X="579" Y="344" WIDTH="31" HEIGHT="992" CONF="0.854" ORDER="23" STRING="本章の如く云ふ譯には行かないが、要するに、右三ケ月は、天災時も過去つて、作柄の見當も凡そ" />
  <LINE TYPE="本文" X="535" Y="339" WIDTH="32" HEIGHT="1000" CONF="0.850" ORDER="24" STRING="付くので、無事と極れば、此三ケ月に底直段を出すべきは、理の當然であるから、翁も、斯く汎論" />
  <LINE TYPE="本文" X="494" Y="347" WIDTH="23" HEIGHT="305" CONF="0.884" ORDER="25" STRING="したものであらうと思はれる。" />
  <LINE TYPE="本文" X="423" Y="494" WIDTH="31" HEIGHT="393" CONF="0.873" ORDER="26" STRING="第二十一章上相塲見様の事" />
  <LINE TYPE="本文" X="362" Y="316" WIDTH="31" HEIGHT="1037" CONF="0.830" ORDER="27" STRING="一上相場の天井日限、不定。大概、月初底にて、廿一日より廿六日迄に、其月の天井出る者也。底よ" />
  <LINE TYPE="本文" X="319" Y="326" WIDTH="30" HEIGHT="1013" CONF="0.795" ORDER="28" STRING="り起き上る米は、幾月も上る者也。段々、百俵上位になり、廿九日晦日迄に一二俵方も上る時は、其" />
  <LINE TYPE="本文" X="284" Y="1126" WIDTH="21" HEIGHT="36" CONF="0.532" ORDER="29" STRING="三五" />
  <LINE TYPE="本文" X="203" Y="105" WIDTH="31" HEIGHT="1334" CONF="0.402" ORDER="30" STRING="}" />
  </PAGE>

