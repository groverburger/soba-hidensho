  <LINE TYPE="本文" X="1179" Y="474" WIDTH="31" HEIGHT="472" CONF="0.861" ORDER="44" STRING="第二十九章六月土用入丑の日の事" />
  <LINE TYPE="本文" X="1115" Y="304" WIDTH="30" HEIGHT="1004" CONF="0.800" ORDER="45" STRING="一六月土用の入六日の内に、丑の日有れば、秋風早く立故、作惡き也。但し、二日目三日目にあれば" />
  <LINE TYPE="本文" X="916" Y="300" WIDTH="37" HEIGHT="1009" CONF="0.875" ORDER="46" STRING="別けて悪しく、四五六日に有れば夫程もなし。又、入る日より五日目雨降れば、見分能く共取り實不" />
  <LINE TYPE="本文" X="872" Y="307" WIDTH="39" HEIGHT="1000" CONF="0.881" ORDER="47" STRING="足也。三日目にあるを土用三郎と云ふ。其上、此年高下著るし。又、三日の内寅の日あるも惡き也。" />
  <LINE TYPE="本文" X="829" Y="301" WIDTH="39" HEIGHT="1019" CONF="0.839" ORDER="48" STRING="是は、二日目に丑の日ある故、三日目に寅の日を言ふなるべし。一日に五日宛、秋五六三十日に當る" />
  <LINE TYPE="本文" X="784" Y="302" WIDTH="24" HEIGHT="195" CONF="0.887" ORDER="49" STRING="故、大切の日取也。" />
  <LINE TYPE="本文" X="716" Y="473" WIDTH="34" HEIGHT="361" CONF="0.845" ORDER="50" STRING="第三十章七月七日雨の事" />
  <LINE TYPE="本文" X="653" Y="296" WIDTH="35" HEIGHT="782" CONF="0.870" ORDER="51" STRING="一七月七日の雨、大雨は、夫程になし、小雨は、大に作に惡き也、違なし。" />
  <LINE TYPE="本文" X="586" Y="474" WIDTH="33" HEIGHT="363" CONF="0.849" ORDER="52" STRING="第三十一章秋の彼岸の事" />
  <LINE TYPE="本文" X="524" Y="300" WIDTH="36" HEIGHT="1022" CONF="0.853" ORDER="53" STRING="一秋の彼岸、一日にても九月へ掛る時は、决して不作也、此事遂なし、後るゝが故なるべし。九月へ" />
  <LINE TYPE="本文" X="479" Y="306" WIDTH="30" HEIGHT="441" CONF="0.825" ORDER="54" STRING="かゝらず共、八月廿日過なれば宜しからず。" />
  <LINE TYPE="本文" X="435" Y="304" WIDTH="34" HEIGHT="582" CONF="0.900" ORDER="55" STRING="但し、彼岸七日の内酉の日あれば、大風吹くに相違なし。" />
  <LINE TYPE="本文" X="368" Y="477" WIDTH="33" HEIGHT="301" CONF="0.854" ORDER="56" STRING="第三十二章日蝕の事" />
  <LINE TYPE="本文" X="314" Y="309" WIDTH="34" HEIGHT="1011" CONF="0.789" ORDER="57" STRING="一日蝕は、四つ前時より八つ過迄にあれば、作に惡き也、其外前後は構なしとなり。然れ共、日食月" />
  <LINE TYPE="本文" X="284" Y="1109" WIDTH="21" HEIGHT="47" CONF="0.586" ORDER="58" STRING="三" />
