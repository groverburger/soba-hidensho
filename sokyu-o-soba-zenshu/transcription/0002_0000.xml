  <LINE TYPE="本文" X="1736" Y="74" WIDTH="45" HEIGHT="1384" CONF="0.352" ORDER="0" STRING="一〇〇、〇〇、、、、、、、、、、、、、、、、、、、、、、〇〇" />
  <LINE TYPE="本文" X="1024" Y="919" WIDTH="18" HEIGHT="178" CONF="0.307" ORDER="1" STRING="一五十一月十一日" />
<LINE TYPE="本文" X="872" Y="314" WIDTH="50" HEIGHT="505" CONF="0.813" ORDER="2" STRING="宗久翁相場全集緒言" />
  <LINE TYPE="本文" X="759" Y="266" WIDTH="17" HEIGHT="19" CONF="0.374" ORDER="3" STRING="緒" />
  <LINE TYPE="本文" X="810" Y="305" WIDTH="42" HEIGHT="1025" CONF="0.798" ORDER="4" STRING="一宗外翁遺稿士挙及位附の書、識見高邁着眼奇警、相塲の機微を洞察するの方" />
  <LINE TYPE="本文" X="762" Y="309" WIDTH="39" HEIGHT="1019" CONF="0.709" ORDER="5" STRING="法を網羅解説して亦遺憾なし、宜なる哉翁が多大の成功を收めたるや、唯翁、" />
  <LINE TYPE="本文" X="709" Y="307" WIDTH="46" HEIGHT="1020" CONF="0.826" ORDER="6" STRING="一が手澤の原本は秘庫に襲藏せられて容易く見る可からず、又坊間の傳寫本は。" />
  <LINE TYPE="本文" X="663" Y="304" WIDTH="38" HEIGHT="1009" CONF="0.828" ORDER="7" STRING="一魯魚誤を傳へ轉訛百田す、是啻に翁が遣訓の眞意を害するのみならず恐らく" />
  <LINE TYPE="本文" X="614" Y="306" WIDTH="39" HEIGHT="1010" CONF="0.865" ORDER="8" STRING="は後進を誤る多汰ならんとを、吾人之を憂ひ同家に懇請して翁の手澤本を謄" />
  <LINE TYPE="本文" X="562" Y="311" WIDTH="38" HEIGHT="1001" CONF="0.878" ORDER="9" STRING="寫し尚坊間の諸傳寫本を參校し以て數十條を増補し且書中の商用語及難解の" />
  <LINE TYPE="本文" X="514" Y="312" WIDTH="35" HEIGHT="997" CONF="0.863" ORDER="10" STRING="處には一々註解を加へ其意義を闡明して一書を述作し名づけて宗久翁相塲全" />
  <LINE TYPE="本文" X="466" Y="306" WIDTH="34" HEIGHT="991" CONF="0.843" ORDER="11" STRING="集と云ふ、今や印刷方に成る、聊か一言を卷首に辯じて其由來を明かにす。" />
  <LINE TYPE="本文" X="396" Y="363" WIDTH="29" HEIGHT="246" CONF="0.532" ORDER="12" STRING="明治四十三年四月" />
  <LINE TYPE="本文" X="393" Y="330" WIDTH="36" HEIGHT="927" CONF="0.588" ORDER="14" STRING="明治四十三年四月二菊早阪豊識" />
