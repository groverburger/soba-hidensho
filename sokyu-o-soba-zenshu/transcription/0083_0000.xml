  <LINE TYPE="本文" X="1513" Y="265" WIDTH="15" HEIGHT="17" CONF="0.343" ORDER="3" STRING="相" />
  <LINE TYPE="本文" X="1479" Y="266" WIDTH="16" HEIGHT="15" CONF="0.339" ORDER="4" STRING="塲" />
  <LINE TYPE="本文" X="1447" Y="265" WIDTH="15" HEIGHT="16" CONF="0.313" ORDER="5" STRING="全" />
<LINE TYPE="本文" X="1415" Y="265" WIDTH="15" HEIGHT="17" CONF="0.330" ORDER="6" STRING="集" />
  <LINE TYPE="本文" X="1383" Y="266" WIDTH="15" HEIGHT="15" CONF="0.332" ORDER="7" STRING="下" />
  <LINE TYPE="本文" X="1350" Y="266" WIDTH="16" HEIGHT="16" CONF="0.399" ORDER="8" STRING="卷" />
  <LINE TYPE="本文" X="1824" Y="1111" WIDTH="23" HEIGHT="56" CONF="0.483" ORDER="9" STRING="一三六" />
  <LINE TYPE="本文" X="1779" Y="339" WIDTH="31" HEIGHT="977" CONF="0.849" ORDER="10" STRING="十俵と云ふ直段から始まると云事は、萬が稀な者で、是は、無論直ぐ底となる者だ。又、二十五六" />
  <LINE TYPE="本文" X="1734" Y="337" WIDTH="33" HEIGHT="988" CONF="0.892" ORDER="11" STRING="俵から始まる米は、五六十俵の下で、底となる者である。右の如く、七八月に底直段を出せば、八" />
  <LINE TYPE="本文" X="1692" Y="337" WIDTH="31" HEIGHT="985" CONF="0.894" ORDER="12" STRING="九十月頃迄二三ヶ月間の内段々起き上り、正月頃迄に天井となる者だ。上げかゝる米には百俵上を" />
  <LINE TYPE="本文" X="1648" Y="326" WIDTH="33" HEIGHT="1014" CONF="0.888" ORDER="13" STRING="標準として、七八十俵上げる迄買重ねてもよい者で、作柄の如何に因ては、百三四十俵から、五六" />
  <LINE TYPE="本文" X="1605" Y="339" WIDTH="32" HEIGHT="987" CONF="0.903" ORDER="14" STRING="十俵乃至百八十俵迄も上げ詰るとある者であるから、宜しく、其年の見聞作合を以て、上下の度數" />
  <LINE TYPE="本文" X="1563" Y="339" WIDTH="31" HEIGHT="984" CONF="0.905" ORDER="15" STRING="の多少を考ふべきであるが、通例は、百俵上げを以て天井底の的とするので、大抵の年は、此百俵" />
  <LINE TYPE="本文" X="1520" Y="326" WIDTH="32" HEIGHT="1010" CONF="0.895" ORDER="16" STRING="上げは、天井となる者であるから、賣場と心得て、火の中に飛込む心持で賣るがよい。果して、大" />
  <LINE TYPE="本文" X="1476" Y="336" WIDTH="31" HEIGHT="981" CONF="0.882" ORDER="17" STRING="勝利を得る者である。賣方の必勝と云ふ場處は、行付天井直段の外はない者で、此天井と云ふのは" />
  <LINE TYPE="本文" X="1433" Y="337" WIDTH="30" HEIGHT="984" CONF="0.910" ORDER="18" STRING="人氣が熱中し切つた、所謂行過の直段であるから、其後どんな強原因が出様共、其上へには拔かな" />
  <LINE TYPE="本文" X="1390" Y="331" WIDTH="31" HEIGHT="1002" CONF="0.907" ORDER="19" STRING="い者であるから、何程惡作年で見込あつても、翌春迄持つべからざるものであつて、若し誤つて強方" />
  <LINE TYPE="本文" X="1347" Y="337" WIDTH="31" HEIGHT="985" CONF="0.868" ORDER="20" STRING="針を採ると、身代破滅の大損を來す者である。だから、天井直段が出だら、悉皆手仕廻し、三四十" />
  <LINE TYPE="本文" X="1303" Y="329" WIDTH="32" HEIGHT="997" CONF="0.853" ORDER="21" STRING="日間休み、湯治か漫遊にても出掛くべきである。此休むとを知らなければ、一時は大勝利を得ても、" />
  <LINE TYPE="本文" X="1260" Y="326" WIDTH="29" HEIGHT="771" CONF="0.894" ORDER="22" STRING="其内には、屹度失敗に終る者で、相塲師の大に警戒すべき處である。翁の、" />
  <LINE TYPE="本文" X="1219" Y="361" WIDTH="23" HEIGHT="397" CONF="0.857" ORDER="23" STRING="休み、折々、備へを立て直すと肝要也。" />
  <LINE TYPE="本文" X="1175" Y="337" WIDTH="24" HEIGHT="263" CONF="0.905" ORDER="24" STRING="と説けるのも、茲のとだ。" />
  <LINE TYPE="本文" X="943" Y="486" WIDTH="35" HEIGHT="570" CONF="0.866" ORDER="25" STRING="第五十二章上方筋當地作合見計らひの事" />
  <LINE TYPE="本文" X="880" Y="318" WIDTH="36" HEIGHT="1012" CONF="0.876" ORDER="26" STRING="一九州、其外、當地共、平作の年には深き高下なし、見計らひ肝要也。諸國當地共、四分が、半作前" />
  <LINE TYPE="本文" X="836" Y="316" WIDTH="36" HEIGHT="1012" CONF="0.896" ORDER="27" STRING="后の年にて、地方人氣立、黒人素人旅客共買進み、亦郷方、札納、夫食當等迄も買取候程の年、何程" />
  <LINE TYPE="本文" X="794" Y="318" WIDTH="35" HEIGHT="1010" CONF="0.905" ORDER="28" STRING="上るも知れぬ樣になる故、段々買孕み多く、持詰る故、前年十八九俵廿一二俵位天井直段にて、三四" />
  <LINE TYPE="本文" X="750" Y="307" WIDTH="36" HEIGHT="1034" CONF="0.895" ORDER="29" STRING="月船盛り迄二十二三俵にて下らざる米は、船手も買はざる故、相塲保合、米持退屈し、六月になり、" />
  <LINE TYPE="本文" X="707" Y="316" WIDTH="34" HEIGHT="1011" CONF="0.886" ORDER="30" STRING="順氣克く作方能き風聞有之、時により人氣惡くなり、特に六月は、黒人素人共に仕廻月故、六月末迄" />
  <LINE TYPE="本文" X="664" Y="323" WIDTH="34" HEIGHT="981" CONF="0.890" ORDER="31" STRING="大下げ疑なし。此事、不作年中作以上の年、前年の天井より夏米の引合、買孕、賣明の考肝要也。" />
  <LINE TYPE="本文" X="620" Y="327" WIDTH="36" HEIGHT="993" CONF="0.865" ORDER="32" STRING="本章の大意は、日本中及當地共、平作以上の年には、大高下のない者である。不作年は。不作年は、買" />
  <LINE TYPE="本文" X="576" Y="335" WIDTH="36" HEIGHT="997" CONF="0.885" ORDER="33" STRING="孕みが多く、翌年好順になると投げ出すから、夏崩れとなる者である。是も、買孕みの多少、賣明" />
  <LINE TYPE="本文" X="533" Y="338" WIDTH="34" HEIGHT="989" CONF="0.878" ORDER="34" STRING="き(即ち問屋より船々に對し豫約の空賣)の多少を考へて、尚、本書第九章、" />
  <LINE TYPE="本文" X="491" Y="337" WIDTH="25" HEIGHT="396" CONF="0.896" ORDER="35" STRING="及第五十一章の註解を參考するがよい。" />
  <LINE TYPE="本文" X="421" Y="487" WIDTH="32" HEIGHT="450" CONF="0.880" ORDER="36" STRING="第五十三章米商踏出し大切の事" />
  <LINE TYPE="本文" X="360" Y="308" WIDTH="33" HEIGHT="1034" CONF="0.793" ORDER="37" STRING="一米商は、踏出し大切なる者也、必らず、賣買共進み急ぐ可からず。急ぐ時は、決して手違出ると心" />
  <LINE TYPE="本文" X="329" Y="1117" WIDTH="21" HEIGHT="56" CONF="0.418" ORDER="38" STRING="一三七" />
  </PAGE>

