<OCRDATASET>
<PAGE IMAGENAME="0067_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1705" Y="366" WIDTH="27" HEIGHT="637" CONF="0.801" ORDER="0" STRING="つて、我胸に合つた時、始めて商内を仕掛けよと云ふのである。" />
  <LINE TYPE="本文" X="1745" Y="1107" WIDTH="21" HEIGHT="53" CONF="0.415" ORDER="1" STRING="一〇四" />
  <LINE TYPE="本文" X="1633" Y="478" WIDTH="33" HEIGHT="450" CONF="0.803" ORDER="2" STRING="第九章大阪相塲を以て掛引の事" />
  <LINE TYPE="本文" X="1537" Y="255" WIDTH="18" HEIGHT="23" CONF="0.445" ORDER="3" STRING="宗" />
  <LINE TYPE="本文" X="1504" Y="256" WIDTH="17" HEIGHT="22" CONF="0.487" ORDER="4" STRING="久" />
  <LINE TYPE="本文" X="1472" Y="255" WIDTH="18" HEIGHT="23" CONF="0.496" ORDER="5" STRING="同" />
  <LINE TYPE="本文" X="1440" Y="254" WIDTH="17" HEIGHT="24" CONF="0.482" ORDER="6" STRING="相" />
  <LINE TYPE="本文" X="1405" Y="255" WIDTH="19" HEIGHT="22" CONF="0.425" ORDER="7" STRING="場" />
  <LINE TYPE="本文" X="1373" Y="256" WIDTH="19" HEIGHT="21" CONF="0.419" ORDER="8" STRING="全" />
  <LINE TYPE="本文" X="1341" Y="254" WIDTH="18" HEIGHT="23" CONF="0.414" ORDER="9" STRING="集" />
  <LINE TYPE="本文" X="1311" Y="253" WIDTH="18" HEIGHT="21" CONF="0.342" ORDER="10" STRING="下" />
  <LINE TYPE="本文" X="1277" Y="254" WIDTH="17" HEIGHT="21" CONF="0.416" ORDER="11" STRING="巷" />
  <LINE TYPE="本文" X="1571" Y="307" WIDTH="30" HEIGHT="1009" CONF="0.838" ORDER="12" STRING="一大阪相塲は、秋は國々作に寄て上げ勝也。春夏七八月に到つては、古米かすり、又は麥作夏中違ひ" />
  <LINE TYPE="本文" X="1526" Y="307" WIDTH="33" HEIGHT="1007" CONF="0.881" ORDER="13" STRING="無之時は、年々、四五六七八月迄下る者也。當地夏米に成ては、大阪相塲よりも、船足早く御蔵米も" />
  <LINE TYPE="本文" X="1484" Y="307" WIDTH="32" HEIGHT="1007" CONF="0.884" ORDER="14" STRING="出透き、瀬戸内邊米かすりにて、船々買急ぐ時は、案外の高直出る事あり。此時、御蔵出方、内米透" />
  <LINE TYPE="本文" X="1441" Y="305" WIDTH="31" HEIGHT="1008" CONF="0.864" ORDER="15" STRING="口、船數の考、第一也。大阪は、何時頃天井、何時頃底直段出ると、年々覺へ置くべし。其模様によ" />
  <LINE TYPE="本文" X="1400" Y="309" WIDTH="29" HEIGHT="668" CONF="0.888" ORDER="16" STRING="り、掛引あるべし。扨加賀米にて、四十八九匁五十一二匁は底也。" />
  <LINE TYPE="本文" X="1356" Y="313" WIDTH="30" HEIGHT="792" CONF="0.905" ORDER="17" STRING="本章は、大阪相塲を以て、当地の駈引をすることを、述べた者である。" />
  <LINE TYPE="本文" X="1311" Y="323" WIDTH="33" HEIGHT="987" CONF="0.892" ORDER="18" STRING="偖、大阪に於ける、米相塲年中の常態から云へば、秋は各國の作柄に因て上勝の者である。春夏か" />
  <LINE TYPE="本文" X="1267" Y="319" WIDTH="32" HEIGHT="992" CONF="0.864" ORDER="19" STRING="ら、七八月に掛けては、古米かすりの案じや、又麥作の違作等ない時には、年々、四月から八月頃" />
  <LINE TYPE="本文" X="1232" Y="327" WIDTH="23" HEIGHT="193" CONF="0.889" ORDER="20" STRING="迄も下る者である。" />
  <LINE TYPE="本文" X="1180" Y="323" WIDTH="32" HEIGHT="987" CONF="0.865" ORDER="21" STRING="當地相塲の常態は、夏米になると、大阪相塲の如何よりも、買船が例年より早く入込んで、在米も" />
  <LINE TYPE="本文" X="1137" Y="325" WIDTH="33" HEIGHT="986" CONF="0.874" ORDER="22" STRING="減じ。中国邊も米かすれて、船々爭ふて買進む様な年は、思の外の高直が出る事があるが、其時に" />
  <LINE TYPE="本文" X="1094" Y="325" WIDTH="32" HEIGHT="986" CONF="0.867" ORDER="23" STRING="は、當地倉庫の在米の多少と、農家団米の多少、輸出米の多少、買船の多少等を考へると第一の駈" />
  <LINE TYPE="本文" X="912" Y="319" WIDTH="37" HEIGHT="992" CONF="0.898" ORDER="24" STRING="引てある。大阪は、年々何時頃天井底を打つと云ふ常勢を記憶して置いて、當地の駈引に應用すべ" />
  <LINE TYPE="本文" X="869" Y="322" WIDTH="35" HEIGHT="984" CONF="0.875" ORDER="25" STRING="きである。年々の例を見ると、加賀米で四十八九匁五十匁と云ふ直段を出せば、大抵底となる者で" />
  <LINE TYPE="本文" X="825" Y="328" WIDTH="22" HEIGHT="57" CONF="0.731" ORDER="26" STRING="ある。" />
  <LINE TYPE="本文" X="757" Y="472" WIDTH="35" HEIGHT="630" CONF="0.820" ORDER="27" STRING="第十章十餘二三丁一二三匁廿匁より其餘の事一" />
  <LINE TYPE="本文" X="486" Y="256" WIDTH="13" HEIGHT="23" CONF="0.336" ORDER="28" STRING="餘" />
  <LINE TYPE="本文" X="468" Y="257" WIDTH="14" HEIGHT="21" CONF="0.332" ORDER="29" STRING="の" />
<LINE TYPE="本文" X="452" Y="257" WIDTH="16" HEIGHT="20" CONF="0.333" ORDER="30" STRING="事" />
  <LINE TYPE="本文" X="693" Y="310" WIDTH="26" HEIGHT="177" CONF="0.882" ORDER="31" STRING="一十余上、可レ売。" />
  <LINE TYPE="本文" X="650" Y="306" WIDTH="28" HEIGHT="395" CONF="0.885" ORDER="32" STRING="但し、其年不熟なる時は、見合すべし。" />
  <LINE TYPE="本文" X="607" Y="318" WIDTH="36" HEIGHT="983" CONF="0.804" ORDER="33" STRING="(釋)底から(十兩に付)十俵以上上げた米は、逆ふて賣る者と心得てよい。併し。不作の時は、" />
  <LINE TYPE="本文" X="564" Y="316" WIDTH="32" HEIGHT="787" CONF="0.826" ORDER="34" STRING="時により百八十俵迄も上げるとがあるから、克く見合せて跡に、賣るがよい。" />
  <LINE TYPE="本文" X="521" Y="315" WIDTH="24" HEIGHT="219" CONF="0.884" ORDER="35" STRING="一二三丁の下、可レ買。" />
  <LINE TYPE="本文" X="477" Y="310" WIDTH="28" HEIGHT="523" CONF="0.778" ORDER="36" STRING="但し、廿五俵より上げ詰る米は、買急ぎなり兼る也。" />
  <LINE TYPE="本文" X="434" Y="310" WIDTH="33" HEIGHT="1010" CONF="0.844" ORDER="37" STRING="暴落の米でも、一ト調子の大下を過ぎて、二タ呼吸三呼吸と下つた米は、一寸買て見てもよ" />
  <LINE TYPE="本文" X="391" Y="328" WIDTH="29" HEIGHT="683" CONF="0.853" ORDER="38" STRING="い、併し、廿五俵位の高直の位置に居る相塲は、買急いではならぬ。" />
  <LINE TYPE="本文" X="347" Y="315" WIDTH="26" HEIGHT="369" CONF="0.866" ORDER="39" STRING="一壹二匁三匁は天井なり、賣るべし。" />
  <LINE TYPE="本文" X="302" Y="314" WIDTH="28" HEIGHT="413" CONF="0.750" ORDER="41" STRING="一二十匁より其餘は、底なり、買ふ可し。" />
  <LINE TYPE="本文" X="273" Y="1103" WIDTH="20" HEIGHT="53" CONF="0.481" ORDER="42" STRING="一〇五" />
  </PAGE>

