  <LINE TYPE="本文" X="1720" Y="360" WIDTH="25" HEIGHT="25" CONF="0.552" ORDER="0" STRING="十一日" />
  <LINE TYPE="本文" X="1712" Y="1110" WIDTH="20" HEIGHT="35" CONF="0.507" ORDER="1" STRING="三八" />
  <LINE TYPE="本文" X="1669" Y="338" WIDTH="32" HEIGHT="978" CONF="0.801" ORDER="2" STRING="相塲を演ずる者である。暴風に於けるも亦然りて、要を云へば、天災時季の相塲と云ふ者は、急に" />
  <LINE TYPE="本文" X="1624" Y="338" WIDTH="32" HEIGHT="986" CONF="0.864" ORDER="3" STRING="上れば急に下げ、又急に下れば、又急に上る者と心得て宜い。併し是は、十中の八九の汎論であ" />
  <LINE TYPE="本文" X="1592" Y="343" WIDTH="19" HEIGHT="32" CONF="0.588" ORDER="4" STRING="る。" />
  <LINE TYPE="本文" X="1504" Y="264" WIDTH="18" HEIGHT="21" CONF="0.377" ORDER="5" STRING="宗" />
  <LINE TYPE="本文" X="1440" Y="266" WIDTH="17" HEIGHT="19" CONF="0.402" ORDER="6" STRING="箱" />
  <LINE TYPE="本文" X="1468" Y="266" WIDTH="20" HEIGHT="19" CONF="0.403" ORDER="7" STRING="久" />
  <LINE TYPE="本文" X="1375" Y="266" WIDTH="18" HEIGHT="19" CONF="0.371" ORDER="8" STRING="傷" />
  <LINE TYPE="本文" X="1407" Y="266" WIDTH="18" HEIGHT="19" CONF="0.391" ORDER="9" STRING="相" />
  <LINE TYPE="本文" X="1341" Y="266" WIDTH="18" HEIGHT="19" CONF="0.366" ORDER="10" STRING="全" />
<LINE TYPE="本文" X="1309" Y="266" WIDTH="16" HEIGHT="18" CONF="0.408" ORDER="11" STRING="集" />
  <LINE TYPE="本文" X="1278" Y="266" WIDTH="15" HEIGHT="18" CONF="0.396" ORDER="12" STRING="上" />
  <LINE TYPE="本文" X="1246" Y="266" WIDTH="15" HEIGHT="18" CONF="0.400" ORDER="13" STRING="卷" />
  <LINE TYPE="本文" X="1513" Y="487" WIDTH="32" HEIGHT="475" CONF="0.869" ORDER="14" STRING="第二十四章上作年の米売崩しの事" />
  <LINE TYPE="本文" X="1450" Y="319" WIDTH="30" HEIGHT="996" CONF="0.865" ORDER="15" STRING="一最上此方共上作の年、冬中より正月頃迄、釣合高直の米は、三月中の日より四月中の日の間にて、" />
  <LINE TYPE="本文" X="1414" Y="314" WIDTH="23" HEIGHT="174" CONF="0.849" ORDER="16" STRING="賣崩しあるべし。" />
  <LINE TYPE="本文" X="1362" Y="333" WIDTH="32" HEIGHT="987" CONF="0.849" ORDER="17" STRING="(釋)最上とは、莊内の隣國で、今の村山最上の兩郡地方を指すのであつて、云心は、近國及當地" />
  <LINE TYPE="本文" X="1319" Y="337" WIDTH="32" HEIGHT="980" CONF="0.881" ORDER="18" STRING="共上作の年でも、何等歟の事情があつて、他所相塲に比べ、釣合高直の位置に持合つて居る時は、" />
  <LINE TYPE="本文" X="1276" Y="336" WIDTH="34" HEIGHT="978" CONF="0.867" ORDER="19" STRING="其内に現物の輸入もあるであらうし、而して少し下ケ目になると、投米新賣抔が一時に顯はれるか" />
  <LINE TYPE="本文" X="1239" Y="330" WIDTH="26" HEIGHT="495" CONF="0.910" ORDER="20" STRING="ら、彼岸前後にかけて、大崩れとなる者である。" />
  <LINE TYPE="本文" X="1165" Y="485" WIDTH="33" HEIGHT="507" CONF="0.873" ORDER="21" STRING="第二十五章作合取沙汰前方掛引の事" />
  <LINE TYPE="本文" X="1100" Y="317" WIDTH="35" HEIGHT="988" CONF="0.863" ORDER="22" STRING="一作合、申分出る頃は、七月中の日の頃也。上作と申ならし候ても、何等の沙汰出來る者故、其前方、" />
  <LINE TYPE="本文" X="1064" Y="313" WIDTH="25" HEIGHT="251" CONF="0.840" ORDER="23" STRING="掛引致し可申事肝要也。" />
  <LINE TYPE="本文" X="907" Y="329" WIDTH="28" HEIGHT="421" CONF="0.882" ORDER="24" STRING="申分と云ふのは、故障のとである。" />
  <LINE TYPE="本文" X="866" Y="329" WIDTH="35" HEIGHT="993" CONF="0.864" ORDER="25" STRING="意は、初め好順を唱へて、作柄を譽めそやして居ても、七月中旬頃からは、何處に洪水があつたと" />
  <LINE TYPE="本文" X="821" Y="321" WIDTH="38" HEIGHT="997" CONF="0.859" ORDER="26" STRING="か、又は何處に虫害があつたとか、乃至亦何處に低氣壓が起つたとか云ふて、動もすれば、上勝の" />
  <LINE TYPE="本文" X="776" Y="321" WIDTH="37" HEIGHT="910" CONF="0.872" ORDER="27" STRING="者であるから、其前方に賣つた者は其覺悟て、手仕舞の駈引をして置くと、肝要である。" />
  <LINE TYPE="本文" X="708" Y="483" WIDTH="35" HEIGHT="450" CONF="0.888" ORDER="28" STRING="第二十六章正月利運持越しの事" />
  <LINE TYPE="本文" X="646" Y="320" WIDTH="36" HEIGHT="1008" CONF="0.877" ORDER="29" STRING="一正月利運の米、二月へ持越すと、甚だ宜しからず。正月の内、サツパリと仕舞ふべき也。尤も、十" />
  <LINE TYPE="本文" X="604" Y="318" WIDTH="28" HEIGHT="460" CONF="0.887" ORDER="30" STRING="二月の模樣にて、正月思入を立ることは格別也。" />
  <LINE TYPE="本文" X="561" Y="325" WIDTH="35" HEIGHT="1007" CONF="0.896" ORDER="31" STRING="次章に述ぶる如く、正二兩月の相塲は、一と目高下で、正月上れば二月下げ、又正月下げ、又正月下げ、又正月下れば" />
  <LINE TYPE="本文" X="518" Y="338" WIDTH="35" HEIGHT="986" CONF="0.888" ORDER="32" STRING="二月上ることが多いから、正月に利運の付た米ならば、早速に手仕廻するがよい。併し、是は相塲毎" />
  <LINE TYPE="本文" X="474" Y="334" WIDTH="36" HEIGHT="980" CONF="0.859" ORDER="33" STRING="月の常勢に就て云ふ者であつて、正月二月、引續ひて同じ様に高下せんとも限らないが、夫は、十" />
  <LINE TYPE="本文" X="430" Y="323" WIDTH="35" HEIGHT="939" CONF="0.829" ORDER="34" STRING="二月の相場の動き工合で分るから、夫に因て思惑を立てた商内は、此限りにあらずである。" />
  <LINE TYPE="本文" X="362" Y="492" WIDTH="35" HEIGHT="559" CONF="0.777" ORDER="35" STRING="第二十七章正二売買退屈四五六崩しの事" />
  <LINE TYPE="本文" X="298" Y="298" WIDTH="38" HEIGHT="1047" CONF="0.817" ORDER="37" STRING="一正二兩月の相塲は、大高下なき者也。但し、右兩月の相塲は、正月上れば二月下げ、正月下れば二" />
  <LINE TYPE="本文" X="271" Y="1115" WIDTH="21" HEIGHT="36" CONF="0.419" ORDER="38" STRING="三九" />
  </PAGE>

