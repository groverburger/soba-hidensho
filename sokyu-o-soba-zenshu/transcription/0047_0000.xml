  <LINE TYPE="本文" X="1461" Y="264" WIDTH="15" HEIGHT="17" CONF="0.455" ORDER="0" STRING="久" />
  <LINE TYPE="本文" X="1493" Y="262" WIDTH="16" HEIGHT="18" CONF="0.449" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1428" Y="262" WIDTH="15" HEIGHT="18" CONF="0.447" ORDER="2" STRING="鍋" />
  <LINE TYPE="本文" X="1396" Y="262" WIDTH="15" HEIGHT="20" CONF="0.469" ORDER="3" STRING="相" />
  <LINE TYPE="本文" X="1362" Y="262" WIDTH="16" HEIGHT="19" CONF="0.430" ORDER="4" STRING="場" />
  <LINE TYPE="本文" X="1330" Y="262" WIDTH="16" HEIGHT="21" CONF="0.409" ORDER="5" STRING="全" />
  <LINE TYPE="本文" X="1298" Y="261" WIDTH="16" HEIGHT="21" CONF="0.406" ORDER="6" STRING="集" />
  <LINE TYPE="本文" X="1266" Y="262" WIDTH="16" HEIGHT="20" CONF="0.391" ORDER="7" STRING="上" />
  <LINE TYPE="本文" X="1234" Y="261" WIDTH="16" HEIGHT="20" CONF="0.432" ORDER="8" STRING="巻" />
  <LINE TYPE="本文" X="1713" Y="1109" WIDTH="19" HEIGHT="39" CONF="0.469" ORDER="9" STRING="六四" />
  <LINE TYPE="本文" X="1666" Y="334" WIDTH="31" HEIGHT="979" CONF="0.814" ORDER="10" STRING="出しが大切であつて、底間際を買つて置かないて、少し高い處に付け出して置くと、右の樣な通下" />
  <LINE TYPE="本文" X="1621" Y="332" WIDTH="32" HEIGHT="982" CONF="0.897" ORDER="11" STRING="げの塲合に、驚いて踏むとがあり。又高い處を賣つて置かないと、右の樣な通上の塲合に煎れて、" />
  <LINE TYPE="本文" X="1579" Y="336" WIDTH="30" HEIGHT="980" CONF="0.900" ORDER="12" STRING="飛でもない馬鹿を見るとがある者である。買方は、賣方に對し月越しに利足を拂はねばならないし。" />
  <LINE TYPE="本文" X="1535" Y="333" WIDTH="32" HEIGHT="992" CONF="0.877" ORDER="13" STRING="一寸割の惡い樣な者であるが、サア上るとなると少しも心配のない者である。又資方は、買方から、利" />
  <LINE TYPE="本文" X="1492" Y="333" WIDTH="31" HEIGHT="987" CONF="0.890" ORDER="14" STRING="足を取るし、其上利益が付くならば、甚だ割のよい譯であるが、偖賣方の駈引となると、至極六ケ敷い" />
  <LINE TYPE="本文" X="1448" Y="334" WIDTH="31" HEIGHT="984" CONF="0.903" ORDER="15" STRING="者である。下げかゝる時は、何程下がるも知れない樣な人氣となり、其内急上げとなる塲合が多い" />
  <LINE TYPE="本文" X="1405" Y="331" WIDTH="31" HEIGHT="990" CONF="0.890" ORDER="16" STRING="から、油斷をすると、買埋の利喰が人の後手となつて、利金の手取が少くなる者である。だから下" />
  <LINE TYPE="本文" X="1362" Y="333" WIDTH="30" HEIGHT="992" CONF="0.856" ORDER="17" STRING="の調子がいくら善からうと、人がまだ〳〵下げ留らないと騒がふと、そんな事に頓着なく、餘り欲" />
  <LINE TYPE="本文" X="1321" Y="331" WIDTH="24" HEIGHT="398" CONF="0.896" ORDER="18" STRING="心を深くせずに、買埋めすべきである。" />
  <LINE TYPE="本文" X="1250" Y="482" WIDTH="31" HEIGHT="458" CONF="0.862" ORDER="19" STRING="第四十八章三位の外の教可守事" />
  <LINE TYPE="本文" X="1188" Y="313" WIDTH="30" HEIGHT="1011" CONF="0.847" ORDER="20" STRING="一新商、年々出初より、二三十俵下にて上に向也。八九月より、十月十一月十二月正月迄に上げずと" />
  <LINE TYPE="本文" X="1144" Y="312" WIDTH="31" HEIGHT="1009" CONF="0.888" ORDER="21" STRING="云ふ事なし。其年、九州上方八分作前後上作なる時は、上なし。又天災ある時は、七八月より急上に" />
  <LINE TYPE="本文" X="1102" Y="311" WIDTH="31" HEIGHT="1010" CONF="0.881" ORDER="22" STRING="なる也。また、自然の不作なる時は、日本作平均、九月迄大阪にて相知る故、十月より十二月迄に大" />
  <LINE TYPE="本文" X="1057" Y="310" WIDTH="32" HEIGHT="1019" CONF="0.842" ORDER="23" STRING="阪引上げ来る故、当地も上がる也。能々考ふべし。上方當地共に相廻の作、又は當地上作年には、秋" />
  <LINE TYPE="本文" X="1684" Y="1414" WIDTH="95" HEIGHT="23" CONF="0.339" ORDER="24" STRING="一一一、一一、" />
<LINE TYPE="本文" X="901" Y="322" WIDTH="31" HEIGHT="994" CONF="0.879" ORDER="25" STRING="冬の内、少々の上にて大上なし。當地不作年には、上方他所に構はず、地大上げになる也。四分半、" />
  <LINE TYPE="本文" X="858" Y="322" WIDTH="33" HEIGHT="995" CONF="0.907" ORDER="26" STRING="六分不作年には、大方十俵墓に入ると心得、二十俵際になり考へ第一也。天井直段、十四五日下らず、" />
  <LINE TYPE="本文" X="815" Y="313" WIDTH="33" HEIGHT="1020" CONF="0.896" ORDER="27" STRING="自然と下る也。三四月頃迄、十俵位通にて、二三十俵下げ、其後持合、四五月に成り、三四十俵下げ、" />
  <LINE TYPE="本文" X="771" Y="320" WIDTH="33" HEIGHT="1010" CONF="0.894" ORDER="28" STRING="又二三十俵も上げ、六月になり、順気能く田畑見事上作の風聞、御藏内米共に相残り、高直故船々も" />
  <LINE TYPE="本文" X="729" Y="320" WIDTH="31" HEIGHT="1002" CONF="0.901" ORDER="29" STRING="買急がぬ故、此時買持の面々退屈し、賣逃る間、急に六七十俵百俵下になり、大崩れとなる心得べし。" />
  <LINE TYPE="本文" X="685" Y="312" WIDTH="32" HEIGHT="1022" CONF="0.900" ORDER="30" STRING="又、五月三位に當る年は、四五月十分に下らざる時は、六七月に上なし。四五六月十分に下る時は、" />
  <LINE TYPE="本文" X="641" Y="320" WIDTH="33" HEIGHT="1010" CONF="0.877" ORDER="31" STRING="七八月決して上る也、&lt;疑なし。七月三位に當る時は、四五月上らざる時は、六月底月故、廿日頃迄決" />
  <LINE TYPE="本文" X="599" Y="322" WIDTH="31" HEIGHT="1007" CONF="0.906" ORDER="32" STRING="して大崩しなり。六月初方より賣付下かゝる節、十二十三日の間下底を考へ、落引になり及はゞ格別、" />
  <LINE TYPE="本文" X="556" Y="323" WIDTH="31" HEIGHT="1006" CONF="0.904" ORDER="33" STRING="落ざる節は、底を見極め買返し又買過すべし。其後の上を待つて利ある時、早速仕廻取留るべし。七" />
  <LINE TYPE="本文" X="513" Y="319" WIDTH="32" HEIGHT="1013" CONF="0.883" ORDER="34" STRING="八九十天井直段出る米は、十二月迄に下ると云数を守るべし。又、七八九十底直段の米は、十二月迄" />
  <LINE TYPE="本文" X="469" Y="321" WIDTH="32" HEIGHT="1009" CONF="0.905" ORDER="35" STRING="に上ると云ふ教を守るべし。又、冬中より正二月頃迄天井直段の米は、四五六月下ると心得べし。五" />
  <LINE TYPE="本文" X="426" Y="326" WIDTH="32" HEIGHT="1002" CONF="0.909" ORDER="36" STRING="月十分に下る時は、六月急上げ也。五月十分に下らざる時は、六月廿日頃迄に大崩し也。前年冬中よ" />
  <LINE TYPE="本文" X="383" Y="322" WIDTH="32" HEIGHT="1013" CONF="0.882" ORDER="37" STRING="り金拂底の年は、極めて思入買多き故、六月崩し也。冬中より正二三月頃迄不位の米は、决して夏上" />
  <LINE TYPE="本文" X="339" Y="322" WIDTH="32" HEIGHT="1009" CONF="0.893" ORDER="38" STRING="げ也。七月頃迄も上がると心得べし。三位の傳の外の教也、心得べし。何分、秋米は賣方すべからず、" />
  <LINE TYPE="本文" X="296" Y="323" WIDTH="31" HEIGHT="1006" CONF="0.871" ORDER="39" STRING="買方に付くべし。多少に限らず上げすと云ふとなし。天井直段後下相塲のとは、三位の處に記す、能" />
  <LINE TYPE="本文" X="262" Y="1118" WIDTH="20" HEIGHT="39" CONF="0.475" ORDER="40" STRING="六五" />
  </PAGE>

