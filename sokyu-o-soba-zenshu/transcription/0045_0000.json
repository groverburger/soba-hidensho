          ]
        ],
        "id": 8,
        "isVertical": "true",
        "text": "位もかゝる程上げつめた塲合には、利のある時は利喰して、更に付け出すことが肝要である。尚宗久",
        "isTextline": "true",
        "confidence": 0.878
