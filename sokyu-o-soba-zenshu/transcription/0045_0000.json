          ]
        ],
        "id": 7,
        "isVertical": "true",
        "text": "上げ位になつたら、克く相塲の位置と人氣の次第を考へ、利を取留る者である。何しろ、損方二敷",
        "isTextline": "true",
        "confidence": 0.881
