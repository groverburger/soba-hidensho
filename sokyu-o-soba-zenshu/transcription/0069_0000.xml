<PAGE IMAGENAME="0069_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1760" Y="1111" WIDTH="24" HEIGHT="59" CONF="0.483" ORDER="0" STRING="一〇八" />
  <LINE TYPE="本文" X="1720" Y="328" WIDTH="35" HEIGHT="975" CONF="0.728" ORDER="1" STRING="兩分位の少玉に限り、目早く見切つて利喰せよと云ふ意味である。餘は、意味が明瞭であるから、" />
  <LINE TYPE="本文" X="1688" Y="340" WIDTH="24" HEIGHT="146" CONF="0.864" ORDER="2" STRING="解釋を略する。" />
  <LINE TYPE="本文" X="1613" Y="486" WIDTH="31" HEIGHT="330" CONF="0.853" ORDER="3" STRING="第十三章一匁天井の事" />
  <LINE TYPE="本文" X="1559" Y="264" WIDTH="17" HEIGHT="20" CONF="0.429" ORDER="4" STRING="宗" />
  <LINE TYPE="本文" X="1528" Y="263" WIDTH="15" HEIGHT="18" CONF="0.437" ORDER="5" STRING="久" />
  <LINE TYPE="本文" X="1429" Y="263" WIDTH="18" HEIGHT="18" CONF="0.466" ORDER="6" STRING="場" />
  <LINE TYPE="本文" X="1494" Y="263" WIDTH="17" HEIGHT="19" CONF="0.447" ORDER="7" STRING="鰈" />
  <LINE TYPE="本文" X="1461" Y="263" WIDTH="18" HEIGHT="19" CONF="0.478" ORDER="8" STRING="相" />
  <LINE TYPE="本文" X="1399" Y="262" WIDTH="16" HEIGHT="18" CONF="0.457" ORDER="10" STRING="全" />
  <LINE TYPE="本文" X="1365" Y="261" WIDTH="17" HEIGHT="19" CONF="0.494" ORDER="11" STRING="集" />
  <LINE TYPE="本文" X="1332" Y="260" WIDTH="17" HEIGHT="21" CONF="0.505" ORDER="12" STRING="下" />
  <LINE TYPE="本文" X="1301" Y="260" WIDTH="16" HEIGHT="20" CONF="0.507" ORDER="13" STRING="巻" />
  <LINE TYPE="本文" X="1558" Y="322" WIDTH="23" HEIGHT="117" CONF="0.858" ORDER="14" STRING="一一匁天井。" />
  <LINE TYPE="本文" X="1501" Y="308" WIDTH="38" HEIGHT="1023" CONF="0.852" ORDER="15" STRING="但し、當地不作年は、乘米十六七匁底にて、天井は一匁又は乘米なしと心得べし。其次三四匁、其次八" />
  <LINE TYPE="本文" X="1457" Y="310" WIDTH="39" HEIGHT="1012" CONF="0.887" ORDER="16" STRING="九匁、夫より十二三匁迄下る者也。此天井出る時は、乘米を考へ賣込む者也。通相塲にて、五六ヶ月" />
  <LINE TYPE="本文" X="1414" Y="312" WIDTH="38" HEIGHT="1006" CONF="0.887" ORDER="17" STRING="定めて下る也。下相場の竇付は、一ケ月切に仕舞ふ者也。夫共に、極引上げ乗米なしの處にて二三ケ" />
  <LINE TYPE="本文" X="1371" Y="311" WIDTH="38" HEIGHT="1013" CONF="0.894" ORDER="18" STRING="月遠き處を賣付け置く時は、仕廻ふに及ばず、二つ仕舞、三つ十分、四つ轉じ、是三位の秘傳也。常" />
  <LINE TYPE="本文" X="1327" Y="311" WIDTH="39" HEIGHT="1012" CONF="0.870" ORDER="19" STRING="の月の賣付は、廿九日迄に仕廻ふ者也。五月六月の賣付けは、十八九日廿一日迄に、サツパリと仕廻" />
  <LINE TYPE="本文" X="1298" Y="313" WIDTH="24" HEIGHT="192" CONF="0.888" ORDER="20" STRING="ふ者也。心得べし。" />
  <LINE TYPE="本文" X="1242" Y="323" WIDTH="36" HEIGHT="996" CONF="0.898" ORDER="21" STRING="本章は、前章に引續き、天井直段になる際の乘米の景況と、夫に對する駈引を説いた者で。" />
  <LINE TYPE="本文" X="1197" Y="326" WIDTH="39" HEIGHT="990" CONF="0.896" ORDER="22" STRING="意味は、天井直段の際は、一匁乘又は無鞘迄上げ詰る者であるが、相塲が数ケ月引つとき上げて來" />
  <LINE TYPE="本文" X="1154" Y="328" WIDTH="37" HEIGHT="985" CONF="0.897" ORDER="23" STRING="た後で、此樣な人気となる時は、屹度天井であるから、此乘米を攻究して賣込むがよい。定めて、" />
  <LINE TYPE="本文" X="1111" Y="330" WIDTH="37" HEIGHT="983" CONF="0.881" ORDER="24" STRING="二三ケ月より五六月引續いて下るであらう。併し。下相塲と云ふ者は、前にも屡々説いた通り、通" />
  <LINE TYPE="本文" X="923" Y="326" WIDTH="36" HEIGHT="988" CONF="0.861" ORDER="25" STRING="ふては下げ、通ふては下る者であるから、其心得で駈引すべき者で、自分の仕掛玉が期近物なら、" />
  <LINE TYPE="本文" X="878" Y="328" WIDTH="37" HEIGHT="998" CONF="0.850" ORDER="26" STRING="大抵の處で手仕廻するがよい。五六月の賣付米手仕廻の説明は、已に前章に述べて置たから、宜し" />
  <LINE TYPE="本文" X="837" Y="331" WIDTH="24" HEIGHT="171" CONF="0.863" ORDER="27" STRING="く參考すべしだ。" />
  <LINE TYPE="本文" X="767" Y="476" WIDTH="34" HEIGHT="539" CONF="0.793" ORDER="28" STRING="第十四章買八分の利賣二分の利と申事" />
  <LINE TYPE="本文" X="704" Y="311" WIDTH="26" HEIGHT="281" CONF="0.837" ORDER="29" STRING="一買八分の利、賣二分の利、" />
  <LINE TYPE="本文" X="662" Y="310" WIDTH="33" HEIGHT="996" CONF="0.890" ORDER="30" STRING="但し、賣方は利足を取り、其上利米ある時は甚だ勝手なる者なれども、萬一上方當地作難ある時は、" />
  <LINE TYPE="本文" X="619" Y="312" WIDTH="34" HEIGHT="993" CONF="0.889" ORDER="31" STRING="大阪上げ來る故買返しならず、損出る也。買方は、數月の利、拂上の程知れず、甚だ買惡き者なれ共、" />
  <LINE TYPE="本文" X="576" Y="309" WIDTH="33" HEIGHT="999" CONF="0.857" ORDER="32" STRING="利運に向く時は、利米は風前の塵にて苦にならず。且多少に限らず、秋米は、上らずと云ふとなし、" />
  <LINE TYPE="本文" X="532" Y="311" WIDTH="23" HEIGHT="171" CONF="0.861" ORDER="33" STRING="売方すべからず。" />
  <LINE TYPE="本文" X="489" Y="328" WIDTH="32" HEIGHT="993" CONF="0.891" ORDER="34" STRING="(釋)本章は、買方の割の善いとを云ふた者で、其割合を數量にして示めせば、殆んど八分と二分" />
  <LINE TYPE="本文" X="445" Y="330" WIDTH="34" HEIGHT="990" CONF="0.891" ORDER="35" STRING="位の釣合だと云つて、大に買に重きを示した。此買方が割のよい者であるとは、古来相場成功者の" />
  <LINE TYPE="本文" X="402" Y="331" WIDTH="32" HEIGHT="989" CONF="0.893" ORDER="36" STRING="大部は、買方であつたとても、認知さるゝので、本書の筆者、宗久翁は大々的買賛成論者であると" />
  <LINE TYPE="本文" X="356" Y="331" WIDTH="35" HEIGHT="992" CONF="0.899" ORDER="37" STRING="は、云ふ迄もないとてあるが、彼の牛田慈雲齋の如きも、夙に此説の主張者て、「挑燈と釣鐘を見よ、" />
  <LINE TYPE="本文" X="313" Y="330" WIDTH="34" HEIGHT="987" CONF="0.871" ORDER="38" STRING="賣と買、買徳多し賣損多し。」と極言し、且其理由を擧げて、米は一體強味勝の者故、買方に利ある" />
  <LINE TYPE="本文" X="280" Y="1114" WIDTH="21" HEIGHT="55" CONF="0.573" ORDER="39" STRING="一〇九" />
  </PAGE>

