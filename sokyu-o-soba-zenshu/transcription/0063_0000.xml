<LINE TYPE="本文" X="1532" Y="254" WIDTH="17" HEIGHT="22" CONF="0.418" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1498" Y="255" WIDTH="18" HEIGHT="22" CONF="0.405" ORDER="2" STRING="久" />
  <LINE TYPE="本文" X="1465" Y="254" WIDTH="19" HEIGHT="23" CONF="0.368" ORDER="3" STRING="概" />
  <LINE TYPE="本文" X="1433" Y="254" WIDTH="19" HEIGHT="22" CONF="0.381" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1400" Y="253" WIDTH="20" HEIGHT="23" CONF="0.334" ORDER="5" STRING="場" />
  <LINE TYPE="本文" X="1272" Y="253" WIDTH="18" HEIGHT="21" CONF="0.336" ORDER="6" STRING="卷" />
  <LINE TYPE="本文" X="1745" Y="1102" WIDTH="18" HEIGHT="36" CONF="0.527" ORDER="7" STRING="九六" />
  <LINE TYPE="本文" X="1699" Y="326" WIDTH="29" HEIGHT="989" CONF="0.805" ORDER="8" STRING="(釋)本章は、落引に對する賣方買方兩者の駈引を述べた者で、右圖中に取方と書いてあるのは、" />
  <LINE TYPE="本文" X="1657" Y="318" WIDTH="26" HEIGHT="567" CONF="0.870" ORDER="9" STRING="落引を取る方、即ち利盆方の掛引に就て説た者である。" />
  <LINE TYPE="本文" X="1611" Y="326" WIDTH="31" HEIGHT="990" CONF="0.902" ORDER="10" STRING="偖買方の方から見れば、此圖に示してある樣に、例へば十俵で買た米は、相塲が上がつて七俵で" />
  <LINE TYPE="本文" X="1567" Y="317" WIDTH="31" HEIGHT="993" CONF="0.860" ORDER="11" STRING="落引となる規定ではあるが、亂高下で、放れ相塲或は飛相塲抔が出て、此圖の落と書てある六俵で" />
  <LINE TYPE="本文" X="1524" Y="327" WIDTH="31" HEIGHT="982" CONF="0.882" ORDER="12" STRING="落引如何の斷りを、賣方に向つてしなければならぬ塲合が、ないとも限らない、そうなると、其一" />
  <LINE TYPE="本文" X="1481" Y="331" WIDTH="31" HEIGHT="978" CONF="0.897" ORDER="13" STRING="ト指金たる三俵を越へた分、即ち六俵から七俵迄の直違ひ一俵は、全く買方の空損とならなければ" />
  <LINE TYPE="本文" X="1439" Y="318" WIDTH="31" HEIGHT="991" CONF="0.870" ORDER="14" STRING="ならぬ譯だから、明日一ト上せば、相手方の賣方が指金落切にする樣子が見へたら、其前日に於て" />
  <LINE TYPE="本文" X="1396" Y="325" WIDTH="31" HEIGHT="987" CONF="0.897" ORDER="15" STRING="相塲の勢を見て、其落られると思ふ玉数を調べて見て、其見替に買つて置くがよい。又、今一段上" />
  <LINE TYPE="本文" X="1353" Y="328" WIDTH="31" HEIGHT="983" CONF="0.904" ORDER="16" STRING="げるだろふと思はれる時、賣方から、指金落切りて商内を止めると云ふ通知を受けたならば、早速" />
  <LINE TYPE="本文" X="1311" Y="324" WIDTH="31" HEIGHT="989" CONF="0.873" ORDER="17" STRING="相塲の上げない内に、落られたと同直段位で、乗替に買て置くがよい。併し、相手方の賣方で、追" />
  <LINE TYPE="本文" X="1267" Y="324" WIDTH="31" HEIGHT="986" CONF="0.863" ORDER="18" STRING="敷を入れて商を繋いだならば、他の見込あれば格別、此落引の駈引計りでは、無論買入れるに及ば" />
  <LINE TYPE="本文" X="1232" Y="330" WIDTH="20" HEIGHT="56" CONF="0.779" ORDER="19" STRING="ない。" />
  <LINE TYPE="本文" X="1181" Y="326" WIDTH="30" HEIGHT="984" CONF="0.864" ORDER="20" STRING="右に述べたのは、買方で相塲が引上げ取方となつた塲合を説明したのであるが、遣り方、即ち損方" />
  <LINE TYPE="本文" X="1137" Y="325" WIDTH="32" HEIGHT="985" CONF="0.883" ORDER="21" STRING="となつた塲合は、全く右の正反對で、右の圖で見る如く、例へば七俵で賣つた米なら、四俵となれ" />
  <LINE TYPE="本文" X="1093" Y="325" WIDTH="32" HEIGHT="982" CONF="0.879" ORDER="22" STRING="ば落にかゝる定めてはあるが、放れ亦飛相塲抔で、三俵となつた時に落るか落ないかと云ふ斷りを受" />
  <LINE TYPE="本文" X="926" Y="320" WIDTH="29" HEIGHT="979" CONF="0.857" ORDER="23" STRING="けても、一ト差金から越へた不足額は、出すに及ばない規定であるから、詰り、四俵から三俵迄差額" />
  <LINE TYPE="本文" X="881" Y="309" WIDTH="32" HEIGHT="998" CONF="0.870" ORDER="24" STRING="の一俵方は、得となる譯であるから、落の断を受けても、急ぐには及ばない、翌日の商况を見て、" />
  <LINE TYPE="本文" X="838" Y="321" WIDTH="32" HEIGHT="983" CONF="0.875" ORDER="25" STRING="ツナイで得だと思ふなら繋ぐもよいが、若し、一俵方も一ト落の證據金を越へて寄付き、得とな" />
  <LINE TYPE="本文" X="797" Y="312" WIDTH="28" HEIGHT="775" CONF="0.829" ORDER="26" STRING="る模様であつたら落切となし、更に高直段の出るのを待つて賣付るがよい。" />
  <LINE TYPE="本文" X="753" Y="318" WIDTH="30" HEIGHT="990" CONF="0.854" ORDER="27" STRING="本章は、現今では僅に薄敷米の掛引に應用が出來るのみであつて、本米に對しては、應用は出來な" />
  <LINE TYPE="本文" X="713" Y="325" WIDTH="24" HEIGHT="31" CONF="0.501" ORDER="28" STRING="い。" />
  <LINE TYPE="本文" X="640" Y="464" WIDTH="32" HEIGHT="542" CONF="0.808" ORDER="29" STRING="第二章相塲二三ケ月持合ふ時心得の事" />
  <LINE TYPE="本文" X="580" Y="302" WIDTH="29" HEIGHT="1003" CONF="0.853" ORDER="30" STRING="一相塲、二三ケ月も持合ふ時は、十人が八九人迄賣方に向く者也。其後極めて上る者也。但し、登り" />
  <LINE TYPE="本文" X="537" Y="291" WIDTH="26" HEIGHT="562" CONF="0.891" ORDER="31" STRING="詰め、百俵以上位にて持合ふ米は、下相塲と心得べし。" />
  <LINE TYPE="本文" X="493" Y="297" WIDTH="30" HEIGHT="1014" CONF="0.889" ORDER="32" STRING="一體、相塲が保合となると陰氣となる者で、人氣も何となく陰に傾向いて、總賣となる者で" />
  <LINE TYPE="本文" X="450" Y="315" WIDTH="31" HEIGHT="990" CONF="0.844" ORDER="33" STRING="あるが、其後は、人氣の反對に上げる者である。其理由は如何と云に、持合相塲と云ふ者は、十中" />
  <LINE TYPE="本文" X="407" Y="321" WIDTH="31" HEIGHT="981" CONF="0.893" ORDER="34" STRING="の八九迄底保合が多い者で、諸人が貿りに賣つた保合で、ウ子りにウチつた跡で、下ぐ可く見へて" />
  <LINE TYPE="本文" X="363" Y="324" WIDTH="32" HEIGHT="978" CONF="0.894" ORDER="35" STRING="も下げられない相塲で、下げられなければ、上の外はないのて、上の潜勢力を蓄へて居るのだから、" />
  <LINE TYPE="本文" X="320" Y="317" WIDTH="31" HEIGHT="985" CONF="0.808" ORDER="36" STRING="僅かの動機を得ると、上に變發するからである。併し、此塲合にも、相塲の位取を見るのが肝腎で、" />
  <LINE TYPE="本文" X="283" Y="1091" WIDTH="21" HEIGHT="39" CONF="0.516" ORDER="37" STRING="九七" />
  <LINE TYPE="本文" X="209" Y="101" WIDTH="30" HEIGHT="1292" CONF="0.454" ORDER="38" STRING="朝鮮、朝朝の日本年十一年に至る。尚尚貞" />
  </PAGE>

