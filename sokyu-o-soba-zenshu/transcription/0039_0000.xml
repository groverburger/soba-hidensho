  <LINE TYPE="本文" X="1772" Y="120" WIDTH="32" HEIGHT="1329" CONF="0.451" ORDER="0" STRING="…………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………" />
  <LINE TYPE="本文" X="1493" Y="271" WIDTH="17" HEIGHT="22" CONF="0.388" ORDER="1" STRING="宗" />
  <LINE TYPE="本文" X="1462" Y="271" WIDTH="15" HEIGHT="22" CONF="0.322" ORDER="2" STRING="久" />
  <LINE TYPE="本文" X="1428" Y="270" WIDTH="17" HEIGHT="23" CONF="0.312" ORDER="3" STRING="鍋" />
  <LINE TYPE="本文" X="1396" Y="271" WIDTH="16" HEIGHT="22" CONF="0.313" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1364" Y="270" WIDTH="17" HEIGHT="23" CONF="0.337" ORDER="5" STRING="場" />
  <LINE TYPE="本文" X="1332" Y="271" WIDTH="16" HEIGHT="23" CONF="0.351" ORDER="6" STRING="全" />
  <LINE TYPE="本文" X="1299" Y="271" WIDTH="16" HEIGHT="22" CONF="0.356" ORDER="7" STRING="集" />
  <LINE TYPE="本文" X="1268" Y="273" WIDTH="15" HEIGHT="21" CONF="0.401" ORDER="8" STRING="上" />
  <LINE TYPE="本文" X="1235" Y="271" WIDTH="17" HEIGHT="22" CONF="0.357" ORDER="9" STRING="卷" />
  <LINE TYPE="本文" X="1710" Y="1117" WIDTH="21" HEIGHT="37" CONF="0.498" ORDER="10" STRING="四八" />
  <LINE TYPE="本文" X="1665" Y="350" WIDTH="29" HEIGHT="975" CONF="0.788" ORDER="11" STRING="一體本章に説く如き塲合の上げは、極々陽に登りつめたる相塲であつて、最早相塲の轉還期である" />
  <LINE TYPE="本文" X="1621" Y="342" WIDTH="30" HEIGHT="991" CONF="0.869" ORDER="12" STRING="から、人気は、強気は買つのり、弱気は、ふるひ恐れて、此上、何程上がるかも知れぬ様の人気と" />
  <LINE TYPE="本文" X="1577" Y="345" WIDTH="31" HEIGHT="983" CONF="0.894" ORDER="13" STRING="なる者である。是諺に所謂、燈火消へんとして光増すと云ふ心であつて、是非共明日は上げるから、" />
  <LINE TYPE="本文" X="1535" Y="340" WIDTH="30" HEIGHT="988" CONF="0.863" ORDER="14" STRING="此處で買つて置けば、利の付くこと手に取る樣に思はれても、決して買はない者である。此處ろ、" />
  <LINE TYPE="本文" X="1492" Y="342" WIDTH="30" HEIGHT="988" CONF="0.854" ORDER="15" STRING="人氣も強く相塲も強いから、強氣の人は、買たくつて溜らない者であるけれども、此處にて天井に" />
  <LINE TYPE="本文" X="1451" Y="339" WIDTH="24" HEIGHT="423" CONF="0.878" ORDER="16" STRING="目を着けるのが、相塲師の大秘訣である。" />
  <LINE TYPE="本文" X="1380" Y="488" WIDTH="30" HEIGHT="452" CONF="0.877" ORDER="17" STRING="第三十六章上の内の下相場の事" />
  <LINE TYPE="本文" X="1319" Y="326" WIDTH="29" HEIGHT="1011" CONF="0.858" ORDER="18" STRING="一新米出初、一二俵方も高下あり、底にて保合、五六十俵位も景氣付、又二俵餘引下け、持合ふとあ" />
  <LINE TYPE="本文" X="1274" Y="325" WIDTH="31" HEIGHT="1006" CONF="0.895" ORDER="19" STRING="り。此相塲、買方は退屈し、賣方は盆々賣募る也。此米、决して賣らざる者也。賣方は、此處にて買" />
  <LINE TYPE="本文" X="1231" Y="311" WIDTH="31" HEIGHT="1029" CONF="0.896" ORDER="20" STRING="返すべし。此米、底より起き上る米也。上の内の下げ也。總べて、天井直段の時節を考ふると第一也。" />
  <LINE TYPE="本文" X="1188" Y="335" WIDTH="30" HEIGHT="990" CONF="0.872" ORDER="21" STRING="本章は、上の内の下相塲、即ち底より起上り起上りの相塲に賣込むなと云ふとを、訓戒した者で、" />
  <LINE TYPE="本文" X="1145" Y="342" WIDTH="31" HEIGHT="981" CONF="0.895" ORDER="22" STRING="其一例を擧示した。例へば、新商の發會後、僅少の高下有て、底間際に保合つて居た米、段々景氣" />
  <LINE TYPE="本文" X="1099" Y="343" WIDTH="33" HEIGHT="983" CONF="0.886" ORDER="23" STRING="付て、五六十錢方位も引上げた跡、二十丁位も下げて保合ふとがある。此場合、買方は永々相場の" />
  <LINE TYPE="本文" X="1057" Y="345" WIDTH="31" HEIGHT="980" CONF="0.843" ORDER="24" STRING="頭を擡げざるに退屈し、賣方は、氣を得て盆々賣募る者であるが、此の如き塲合は、决して賣るべ" />
  <LINE TYPE="本文" X="738" Y="255" WIDTH="16" HEIGHT="22" CONF="0.409" ORDER="25" STRING="第" />
  <LINE TYPE="本文" X="717" Y="255" WIDTH="14" HEIGHT="21" CONF="0.380" ORDER="26" STRING="三" />
  <LINE TYPE="本文" X="696" Y="256" WIDTH="13" HEIGHT="20" CONF="0.374" ORDER="27" STRING="十" />
  <LINE TYPE="本文" X="675" Y="256" WIDTH="15" HEIGHT="21" CONF="0.328" ORDER="28" STRING="七" />
  <LINE TYPE="本文" X="652" Y="257" WIDTH="14" HEIGHT="20" CONF="0.362" ORDER="29" STRING="章" />
  <LINE TYPE="本文" X="631" Y="258" WIDTH="15" HEIGHT="19" CONF="0.350" ORDER="30" STRING="不" />
  <LINE TYPE="本文" X="910" Y="317" WIDTH="31" HEIGHT="1005" CONF="0.868" ORDER="31" STRING="からざる者で、売つた者なら此處て買返すべきである、何故と云ふに、此相場は、底より起き上り" />
  <LINE TYPE="本文" X="868" Y="326" WIDTH="32" HEIGHT="990" CONF="0.864" ORDER="32" STRING="相塲の形式で、上の内の下けである故である。賣らうと思ふならば、天井直段の時機を考へると肝" />
  <LINE TYPE="本文" X="825" Y="332" WIDTH="22" HEIGHT="101" CONF="0.864" ORDER="33" STRING="要である。" />
  <LINE TYPE="本文" X="782" Y="325" WIDTH="32" HEIGHT="991" CONF="0.873" ORDER="34" STRING="前章では、天井打下ろしの相塲に、買ふてならぬと注意を與へ、亦本章では、底直より起上り相場" />
  <LINE TYPE="本文" X="740" Y="325" WIDTH="29" HEIGHT="712" CONF="0.833" ORDER="35" STRING="に對して、賣方に警告を與へた。翁が老婆親切、以て謝すべきである。" />
  <LINE TYPE="本文" X="670" Y="475" WIDTH="33" HEIGHT="481" CONF="0.835" ORDER="36" STRING="第三十七章不利運の節心得方の事" />
  <LINE TYPE="本文" X="610" Y="312" WIDTH="30" HEIGHT="1002" CONF="0.855" ORDER="37" STRING="一不利運の節、賣平均買平均、决してせざる者也。思入違ひの節は、早速仕廻ひ、四五十日休むべし。" />
  <LINE TYPE="本文" X="566" Y="311" WIDTH="32" HEIGHT="1003" CONF="0.905" ORDER="38" STRING="十分仕當る商内にても、商内仕廻侯後は、四五十日休み、米の通ひを考へ、三位の傳に引合せ、圖に當" />
  <LINE TYPE="本文" X="522" Y="315" WIDTH="32" HEIGHT="996" CONF="0.890" ORDER="39" STRING="る時を考へ又仕掛く可し。何程利運を得ても、此休むとを忘るゝ時は、商仕廻の時は、極めて損出る" />
  <LINE TYPE="本文" X="480" Y="312" WIDTH="31" HEIGHT="1006" CONF="0.845" ORDER="40" STRING="と心得べし。但し、商仕廻休むと云ふは、何心なく休むにあらず、其氣の強弱を離れ、日々通ひ高下" />
  <LINE TYPE="本文" X="464" Y="612" WIDTH="20" HEIGHT="35" CONF="0.312" ORDER="41" STRING="四十五日" />
<LINE TYPE="本文" X="437" Y="299" WIDTH="32" HEIGHT="1028" CONF="0.851" ORDER="42" STRING="を油断なく考ふべき也。又前年医方にて利運する時は、又々強氣に張詰る者なれども、是又前年の気" />
  <LINE TYPE="本文" X="394" Y="307" WIDTH="30" HEIGHT="826" CONF="0.871" ORDER="43" STRING="をサツパリ離れ、其時其年の作の様子、物の多少、人気の次第を考ふると第一也。" />
  <LINE TYPE="本文" X="351" Y="327" WIDTH="31" HEIGHT="991" CONF="0.867" ORDER="44" STRING="(釋)不利運の時、賣ならし又買ならし杯は、决してすまじき者である。是は詰り、相塲に逆らひ、" />
  <LINE TYPE="本文" X="305" Y="331" WIDTH="32" HEIGHT="985" CONF="0.844" ORDER="45" STRING="我意を立て通さんとする者で、相塲の成功原則なる、「相塲に隨ふ」と云ふとに背ひて居る。故に自" />
  <LINE TYPE="本文" X="273" Y="1106" WIDTH="20" HEIGHT="41" CONF="0.481" ORDER="46" STRING="四九" />
  </PAGE>

