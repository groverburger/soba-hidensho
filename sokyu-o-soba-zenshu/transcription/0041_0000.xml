<PAGE IMAGENAME="0041_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1791" Y="345" WIDTH="28" HEIGHT="1103" CONF="0.498" ORDER="0" STRING="二十七七、一二七四、一九、七七七、一七、七七、七七、七七、七七、七七、一九、一九、一九、七九、一七、一九、一九、七七、一九、七七、一四、一九、一九九一、一九、一九二、一九、一九、一九、一九、一九、" />
  <LINE TYPE="本文" X="1682" Y="349" WIDTH="30" HEIGHT="984" CONF="0.822" ORDER="2" STRING="塲が轉還するから、唯何事もなく、利を取留ることを心掛く可きである。慾と云ふ者は、限りのな" />
  <LINE TYPE="本文" X="1639" Y="350" WIDTH="24" HEIGHT="77" CONF="0.754" ORDER="3" STRING="い者だ。" />
  <LINE TYPE="本文" X="1570" Y="491" WIDTH="31" HEIGHT="479" CONF="0.839" ORDER="4" STRING="第四十章底ねらひ天井ねらひの事" />
  <LINE TYPE="本文" X="1514" Y="271" WIDTH="17" HEIGHT="21" CONF="0.323" ORDER="5" STRING="宗" />
<LINE TYPE="本文" X="1509" Y="327" WIDTH="27" HEIGHT="596" CONF="0.785" ORDER="6" STRING="一底ねらひ、天井ねらひ、賣買すること、専ら心掛く可し。" />
  <LINE TYPE="本文" X="1465" Y="339" WIDTH="30" HEIGHT="995" CONF="0.891" ORDER="7" STRING="(釋)相塲必勝の要訣は、天井底を狙つて賣買するにあるは、云ふ迄もないことであるが、偖其觀" />
  <LINE TYPE="本文" X="1421" Y="331" WIDTH="31" HEIGHT="999" CONF="0.884" ORDER="8" STRING="察法となると、甚だ六ヶ敷い者である。其各説に就ては、長くなるから説かぬが、翁の説く所に、" />
  <LINE TYPE="本文" X="1379" Y="339" WIDTH="30" HEIGHT="993" CONF="0.843" ORDER="9" STRING="因ると、天井と底とを見るには、高下直段の割合と、其高下經過の月数とを推理するにある。其割" />
  <LINE TYPE="本文" X="1335" Y="328" WIDTH="31" HEIGHT="1018" CONF="0.843" ORDER="10" STRING="合説を擧げれば、本書の一節には底をねらふは、百俵下の的あり。天井をねらふには、百俵上を的" />
  <LINE TYPE="本文" X="1295" Y="340" WIDTH="23" HEIGHT="286" CONF="0.905" ORDER="11" STRING="にすれども云々。とある又、" />
  <LINE TYPE="本文" X="1250" Y="341" WIDTH="29" HEIGHT="895" CONF="0.790" ORDER="12" STRING="◎其時の模様に因り、百俵上に限らず、百三十俵百四五十俵百八十俵迄も上ることあり。" />
  <LINE TYPE="本文" X="1208" Y="346" WIDTH="24" HEIGHT="123" CONF="0.831" ORDER="13" STRING="と説き。亦、" />
  <LINE TYPE="本文" X="1165" Y="345" WIDTH="25" HEIGHT="527" CONF="0.889" ORDER="14" STRING="◎急に上げ急に下る相塲は、天井底の日限定まらず。" />
  <LINE TYPE="本文" X="1122" Y="345" WIDTH="23" HEIGHT="124" CONF="0.815" ORDER="15" STRING="とも説いた。" />
  <LINE TYPE="本文" X="1074" Y="342" WIDTH="33" HEIGHT="989" CONF="0.815" ORDER="16" STRING="次に月数に就ては、其轉還に就て、三ケ月説、六ケ月説、一二ケ月説の三つあるが、其六ケ月説に" />
  <LINE TYPE="本文" X="911" Y="359" WIDTH="21" HEIGHT="32" CONF="0.599" ORDER="17" STRING="は、" />
  <LINE TYPE="本文" X="906" Y="351" WIDTH="23" HEIGHT="42" CONF="0.375" ORDER="18" STRING="は、" />
  <LINE TYPE="本文" X="867" Y="333" WIDTH="33" HEIGHT="984" CONF="0.850" ORDER="19" STRING="◎天井直段後の下相場は、五六ケ月の間、一ケ月に一俵より三四俵方づゝ毎月定めて下る者とすと、" />
  <LINE TYPE="本文" X="824" Y="331" WIDTH="25" HEIGHT="336" CONF="0.892" ORDER="20" STRING="説き。そして、其例證を擧げて、" />
  <LINE TYPE="本文" X="781" Y="329" WIDTH="26" HEIGHT="492" CONF="0.891" ORDER="21" STRING="◎七八兩月天井直段の米は、十二月迄下る者也。" />
  <LINE TYPE="本文" X="737" Y="338" WIDTH="33" HEIGHT="982" CONF="0.840" ORDER="22" STRING="◎正月より三四月頃迄天井にて保合の米は、五六月の内决して下るべし。五月十分下る時は、六月" />
  <LINE TYPE="本文" X="694" Y="359" WIDTH="23" HEIGHT="79" CONF="0.836" ORDER="23" STRING="急上也。" />
  <LINE TYPE="本文" X="651" Y="342" WIDTH="31" HEIGHT="976" CONF="0.872" ORDER="24" STRING="◎冬中より正二月頃迄底直段にて保合ふ米は、三四月より五六月决して上る也。七八兩月、底直段" />
  <LINE TYPE="本文" X="607" Y="356" WIDTH="26" HEIGHT="380" CONF="0.870" ORDER="25" STRING="の米は、十二月正月迄に上なるべし、" />
  <LINE TYPE="本文" X="566" Y="338" WIDTH="24" HEIGHT="307" CONF="0.880" ORDER="26" STRING="と論じた。又其三ケ月説には、" />
  <LINE TYPE="本文" X="521" Y="346" WIDTH="32" HEIGHT="980" CONF="0.878" ORDER="27" STRING="◎底直段にて上る米は、二三ヶ月に急に天井直段出るとあり。其時の模樣にて、三ケ月下げ四ケ月" />
  <LINE TYPE="本文" X="479" Y="336" WIDTH="28" HEIGHT="890" CONF="0.661" ORDER="28" STRING="目上ることあり、又五ケ月目より下ることもあり。六ケ月皆下ることもありと。" />
  <LINE TYPE="本文" X="435" Y="330" WIDTH="30" HEIGHT="936" CONF="0.809" ORDER="29" STRING="又翁は、此定則の例外として、七八ケ月高下、一二ケ月高下をも説いた。其七八ケ月説には、" />
  <LINE TYPE="本文" X="390" Y="335" WIDTH="29" HEIGHT="751" CONF="0.864" ORDER="30" STRING="◎十一、十二、正月頃下直の米は、夏上と心得べし、七月頃迄も上る者也。" />
  <LINE TYPE="本文" X="349" Y="346" WIDTH="22" HEIGHT="160" CONF="0.855" ORDER="31" STRING="一二ケ月説には、" />
  <LINE TYPE="本文" X="303" Y="340" WIDTH="32" HEIGHT="990" CONF="0.826" ORDER="32" STRING="◎何れの月にても、急に十俵より十二三俵の上ある時は、一ト天井と心得べし、五六俵の上なる時" />
  <LINE TYPE="本文" X="271" Y="1111" WIDTH="20" HEIGHT="37" CONF="0.490" ORDER="33" STRING="五三" />
  </PAGE>

