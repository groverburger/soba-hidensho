  <LINE TYPE="本文" X="1589" Y="283" WIDTH="17" HEIGHT="18" CONF="0.385" ORDER="0" STRING="宗" />
  <LINE TYPE="本文" X="1523" Y="282" WIDTH="18" HEIGHT="19" CONF="0.329" ORDER="1" STRING="翁" />
  <LINE TYPE="本文" X="1557" Y="283" WIDTH="15" HEIGHT="18" CONF="0.326" ORDER="2" STRING="久" />
  <LINE TYPE="本文" X="1492" Y="282" WIDTH="16" HEIGHT="20" CONF="0.310" ORDER="3" STRING="相" />
  <LINE TYPE="本文" X="1460" Y="282" WIDTH="16" HEIGHT="19" CONF="0.309" ORDER="4" STRING="塲" />
<LINE TYPE="本文" X="1428" Y="283" WIDTH="16" HEIGHT="17" CONF="0.344" ORDER="5" STRING="全" />
  <LINE TYPE="本文" X="1395" Y="283" WIDTH="15" HEIGHT="18" CONF="0.373" ORDER="6" STRING="集" />
  <LINE TYPE="本文" X="1365" Y="284" WIDTH="14" HEIGHT="17" CONF="0.389" ORDER="7" STRING="下" />
  <LINE TYPE="本文" X="1331" Y="283" WIDTH="17" HEIGHT="18" CONF="0.441" ORDER="8" STRING="卷" />
  <LINE TYPE="本文" X="1757" Y="328" WIDTH="26" HEIGHT="474" CONF="0.865" ORDER="9" STRING="百俵上げ位にて落引の米は、賣方と心得べし。" />
  <LINE TYPE="本文" X="1799" Y="1131" WIDTH="22" HEIGHT="52" CONF="0.394" ORDER="10" STRING="一四二" />
  <LINE TYPE="本文" X="1712" Y="325" WIDTH="28" HEIGHT="773" CONF="0.870" ORDER="11" STRING="但し、春夏の米にて、乗米多き時は、百俵上にても、算用に背かざるべし。" />
  <LINE TYPE="本文" X="1667" Y="346" WIDTH="32" HEIGHT="1001" CONF="0.874" ORDER="12" STRING="右三ヶ月は、船手多買の入込む時である。其冬買が入込んで上げにかゝる時は、百俵位も上" />
  <LINE TYPE="本文" X="1623" Y="342" WIDTH="31" HEIGHT="1007" CONF="0.862" ORDER="13" STRING="る者であるから、五六十俵上げた迚賣らない者である。そして、航海の自由なる春か夏の米で、各" />
  <LINE TYPE="本文" X="1582" Y="348" WIDTH="29" HEIGHT="793" CONF="0.885" ORDER="14" STRING="地に比べて過分の下鞘で居る米は、百俵上げても、買の餘地がある者である。" />
  <LINE TYPE="本文" X="1511" Y="506" WIDTH="31" HEIGHT="474" CONF="0.870" ORDER="15" STRING="第六十二章霜月限商利運の時の事" />
  <LINE TYPE="本文" X="1449" Y="341" WIDTH="31" HEIGHT="1005" CONF="0.878" ORDER="16" STRING="一霜月限の商仕當る時は、心持第一也。譬へば、分限に應じ、千俵利分付かば、五百俵収留むる心に" />
  <LINE TYPE="本文" X="1406" Y="336" WIDTH="31" HEIGHT="1009" CONF="0.876" ORDER="17" STRING="なる可し。百俵利分ある時は、五十俵取留る樣心掛く可し。此心持なき時は、慾に迷ひ天井底にて賣" />
  <LINE TYPE="本文" X="1364" Y="334" WIDTH="29" HEIGHT="830" CONF="0.836" ORDER="18" STRING="買致し、苦勞の上、不利運になる也。此道を心掛る人、常に此心持怠る可からず。" />
  <LINE TYPE="本文" X="1318" Y="349" WIDTH="31" HEIGHT="1002" CONF="0.839" ORDER="19" STRING="(釋)本章は、利運の時の利留の心得を述べた者で、最早時分と思ふたなら先づ、其半分を手仕廻" />
  <LINE TYPE="本文" X="1278" Y="353" WIDTH="28" HEIGHT="747" CONF="0.776" ORDER="20" STRING="して相塲の成行を見よと云ふのである。上卷第五十九章を參照するがよい。" />
  <LINE TYPE="本文" X="1210" Y="504" WIDTH="30" HEIGHT="420" CONF="0.856" ORDER="21" STRING="第六十三章通にて下相塲の事" />
  <LINE TYPE="本文" X="1150" Y="343" WIDTH="25" HEIGHT="657" CONF="0.777" ORDER="22" STRING="一通にて下相塲は、月頭に上げ、月末廿九日晦日迄に下げ候者也。" />
  <LINE TYPE="本文" X="1794" Y="1420" WIDTH="69" HEIGHT="30" CONF="0.333" ORDER="23" STRING="十一" />
  <LINE TYPE="本文" X="971" Y="358" WIDTH="29" HEIGHT="796" CONF="0.866" ORDER="24" STRING="(釋)本章の意味は、上卷六十三章に精しく説てある。本章は、其異本である。" />
  <LINE TYPE="本文" X="901" Y="507" WIDTH="31" HEIGHT="478" CONF="0.852" ORDER="25" STRING="第六十四章買米利運取留心得の事" />
  <LINE TYPE="本文" X="839" Y="347" WIDTH="30" HEIGHT="1001" CONF="0.884" ORDER="26" STRING="一買米、利運になり候に付、二三俵方も取留可申と、賣返す事ある也、是は商の道知らざる故也、甚" />
  <LINE TYPE="本文" X="796" Y="336" WIDTH="31" HEIGHT="1011" CONF="0.887" ORDER="27" STRING="だ不宜也、売返し候とて、少しも安堵ならざる者也。新米の底は、景気付時は商不出急に引上る者" />
  <LINE TYPE="本文" X="753" Y="334" WIDTH="31" HEIGHT="1011" CONF="0.869" ORDER="28" STRING="故、賣買連れ落になり、手取無之、其上、十一月迄數月の間故甚だ苦勞多し。其上、急に引上る時は" />
  <LINE TYPE="本文" X="710" Y="344" WIDTH="29" HEIGHT="1000" CONF="0.862" ORDER="29" STRING="其返し又々下落の心遣ひ出る也。賣買手の内にある時は、晝夜無油斷右圖を以て駈引致し、十一月" />
  <LINE TYPE="本文" X="669" Y="332" WIDTH="24" HEIGHT="355" CONF="0.857" ORDER="30" STRING="晦日迄油斷なき樣、可心掛事也。" />
  <LINE TYPE="本文" X="624" Y="354" WIDTH="30" HEIGHT="992" CONF="0.877" ORDER="31" STRING="(釋)本章は、酒田米會所の商習慣から言つた者で、意ろは、例へば十俵も上げる米を、僅か二三" />
  <LINE TYPE="本文" X="580" Y="355" WIDTH="31" HEIGHT="990" CONF="0.883" ORDER="32" STRING="俵上げた處で、利留めをして置かふと賣立てして置くとあるが、是は、落引の規則を心得ぬ仕方で" />
  <LINE TYPE="本文" X="536" Y="357" WIDTH="31" HEIGHT="989" CONF="0.893" ORDER="33" STRING="ある。酒田米会所の慣習として、十一月迄、切上げ決算をしない規定であるから、夫迄の間は、利" />
  <LINE TYPE="本文" X="494" Y="352" WIDTH="30" HEIGHT="1003" CONF="0.897" ORDER="34" STRING="喰と新規とを問はず、賣は賣、又買は買と見做すから、若し其利喰した直段以上に相場が引上る時" />
  <LINE TYPE="本文" X="451" Y="359" WIDTH="30" HEIGHT="988" CONF="0.846" ORDER="35" STRING="は、其利喰竄した玉にも、落引が掛りて、所謂連れ落と云ふ者になつて、數ケ月の間苦勞する計り" />
  <LINE TYPE="本文" X="408" Y="349" WIDTH="31" HEIGHT="993" CONF="0.853" ORDER="36" STRING="で、手取が少い者である。だから下卷第一章の落引の圖を見て、油斷なく駈引をすべきである。尚、" />
  <LINE TYPE="本文" X="368" Y="358" WIDTH="25" HEIGHT="335" CONF="0.896" ORDER="37" STRING="巻首落引の項を參讀するがよい。" />
  <LINE TYPE="本文" X="329" Y="1139" WIDTH="21" HEIGHT="50" CONF="0.510" ORDER="38" STRING="一四三" />
