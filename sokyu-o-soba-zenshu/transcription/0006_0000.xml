  <LINE TYPE="本文" X="1703" Y="1111" WIDTH="20" HEIGHT="20" CONF="0.365" ORDER="0" STRING="四" />
  <LINE TYPE="本文" X="1653" Y="312" WIDTH="34" HEIGHT="985" CONF="0.833" ORDER="1" STRING="執乎、善兵曰奴尚欲買焉、翁曰善、我給汝資矣、唯速買焉、莫顧慮也、善兵衛踊" />
  <LINE TYPE="本文" X="1603" Y="310" WIDTH="35" HEIGHT="995" CONF="0.875" ORDER="2" STRING="躍、至市大買之、未幾、米價暴騰、遂得恢復資産也、善兵深徳宗久翁、歳次詣根" />
  <LINE TYPE="本文" X="1554" Y="300" WIDTH="36" HEIGHT="1023" CONF="0.870" ORDER="3" STRING="岸謝其恩云、宗久翁曾語善兵衛曰、酒田米賈皆味于見機、我今授汝韜略、乃一" />
  <LINE TYPE="本文" X="1506" Y="298" WIDTH="33" HEIGHT="859" CONF="0.770" ORDER="4" STRING="一出書一卷與之、乃此書也、然則此書之價値有不俟言而可知者焉。" />
  <LINE TYPE="本文" X="1454" Y="301" WIDTH="35" HEIGHT="1016" CONF="0.812" ORDER="5" STRING="翁生于田川郡一農家、以天稟之敏才與多年之實驗、保其成功、且増殖宗家資" />
  <LINE TYPE="本文" X="1406" Y="298" WIDTH="33" HEIGHT="1008" CONF="0.789" ORDER="6" STRING="産、而其身亦至爲素封家列格式於士流之上、可謂偉矣、翁死既百數十年、而今" />
  <LINE TYPE="本文" X="1357" Y="306" WIDTH="30" HEIGHT="431" CONF="0.879" ORDER="7" STRING="尚爲米賈所尊重者、豈偶然也乎。" />
  <LINE TYPE="本文" X="1317" Y="264" WIDTH="16" HEIGHT="17" CONF="0.492" ORDER="8" STRING="塲" />
  <LINE TYPE="本文" X="1269" Y="265" WIDTH="15" HEIGHT="16" CONF="0.489" ORDER="9" STRING="全" />
  <LINE TYPE="本文" X="1220" Y="263" WIDTH="15" HEIGHT="19" CONF="0.440" ORDER="10" STRING="集" />
  <LINE TYPE="本文" X="851" Y="450" WIDTH="34" HEIGHT="332" CONF="0.881" ORDER="11" STRING="酒田米会所の商習慣" />
  <LINE TYPE="本文" X="721" Y="261" WIDTH="17" HEIGHT="21" CONF="0.477" ORDER="12" STRING="酒" />
  <LINE TYPE="本文" X="684" Y="263" WIDTH="16" HEIGHT="17" CONF="0.449" ORDER="13" STRING="田" />
  <LINE TYPE="本文" X="646" Y="264" WIDTH="16" HEIGHT="17" CONF="0.454" ORDER="14" STRING="米" />
  <LINE TYPE="本文" X="571" Y="264" WIDTH="16" HEIGHT="17" CONF="0.404" ORDER="15" STRING="所" />
  <LINE TYPE="本文" X="605" Y="263" WIDTH="19" HEIGHT="19" CONF="0.382" ORDER="16" STRING="會" />
  <LINE TYPE="本文" X="499" Y="266" WIDTH="15" HEIGHT="17" CONF="0.404" ORDER="17" STRING="商" />
  <LINE TYPE="本文" X="534" Y="266" WIDTH="14" HEIGHT="15" CONF="0.351" ORDER="18" STRING="の" />
  <LINE TYPE="本文" X="462" Y="265" WIDTH="16" HEIGHT="18" CONF="0.375" ORDER="19" STRING="習" />
  <LINE TYPE="本文" X="428" Y="264" WIDTH="16" HEIGHT="18" CONF="0.424" ORDER="20" STRING="増" />
  <LINE TYPE="本文" X="787" Y="302" WIDTH="41" HEIGHT="1023" CONF="0.858" ORDER="21" STRING="酒田米會所の商習慣を述ぶるに當り、先づ酒田の地勢に就て一言せざるを得ず。蓋し、酒田の地たる一" />
  <LINE TYPE="本文" X="744" Y="308" WIDTH="43" HEIGHT="1015" CONF="0.881" ORDER="22" STRING="西方一帶は、日本海に面したる港灣にして、最上河の下流に當るを以て、運漕甚だ便宜あり、左れば" />
  <LINE TYPE="本文" X="700" Y="308" WIDTH="43" HEIGHT="1012" CONF="0.877" ORDER="23" STRING="最上河に副へる沿岸の諸侯は、皆其領内の納米及貢米は勿論、商人の持米に至る迄、大概此港に輸送" />
  <LINE TYPE="本文" X="659" Y="311" WIDTH="42" HEIGHT="1012" CONF="0.899" ORDER="24" STRING="し来り、米會所の相塲に據て賣買するの慣例にして、最上、米澤、荘内地方の米穀は、皆酒田に集中" />
  <LINE TYPE="本文" X="615" Y="312" WIDTH="43" HEIGHT="1017" CONF="0.890" ORDER="25" STRING="し来り、無虚数十萬石に上ることあり、又之を購入せんとして、長、雲、石、四、加、能、及松前地方" />
  <LINE TYPE="本文" X="571" Y="311" WIDTH="43" HEIGHT="1017" CONF="0.878" ORDER="26" STRING="の商買は、各其産物を和船に積載し來りて、商品を販賣して米穀を買取去るを例とす。左れど、北國" />
  <LINE TYPE="本文" X="530" Y="314" WIDTH="41" HEIGHT="1012" CONF="0.901" ORDER="27" STRING="地方の常として、毎年冬十月頃より翌春二三月迄の期間は、北風烈しく巨浪怒號して、航海困難なる" />
  <LINE TYPE="本文" X="487" Y="318" WIDTH="43" HEIGHT="1005" CONF="0.898" ORDER="28" STRING="が爲め、入船少きに拘はらず、出穀多く、隨つて米價も低位に居るを以て、諸州の商賈、冬買と稱し" />
  <LINE TYPE="本文" X="444" Y="313" WIDTH="41" HEIGHT="1013" CONF="0.889" ORDER="29" STRING="て十一二月頃より此地に来りて正米を購入し置き、翌春一番船の上るを待て輸出し去るの常なるを以" />
  <LINE TYPE="本文" X="402" Y="315" WIDTH="40" HEIGHT="1009" CONF="0.878" ORDER="30" STRING="て、正米の取引甚だ繁昌にして、随つて米取引所の必要を生じ、其歩座方と稱する取引所の如きは、" />
  <LINE TYPE="本文" X="359" Y="314" WIDTH="26" HEIGHT="377" CONF="0.867" ORDER="31" STRING="百四五十年以前の創立に係る者なり。" />
  <LINE TYPE="本文" X="314" Y="311" WIDTH="44" HEIGHT="1025" CONF="0.860" ORDER="32" STRING="▲荘内米札荘内藩の倉荷證書なり、今其由來を尋ぬるに、元和八年酒井忠勝の莊内に封ぜらるゝや、" />
  <LINE TYPE="本文" X="271" Y="317" WIDTH="42" HEIGHT="1020" CONF="0.835" ORDER="33" STRING="大に農業と開墾を獎勵せるを以て、米穀の産額年を追ふて遞加せり。時に非凡の才能を有せる柴谷武" />
  <LINE TYPE="本文" X="249" Y="1114" WIDTH="24" HEIGHT="29" CONF="0.302" ORDER="34" STRING="一、" />
