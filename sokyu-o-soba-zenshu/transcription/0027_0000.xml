  <LINE TYPE="本文" X="1783" Y="102" WIDTH="22" HEIGHT="1093" CONF="0.351" ORDER="2" STRING="一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一一" />
  <LINE TYPE="本文" X="1516" Y="263" WIDTH="16" HEIGHT="19" CONF="0.314" ORDER="3" STRING="宗" />
  <LINE TYPE="本文" X="1354" Y="263" WIDTH="17" HEIGHT="18" CONF="0.304" ORDER="4" STRING="全" />
  <LINE TYPE="本文" X="1323" Y="263" WIDTH="16" HEIGHT="18" CONF="0.303" ORDER="5" STRING="集" />
  <LINE TYPE="本文" X="1687" Y="315" WIDTH="23" HEIGHT="150" CONF="0.851" ORDER="6" STRING="付天井直段也。" />
  <LINE TYPE="本文" X="1728" Y="1105" WIDTH="18" HEIGHT="39" CONF="0.326" ORDER="7" STRING="二四" />
  <LINE TYPE="本文" X="1640" Y="324" WIDTH="26" HEIGHT="672" CONF="0.832" ORDER="8" STRING="本章は、天井直段を出す際の人氣の模樣を述べた者である。" />
  <LINE TYPE="本文" X="1593" Y="331" WIDTH="30" HEIGHT="993" CONF="0.884" ORDER="9" STRING="天井行付直段一には行付天井とも稱へて、一年中の最高天井を指すのである。偖、天井行付直段" />
  <LINE TYPE="本文" X="1551" Y="324" WIDTH="31" HEIGHT="1004" CONF="0.885" ORDER="10" STRING="になる塲合の人氣の模樣を云はゞ、數ケ月の間、下げては上げ、又下げては上げして、幾度も通ふ" />
  <LINE TYPE="本文" X="1507" Y="335" WIDTH="31" HEIGHT="981" CONF="0.856" ORDER="11" STRING="て、段々底直から五六十俵も引上げた後、一寸気迷の姿となり、夫から又、毎日十俵方づゝもミリ" />
  <LINE TYPE="本文" X="1464" Y="325" WIDTH="31" HEIGHT="998" CONF="0.872" ORDER="12" STRING="〳〵と引上げ、昨日賣た分は今日追敷、前塲に買た分、後塲には倍數となつて戻つて來ると云ふ樣" />
  <LINE TYPE="本文" X="1424" Y="325" WIDTH="26" HEIGHT="674" CONF="0.928" ORDER="13" STRING="に、人々が騒ぎ立時、是即ち上留り年中行付直段の出る時である。" />
  <LINE TYPE="本文" X="1382" Y="312" WIDTH="24" HEIGHT="393" CONF="0.835" ORDER="14" STRING="一甲乙丙丁但し、此四つ上げ也。" />
  <LINE TYPE="本文" X="1338" Y="314" WIDTH="25" HEIGHT="532" CONF="0.915" ORDER="15" STRING="一戊己庚辛壬癸但し、此六つ下げ也、癸を底とす。" />
  <LINE TYPE="本文" X="1291" Y="312" WIDTH="31" HEIGHT="999" CONF="0.899" ORDER="16" STRING="右、暦十二ケ月の下、月々の干支也。其年により甲より上げ初め、丁迄に上ることもあり。戊己に遲るゝと" />
  <LINE TYPE="本文" X="1247" Y="311" WIDTH="32" HEIGHT="1001" CONF="0.852" ORDER="17" STRING="もあり。十に八九、甲より上ると多し。百俵上を的にする時は、利を得ずと云ふとなし。何れにも、此" />
  <LINE TYPE="本文" X="1203" Y="311" WIDTH="33" HEIGHT="999" CONF="0.876" ORDER="18" STRING="四つの内に、上げずと云事なし。戌より己迄、六つの間上げなし、下げとす、癸を底直段出る月とす" />
  <LINE TYPE="本文" X="1159" Y="314" WIDTH="34" HEIGHT="997" CONF="0.872" ORDER="19" STRING="る也。又、不時天災時の變により、戌より後れ、辛迄上げ終るともあり。此事三十年に一度極々稀也、" />
  <LINE TYPE="本文" X="1121" Y="307" WIDTH="26" HEIGHT="403" CONF="0.760" ORDER="20" STRING="右、明和五年より寛政九年迄相違なし。" />
  <LINE TYPE="本文" X="1071" Y="321" WIDTH="37" HEIGHT="1005" CONF="0.853" ORDER="22" STRING="本節は、其月の十干干に因て、毎月の高下を知るの法を述べた者である。其業方及實例等は、" />
  <LINE TYPE="本文" X="912" Y="323" WIDTH="35" HEIGHT="991" CONF="0.871" ORDER="23" STRING="後章及卷末に書いてあるから、參照するがよい。文中に、其年により甲より上げ初め、丁迄に上げ" />
  <LINE TYPE="本文" X="869" Y="330" WIDTH="35" HEIGHT="986" CONF="0.874" ORDER="24" STRING="終るとあり云々は、甲月より上げ初めて、丁の月迄に上て仕廻つて、夫から下げに向ふとあると云" />
  <LINE TYPE="本文" X="827" Y="333" WIDTH="27" HEIGHT="527" CONF="0.869" ORDER="25" STRING="ふ意味である。以下も、之に準じて知るべきである。" />
  <LINE TYPE="本文" X="734" Y="260" WIDTH="18" HEIGHT="21" CONF="0.334" ORDER="26" STRING="第" />
  <LINE TYPE="本文" X="713" Y="261" WIDTH="15" HEIGHT="18" CONF="0.417" ORDER="27" STRING="十" />
  <LINE TYPE="本文" X="693" Y="262" WIDTH="15" HEIGHT="18" CONF="0.418" ORDER="28" STRING="二" />
  <LINE TYPE="本文" X="670" Y="262" WIDTH="16" HEIGHT="19" CONF="0.439" ORDER="29" STRING="章" />
  <LINE TYPE="本文" X="646" Y="261" WIDTH="17" HEIGHT="20" CONF="0.451" ORDER="30" STRING="三" />
  <LINE TYPE="本文" X="622" Y="261" WIDTH="15" HEIGHT="19" CONF="0.399" ORDER="31" STRING="位" />
  <LINE TYPE="本文" X="599" Y="262" WIDTH="15" HEIGHT="18" CONF="0.415" ORDER="32" STRING="甲" />
  <LINE TYPE="本文" X="573" Y="262" WIDTH="15" HEIGHT="19" CONF="0.346" ORDER="33" STRING="月" />
  <LINE TYPE="本文" X="550" Y="263" WIDTH="16" HEIGHT="18" CONF="0.374" ORDER="34" STRING="秘" />
  <LINE TYPE="本文" X="524" Y="262" WIDTH="16" HEIGHT="19" CONF="0.409" ORDER="35" STRING="傳" />
  <LINE TYPE="本文" X="502" Y="263" WIDTH="15" HEIGHT="17" CONF="0.418" ORDER="36" STRING="の" />
  <LINE TYPE="本文" X="476" Y="262" WIDTH="17" HEIGHT="17" CONF="0.423" ORDER="37" STRING="斑" />
  <LINE TYPE="本文" X="756" Y="481" WIDTH="32" HEIGHT="389" CONF="0.868" ORDER="38" STRING="第十二章三位甲月秘伝の事" />
  <LINE TYPE="本文" X="694" Y="310" WIDTH="35" HEIGHT="1009" CONF="0.900" ORDER="39" STRING="一七月甲に廻る年は、上方當地共に天災あつて、七月より急上げになると度々也。此年六月より、油" />
  <LINE TYPE="本文" X="651" Y="310" WIDTH="37" HEIGHT="1006" CONF="0.901" ORDER="40" STRING="断なく買入る可し、天災なく共、十二月迄に大阪引上げ来て、百俵以上の天井出づべし。七月に廻り" />
  <LINE TYPE="本文" X="607" Y="309" WIDTH="36" HEIGHT="1007" CONF="0.889" ORDER="41" STRING="候節は、上方当地共、上作にても無構買入るべし。又何れの月にも、百俵より百二十俵位甲に急上げ" />
  <LINE TYPE="本文" X="565" Y="311" WIDTH="35" HEIGHT="1005" CONF="0.892" ORDER="42" STRING="にならば、跡に上げなしと心得べし。五六十俵上なる時は、丙丁にも上有りと心得べし。寒西へ廻る" />
  <LINE TYPE="本文" X="522" Y="313" WIDTH="35" HEIGHT="1003" CONF="0.901" ORDER="43" STRING="年は、決して大上げ疑なし、六月より油斷なく買入る可し。八、九、十、十一月天井出づべし、其後" />
  <LINE TYPE="本文" X="478" Y="310" WIDTH="35" HEIGHT="1011" CONF="0.873" ORDER="44" STRING="三四十俵下にて持合ふ内、三月正月十一月甲に廻る故、此時、又五六十俵上有り疑なし、秋春往來に" />
  <LINE TYPE="本文" X="439" Y="314" WIDTH="22" HEIGHT="124" CONF="0.860" ORDER="45" STRING="儲くる年也。" />
  <LINE TYPE="本文" X="393" Y="332" WIDTH="33" HEIGHT="987" CONF="0.901" ORDER="46" STRING="(釋)前章に述べた、其月に對する十干を繰つて、七月甲に當る年を經驗して見るに、其年は、上" />
  <LINE TYPE="本文" X="349" Y="332" WIDTH="34" HEIGHT="991" CONF="0.881" ORDER="47" STRING="方筋關東筋共、何歟の天災が出て來て、七月から急上げになるとが多い様であるから、六月から油" />
  <LINE TYPE="本文" X="305" Y="330" WIDTH="35" HEIGHT="990" CONF="0.866" ORDER="48" STRING="斷なく買付けて置くがよい、天災が無い年でも、十二月頃迄には、百俵上位ゐはある者である。又、二" />
  <LINE TYPE="本文" X="275" Y="1111" WIDTH="20" HEIGHT="35" CONF="0.429" ORDER="49" STRING="二五" />
  </PAGE>

