<PAGE IMAGENAME="0057_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1744" Y="1084" WIDTH="23" HEIGHT="39" CONF="0.423" ORDER="0" STRING="八四" />
  <LINE TYPE="本文" X="1699" Y="313" WIDTH="32" HEIGHT="983" CONF="0.812" ORDER="1" STRING="され易い者であるが、自分は人氣に欺かれない樣に、百俵上げを標準にして、天井底の位取を知つ" />
  <LINE TYPE="本文" X="1654" Y="313" WIDTH="32" HEIGHT="989" CONF="0.839" ORDER="2" STRING="て、人気の反対に竇込み、又は買入るの處置を取る可きである。尚、參考として第四十二章を見る" />
  <LINE TYPE="本文" X="1611" Y="315" WIDTH="23" HEIGHT="80" CONF="0.780" ORDER="3" STRING="がよい。" />
  <LINE TYPE="本文" X="1526" Y="240" WIDTH="19" HEIGHT="23" CONF="0.391" ORDER="4" STRING="宗" />
  <LINE TYPE="本文" X="1493" Y="241" WIDTH="20" HEIGHT="22" CONF="0.428" ORDER="5" STRING="久" />
  <LINE TYPE="本文" X="1461" Y="242" WIDTH="19" HEIGHT="21" CONF="0.438" ORDER="6" STRING="翁" />
  <LINE TYPE="本文" X="1429" Y="243" WIDTH="19" HEIGHT="21" CONF="0.491" ORDER="7" STRING="相" />
  <LINE TYPE="本文" X="1397" Y="242" WIDTH="18" HEIGHT="21" CONF="0.402" ORDER="8" STRING="塲" />
  <LINE TYPE="本文" X="1365" Y="243" WIDTH="18" HEIGHT="20" CONF="0.368" ORDER="9" STRING="全" />
  <LINE TYPE="本文" X="1333" Y="244" WIDTH="18" HEIGHT="21" CONF="0.366" ORDER="10" STRING="集" />
<LINE TYPE="本文" X="1301" Y="247" WIDTH="17" HEIGHT="18" CONF="0.371" ORDER="11" STRING="上" />
  <LINE TYPE="本文" X="1268" Y="245" WIDTH="17" HEIGHT="20" CONF="0.395" ORDER="12" STRING="卷" />
  <LINE TYPE="本文" X="1542" Y="462" WIDTH="32" HEIGHT="423" CONF="0.874" ORDER="13" STRING="第六十二章底直段買重ねの事" />
  <LINE TYPE="本文" X="1481" Y="304" WIDTH="32" HEIGHT="998" CONF="0.863" ORDER="14" STRING="一底直段にて持合、上げかゝる米は、二三ケ月に急に天井直段出る也。其節、百俵上げ的にして買重" />
  <LINE TYPE="本文" X="1438" Y="296" WIDTH="22" HEIGHT="121" CONF="0.838" ORDER="15" STRING="ねて善き也。" />
  <LINE TYPE="本文" X="1395" Y="311" WIDTH="32" HEIGHT="998" CONF="0.858" ORDER="16" STRING="(釋)永々底直段で、ウチリ〳〵保合つて、潜勢力を養つて居る時、何等かの動機が出て上げに變" />
  <LINE TYPE="本文" X="1350" Y="315" WIDTH="33" HEIGHT="990" CONF="0.871" ORDER="17" STRING="發した米は、二三ケ月も引續いて上げる者であるが、其時上の割合を考へ、百俵位は上る者として、一" />
  <LINE TYPE="本文" X="1308" Y="316" WIDTH="23" HEIGHT="142" CONF="0.845" ORDER="18" STRING="買重ねてよい。" />
  <LINE TYPE="本文" X="1266" Y="314" WIDTH="32" HEIGHT="994" CONF="0.852" ORDER="19" STRING="底保合と云者は、大底三十日間位の者であつて、通例は、四五十日間の内に、前の月の月節を抜い" />
  <LINE TYPE="本文" X="1221" Y="316" WIDTH="33" HEIGHT="991" CONF="0.860" ORDER="20" STRING="て上る者であるが、豊作年大高下の跡の長持合は、時として、百日位に亘るともあるから、注意す" />
  <LINE TYPE="本文" X="1176" Y="322" WIDTH="27" HEIGHT="77" CONF="0.777" ORDER="21" STRING="べしだ。" />
  <LINE TYPE="本文" X="1107" Y="471" WIDTH="36" HEIGHT="534" CONF="0.847" ORDER="22" STRING="第六十三章下相塲は上相塲と大違の事" />
  <LINE TYPE="本文" X="915" Y="286" WIDTH="40" HEIGHT="1009" CONF="0.883" ORDER="23" STRING="一下相塲は、百俵餘上げ天井直段入月より、五六ケ月も段々下る者也。上相塲とは、大違ひ也。米の" />
  <LINE TYPE="本文" X="870" Y="290" WIDTH="40" HEIGHT="1003" CONF="0.888" ORDER="24" STRING="通にて、月頭に上げ、又月末に下げ、毎月一俵方も上げ、又々月末に二俵方も下る者也。若し、一日" />
  <LINE TYPE="本文" X="827" Y="280" WIDTH="39" HEIGHT="1026" CONF="0.858" ORDER="25" STRING="より四日五日頃迄、一ト目二タ目潜る米は、通の内の買相塲也。併し、全體下の内の上なる故、當分" />
  <LINE TYPE="本文" X="782" Y="280" WIDTH="34" HEIGHT="569" CONF="0.894" ORDER="26" STRING="の事にて、過分の買入成兼る也其月中に齎返すべし。" />
  <LINE TYPE="本文" X="739" Y="294" WIDTH="35" HEIGHT="641" CONF="0.877" ORDER="27" STRING="本章は、下相塲の常勢と、其通ひとを説いた者である。" />
  <LINE TYPE="本文" X="698" Y="310" WIDTH="38" HEIGHT="988" CONF="0.893" ORDER="28" STRING="一體下相塲と云者は、通ひの上けが少い者で、多くは急激に下げる者で、そして、下相場の常とし" />
  <LINE TYPE="本文" X="655" Y="310" WIDTH="38" HEIGHT="994" CONF="0.899" ORDER="29" STRING="て、月頭に上げ月末に下げる者であるが、若し此徹を踏まずに、月の始めに意外の下げを見せる時" />
  <LINE TYPE="本文" X="611" Y="298" WIDTH="39" HEIGHT="1003" CONF="0.886" ORDER="30" STRING="は、一と通となる者であるから、宜しく、其押した處を買ふ可きである。果して月中には、一ト上" />
  <LINE TYPE="本文" X="569" Y="311" WIDTH="37" HEIGHT="959" CONF="0.886" ORDER="31" STRING="げする者だ。併し、是は下の内の通上けて、眞正の伸上でないから、玉を少く仕掛けるがよい。" />
  <LINE TYPE="本文" X="499" Y="455" WIDTH="38" HEIGHT="660" CONF="0.877" ORDER="32" STRING="第六十四章米は天性自然の理算用に及ばざる事" />
  <LINE TYPE="本文" X="438" Y="302" WIDTH="37" HEIGHT="1003" CONF="0.888" ORDER="33" STRING="一上方相塲引合せ、乘米多少の考を以て賣買致時は、相塲にさからひ、過ち有之也。米は、天性自然" />
  <LINE TYPE="本文" X="392" Y="296" WIDTH="41" HEIGHT="1010" CONF="0.864" ORDER="34" STRING="の道理にて高下する者故、算用に不及也。極意は、天井底の次第を心得、毎日の相塲に氣を付べき事。" />
  <LINE TYPE="本文" X="350" Y="292" WIDTH="24" HEIGHT="77" CONF="0.822" ORDER="35" STRING="肝要也。" />
  <LINE TYPE="本文" X="306" Y="308" WIDTH="39" HEIGHT="987" CONF="0.801" ORDER="36" STRING="其時の相場が、天井の位置が、底直の位置かと云事を度外に置き、唯々各地に對して算盤が" />
  <LINE TYPE="本文" X="279" Y="1085" WIDTH="21" HEIGHT="39" CONF="0.531" ORDER="37" STRING="八五" />
  </PAGE>

</OCRDATASET>