<PAGE IMAGENAME="0084_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1816" Y="1127" WIDTH="20" HEIGHT="48" CONF="0.460" ORDER="0" STRING="一三八" />
  <LINE TYPE="本文" X="1771" Y="324" WIDTH="29" HEIGHT="1025" CONF="0.823" ORDER="1" STRING="得べし。今日より外に。商場なしと進立候時、二三日四五日、米の通ひを得と考へ仕掛くべし。秋冬" />
  <LINE TYPE="本文" X="1730" Y="317" WIDTH="27" HEIGHT="681" CONF="0.790" ORDER="2" STRING="共、底直段出ざる内は、幾月も見合せ、丈夫なる時、仕掛く可し。" />
  <LINE TYPE="本文" X="1685" Y="333" WIDTH="30" HEIGHT="930" CONF="0.864" ORDER="3" STRING="本章は、上巻第一章の異本である。意味は、第一章の註釋を見て、悟るべきである。" />
  <LINE TYPE="本文" X="1597" Y="277" WIDTH="17" HEIGHT="20" CONF="0.465" ORDER="4" STRING="宗" />
  <LINE TYPE="本文" X="1565" Y="278" WIDTH="16" HEIGHT="18" CONF="0.487" ORDER="5" STRING="久" />
  <LINE TYPE="本文" X="1501" Y="278" WIDTH="15" HEIGHT="17" CONF="0.442" ORDER="6" STRING="相" />
  <LINE TYPE="本文" X="1533" Y="278" WIDTH="16" HEIGHT="18" CONF="0.498" ORDER="7" STRING="翁" />
  <LINE TYPE="本文" X="1468" Y="278" WIDTH="16" HEIGHT="18" CONF="0.365" ORDER="8" STRING="塲" />
  <LINE TYPE="本文" X="1436" Y="279" WIDTH="16" HEIGHT="17" CONF="0.432" ORDER="9" STRING="全" />
  <LINE TYPE="本文" X="1404" Y="278" WIDTH="16" HEIGHT="18" CONF="0.418" ORDER="10" STRING="集" />
  <LINE TYPE="本文" X="1372" Y="277" WIDTH="15" HEIGHT="18" CONF="0.347" ORDER="11" STRING="下" />
  <LINE TYPE="本文" X="1340" Y="278" WIDTH="14" HEIGHT="18" CONF="0.343" ORDER="12" STRING="卷" />
  <LINE TYPE="本文" X="1616" Y="496" WIDTH="30" HEIGHT="448" CONF="0.832" ORDER="13" STRING="第五十四章商利運の時心得の事" />
  <LINE TYPE="本文" X="1553" Y="327" WIDTH="29" HEIGHT="1029" CONF="0.850" ORDER="14" STRING="一商利運に向ふ時、勝に乘るべからず。百俵上げ近き時は、唯無難に取留る事を工夫す可し。必らず" />
  <LINE TYPE="本文" X="1511" Y="327" WIDTH="25" HEIGHT="580" CONF="0.862" ORDER="15" STRING="強慾を思はず、無難に手取して、商仕舞、休むと第一也。" />
  <LINE TYPE="本文" X="1468" Y="337" WIDTH="24" HEIGHT="429" CONF="0.861" ORDER="16" STRING="註解を俟たずして意味明瞭である。" />
  <LINE TYPE="本文" X="1397" Y="501" WIDTH="30" HEIGHT="444" CONF="0.872" ORDER="17" STRING="第五十五章底直段を見極むる事" />
  <LINE TYPE="本文" X="1332" Y="338" WIDTH="30" HEIGHT="993" CONF="0.854" ORDER="18" STRING="一底直段を見極め買出す時は、其間の高下に迷ふとなく、立派を極め、自俵上前迄、片買と心得べし。" />
  <LINE TYPE="本文" X="1289" Y="343" WIDTH="31" HEIGHT="990" CONF="0.872" ORDER="19" STRING="(釋)底直段を買入れたる時は、其間の通ひの下げに迷はないで、百俵位上る迄は、買主義一方に" />
  <LINE TYPE="本文" X="1246" Y="343" WIDTH="29" HEIGHT="983" CONF="0.819" ORDER="20" STRING="心得るがよい。天井を見るは、百俵上げを的とせよと云ふとは、前の各章に繰返べし説て置た。尚、" />
  <LINE TYPE="本文" X="1204" Y="350" WIDTH="23" HEIGHT="289" CONF="0.863" ORDER="21" STRING="上卷第三十四章を參照せよ。" />
  <LINE TYPE="本文" X="955" Y="506" WIDTH="33" HEIGHT="504" CONF="0.842" ORDER="22" STRING="第五十六章我一分の了簡立て間敷事" />
  <LINE TYPE="本文" X="894" Y="331" WIDTH="31" HEIGHT="1010" CONF="0.751" ORDER="23" STRING="一我一分の了簡にて商す可からず。年中、三位の傳に引合せ、上るか下るかを得と考へ、前廣より、" />
  <LINE TYPE="本文" X="850" Y="332" WIDTH="24" HEIGHT="312" CONF="0.905" ORDER="24" STRING="段々見合せ、仕掛け置くべし。" />
  <LINE TYPE="本文" X="809" Y="379" WIDTH="22" HEIGHT="215" CONF="0.809" ORDER="25" STRING="買方、八分の利なり。" />
  <LINE TYPE="本文" X="764" Y="379" WIDTH="25" HEIGHT="222" CONF="0.874" ORDER="26" STRING="賣方、二分の利なり。" />
  <LINE TYPE="本文" X="721" Y="359" WIDTH="34" HEIGHT="996" CONF="0.881" ORDER="27" STRING="我意に任せて、商内を仕かける時は、動もすれば、其時の相塲の相塲の位取を忘れ、人氣に欺かれ" />
  <LINE TYPE="本文" X="677" Y="359" WIDTH="34" HEIGHT="990" CONF="0.867" ORDER="28" STRING="て天井を買重ね、又は底を賣り易い者である。故に、本書を精く讀んで、上下の月數俵數等を繰り" />
  <LINE TYPE="本文" X="633" Y="362" WIDTH="35" HEIGHT="989" CONF="0.887" ORDER="29" STRING="合せ、然る後ち、虚心平氣、相塲の一體、上か下かと云ふ事を見極め、急に見込を立てずに、前方" />
  <LINE TYPE="本文" X="590" Y="361" WIDTH="35" HEIGHT="1002" CONF="0.865" ORDER="30" STRING="から、克々見合せ、我胸に引合た時に商内を仕かく可きである。前廣と云ふ言には、數ケ月後の高" />
  <LINE TYPE="本文" X="545" Y="364" WIDTH="28" HEIGHT="375" CONF="0.869" ORDER="31" STRING="下をも透察するの意味を含んで居る。" />
  <LINE TYPE="本文" X="475" Y="513" WIDTH="37" HEIGHT="482" CONF="0.840" ORDER="32" STRING="第五十七章月々干支上げ下げの事" />
  <LINE TYPE="本文" X="412" Y="349" WIDTH="29" HEIGHT="328" CONF="0.826" ORDER="33" STRING="一甲、乙、丙、丁、上げとす。" />
  <LINE TYPE="本文" X="371" Y="348" WIDTH="28" HEIGHT="418" CONF="0.823" ORDER="34" STRING="一戊、己、庚、辛、壬、癸、下げとす、" />
  <LINE TYPE="本文" X="343" Y="1148" WIDTH="22" HEIGHT="54" CONF="0.520" ORDER="35" STRING="一三九" />
  <LINE TYPE="本文" X="247" Y="118" WIDTH="38" HEIGHT="1376" CONF="0.335" ORDER="37" STRING="したものは" />
  </PAGE>

