  <LINE TYPE="本文" X="1547" Y="258" WIDTH="15" HEIGHT="21" CONF="0.512" ORDER="0" STRING="宗" />
  <LINE TYPE="本文" X="1515" Y="259" WIDTH="14" HEIGHT="20" CONF="0.480" ORDER="1" STRING="久" />
  <LINE TYPE="本文" X="1482" Y="256" WIDTH="17" HEIGHT="22" CONF="0.443" ORDER="2" STRING="翁" />
  <LINE TYPE="本文" X="1448" Y="255" WIDTH="18" HEIGHT="22" CONF="0.427" ORDER="3" STRING="相" />
  <LINE TYPE="本文" X="1417" Y="254" WIDTH="17" HEIGHT="23" CONF="0.422" ORDER="4" STRING="場" />
  <LINE TYPE="本文" X="1383" Y="254" WIDTH="18" HEIGHT="22" CONF="0.388" ORDER="5" STRING="全" />
  <LINE TYPE="本文" X="1350" Y="253" WIDTH="18" HEIGHT="23" CONF="0.408" ORDER="6" STRING="集" />
  <LINE TYPE="本文" X="1320" Y="253" WIDTH="15" HEIGHT="19" CONF="0.376" ORDER="7" STRING="下" />
  <LINE TYPE="本文" X="1286" Y="248" WIDTH="16" HEIGHT="24" CONF="0.375" ORDER="8" STRING="卷" />
  <LINE TYPE="本文" X="1755" Y="1111" WIDTH="23" HEIGHT="55" CONF="0.410" ORDER="9" STRING="一一" />
  <LINE TYPE="本文" X="1713" Y="319" WIDTH="32" HEIGHT="998" CONF="0.773" ORDER="10" STRING="者也。其故は、強氣の味方には、風雨、旱魃、虫付、洪水等の天災、時變、船間等あり。弱氣の味方は、天保" />
  <LINE TYPE="本文" X="1669" Y="330" WIDTH="32" HEIGHT="986" CONF="0.892" ORDER="11" STRING="の適順、入米の外には、一の材料あるとなきを以てなりと説明したが。又本節同樣の意味合である。" />
  <LINE TYPE="本文" X="1625" Y="329" WIDTH="32" HEIGHT="990" CONF="0.904" ORDER="12" STRING="但し書は酒田米会所の商習慣として、賣方が其仕掛た月の内に手仕廻をしないで、其次の月に商内" />
  <LINE TYPE="本文" X="1582" Y="320" WIDTH="34" HEIGHT="1009" CONF="0.912" ORDER="13" STRING="を持越す時は、其月数に應じ、差引勘定の時になつて、其相手方たる買方から賣方に向つて、利足" />
  <LINE TYPE="本文" X="1538" Y="327" WIDTH="33" HEIGHT="988" CONF="0.891" ORDER="14" STRING="として一ケ月に何程づゝかを仕拂はねばならぬとは、已に首卷に説いて置た通りてあつて、賣方は、" />
  <LINE TYPE="本文" X="1496" Y="328" WIDTH="32" HEIGHT="980" CONF="0.909" ORDER="15" STRING="買方から利足を取つた上に、利がのる時は、甚だ都合のよい樣なものゝ、萬一作難等が出る時は、" />
  <LINE TYPE="本文" X="1452" Y="319" WIDTH="32" HEIGHT="999" CONF="0.903" ORDER="16" STRING="急上げとなつて、買埋方が後れて損となり易い者だ。之に反して、買方は、利足の仕拂方で、甚だ" />
  <LINE TYPE="本文" X="1409" Y="323" WIDTH="32" HEIGHT="996" CONF="0.867" ORDER="17" STRING="割の惡い様だが、呼吸にかゝる時は、大上げする者だから、利足の如きは利盆金に比ぶれば、ほん" />
  <LINE TYPE="本文" X="1366" Y="326" WIDTH="32" HEIGHT="992" CONF="0.894" ORDER="18" STRING="の九牛が一毛で、少しも苦にならない者である。特に秋になつては、ヤレ鎌入不足だの、譽め過ぎ" />
  <LINE TYPE="本文" X="1324" Y="327" WIDTH="32" HEIGHT="985" CONF="0.899" ORDER="19" STRING="だの、秋上不良だの、何の彼のと、相塲は上勝の者であるから、賣方となつては、割の惡い者であ" />
  <LINE TYPE="本文" X="1280" Y="320" WIDTH="32" HEIGHT="990" CONF="0.881" ORDER="20" STRING="る。其外に、割の悪い理由を云へば、受渡の時に、買方は金の準備計りをすればよいが、賣方は、" />
  <LINE TYPE="本文" X="1238" Y="314" WIDTH="28" HEIGHT="755" CONF="0.894" ORDER="21" STRING="資金を用意した上に、米を集めて渡さなければならぬと云ふ手數がある。" />
  <LINE TYPE="本文" X="1169" Y="472" WIDTH="32" HEIGHT="467" CONF="0.837" ORDER="22" STRING="第十五章豊年に米売り不可申事" />
  <LINE TYPE="本文" X="1111" Y="302" WIDTH="24" HEIGHT="334" CONF="0.876" ORDER="23" STRING="一豊年に、米賣るなと云事あり。一" />
  <LINE TYPE="本文" X="750" Y="256" WIDTH="16" HEIGHT="21" CONF="0.392" ORDER="24" STRING="第" />
  <LINE TYPE="本文" X="730" Y="257" WIDTH="14" HEIGHT="20" CONF="0.391" ORDER="25" STRING="十" />
  <LINE TYPE="本文" X="708" Y="256" WIDTH="15" HEIGHT="22" CONF="0.406" ORDER="26" STRING="六" />
  <LINE TYPE="本文" X="685" Y="257" WIDTH="16" HEIGHT="20" CONF="0.393" ORDER="27" STRING="章" />
  <LINE TYPE="本文" X="665" Y="257" WIDTH="14" HEIGHT="20" CONF="0.401" ORDER="28" STRING="凶" />
  <LINE TYPE="本文" X="644" Y="256" WIDTH="15" HEIGHT="22" CONF="0.355" ORDER="29" STRING="年" />
  <LINE TYPE="本文" X="927" Y="301" WIDTH="32" HEIGHT="1025" CONF="0.821" ORDER="30" STRING="但し、豊年故人気弱く、相塲見越し安き也。日本中、上作稀也。何れの國か欠作出る故、九十月より" />
  <LINE TYPE="本文" X="882" Y="300" WIDTH="30" HEIGHT="707" CONF="0.837" ORDER="31" STRING="大阪上げ來る可し。又豊年と諸方へ聞ゆる故、冬中買人も來る可し。" />
  <LINE TYPE="本文" X="838" Y="325" WIDTH="33" HEIGHT="989" CONF="0.908" ORDER="32" STRING="(釋)本章は豊年となる樣な年は順氣が順々に善くなるから、相塲も豐作を見越して、段々下がれ" />
  <LINE TYPE="本文" X="796" Y="327" WIDTH="33" HEIGHT="985" CONF="0.899" ORDER="33" STRING="る迄は引下げて居て、豊年と保險の付いた時分には、已に相塲は底を極めて居る者である。併し、" />
  <LINE TYPE="本文" X="752" Y="317" WIDTH="34" HEIGHT="1001" CONF="0.881" ORDER="34" STRING="日本中、揃て上作と云ふとは極稀で、何れの国かに、作柄の故障が出る者であるから夫等を動機と" />
  <LINE TYPE="本文" X="709" Y="328" WIDTH="31" HEIGHT="841" CONF="0.854" ORDER="35" STRING="して、相塲は引返す者である。是れが、即ち豐年に米を賣るなと云ふ訓戒の理由だ。" />
  <LINE TYPE="本文" X="639" Y="477" WIDTH="32" HEIGHT="434" CONF="0.831" ORDER="36" STRING="第十六章凶年に米買不可申事" />
  <LINE TYPE="本文" X="600" Y="258" WIDTH="15" HEIGHT="20" CONF="0.391" ORDER="37" STRING="米" />
  <LINE TYPE="本文" X="579" Y="258" WIDTH="16" HEIGHT="21" CONF="0.387" ORDER="38" STRING="買" />
  <LINE TYPE="本文" X="557" Y="258" WIDTH="15" HEIGHT="19" CONF="0.402" ORDER="39" STRING="不" />
  <LINE TYPE="本文" X="537" Y="258" WIDTH="14" HEIGHT="20" CONF="0.395" ORDER="40" STRING="可" />
  <LINE TYPE="本文" X="515" Y="256" WIDTH="15" HEIGHT="22" CONF="0.377" ORDER="41" STRING="申" />
  <LINE TYPE="本文" X="491" Y="257" WIDTH="15" HEIGHT="21" CONF="0.421" ORDER="42" STRING="事" />
  <LINE TYPE="本文" X="579" Y="313" WIDTH="24" HEIGHT="327" CONF="0.867" ORDER="43" STRING="一凶年に米買ふなと云ふとあり。" />
  <LINE TYPE="本文" X="533" Y="303" WIDTH="33" HEIGHT="1020" CONF="0.870" ORDER="44" STRING="但し、凶年故見越し高直に商出て、其上、地方他所の商人共思入多く、其外、町在共に無用の米も買" />
  <LINE TYPE="本文" X="490" Y="307" WIDTH="33" HEIGHT="1016" CONF="0.871" ORDER="45" STRING="取、札納旁々、作割よりも、七八九十月迄に上詰る、其上人氣張詰め夏中迄に持詰る故、極意は下る" />
  <LINE TYPE="本文" X="447" Y="310" WIDTH="24" HEIGHT="169" CONF="0.819" ORDER="46" STRING="なり、心得べし。" />
  <LINE TYPE="本文" X="403" Y="323" WIDTH="34" HEIGHT="998" CONF="0.881" ORDER="47" STRING="本章は、凶作の場合は、前章の説明と反對で、凶年であるから、相場は割高を叩く、割高の" />
  <LINE TYPE="本文" X="361" Y="327" WIDTH="32" HEIGHT="997" CONF="0.880" ORDER="48" STRING="相場は、詰り下るに極まつて居るから、其上詰めた處は、大に警戒して買てはならぬと云ふのであ" />
  <LINE TYPE="本文" X="323" Y="331" WIDTH="20" HEIGHT="51" CONF="0.331" ORDER="49" STRING="る。" />
<LINE TYPE="本文" X="320" Y="334" WIDTH="19" HEIGHT="32" CONF="0.494" ORDER="50" STRING="る。" />
  <LINE TYPE="本文" X="285" Y="1109" WIDTH="20" HEIGHT="48" CONF="0.438" ORDER="52" STRING="二一" />
