  <LINE TYPE="本文" X="1786" Y="76" WIDTH="32" HEIGHT="1376" CONF="0.340" ORDER="1" STRING="}" />
  <LINE TYPE="本文" X="1782" Y="115" WIDTH="26" HEIGHT="1225" CONF="0.314" ORDER="2" STRING="同一一一一、、、、、、一、、七七一、一一一一、一七、七一、一九、、、、一一、一一一一一、一九一一、一九二" />
  <LINE TYPE="本文" X="1735" Y="1114" WIDTH="21" HEIGHT="38" CONF="0.465" ORDER="3" STRING="六八" />
  <LINE TYPE="本文" X="1687" Y="340" WIDTH="32" HEIGHT="984" CONF="0.865" ORDER="4" STRING="少によらず必ず上げる者であるから、買方に付くが宜い。是等の説明は、已に前章に説いて置たか" />
  <LINE TYPE="本文" X="1643" Y="340" WIDTH="32" HEIGHT="990" CONF="0.869" ORDER="5" STRING="ら、累々しく説かない。亦、天井直段後下相塲のとは、是又前章の三位と云ふ處に細かく説て置た" />
  <LINE TYPE="本文" X="1599" Y="340" WIDTH="26" HEIGHT="257" CONF="0.867" ORDER="6" STRING="から、其處を見るがよい。" />
  <LINE TYPE="本文" X="1530" Y="484" WIDTH="32" HEIGHT="539" CONF="0.861" ORDER="7" STRING="第四十九章夏中冷数時は油断ならぬ事" />
  <LINE TYPE="本文" X="1469" Y="319" WIDTH="31" HEIGHT="1013" CONF="0.876" ORDER="8" STRING="一夏中、時候惡しく雨勝の年は、自然の不作と心得べし。夏中冷氣強く、虫付洪水大風等天災有之時、" />
  <LINE TYPE="本文" X="1426" Y="317" WIDTH="32" HEIGHT="1011" CONF="0.876" ORDER="9" STRING="油断なく六七月より相場安き内買入るべし。六七月、順気能く旱續き、上作の取沙汰、一分の見聞" />
  <LINE TYPE="本文" X="1383" Y="317" WIDTH="32" HEIGHT="1003" CONF="0.894" ORDER="10" STRING="にも上作と見ゆる年は、買急がず、八九月專ら年の貿塲也。月頭〳〵に買ふべし。但し、九月は少々" />
  <LINE TYPE="本文" X="1340" Y="318" WIDTH="31" HEIGHT="998" CONF="0.881" ORDER="11" STRING="遲るゝ方也、八月專らにすべし。上作年にても、年々九十月より上る者也。又六月末七月中旬迄も、" />
  <LINE TYPE="本文" X="1297" Y="319" WIDTH="31" HEIGHT="1006" CONF="0.868" ORDER="12" STRING="何十年にもなき上作と沙汰し候共、何等のと出來て、多少に限らず違作になる者也、少しも申分なく" />
  <LINE TYPE="本文" X="1255" Y="315" WIDTH="25" HEIGHT="332" CONF="0.820" ORDER="13" STRING="取收るとは、極々稀也考ふべし。" />
  <LINE TYPE="本文" X="1211" Y="331" WIDTH="31" HEIGHT="993" CONF="0.877" ORDER="14" STRING="(釋)本章は、新商に對する買惑に付ての注意で、云ふ心は、氣候が不順で、不作の見越し十分" />
  <LINE TYPE="本文" X="1167" Y="326" WIDTH="32" HEIGHT="1010" CONF="0.899" ORDER="15" STRING="に立つた時は、六七月より買思惑するも善いが、順気のよい年は、七月中より八月に、順気要めの" />
  <LINE TYPE="本文" X="1124" Y="342" WIDTH="32" HEIGHT="982" CONF="0.883" ORDER="16" STRING="人氣下げ等もあらうから、そんなに買急がないて、其人氣のダラ〳〵になつたドン底を買ねらふがよ" />
  <LINE TYPE="本文" X="1079" Y="331" WIDTH="33" HEIGHT="1003" CONF="0.858" ORDER="17" STRING="い。月頭は、補安旁安直となることが多いから、其處を買ふが宜しい。買塲は、多く八月中に出る" />
  <LINE TYPE="本文" X="877" Y="335" WIDTH="38" HEIGHT="999" CONF="0.894" ORDER="18" STRING="一者である。如何んな上作年でも、年々九十月頃から上る者て、六月末から七月中は頃迄も、何十年" />
  <LINE TYPE="本文" X="832" Y="335" WIDTH="38" HEIGHT="998" CONF="0.894" ORDER="19" STRING="間にもない上作を唱へても、其後何かの天災が出て、多少に因らず違作になり、相塲も夫れに連れ" />
  <LINE TYPE="本文" X="788" Y="330" WIDTH="36" HEIGHT="916" CONF="0.878" ORDER="20" STRING="て上る者で、少しも故障なく收穫迄通すことは、極々稀である、能く考へ計るが宜しい。" />
  <LINE TYPE="本文" X="636" Y="278" WIDTH="15" HEIGHT="18" CONF="0.334" ORDER="21" STRING="寧" />
  <LINE TYPE="本文" X="680" Y="277" WIDTH="15" HEIGHT="19" CONF="0.317" ORDER="22" STRING="五" />
  <LINE TYPE="本文" X="719" Y="494" WIDTH="36" HEIGHT="424" CONF="0.864" ORDER="23" STRING="第五十章諸方上作年心得の事" />
  <LINE TYPE="本文" X="658" Y="328" WIDTH="35" HEIGHT="1006" CONF="0.875" ORDER="24" STRING="一當地近國も上作、上方も大方上作にて、三四五月迄底直段出でざる時は、其后底直段出ると心得べ" />
  <LINE TYPE="本文" X="618" Y="326" WIDTH="22" HEIGHT="39" CONF="0.546" ORDER="25" STRING="し。" />
  <LINE TYPE="本文" X="573" Y="327" WIDTH="36" HEIGHT="1011" CONF="0.882" ORDER="26" STRING="右、當地最上右作合の年は、四月中の日の頃賣崩しあると云ふ、相違なし、三月三位に當るとも、享" />
  <LINE TYPE="本文" X="530" Y="326" WIDTH="35" HEIGHT="1012" CONF="0.883" ORDER="27" STRING="和二酉年四月、二十俵方崩し有りし也。近國當地上作の年は、決して一番過ざる内は、夏米の思入立" />
  <LINE TYPE="本文" X="485" Y="329" WIDTH="30" HEIGHT="460" CONF="0.838" ORDER="28" STRING="つ可からず、尤四五月崩の節買入心掛く可し。" />
  <LINE TYPE="本文" X="443" Y="332" WIDTH="37" HEIGHT="1004" CONF="0.893" ORDER="29" STRING="自地及近國共上作であつて、可なりの下げあつても、何かの事情に制されて、相場釣合上高直" />
  <LINE TYPE="本文" X="399" Y="343" WIDTH="36" HEIGHT="995" CONF="0.876" ORDER="30" STRING="保合で、底らしき底を出さない事ある者だが、相場は、三四五月の間に、一ト崩れして、底直らし" />
  <LINE TYPE="本文" X="356" Y="347" WIDTH="31" HEIGHT="568" CONF="0.760" ORDER="31" STRING="い底を造る者である。享和二年の如きも其一例である。" />
  <LINE TYPE="本文" X="313" Y="345" WIDTH="35" HEIGHT="986" CONF="0.880" ORDER="33" STRING="自地及近國共上作年には、一番草取の時季を過ぎない内は、夏米の思惑を立て可からざる者である。" />
  <LINE TYPE="本文" X="269" Y="346" WIDTH="29" HEIGHT="380" CONF="0.880" ORDER="34" STRING="専ら四五月の崩落を買ねらふがよい。" />
  <LINE TYPE="本文" X="240" Y="1118" WIDTH="20" HEIGHT="45" CONF="0.544" ORDER="35" STRING="十九" />
  </PAGE>

