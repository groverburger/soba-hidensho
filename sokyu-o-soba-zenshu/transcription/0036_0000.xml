<PAGE IMAGENAME="0036_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1736" Y="1119" WIDTH="21" HEIGHT="37" CONF="0.455" ORDER="0" STRING="四二" />
  <LINE TYPE="本文" X="1693" Y="324" WIDTH="34" HEIGHT="1001" CONF="0.840" ORDER="1" STRING="を考ふると、第一也。但し、大高下もなく、底にて保合ひ自然と起き上る米は、賣らざる者也。段々" />
  <LINE TYPE="本文" X="1655" Y="317" WIDTH="31" HEIGHT="604" CONF="0.850" ORDER="2" STRING="買重ぬる者也。是は、通相塲には無之、自然と起き相塲也。" />
  <LINE TYPE="本文" X="1606" Y="334" WIDTH="36" HEIGHT="995" CONF="0.869" ORDER="3" STRING="此章は、天井直段後の、通相塲に對する、賣付の心得を説いた者で、文意は、註釋によらなく" />
  <LINE TYPE="本文" X="1576" Y="343" WIDTH="23" HEIGHT="173" CONF="0.847" ORDER="4" STRING="とも明瞭である。" />
  <LINE TYPE="本文" X="1520" Y="338" WIDTH="36" HEIGHT="992" CONF="0.867" ORDER="5" STRING="天井後の通上げは、数ケ月間賣方もよいが、天井底の月数、日數、直数とを推し考へて、餘り深入り" />
  <LINE TYPE="本文" X="1477" Y="344" WIDTH="35" HEIGHT="981" CONF="0.894" ORDER="6" STRING="をしてはならぬ。特に、底を極めて自然と起き上る相塲も、時に因ると、通ひ相塲と誤解するとも" />
  <LINE TYPE="本文" X="1434" Y="341" WIDTH="35" HEIGHT="984" CONF="0.888" ORDER="7" STRING="ある者だが、此大高下もなく、自然と起き上る相塲には、决して賣つてはならない、却つて買重ぬ" />
  <LINE TYPE="本文" X="1403" Y="344" WIDTH="24" HEIGHT="146" CONF="0.809" ORDER="8" STRING="べき者である。" />
  <LINE TYPE="本文" X="1340" Y="267" WIDTH="15" HEIGHT="19" CONF="0.301" ORDER="9" STRING="集" />
<LINE TYPE="本文" X="1326" Y="485" WIDTH="33" HEIGHT="424" CONF="0.864" ORDER="10" STRING="第三十章持合後売買秘傳の事" />
  <LINE TYPE="本文" X="1276" Y="266" WIDTH="15" HEIGHT="17" CONF="0.339" ORDER="11" STRING="卷" />
  <LINE TYPE="本文" X="1259" Y="303" WIDTH="38" HEIGHT="1034" CONF="0.887" ORDER="12" STRING="一右持合の時、少々下げ目に成時、此米下相塲と皆々思ひ付、兼て賣方の人は圖に當ると心得、猶々" />
  <LINE TYPE="本文" X="1216" Y="313" WIDTH="36" HEIGHT="1012" CONF="0.882" ORDER="13" STRING="賣込み、買方の人も、扨こそと賣逃げ、却つて賣過致す心になり、我先〳〵と賣込み候故、猶々下る" />
  <LINE TYPE="本文" X="1172" Y="315" WIDTH="36" HEIGHT="1014" CONF="0.863" ORDER="14" STRING="也、此時買ふべし、極めて利運也。甚だ買惡き者なれども、買ふべき也。數年の者も、後悔多し、通一" />
  <LINE TYPE="本文" X="1136" Y="310" WIDTH="30" HEIGHT="514" CONF="0.825" ORDER="15" STRING="の商は、十俵高下を的にし手早に見切ると第一也。" />
  <LINE TYPE="本文" X="1128" Y="1015" WIDTH="16" HEIGHT="98" CONF="0.312" ORDER="16" STRING="一同二十一日" />
  <LINE TYPE="本文" X="1084" Y="327" WIDTH="39" HEIGHT="1005" CONF="0.839" ORDER="17" STRING="前章に説ける、天井直段後の腰掛け持合相塲の時、少々でも相塲下げ目となる時には、飛人" />
  <LINE TYPE="本文" X="914" Y="333" WIDTH="36" HEIGHT="992" CONF="0.878" ORDER="18" STRING="の意向も、皆下げ相塲と心付き、其上賣方の人は、我御世になつたとて、圖に乘つて賣叩く計りては" />
  <LINE TYPE="本文" X="871" Y="338" WIDTH="38" HEIGHT="985" CONF="0.900" ORDER="19" STRING="なく買方の人も先を爭つて賣逃げ却つて賣過する心になるから、猶々下る者であるが、斯る塲合は" />
  <LINE TYPE="本文" X="827" Y="335" WIDTH="38" HEIGHT="991" CONF="0.886" ORDER="20" STRING="買ふべしてある。甚だ買惡い者で、黒人でも、中々買へない者だが、買へば必らず勝利である。併" />
  <LINE TYPE="本文" X="782" Y="339" WIDTH="38" HEIGHT="987" CONF="0.885" ORDER="21" STRING="し、通の高下と云ふ者は、大抵十俵位の標準の者であるから、見計らひ、機敏に利喰すべきである。" />
  <LINE TYPE="本文" X="714" Y="483" WIDTH="37" HEIGHT="522" CONF="0.871" ORDER="22" STRING="第三十一章可買入見合候時心得の事" />
  <LINE TYPE="本文" X="653" Y="324" WIDTH="35" HEIGHT="1011" CONF="0.882" ORDER="23" STRING="一米買ふ可しと見込候時、二俵方も引上る時は、買後れしと心得、却つて賣方になる事あり。甚だ誤" />
  <LINE TYPE="本文" X="608" Y="320" WIDTH="30" HEIGHT="422" CONF="0.873" ORDER="24" STRING="り也。買後るゝ時は、唯買塲を待つべし。" />
  <LINE TYPE="本文" X="567" Y="333" WIDTH="36" HEIGHT="998" CONF="0.869" ORDER="25" STRING="(釋)相塲の見込みを立てるに、心得べきと二つある。一は智て、一は情てある。未來の見込を立" />
  <LINE TYPE="本文" X="522" Y="333" WIDTH="35" HEIGHT="860" CONF="0.867" ORDER="26" STRING="てるには、宜しく智の一方で決すべき者であつて、返す〳〵も情を混へてはならぬ。" />
  <LINE TYPE="本文" X="478" Y="327" WIDTH="38" HEIGHT="1019" CONF="0.874" ORDER="27" STRING="本章の場合に於ても又然りて、米を買はふと見込みを立てたのは、智であるが、躊躇して居る内に、" />
  <LINE TYPE="本文" X="435" Y="340" WIDTH="38" HEIGHT="991" CONF="0.905" ORDER="28" STRING="二俵方も上げられて買後れたとを悔んで、燒糞的に賣方に廻らふとする、是即ち、見込を立てるに" />
  <LINE TYPE="本文" X="392" Y="340" WIDTH="39" HEIGHT="993" CONF="0.899" ORDER="29" STRING="必要なる智を捨てゝ、何時も見込を誤らしめる因となる情を採るので、恰も、珠玉を捨てゝ糞土を" />
  <LINE TYPE="本文" X="347" Y="340" WIDTH="39" HEIGHT="994" CONF="0.857" ORDER="30" STRING="取る様な者である。既に買見込を立てた以上は、最初の見込通りに、通ひ下の買場即ち押目を待つ" />
  <LINE TYPE="本文" X="304" Y="347" WIDTH="25" HEIGHT="102" CONF="0.857" ORDER="31" STRING="が宜しい。" />
  <LINE TYPE="本文" X="277" Y="1117" WIDTH="21" HEIGHT="39" CONF="0.477" ORDER="32" STRING="四三" />
  </PAGE>

</OCRDATASET>