  <LINE TYPE="本文" X="1795" Y="90" WIDTH="28" HEIGHT="1208" CONF="0.407" ORDER="0" STRING="諸君の御用人の方には、その間には、其他の地域には、其の間には、其の事を以て、其の事を以て、其の事を以て、" />
  <LINE TYPE="本文" X="1794" Y="329" WIDTH="28" HEIGHT="1128" CONF="0.350" ORDER="1" STRING="名社社社組合、市場合理事業社共会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会社会会会社会" />
  <LINE TYPE="本文" X="1524" Y="260" WIDTH="16" HEIGHT="20" CONF="0.394" ORDER="2" STRING="宗" />
  <LINE TYPE="本文" X="1491" Y="260" WIDTH="17" HEIGHT="21" CONF="0.381" ORDER="3" STRING="久" />
  <LINE TYPE="本文" X="1459" Y="259" WIDTH="16" HEIGHT="22" CONF="0.407" ORDER="4" STRING="翁" />
  <LINE TYPE="本文" X="1426" Y="260" WIDTH="16" HEIGHT="21" CONF="0.413" ORDER="5" STRING="相" />
  <LINE TYPE="本文" X="1394" Y="260" WIDTH="17" HEIGHT="20" CONF="0.348" ORDER="6" STRING="場" />
  <LINE TYPE="本文" X="1361" Y="260" WIDTH="17" HEIGHT="21" CONF="0.305" ORDER="7" STRING="全" />
<LINE TYPE="本文" X="1328" Y="259" WIDTH="18" HEIGHT="22" CONF="0.318" ORDER="8" STRING="集" />
  <LINE TYPE="本文" X="1297" Y="261" WIDTH="17" HEIGHT="20" CONF="0.321" ORDER="9" STRING="上" />
  <LINE TYPE="本文" X="1264" Y="259" WIDTH="18" HEIGHT="21" CONF="0.322" ORDER="10" STRING="巻" />
  <LINE TYPE="本文" X="1697" Y="358" WIDTH="26" HEIGHT="324" CONF="0.876" ORDER="11" STRING="は、跡二ケ月位も上るべし云々。" />
  <LINE TYPE="本文" X="1653" Y="351" WIDTH="26" HEIGHT="513" CONF="0.878" ORDER="12" STRING="急に高下する相場は、天井底の日限定まらず云々、" />
  <LINE TYPE="本文" X="1734" Y="1107" WIDTH="20" HEIGHT="37" CONF="0.510" ORDER="13" STRING="五四" />
  <LINE TYPE="本文" X="1607" Y="333" WIDTH="28" HEIGHT="772" CONF="0.812" ORDER="14" STRING="と説いて居る。其處て、翁の説く處を總べ括つて見ると、左の數點に歸する。" />
  <LINE TYPE="本文" X="1549" Y="316" WIDTH="30" HEIGHT="40" CONF="0.349" ORDER="15" STRING="○" />
  <LINE TYPE="本文" X="1567" Y="444" WIDTH="23" HEIGHT="185" CONF="0.795" ORDER="16" STRING="月数常例" />
  <LINE TYPE="本文" X="1523" Y="355" WIDTH="25" HEIGHT="515" CONF="0.900" ORDER="17" STRING="一月數は三ヶ月以上、六ケ月を上下の極點とす。" />
  <LINE TYPE="本文" X="1479" Y="352" WIDTH="26" HEIGHT="471" CONF="0.880" ORDER="18" STRING="二時として、四ヶ月目より轉還することあり。" />
  <LINE TYPE="本文" X="1436" Y="443" WIDTH="24" HEIGHT="184" CONF="0.839" ORDER="19" STRING="同上異例" />
  <LINE TYPE="本文" X="1389" Y="354" WIDTH="28" HEIGHT="689" CONF="0.889" ORDER="20" STRING="一急に上下する米は、一二ヶ月にて天井を造り、亦底を極むると。" />
  <LINE TYPE="本文" X="1348" Y="352" WIDTH="26" HEIGHT="531" CONF="0.865" ORDER="21" STRING="二時として、稀には七八ヶ月に跨る天井底あると。" />
  <LINE TYPE="本文" X="1306" Y="443" WIDTH="23" HEIGHT="184" CONF="0.873" ORDER="22" STRING="高下直幅の常例" />
  <LINE TYPE="本文" X="1258" Y="352" WIDTH="28" HEIGHT="742" CONF="0.854" ORDER="23" STRING="一割合は、百俵内外の高下をなしたる時は、大抵天井底となる者とす。" />
  <LINE TYPE="本文" X="1217" Y="442" WIDTH="26" HEIGHT="189" CONF="0.802" ORDER="24" STRING="同上異例" />
  <LINE TYPE="本文" X="1169" Y="360" WIDTH="32" HEIGHT="966" CONF="0.859" ORDER="25" STRING="一四十五六俵五十俵位の大底より起き上る米は、少く違作となる時は、天井直段百俵上に限ら" />
  <LINE TYPE="本文" X="1124" Y="372" WIDTH="32" HEIGHT="952" CONF="0.862" ORDER="26" STRING="ず、時により百六十俵百八十俵位も上る者と心得べし。又、三十四五俵位底にて起き上る米は、" />
  <LINE TYPE="本文" X="1082" Y="371" WIDTH="30" HEIGHT="721" CONF="0.840" ORDER="27" STRING="作合も相応、又、他所と乗米有之候ても、百俵上げは天井と心得べし。" />
  <LINE TYPE="本文" X="728" Y="273" WIDTH="16" HEIGHT="21" CONF="0.397" ORDER="28" STRING="第" />
  <LINE TYPE="本文" X="679" Y="275" WIDTH="15" HEIGHT="19" CONF="0.341" ORDER="29" STRING="十" />
  <LINE TYPE="本文" X="631" Y="278" WIDTH="15" HEIGHT="18" CONF="0.338" ORDER="30" STRING="章・" />
  <LINE TYPE="本文" X="904" Y="345" WIDTH="40" HEIGHT="988" CONF="0.855" ORDER="31" STRING="と結論した。再び、翁の説に付て、天井と底との觀察法を、現今の價位に引直し、平易に其應用を" />
  <LINE TYPE="本文" X="859" Y="340" WIDTH="31" HEIGHT="407" CONF="0.869" ORDER="32" STRING="説けば、次の如くに解されるのである。" />
  <LINE TYPE="本文" X="818" Y="341" WIDTH="41" HEIGHT="998" CONF="0.841" ORDER="33" STRING="相塲三ケ月、(跨)、日數五十日以上、割合も一割五分内外も上げ詰めた米は、天井乃至天井近" />
  <LINE TYPE="本文" X="774" Y="386" WIDTH="28" HEIGHT="389" CONF="0.861" ORDER="34" STRING="い相塲であるから、買つてはならぬと" />
  <LINE TYPE="本文" X="730" Y="362" WIDTH="42" HEIGHT="972" CONF="0.854" ORDER="35" STRING="二相場三ヶ月以上、日数五十日に跨りて下げ、割合も最早一割五分以上、或は内外も下げ詰め" />
  <LINE TYPE="本文" X="686" Y="366" WIDTH="32" HEIGHT="517" CONF="0.827" ORDER="36" STRING="た米は、底間際であるから、賣つてはならぬと。" />
  <LINE TYPE="本文" X="641" Y="348" WIDTH="44" HEIGHT="992" CONF="0.861" ORDER="37" STRING="三急に、一ヶ月内乃至二ヶ月の間に、一割以上の高下した米は、天井となり又は底となるとが" />
  <LINE TYPE="本文" X="600" Y="397" WIDTH="22" HEIGHT="76" CONF="0.789" ORDER="38" STRING="あること。" />
  <LINE TYPE="本文" X="556" Y="368" WIDTH="34" HEIGHT="565" CONF="0.879" ORDER="39" STRING="四相塲の天井底の位置、及高下度數の大小を見ると。" />
  <LINE TYPE="本文" X="512" Y="354" WIDTH="42" HEIGHT="986" CONF="0.896" ORDER="40" STRING="併し以上に述べた、月數割合等は、翁の説を根據とした大體の論であるから、讀者、宜しく世間の" />
  <LINE TYPE="本文" X="471" Y="346" WIDTH="40" HEIGHT="1009" CONF="0.859" ORDER="41" STRING="景況と、人気の様子に因て、高下の割合を加減し、臨機應變に駈引をすべき者で、所謂、運用の妙一" />
  <LINE TYPE="本文" X="425" Y="350" WIDTH="30" HEIGHT="352" CONF="0.900" ORDER="42" STRING="は、読者の一心に存するのである。" />
  <LINE TYPE="本文" X="359" Y="506" WIDTH="34" HEIGHT="389" CONF="0.833" ORDER="43" STRING="第四十一章上げ留見様の事" />
  <LINE TYPE="本文" X="294" Y="336" WIDTH="37" HEIGHT="672" CONF="0.818" ORDER="44" STRING="一不作年に大高下出で、落引二度有之後は、上留近しと心得べし。" />
  <LINE TYPE="本文" X="273" Y="1131" WIDTH="19" HEIGHT="39" CONF="0.551" ORDER="45" STRING="五五" />
