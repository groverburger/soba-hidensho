  <LINE TYPE="本文" X="1806" Y="89" WIDTH="28" HEIGHT="1291" CONF="0.351" ORDER="0" STRING="・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・" />
  <LINE TYPE="本文" X="1753" Y="1091" WIDTH="22" HEIGHT="38" CONF="0.327" ORDER="1" STRING="九二" />
  <LINE TYPE="本文" X="1682" Y="467" WIDTH="33" HEIGHT="625" CONF="0.826" ORDER="2" STRING="第七十一章霜月前引上落引の米賣方無用の事" />
  <LINE TYPE="本文" X="1476" Y="243" WIDTH="19" HEIGHT="20" CONF="0.359" ORDER="3" STRING="編" />
  <LINE TYPE="本文" X="1445" Y="243" WIDTH="18" HEIGHT="21" CONF="0.408" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1414" Y="241" WIDTH="17" HEIGHT="22" CONF="0.363" ORDER="5" STRING="場" />
  <LINE TYPE="本文" X="1380" Y="242" WIDTH="18" HEIGHT="21" CONF="0.384" ORDER="6" STRING="全" />
  <LINE TYPE="本文" X="1347" Y="241" WIDTH="18" HEIGHT="24" CONF="0.331" ORDER="7" STRING="集" />
  <LINE TYPE="本文" X="1316" Y="243" WIDTH="18" HEIGHT="21" CONF="0.307" ORDER="8" STRING="上" />
<LINE TYPE="本文" X="1281" Y="241" WIDTH="19" HEIGHT="22" CONF="0.324" ORDER="9" STRING="巻" />
  <LINE TYPE="本文" X="1620" Y="290" WIDTH="33" HEIGHT="1012" CONF="0.844" ORDER="10" STRING="一霜月前、五六十俵上にて落引の米は、决して賣ると無用、百俵位にて落引の米は、賣方と心得べし。" />
  <LINE TYPE="本文" X="1578" Y="297" WIDTH="30" HEIGHT="755" CONF="0.862" ORDER="11" STRING="但し、春夏の米にて、乗米多き時は、百俵上にても、算用に背かざるべし。" />
  <LINE TYPE="本文" X="1535" Y="306" WIDTH="30" HEIGHT="1001" CONF="0.859" ORDER="12" STRING="霜月限、底から上げかゝる時は、無論百俵は、上る者だから、五六十俵の上では、利喰はし" />
  <LINE TYPE="本文" X="1491" Y="313" WIDTH="31" HEIGHT="989" CONF="0.865" ORDER="13" STRING="ない者である。百俵上ならば、天井の其標準直段であるから、利喰してもよいと思へ、併し、春か" />
  <LINE TYPE="本文" X="1448" Y="313" WIDTH="29" HEIGHT="980" CONF="0.864" ORDER="14" STRING="夏の相塲で各地と較べて十分に鞘が付いて居た塲合には、百俵の上けでも、天井は極らないから、" />
  <LINE TYPE="本文" X="1408" Y="316" WIDTH="25" HEIGHT="305" CONF="0.834" ORDER="15" STRING="其邊を能く心得て置くがよい。" />
  <LINE TYPE="本文" X="1335" Y="460" WIDTH="31" HEIGHT="392" CONF="0.846" ORDER="16" STRING="第七十二章通相塲用心の事" />
  <LINE TYPE="本文" X="1272" Y="294" WIDTH="30" HEIGHT="1003" CONF="0.874" ORDER="17" STRING="一通相塲抔にて四五百兩も賣付け置き、二十俵方も利分付候時、的へ當ると心得賣込むことあり、大" />
  <LINE TYPE="本文" X="1228" Y="293" WIDTH="32" HEIGHT="1002" CONF="0.874" ORDER="18" STRING="に心得違ひ也。通の高下は、一二俵の者に候得ば、十俵二十俵の高下、早く見切り取留る者也、賣買" />
  <LINE TYPE="本文" X="1190" Y="294" WIDTH="24" HEIGHT="235" CONF="0.820" ORDER="19" STRING="を浦山敷思ふ可からず。" />
  <LINE TYPE="本文" X="1141" Y="310" WIDTH="32" HEIGHT="987" CONF="0.862" ORDER="20" STRING="(釋)通相場と見込んて商内を仕掛けた時、例へば、二三十丁方も利が乗る時は、圖に乘つて欲心" />
  <LINE TYPE="本文" X="1098" Y="316" WIDTH="30" HEIGHT="978" CONF="0.862" ORDER="21" STRING="を起し、初め仕かけた時の見込を忘れて、賣乘せることある者だが、是は大に心得違て、一體通の" />
  <LINE TYPE="本文" X="908" Y="324" WIDTH="37" HEIGHT="990" CONF="0.870" ORDER="22" STRING="高下と云ふ者は、其直幅が、大抵二三十丁位の者だから、一二十丁方も利が乘たら、早く見切りて、" />
  <LINE TYPE="本文" X="865" Y="323" WIDTH="37" HEIGHT="992" CONF="0.864" ORDER="23" STRING="利留をすべき者である。市塲は、日々立つ者で、商内は、何時でも出來るから、玉を手放すことを" />
  <LINE TYPE="本文" X="820" Y="328" WIDTH="24" HEIGHT="172" CONF="0.872" ORDER="24" STRING="惜んではならぬ。" />
  <LINE TYPE="本文" X="751" Y="468" WIDTH="37" HEIGHT="668" CONF="0.841" ORDER="25" STRING="第七十三章売買共心進立候節二日相待秘傳の事一" />
  <LINE TYPE="本文" X="690" Y="316" WIDTH="36" HEIGHT="1001" CONF="0.894" ORDER="26" STRING="一此米是非〳〵上る可し、今日中に買ふべしと進み立候節、二日待つべし。是非〳〵下くべしと賣氣" />
  <LINE TYPE="本文" X="646" Y="315" WIDTH="37" HEIGHT="992" CONF="0.887" ORDER="27" STRING="進む時は、是又、二日待つべし。是極意の秘傳也。總べて、天井直段の時に成ては、見計ひ第一也。" />
  <LINE TYPE="本文" X="603" Y="313" WIDTH="37" HEIGHT="1004" CONF="0.875" ORDER="28" STRING="天井直段出る時は、賣る可しの心專一也。底直段の節は、買ふ可しの心專一也。此心掛忘る可から" />
  <LINE TYPE="本文" X="558" Y="315" WIDTH="23" HEIGHT="36" CONF="0.611" ORDER="29" STRING="ず。" />
  <LINE TYPE="本文" X="516" Y="335" WIDTH="36" HEIGHT="981" CONF="0.902" ORDER="31" STRING="(釋)孫子の軍形篇に、日や月をいても明かなる目とは云へない、又雷の音が聞へる耳でも、决し" />
  <LINE TYPE="本文" X="473" Y="337" WIDTH="36" HEIGHT="976" CONF="0.911" ORDER="32" STRING="て聴き耳とは云はれぬ、何故なれば、是は何人の耳目にも聞たり見たりするが、出來るからである" />
  <LINE TYPE="本文" X="428" Y="338" WIDTH="38" HEIGHT="979" CONF="0.890" ORDER="33" STRING="と説てある其通りで、天井際の相場は、誰人の目にも上ると見へ、又底際の相塲は、誰が見ても、" />
  <LINE TYPE="本文" X="386" Y="340" WIDTH="36" HEIGHT="984" CONF="0.903" ORDER="34" STRING="下げと見へる者であつて、我も亦、人氣通りに賣買し度い者であるが、こんな時は、上下げ原因の" />
  <LINE TYPE="本文" X="342" Y="340" WIDTH="37" HEIGHT="987" CONF="0.911" ORDER="35" STRING="相塲に顯はれ盡した時で、最早相場一轉の機であるから、幾ら賣買し度くとも二三日計り商内を見合" />
  <LINE TYPE="本文" X="297" Y="339" WIDTH="39" HEIGHT="994" CONF="0.847" ORDER="36" STRING="せるがよい。果して相塲は、人気の反對に高下する者である。それだから、最早天井直段近いと思" />
  <LINE TYPE="本文" X="271" Y="1110" WIDTH="20" HEIGHT="35" CONF="0.495" ORDER="37" STRING="九三" />
  </PAGE>

