          ]
        ],
        "id": 10,
        "isVertical": "true",
        "text": "嗣、早世、其子四郎三郎君承後、四郎三郎號宗善、實爲本間家中興之偉人也。",
        "isTextline": "true",
        "confidence": 0.885
      },
