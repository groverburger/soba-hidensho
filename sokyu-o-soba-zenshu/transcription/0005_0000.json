          ]
        ],
        "id": 9,
        "isVertical": "true",
        "text": "一擧得于金之利矣、君自後連年従事米穀之売買、頻収利益、久四郎君沒子某君一",
        "isTextline": "true",
        "confidence": 0.893
      },
