          ]
        ],
        "id": 11,
        "isVertical": "true",
        "text": "宗久翁以亨保二年生于出羽國田川郡新堀村、幼爲本間氏二世之猶子、娶其",
        "isTextline": "true",
        "confidence": 0.899
      },
