          ]
        ],
        "id": 8,
        "isVertical": "true",
        "text": "庄内米價特賤、爭先來買、是以需要超二于供給、米價俄騰、君乘機賣會所買正米、",
        "isTextline": "true",
        "confidence": 0.898
