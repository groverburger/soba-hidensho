  <LINE TYPE="本文" X="1778" Y="1113" WIDTH="17" HEIGHT="53" CONF="0.395" ORDER="0" STRING="三〇" />
  <LINE TYPE="本文" X="1732" Y="336" WIDTH="29" HEIGHT="998" CONF="0.787" ORDER="1" STRING="した者で、意ろは、市塲に金が澤山に顯はれて見へるのは、米に思入が少く、歩金に澤山出た結果" />
  <LINE TYPE="本文" X="1688" Y="322" WIDTH="30" HEIGHT="1010" CONF="0.858" ORDER="2" STRING="であつて、隨つて、相塲は安い者だ。、又、市塲に通用金の少い原因を尋ねて見れば、米に思入多く" />
  <LINE TYPE="本文" X="1647" Y="331" WIDTH="26" HEIGHT="636" CONF="0.883" ORDER="3" STRING="歩金に出た結果であるから、相場は高い者だと云ふのである。" />
  <LINE TYPE="本文" X="1466" Y="265" WIDTH="14" HEIGHT="16" CONF="0.317" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1498" Y="265" WIDTH="15" HEIGHT="16" CONF="0.381" ORDER="5" STRING="翁" />
  <LINE TYPE="本文" X="1531" Y="265" WIDTH="13" HEIGHT="16" CONF="0.410" ORDER="6" STRING="久" />
  <LINE TYPE="本文" X="1562" Y="265" WIDTH="16" HEIGHT="18" CONF="0.411" ORDER="7" STRING="宗" />
  <LINE TYPE="本文" X="1303" Y="263" WIDTH="15" HEIGHT="18" CONF="0.308" ORDER="8" STRING="巻" />
<LINE TYPE="本文" X="1577" Y="486" WIDTH="31" HEIGHT="538" CONF="0.869" ORDER="9" STRING="第四十七章冬買船手へ落又不落年の事" />
  <LINE TYPE="本文" X="1509" Y="322" WIDTH="29" HEIGHT="1015" CONF="0.842" ORDER="10" STRING="一冬買船手に落ざる年は、翌春より、段々景氣付米上ると心得可し。冬賀澤山に船手へ落る年は、春" />
  <LINE TYPE="本文" X="1468" Y="309" WIDTH="27" HEIGHT="675" CONF="0.872" ORDER="11" STRING="中より必らず不景氣なる者也。左様の年は、五六月より上るべし。" />
  <LINE TYPE="本文" X="1423" Y="321" WIDTH="29" HEIGHT="835" CONF="0.885" ORDER="12" STRING="(釋)船手冬買のとは、首卷酒田米會所の商習慣と云ふ處に、精しく説いて置た。" />
  <LINE TYPE="本文" X="1378" Y="332" WIDTH="31" HEIGHT="988" CONF="0.834" ORDER="13" STRING="偖當地(莊内地方)が豊作の年は、米價が比較的割安いので、夫を見込んで、貿易地方の商人冬買" />
  <LINE TYPE="本文" X="1335" Y="332" WIDTH="30" HEIGHT="990" CONF="0.894" ORDER="14" STRING="と唱へて入込の例だが、若し、商人の賣惜みとか、何等かの事情で、現物が船手即ち冬買手筋の手" />
  <LINE TYPE="本文" X="1292" Y="333" WIDTH="32" HEIGHT="991" CONF="0.897" ORDER="15" STRING="に這入らないともある。そんな年は。翌年の春になつて、追々入船の時季に近付くに随ひ、船手筋" />
  <LINE TYPE="本文" X="1250" Y="332" WIDTH="31" HEIGHT="992" CONF="0.859" ORDER="16" STRING="が止むを得ず買進むから、段々と景気付て、相場が上る者である。之に反して、現物の十分冬買の" />
  <LINE TYPE="本文" X="1206" Y="336" WIDTH="31" HEIGHT="987" CONF="0.837" ORDER="17" STRING="手に行互つた年は、翌春になつても、買入が少い道理であるから、翌春は、不気配だ者である。併" />
  <LINE TYPE="本文" X="1167" Y="331" WIDTH="24" HEIGHT="492" CONF="0.888" ORDER="18" STRING="し、此んな年は、五六月に上げとなる者である。" />
  <LINE TYPE="本文" X="890" Y="481" WIDTH="34" HEIGHT="630" CONF="0.800" ORDER="19" STRING="第四十八章まふはまだ也まだはまふ也と申事" />
  <LINE TYPE="本文" X="828" Y="317" WIDTH="31" HEIGHT="1008" CONF="0.868" ORDER="20" STRING="一まふは、まだ也。まだは、まふ也。と云ふとあり。但し、數日最早時分と思ひ取りかゝるに、見計" />
  <LINE TYPE="本文" X="787" Y="313" WIDTH="29" HEIGHT="790" CONF="0.892" ORDER="21" STRING="らひ惡しければ、間違ひになる也。まだ〳〵と見合せ居る内に遲るゝとあり。" />
  <LINE TYPE="本文" X="741" Y="333" WIDTH="32" HEIGHT="988" CONF="0.843" ORDER="22" STRING="(釋)本章は、商内仕掛の調子、即ち機會の乗じ方を述た者て、本文は、猛虎軒の八木虎之卷と同" />
  <LINE TYPE="本文" X="699" Y="334" WIDTH="31" HEIGHT="983" CONF="0.894" ORDER="23" STRING="文で、註釋は聊か文句が違ふが、意味は矢張り同樣である。言。は、虎の卷の説明で盡して居る。" />
  <LINE TYPE="本文" X="655" Y="324" WIDTH="32" HEIGHT="1008" CONF="0.899" ORDER="24" STRING="例へば、最早底で起き上るだろふと、我心が買に進み立つ時に、今一應未だと云ふ心を扣へて、暫時" />
  <LINE TYPE="本文" X="612" Y="333" WIDTH="32" HEIGHT="987" CONF="0.889" ORDER="25" STRING="待つがよい。又、未だ底ではない、今少しは下げるであらうと心進み立時に、最ふ底であると云ふ" />
  <LINE TYPE="本文" X="569" Y="334" WIDTH="31" HEIGHT="978" CONF="0.904" ORDER="26" STRING="心で、買方となるべきである。我心に、まだと思ふ心のある時には、我思ふ反對に上る者である。" />
  <LINE TYPE="本文" X="527" Y="333" WIDTH="31" HEIGHT="980" CONF="0.890" ORDER="27" STRING="だからして、此際に於ける心得方は、百枚買ふと思つたら、三四十枚も買ふ様に心得て居るがよい。" />
  <LINE TYPE="本文" X="487" Y="335" WIDTH="26" HEIGHT="576" CONF="0.842" ORDER="28" STRING="まふの心ある時も、之に準じて了るべしと、述べてある。" />
  <LINE TYPE="本文" X="440" Y="334" WIDTH="31" HEIGHT="991" CONF="0.896" ORDER="29" STRING="本章は、相塲に對する人性の弱點を道破した言であつて、已に、本書第一章に述べて置た、賣氣進" />
  <LINE TYPE="本文" X="396" Y="326" WIDTH="33" HEIGHT="1008" CONF="0.902" ORDER="30" STRING="立時は、三日待心を轉じ買方すべし、又買氣進み立つて、今日より外買塲なしと進み立時、是亦、暫一" />
  <LINE TYPE="本文" X="354" Y="335" WIDTH="32" HEIGHT="992" CONF="0.879" ORDER="31" STRING="時待つて反對に賣方すべし、極めて利運なり。又本書の一章に、二つ仕廻、三つ十分、四つ轉じと" />
  <LINE TYPE="本文" X="308" Y="336" WIDTH="33" HEIGHT="987" CONF="0.840" ORDER="32" STRING="説いてあるのも、詰り同意で、相塲は、極まつて變ずる者だから、其人氣の極端に人氣通りに付出" />
  <LINE TYPE="本文" X="272" Y="1115" WIDTH="23" HEIGHT="47" CONF="0.499" ORDER="33" STRING="一三一" />
