  <LINE TYPE="本文" X="1812" Y="335" WIDTH="28" HEIGHT="1093" CONF="0.336" ORDER="0" STRING="}" />
  <LINE TYPE="本文" X="1759" Y="1101" WIDTH="19" HEIGHT="38" CONF="0.407" ORDER="1" STRING="九八" />
  <LINE TYPE="本文" X="1713" Y="319" WIDTH="31" HEIGHT="980" CONF="0.789" ORDER="2" STRING="足取表を見て、底から段々上りつめて、百俵上もした處で保合つて居る米は、下相塲の方で、本奇" />
  <LINE TYPE="本文" X="1671" Y="328" WIDTH="25" HEIGHT="303" CONF="0.880" ORDER="3" STRING="に説く保合相場の例外である。" />
  <LINE TYPE="本文" X="1600" Y="471" WIDTH="31" HEIGHT="628" CONF="0.675" ORDER="4" STRING="第三章一ト足踏みはづす時は皆裏表になる事" />
  <LINE TYPE="本文" X="1382" Y="250" WIDTH="15" HEIGHT="18" CONF="0.307" ORDER="5" STRING="全" />
<LINE TYPE="本文" X="1414" Y="250" WIDTH="15" HEIGHT="18" CONF="0.313" ORDER="6" STRING="梅" />
  <LINE TYPE="本文" X="1446" Y="251" WIDTH="17" HEIGHT="17" CONF="0.392" ORDER="7" STRING="相" />
  <LINE TYPE="本文" X="1479" Y="251" WIDTH="17" HEIGHT="17" CONF="0.394" ORDER="8" STRING="噐" />
  <LINE TYPE="本文" X="1511" Y="251" WIDTH="16" HEIGHT="18" CONF="0.391" ORDER="9" STRING="久" />
  <LINE TYPE="本文" X="1543" Y="252" WIDTH="17" HEIGHT="19" CONF="0.407" ORDER="10" STRING="宗" />
  <LINE TYPE="本文" X="1349" Y="250" WIDTH="16" HEIGHT="19" CONF="0.337" ORDER="11" STRING="集" />
  <LINE TYPE="本文" X="1318" Y="251" WIDTH="14" HEIGHT="16" CONF="0.358" ORDER="12" STRING="下" />
  <LINE TYPE="本文" X="1284" Y="251" WIDTH="15" HEIGHT="16" CONF="0.357" ORDER="13" STRING="卷" />
  <LINE TYPE="本文" X="1538" Y="304" WIDTH="29" HEIGHT="1011" CONF="0.848" ORDER="14" STRING="一商數月思入克く仕當る時、决して勝に乘る可からず、唯無難に取留ることを專らにすべし。數月思" />
  <LINE TYPE="本文" X="1494" Y="305" WIDTH="30" HEIGHT="998" CONF="0.896" ORDER="15" STRING="入當る故、賣買共心易き者に心得、少々の高下にも、思入を立たがる事あり、是愼むべし。此商、一" />
  <LINE TYPE="本文" X="1453" Y="306" WIDTH="29" HEIGHT="1000" CONF="0.895" ORDER="16" STRING="ト足踏外す時は、皆裏表になる者也。返す〳〵大切に取り、麁略に心得べからず。此商、天性自然の" />
  <LINE TYPE="本文" X="1412" Y="294" WIDTH="25" HEIGHT="575" CONF="0.855" ORDER="17" STRING="者にて高下ある故、三位の傳を離れ利を得ることなし。" />
  <LINE TYPE="本文" X="1366" Y="318" WIDTH="30" HEIGHT="996" CONF="0.889" ORDER="18" STRING="數ケ月先きの高下を見定めて、商を仕かけ、見込が當つて思ふ存分に利の乘つた商は、圖に" />
  <LINE TYPE="本文" X="1322" Y="325" WIDTH="30" HEIGHT="984" CONF="0.892" ORDER="19" STRING="乘つて、マダ〳〵と云ふ慾心を起さずに、唯無難に利喰をする心がけが肝腎である。數ケ月來、自" />
  <LINE TYPE="本文" X="1279" Y="319" WIDTH="31" HEIGHT="991" CONF="0.867" ORDER="20" STRING="分の見込が當つて居るから、相場は儲け易い者と侮つて、少しの高下にも、大思惑を立てゝ賣買を" />
  <LINE TYPE="本文" X="1236" Y="321" WIDTH="31" HEIGHT="982" CONF="0.871" ORDER="21" STRING="したがる者だが、是は、大に愼むべき事であつて、相場の見込みを立てると云ふことは、そんな、" />
  <LINE TYPE="本文" X="1192" Y="322" WIDTH="31" HEIGHT="983" CONF="0.893" ORDER="22" STRING="かり易い者じやない、儲かつて居る時はよいが、萬一、一ト調子間違ふ時は、裏表になつて、今儲" />
  <LINE TYPE="本文" X="1150" Y="320" WIDTH="30" HEIGHT="988" CONF="0.864" ORDER="23" STRING="けて居る反對に、損分の立つ者であるから、返す〳〵、罫線表を熟く視て、天井底の位取を考へ察" />
  <LINE TYPE="本文" X="1108" Y="316" WIDTH="27" HEIGHT="698" CONF="0.895" ORDER="24" STRING="して、賣買すべき者であつて、禪心を離れては、利盆を得難い者だ。" />
  <LINE TYPE="本文" X="913" Y="404" WIDTH="34" HEIGHT="484" CONF="0.893" ORDER="25" STRING="第四章賣買買氣を轉じ秘傳の事" />
  <LINE TYPE="本文" X="508" Y="242" WIDTH="15" HEIGHT="20" CONF="0.353" ORDER="26" STRING="事" />
  <LINE TYPE="本文" X="851" Y="294" WIDTH="32" HEIGHT="1011" CONF="0.876" ORDER="27" STRING="一米弱みに見へ、頻りに賣氣進み立候節、三日待、氣轉じ買方に付くべし、極めて利運也。是非上ぐ" />
  <LINE TYPE="本文" X="808" Y="295" WIDTH="32" HEIGHT="1006" CONF="0.890" ORDER="28" STRING="可しと買氣進み立候節、是亦、氣を轉じ賣るべし。米商の極意也、此心忘る可からず。我強氣の節は、" />
  <LINE TYPE="本文" X="765" Y="294" WIDTH="32" HEIGHT="1006" CONF="0.870" ORDER="29" STRING="人も強気と思ふべし、我弱気の節は、人も弱気に片寄る也、上げ詰下げ、下げ詰め上る、陰陽自然の" />
  <LINE TYPE="本文" X="722" Y="291" WIDTH="28" HEIGHT="516" CONF="0.923" ORDER="30" STRING="道理なる故、考に不及也。専ら三位傳に任すべし。" />
  <LINE TYPE="本文" X="679" Y="317" WIDTH="30" HEIGHT="982" CONF="0.895" ORDER="31" STRING="(釋)底直段間際では、諸人弱氣に片寄り、我も亦、夫に附いて賣度い者であるが、直と賣らずに、" />
  <LINE TYPE="本文" X="636" Y="318" WIDTH="31" HEIGHT="983" CONF="0.897" ORDER="32" STRING="一歩を退いて、三日間も克々考へて、心を轉じて、買方に廻るべきである。相場は、果して上る者" />
  <LINE TYPE="本文" X="592" Y="308" WIDTH="31" HEIGHT="1008" CONF="0.894" ORDER="33" STRING="で、又、天井間際は、人々此上何程上るも知れない様に申觸らし、表面上、顯はれる處は、皆強原" />
  <LINE TYPE="本文" X="549" Y="317" WIDTH="31" HEIGHT="985" CONF="0.894" ORDER="34" STRING="因計り故、我も其人気に釣り込まれて買度なる者だか、是又、翻然として賣に廻る可きである。相" />
  <LINE TYPE="本文" X="506" Y="317" WIDTH="31" HEIGHT="985" CONF="0.895" ORDER="35" STRING="場と云ふ者は、諸人の思想の先き廻りをする者だから、諸人皆々強氣に偏り。猫子も杓子も買進む" />
  <LINE TYPE="本文" X="463" Y="311" WIDTH="31" HEIGHT="999" CONF="0.893" ORDER="36" STRING="ときは、最早相場の暗潮は、下げに向つて居る者である、上げ詰めて下げ、下げ詰めて上るは、相" />
  <LINE TYPE="本文" X="420" Y="313" WIDTH="30" HEIGHT="989" CONF="0.850" ORDER="37" STRING="場の常態で、又其原理であるから、熱して居る人氣に馬鹿にされずに、本書説く所の三位傳に據て、" />
  <LINE TYPE="本文" X="380" Y="316" WIDTH="22" HEIGHT="189" CONF="0.843" ORDER="38" STRING="駈引をするがよい。" />
  <LINE TYPE="本文" X="296" Y="1090" WIDTH="21" HEIGHT="42" CONF="0.480" ORDER="39" STRING="九九" />
  </PAGE>

