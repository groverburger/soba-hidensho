  <LINE TYPE="本文" X="1731" Y="358" WIDTH="21" HEIGHT="160" CONF="0.466" ORDER="0" STRING="同同同一" />
  <LINE TYPE="本文" X="1692" Y="499" WIDTH="35" HEIGHT="420" CONF="0.781" ORDER="1" STRING="第五十一章七月三位頭月の事" />
  <LINE TYPE="本文" X="1762" Y="1125" WIDTH="20" HEIGHT="45" CONF="0.411" ORDER="2" STRING="七〇" />
  <LINE TYPE="本文" X="1554" Y="279" WIDTH="17" HEIGHT="20" CONF="0.401" ORDER="3" STRING="宗" />
  <LINE TYPE="本文" X="1523" Y="280" WIDTH="15" HEIGHT="20" CONF="0.435" ORDER="4" STRING="久" />
  <LINE TYPE="本文" X="1488" Y="277" WIDTH="18" HEIGHT="24" CONF="0.335" ORDER="5" STRING="翁" />
  <LINE TYPE="本文" X="1457" Y="279" WIDTH="17" HEIGHT="20" CONF="0.434" ORDER="6" STRING="相" />
  <LINE TYPE="本文" X="1424" Y="279" WIDTH="18" HEIGHT="19" CONF="0.402" ORDER="7" STRING="塲" />
  <LINE TYPE="本文" X="1390" Y="265" WIDTH="17" HEIGHT="33" CONF="0.349" ORDER="9" STRING="・全" />
  <LINE TYPE="本文" X="1356" Y="277" WIDTH="19" HEIGHT="21" CONF="0.432" ORDER="10" STRING="集" />
  <LINE TYPE="本文" X="1327" Y="278" WIDTH="18" HEIGHT="21" CONF="0.329" ORDER="11" STRING="上" />
  <LINE TYPE="本文" X="1293" Y="276" WIDTH="16" HEIGHT="21" CONF="0.308" ORDER="12" STRING="卷" />
<LINE TYPE="本文" X="1630" Y="326" WIDTH="34" HEIGHT="1019" CONF="0.845" ORDER="13" STRING="一七月三位の頭月に當る時は、六月順氣上々作宜く、此上へ下く可き樣子なれ共、夫に搆はず三拾俵" />
  <LINE TYPE="本文" X="1586" Y="324" WIDTH="33" HEIGHT="1013" CONF="0.880" ORDER="14" STRING="前後の米は、六月より油断なく買入るべし。秋米は、日本上作と申唱へ候ても、作難なきこと稀也。" />
  <LINE TYPE="本文" X="1543" Y="321" WIDTH="33" HEIGHT="1014" CONF="0.895" ORDER="15" STRING="若し平作年、當地上方共上作の年は、八九十月より見合せ、底直を見極め買入る可し。累年、作大概" />
  <LINE TYPE="本文" X="1500" Y="321" WIDTH="33" HEIGHT="1008" CONF="0.903" ORDER="16" STRING="の年、出初より十俵二三十俵下にて、多くは上に向く也。四五十俵下げ極稀也。但し、六七月の間、" />
  <LINE TYPE="本文" X="1456" Y="315" WIDTH="34" HEIGHT="1028" CONF="0.884" ORDER="17" STRING="不時の天災上方当地共変ある時は、商出ずして俵飛び急上になりて、後れになる故、決して油断なら" />
  <LINE TYPE="本文" X="1413" Y="318" WIDTH="33" HEIGHT="1017" CONF="0.895" ORDER="18" STRING="ざる也。此事、大事なる故、返す〳〵も心得肝要也。何分、七月頭月に當る時は、六月より油斷なく" />
  <LINE TYPE="本文" X="1370" Y="320" WIDTH="33" HEIGHT="1009" CONF="0.906" ORDER="19" STRING="買入、十に八九過ちなし。七月の頭月は、多く上方當地とも變事あり、急上げの月也、必ず油斷すべ" />
  <LINE TYPE="本文" X="1327" Y="316" WIDTH="33" HEIGHT="1020" CONF="0.907" ORDER="20" STRING="からず。八月天井終月に當る時は、新古共、天井出ることあるは稀也。尤、古米は此月に終り月也。" />
  <LINE TYPE="本文" X="1283" Y="319" WIDTH="33" HEIGHT="1010" CONF="0.889" ORDER="21" STRING="新米は、翌年の七月迄高下ある米なれば、此處にて天井と限る可からず。此事も、九州邊天災ある順" />
  <LINE TYPE="本文" X="1239" Y="322" WIDTH="34" HEIGHT="1003" CONF="0.913" ORDER="22" STRING="の年也。若し、八月天井直段出る共、其年九州上方作難の年は、十月霜月の内、百俵近き上ある可し、" />
  <LINE TYPE="本文" X="1197" Y="317" WIDTH="35" HEIGHT="1019" CONF="0.909" ORDER="23" STRING="見計らひ第一也。天井直段、十八俵より二十一二俵位の米は、來夏に至り、四五十俵下げにて向く年" />
  <LINE TYPE="本文" X="1154" Y="324" WIDTH="34" HEIGHT="1007" CONF="0.895" ORDER="24" STRING="は、極めて上方物不足也。船々買急ぐ年の事也。先づは、六七十俵百俵近く、三位の底月迄に下る順" />
  <LINE TYPE="本文" X="1109" Y="323" WIDTH="34" HEIGHT="1004" CONF="0.875" ORDER="25" STRING="なれども、前年の不作に人氣張詰め、四五月迄下く可き程下ざる年は、船盛りより過目になり、少し" />
  <LINE TYPE="本文" X="912" Y="317" WIDTH="31" HEIGHT="1012" CONF="0.859" ORDER="26" STRING="下げ、五月船間になり二三十俵も下げ、其後六月に至り、順氣能く、土用中照り込み、上作の取沙汰" />
  <LINE TYPE="本文" X="869" Y="320" WIDTH="31" HEIGHT="1003" CONF="0.889" ORDER="27" STRING="あり、高直故、船々買急がず、夫より段々人氣悪敷なり、六月は米持の仕廻月故、他所衆買持は勿論、" />
  <LINE TYPE="本文" X="826" Y="319" WIDTH="31" HEIGHT="1000" CONF="0.884" ORDER="28" STRING="素人黒人も賣仕廻月故、六月中旬より大崩し疑なし、別けて、前年四分半不作にて他所の買孕み多き" />
  <LINE TYPE="本文" X="782" Y="306" WIDTH="32" HEIGHT="1025" CONF="0.864" ORDER="29" STRING="年は、尚の事也、此年前後能々考ふべし。但し、八月天井に當るも、四五六月の間底直段出るを待つ、" />
  <LINE TYPE="本文" X="753" Y="269" WIDTH="17" HEIGHT="25" CONF="0.329" ORDER="30" STRING="第一" />
  <LINE TYPE="本文" X="741" Y="311" WIDTH="25" HEIGHT="368" CONF="0.808" ORDER="31" STRING="新古共買入八月の上げを待つべし。" />
  <LINE TYPE="本文" X="697" Y="313" WIDTH="30" HEIGHT="1015" CONF="0.875" ORDER="33" STRING="多くは、八月の天井稀也。八月は、時節後るゝと雖も、八月天井と見る年は、六七月歩商大方なし、" />
  <LINE TYPE="本文" X="654" Y="307" WIDTH="31" HEIGHT="1030" CONF="0.898" ORDER="34" STRING="三四十俵面ならば、五六月の内買なりの米は、二三十俵足米本質等、八月を待つべし。尤も、七月上" />
  <LINE TYPE="本文" X="611" Y="319" WIDTH="30" HEIGHT="1005" CONF="0.870" ORDER="35" STRING="詰る時は、其節賣仕廻ふべし。八月天井の年は、常の年になし、冬春天井直段出で格外の下ある時は、" />
  <LINE TYPE="本文" X="566" Y="307" WIDTH="31" HEIGHT="1025" CONF="0.867" ORDER="36" STRING="七八月又々天井出づべし。傳に曰く、五月十分に下る時は、六月急上也と云ふ心と同じ。常の年、三" />
  <LINE TYPE="本文" X="524" Y="317" WIDTH="27" HEIGHT="652" CONF="0.908" ORDER="37" STRING="四月より五六月迄夏上げの年は、決して八月上なしと心得べし。" />
  <LINE TYPE="本文" X="480" Y="334" WIDTH="28" HEIGHT="604" CONF="0.885" ORDER="38" STRING="本章は、七月甲月に當る時の心得を説いた者である。" />
  <LINE TYPE="本文" X="437" Y="338" WIDTH="30" HEIGHT="984" CONF="0.894" ORDER="39" STRING="意は、七月甲に當る時は、六月順氣が能くつて上作の見當で、此上への下がある模樣であるとも、" />
  <LINE TYPE="本文" X="393" Y="343" WIDTH="31" HEIGHT="984" CONF="0.894" ORDER="40" STRING="そんな事には頓着せず、三拾俵前後の相場であるならば、油斷なく押目を買ふ可きである。夏の内" />
  <LINE TYPE="本文" X="351" Y="341" WIDTH="31" HEIGHT="991" CONF="0.862" ORDER="41" STRING="にいくら上作を唱へても、十年の内の九年は、秋になると、作柄非難の聲が出て上る者である。若" />
  <LINE TYPE="本文" X="306" Y="340" WIDTH="32" HEIGHT="991" CONF="0.850" ORDER="42" STRING="し、前年も平作年であつて、當地上方共上作の年には、そんなに買急がす、八九十月の内の底直を克" />
  <LINE TYPE="本文" X="272" Y="1117" WIDTH="21" HEIGHT="41" CONF="0.441" ORDER="43" STRING="七一" />
  </PAGE>

