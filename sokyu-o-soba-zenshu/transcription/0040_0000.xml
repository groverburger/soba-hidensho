<PAGE IMAGENAME="0040_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1779" Y="109" WIDTH="34" HEIGHT="1366" CONF="0.411" ORDER="1" STRING="下痢、九十一年十一年十一年十一年十一年十一年二月十一年二月二十一年二月二十一年二月十一年二月十一日" />
  <LINE TYPE="本文" X="1341" Y="266" WIDTH="17" HEIGHT="19" CONF="0.332" ORDER="2" STRING="全" />
  <LINE TYPE="本文" X="1374" Y="266" WIDTH="17" HEIGHT="18" CONF="0.335" ORDER="3" STRING="場" />
  <LINE TYPE="本文" X="1405" Y="266" WIDTH="18" HEIGHT="19" CONF="0.353" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1438" Y="266" WIDTH="17" HEIGHT="19" CONF="0.369" ORDER="5" STRING="船" />
  <LINE TYPE="本文" X="1469" Y="266" WIDTH="19" HEIGHT="20" CONF="0.387" ORDER="6" STRING="久" />
  <LINE TYPE="本文" X="1504" Y="266" WIDTH="17" HEIGHT="20" CONF="0.373" ORDER="7" STRING="宗" />
  <LINE TYPE="本文" X="1309" Y="265" WIDTH="16" HEIGHT="18" CONF="0.367" ORDER="8" STRING="集" />
  <LINE TYPE="本文" X="1277" Y="266" WIDTH="15" HEIGHT="17" CONF="0.346" ORDER="9" STRING="上" />
  <LINE TYPE="本文" X="1245" Y="265" WIDTH="16" HEIGHT="17" CONF="0.386" ORDER="10" STRING="卷" />
  <LINE TYPE="本文" X="1716" Y="1113" WIDTH="19" HEIGHT="39" CONF="0.392" ORDER="11" STRING="五〇" />
  <LINE TYPE="本文" X="1670" Y="345" WIDTH="31" HEIGHT="978" CONF="0.868" ORDER="12" STRING="分の見込が、違つたと思ふたならば、其損の深くならぬ中に損止めして、四五十日間も休んで、強" />
  <LINE TYPE="本文" X="1626" Y="333" WIDTH="32" HEIGHT="998" CONF="0.895" ORDER="13" STRING="弱を離れ、虚心平気、相場の通ひ高下と天井底とを克々考察して、相塲の如何を見定め、十分見込" />
  <LINE TYPE="本文" X="1584" Y="331" WIDTH="31" HEIGHT="1004" CONF="0.894" ORDER="14" STRING="の付た處で、付け出すべきである。十分に儲つた時でも、商内を仕廻つた跡は、四五十日間は休み" />
  <LINE TYPE="本文" X="1541" Y="341" WIDTH="31" HEIGHT="984" CONF="0.898" ORDER="15" STRING="静養して、昂上心を抑え、常識を修養すべきである。此休むとを忘れ、目前の成功に慢じて、長追" />
  <LINE TYPE="本文" X="1498" Y="332" WIDTH="31" HEIGHT="995" CONF="0.894" ORDER="16" STRING="ひするならば、思はざる伏兵、即ち相塲の引返すに遇つて、商内を仕廻ふ時には、屹度損になる者" />
  <LINE TYPE="本文" X="1456" Y="330" WIDTH="30" HEIGHT="1004" CONF="0.903" ORDER="17" STRING="である。併し、茲に、商内を休めと云ふのは、何心なく休めと云ふ意味ではない。強弱の人氣を離" />
  <LINE TYPE="本文" X="1413" Y="341" WIDTH="31" HEIGHT="982" CONF="0.896" ORDER="18" STRING="れ、禪心を以て相塲を俯察せよとの意味であつて、所謂、動中の靜觀である。詳しくは、宗久翁の相" />
  <LINE TYPE="本文" X="1369" Y="338" WIDTH="31" HEIGHT="979" CONF="0.900" ORDER="19" STRING="塲禪の處に説いて置たから、茲には略するが、一躰人性の弱點として、先入主となる者で、特に、" />
  <LINE TYPE="本文" X="1326" Y="331" WIDTH="31" HEIGHT="1000" CONF="0.902" ORDER="20" STRING="相塲に於て此弱點を發揮する塲合が極めて多い。一寸例を示せば、前方強氣で儲けた人は、兎角其" />
  <LINE TYPE="本文" X="1283" Y="338" WIDTH="31" HEIGHT="987" CONF="0.863" ORDER="21" STRING="時の味を忘れ兼、買たがる者。亦前方賣つて儲けた人は、當時のとが腦にしみこんで、得て弱氣に" />
  <LINE TYPE="本文" X="1239" Y="339" WIDTH="31" HEIGHT="985" CONF="0.878" ORDER="22" STRING="傾き易い者であるが、相塲の駈引運用は、猶ほ兵を用ゆると同じとて、其時に隨ひ尅に應じて、駈" />
  <LINE TYPE="本文" X="1196" Y="338" WIDTH="31" HEIGHT="988" CONF="0.860" ORDER="23" STRING="引を異にすべき者で、相塲は其年其時の作の樣子柄、世間の景氣、正米集散の状態、人氣の趨向如" />
  <LINE TYPE="本文" X="1158" Y="334" WIDTH="24" HEIGHT="375" CONF="0.842" ORDER="24" STRING="何を考へることが、第一の要訣である。" />
  <LINE TYPE="本文" X="1077" Y="409" WIDTH="17" HEIGHT="15" CONF="0.327" ORDER="25" STRING="一" />
<LINE TYPE="本文" X="1100" Y="453" WIDTH="22" HEIGHT="33" CONF="0.403" ORDER="26" STRING="○" />
  <LINE TYPE="本文" X="1083" Y="451" WIDTH="33" HEIGHT="485" CONF="0.735" ORDER="27" STRING="第三十八章利運の節心得方の事" />
  <LINE TYPE="本文" X="1490" Y="1418" WIDTH="70" HEIGHT="27" CONF="0.398" ORDER="28" STRING="同同一" />
  <LINE TYPE="本文" X="905" Y="330" WIDTH="33" HEIGHT="1000" CONF="0.872" ORDER="29" STRING="一商利運仕當る時、先づ大概に致し、取留る者也。其節一兩月休むべし。此休むとを忘るゝ時は、何" />
  <LINE TYPE="本文" X="862" Y="326" WIDTH="33" HEIGHT="1002" CONF="0.861" ORDER="30" STRING="程利運に向きても、商仕廻の節は、決して損出づべし。勝に誇り、百兩の利は二百兩取る氣になり。" />
  <LINE TYPE="本文" X="818" Y="324" WIDTH="34" HEIGHT="1008" CONF="0.869" ORDER="31" STRING="千兩二千兩の氣移り、欲に迷ふて見切兼、損出る也。是慾より出て迷ふ也。不利運の時は、尚以ての" />
  <LINE TYPE="本文" X="774" Y="320" WIDTH="28" HEIGHT="467" CONF="0.889" ORDER="32" STRING="事也。其時の見切大切の事也。愼み心得べし。" />
  <LINE TYPE="本文" X="731" Y="342" WIDTH="33" HEIGHT="995" CONF="0.891" ORDER="33" STRING="(釋)本章は、前章と同意味だから、別に註釋をせぬ、一兩月と云つたのも、四五十日と云ふのも。" />
  <LINE TYPE="本文" X="687" Y="336" WIDTH="35" HEIGHT="1007" CONF="0.895" ORDER="34" STRING="詰り同じ事である。併し、前章と異なる所は、勝に誇り相塲の極點をも忘れ深入りするとを戒飾し、" />
  <LINE TYPE="本文" X="645" Y="348" WIDTH="35" HEIGHT="984" CONF="0.895" ORDER="35" STRING="又短日月の間に儲け様として、上と下との兩方て利盆しよふと思つて、強て見込付け、相塲の跡を" />
  <LINE TYPE="本文" X="602" Y="350" WIDTH="34" HEIGHT="983" CONF="0.889" ORDER="36" STRING="追かけ〳〵賣買するから、却つて上げ下げ兩方で損の出る者である。是詰りは、慾に迷ふ爲めてあ" />
  <LINE TYPE="本文" X="560" Y="352" WIDTH="24" HEIGHT="215" CONF="0.882" ORDER="37" STRING="るとて訓戒したとだ。" />
  <LINE TYPE="本文" X="490" Y="500" WIDTH="32" HEIGHT="473" CONF="0.877" ORDER="38" STRING="第三十九章勝に乘る可からざる事" />
  <LINE TYPE="本文" X="427" Y="341" WIDTH="33" HEIGHT="1006" CONF="0.866" ORDER="39" STRING="一數月思入能く、八九分通り仕當り候時、必らず勝に乘る可からず。唯無難に取留ることを專らにすべ" />
  <LINE TYPE="本文" X="384" Y="335" WIDTH="27" HEIGHT="435" CONF="0.856" ORDER="40" STRING="し。必らず〳〵、慾を深ふし迷ふ可からず。" />
  <LINE TYPE="本文" X="339" Y="344" WIDTH="36" HEIGHT="998" CONF="0.900" ORDER="41" STRING="例へば、賣又は買にて思入が當つて、數ケ月間引上げ、又は引下げてげて來て、最早上げ留り下" />
  <LINE TYPE="本文" X="297" Y="335" WIDTH="34" HEIGHT="1014" CONF="0.804" ORDER="42" STRING="げ留りの時機となつても、まだ〳〵利盆が足りない抔と、慾心を深くして、見合せて居る内に、相一" />
  <LINE TYPE="本文" X="267" Y="1112" WIDTH="20" HEIGHT="47" CONF="0.511" ORDER="43" STRING="五一" />
  </PAGE>

