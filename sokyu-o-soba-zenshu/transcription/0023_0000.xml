  <LINE TYPE="本文" X="1773" Y="87" WIDTH="34" HEIGHT="1349" CONF="0.392" ORDER="0" STRING="}" />
  <LINE TYPE="本文" X="1505" Y="264" WIDTH="16" HEIGHT="20" CONF="0.419" ORDER="1" STRING="宗" />
