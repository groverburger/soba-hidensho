  <LINE TYPE="本文" X="1438" Y="265" WIDTH="17" HEIGHT="19" CONF="0.366" ORDER="3" STRING="加州" />
<LINE TYPE="本文" X="1406" Y="265" WIDTH="17" HEIGHT="19" CONF="0.384" ORDER="4" STRING="相" />
  <LINE TYPE="本文" X="1373" Y="266" WIDTH="17" HEIGHT="18" CONF="0.385" ORDER="5" STRING="塲" />
  <LINE TYPE="本文" X="1245" Y="266" WIDTH="16" HEIGHT="17" CONF="0.402" ORDER="6" STRING="卷" />
  <LINE TYPE="本文" X="1277" Y="267" WIDTH="16" HEIGHT="17" CONF="0.393" ORDER="7" STRING="上" />
  <LINE TYPE="本文" X="1309" Y="266" WIDTH="16" HEIGHT="18" CONF="0.397" ORDER="8" STRING="集" />
  <LINE TYPE="本文" X="1341" Y="266" WIDTH="17" HEIGHT="17" CONF="0.388" ORDER="9" STRING="全" />
  <LINE TYPE="本文" X="1717" Y="1117" WIDTH="20" HEIGHT="65" CONF="0.477" ORDER="10" STRING="一六一" />
  <LINE TYPE="本文" X="1672" Y="341" WIDTH="30" HEIGHT="983" CONF="0.865" ORDER="11" STRING="から、少し變事でも出ると、直ぐに相塲は上向くのである。是は、平穩無事の年に就て云ふのであ" />
  <LINE TYPE="本文" X="1634" Y="345" WIDTH="20" HEIGHT="54" CONF="0.784" ORDER="12" STRING="るが、" />
  <LINE TYPE="本文" X="1586" Y="338" WIDTH="30" HEIGHT="989" CONF="0.852" ORDER="13" STRING="上方地方當地共、天災等ある年には、六月の發會から、此下げを見せずに直ぐに急上げになるとも" />
  <LINE TYPE="本文" X="1542" Y="337" WIDTH="30" HEIGHT="988" CONF="0.869" ORDER="14" STRING="ある。何しろ、其年不作の淺深、天災の如何、古米の多少、九州國々の模樣如何に因て、當地も高" />
  <LINE TYPE="本文" X="1502" Y="337" WIDTH="23" HEIGHT="349" CONF="0.881" ORDER="15" STRING="下するから、油斷してはならない。" />
  <LINE TYPE="本文" X="1455" Y="320" WIDTH="30" HEIGHT="1006" CONF="0.886" ORDER="16" STRING="但し、其年の底直段より起き上る米は、五俵下げては十俵上げ、十俵下げては二十俵上げ、徃來して、" />
  <LINE TYPE="本文" X="1411" Y="319" WIDTH="30" HEIGHT="1006" CONF="0.864" ORDER="17" STRING="八、九、十、十一、十二、正月迄に天井直段出ると心得べし。此天井になり極不作年は、二三ヶ月も" />
  <LINE TYPE="本文" X="1367" Y="317" WIDTH="30" HEIGHT="1006" CONF="0.899" ORDER="18" STRING="持合下らざるとあり。正二月頃より、少々宛不位になり、四五六月に至り、高直の米故船々も買進ま" />
  <LINE TYPE="本文" X="1324" Y="319" WIDTH="30" HEIGHT="1004" CONF="0.893" ORDER="19" STRING="ず、特に、六月順氣能く、土用中照り込み人氣惡くなり、特更六月は、素人、黒人、他所買持の衆共" />
  <LINE TYPE="本文" X="1282" Y="310" WIDTH="30" HEIGHT="831" CONF="0.814" ORDER="20" STRING="仕舞月故、大崩れになり、七八拾俵より百俵下げ位に、段々下がると心得べし。" />
  <LINE TYPE="本文" X="1236" Y="326" WIDTH="31" HEIGHT="998" CONF="0.869" ORDER="21" STRING="本節は其第四節で、前節に引續き、底直段より天井迄の起上り模樣を説き、次に、次に、不作年翌" />
  <LINE TYPE="本文" X="1199" Y="336" WIDTH="23" HEIGHT="332" CONF="0.898" ORDER="22" STRING="春の天井保合を説いた者である。" />
  <LINE TYPE="本文" X="1151" Y="330" WIDTH="30" HEIGHT="987" CONF="0.841" ORDER="23" STRING="茲に、其年の底直段より起き上る相塲の例を擧げんに、此相塲は、五俵下げては十俵上げ、十俵下" />
  <LINE TYPE="本文" X="1106" Y="337" WIDTH="32" HEIGHT="981" CONF="0.875" ORDER="24" STRING="ては二十俵上ると云ふ樣に、通ふては上げ、通ふては上げて、八月頃より翌年の正月頃迄に、五六" />
  <LINE TYPE="本文" X="1062" Y="339" WIDTH="32" HEIGHT="985" CONF="0.854" ORDER="25" STRING="ケ月も上詰め、天井直段を出す者と心得て置くがよい。通例の年なれば、此天井行当ると急下げする" />
  <LINE TYPE="本文" X="746" Y="255" WIDTH="17" HEIGHT="22" CONF="0.488" ORDER="26" STRING="第" />
  <LINE TYPE="本文" X="718" Y="255" WIDTH="17" HEIGHT="24" CONF="0.419" ORDER="27" STRING="九" />
  <LINE TYPE="本文" X="693" Y="254" WIDTH="15" HEIGHT="23" CONF="0.466" ORDER="28" STRING="章" />
  <LINE TYPE="本文" X="666" Y="256" WIDTH="16" HEIGHT="22" CONF="0.478" ORDER="29" STRING="不" />
  <LINE TYPE="本文" X="638" Y="256" WIDTH="17" HEIGHT="21" CONF="0.436" ORDER="30" STRING="作" />
  <LINE TYPE="本文" X="613" Y="256" WIDTH="15" HEIGHT="22" CONF="0.442" ORDER="31" STRING="年" />
  <LINE TYPE="本文" X="585" Y="256" WIDTH="18" HEIGHT="22" CONF="0.475" ORDER="32" STRING="駈" />
  <LINE TYPE="本文" X="553" Y="257" WIDTH="16" HEIGHT="20" CONF="0.482" ORDER="33" STRING="引" />
  <LINE TYPE="本文" X="521" Y="258" WIDTH="14" HEIGHT="18" CONF="0.446" ORDER="34" STRING="の" />
  <LINE TYPE="本文" X="487" Y="256" WIDTH="18" HEIGHT="21" CONF="0.434" ORDER="35" STRING="事" />
  <LINE TYPE="本文" X="914" Y="329" WIDTH="29" HEIGHT="983" CONF="0.847" ORDER="36" STRING="のが普通であるが、極不作年となると人気が張詰めて居るから、二三ケ月間も、此天井の高直間際" />
  <LINE TYPE="本文" X="871" Y="330" WIDTH="31" HEIGHT="979" CONF="0.894" ORDER="37" STRING="に持合ひになつて、下らないともある。併し、其天井月(正月)と次の月(二月)あたりから、些" />
  <LINE TYPE="本文" X="827" Y="329" WIDTH="32" HEIGHT="977" CONF="0.908" ORDER="38" STRING="とダン気味となり、四五月頃ろとなつて、高直で不引合であるから、買人(船々茲には買人を云ふ" />
  <LINE TYPE="本文" X="784" Y="319" WIDTH="31" HEIGHT="996" CONF="0.904" ORDER="39" STRING="酒田は港地にして買人は多く船手筋なるが故に斯く云ふのである)も不進み、其内、六月天気克く" />
  <LINE TYPE="本文" X="741" Y="328" WIDTH="30" HEIGHT="976" CONF="0.879" ORDER="40" STRING="照り込み強くなる時は、人気盆々惡くなり、特に六月は、米痛桝減りの案じもあるし、又新甫十一" />
  <LINE TYPE="本文" X="698" Y="316" WIDTH="31" HEIGHT="996" CONF="0.868" ORDER="41" STRING="期の発會月にもあり旁々、素人は勿論のと、他所買持の人々も、手仕舞急ぎする月であるから、七" />
  <LINE TYPE="本文" X="659" Y="323" WIDTH="23" HEIGHT="402" CONF="0.928" ORDER="42" STRING="八十俵より百俵方も暴落する者である。" />
  <LINE TYPE="本文" X="612" Y="310" WIDTH="30" HEIGHT="996" CONF="0.863" ORDER="43" STRING="冬中天井直段出る時は、當地并に近國上方共、天災又は自然の不作にて、大阪當地共此上何程上げる" />
  <LINE TYPE="本文" X="570" Y="307" WIDTH="29" HEIGHT="999" CONF="0.890" ORDER="44" STRING="も知れぬ樣になり、五六ケ月も段々引上げ、十日、十二日、十三日人々騷ぎ立て、ひり〳〵と云ふが" />
  <LINE TYPE="本文" X="527" Y="301" WIDTH="30" HEIGHT="1015" CONF="0.901" ORDER="45" STRING="如き時、是年中行付天井直段也。危く思ひ、油断すべからず。火中へ飛入る思切にて賣るべし、大利" />
  <LINE TYPE="本文" X="483" Y="305" WIDTH="31" HEIGHT="996" CONF="0.865" ORDER="46" STRING="疑なし。甚だ致し難き者なれども、段々持替〳〵五六ケ月も送る時は、大利疑なし。此天井出る後、" />
  <LINE TYPE="本文" X="441" Y="306" WIDTH="30" HEIGHT="995" CONF="0.861" ORDER="47" STRING="十日計りも、相場落付を見定めたる上賣附くるとよし。其外常に思入立てし賣方致時は、極めて不意" />
  <LINE TYPE="本文" X="400" Y="306" WIDTH="25" HEIGHT="512" CONF="0.922" ORDER="48" STRING="の上げ來り、損すること決定也、此事常々愼むべし。" />
  <LINE TYPE="本文" X="354" Y="322" WIDTH="30" HEIGHT="992" CONF="0.823" ORDER="49" STRING="(釋)本節は、天井直段に際し、賣付の心得を説いた者である。自然と不作とは、冷氣の爲に不作と" />
  <LINE TYPE="本文" X="315" Y="331" WIDTH="22" HEIGHT="125" CONF="0.859" ORDER="50" STRING="なるを云ふ。" />
  <LINE TYPE="本文" X="273" Y="1101" WIDTH="20" HEIGHT="34" CONF="0.524" ORDER="51" STRING="一七" />
  </PAGE>

