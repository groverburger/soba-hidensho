  <LINE TYPE="本文" X="1474" Y="479" WIDTH="31" HEIGHT="414" CONF="0.791" ORDER="18" STRING="第十章相塲引上げ大騒考の事" />
  <LINE TYPE="本文" X="1412" Y="311" WIDTH="30" HEIGHT="998" CONF="0.863" ORDER="19" STRING="一新商初てより、段々引上け、大騒ぎ出て、天井直段に成り、其日二俵三分迄出て行當り、其日の内" />
  <LINE TYPE="本文" X="1368" Y="313" WIDTH="32" HEIGHT="996" CONF="0.886" ORDER="20" STRING="に狂ひ、三俵二三分迄返す、此日の二俵三分に、心を付け考ふ可し。此米、又一兩日の内に、二俵半" />
  <LINE TYPE="本文" X="1325" Y="305" WIDTH="32" HEIGHT="1017" CONF="0.887" ORDER="21" STRING="六分迄通ふ者なれども、二俵三分迄引立勢なく、クラリ三俵臺へ返す者也。此處にて賣込也。急に二一" />
  <LINE TYPE="本文" X="1282" Y="311" WIDTH="32" HEIGHT="1005" CONF="0.868" ORDER="22" STRING="俵三分迄引上げ候米故、三四俵の内は、人気張詰め居る故、四俵臺へ下る時は、又々三俵へ買戻す者" />
  <LINE TYPE="本文" X="1238" Y="315" WIDTH="33" HEIGHT="993" CONF="0.891" ORDER="23" STRING="なれども、自然と買人なく、五六俵迄下る也。此時、乘米を考へ買入るゝ奢也。極めて三俵臺へ上る" />
  <LINE TYPE="本文" X="1195" Y="315" WIDTH="33" HEIGHT="987" CONF="0.880" ORDER="24" STRING="者也。是大通ひ也。次の月二俵三分を打越し一二分共上らば、油斷なく買入るべきなり、又次の月、" />
  <LINE TYPE="本文" X="1152" Y="314" WIDTH="30" HEIGHT="734" CONF="0.804" ORDER="25" STRING="三俵位二俵六七分に上留り候はゞ、思入に賣込むべし、是三位の秘傳也。" />
  <LINE TYPE="本文" X="1106" Y="324" WIDTH="35" HEIGHT="987" CONF="0.882" ORDER="26" STRING="今一ト天井直段後、大通ひの例を示さんに、十一月期の發會後、段々引上げて來て來て來て、假令ば、" />
  <LINE TYPE="本文" X="1064" Y="330" WIDTH="37" HEIGHT="983" CONF="0.864" ORDER="27" STRING="前場に九十五銭の高直を出して、其日の内に七十五銭迄下げたとするに、此日の九十五銭に能々心" />
  <LINE TYPE="本文" X="899" Y="149" WIDTH="25" HEIGHT="66" CONF="0.326" ORDER="28" STRING="十一" />
  <LINE TYPE="本文" X="880" Y="153" WIDTH="18" HEIGHT="71" CONF="0.304" ORDER="29" STRING="一□" />
  <LINE TYPE="本文" X="724" Y="270" WIDTH="16" HEIGHT="21" CONF="0.398" ORDER="30" STRING="第一" />
  <LINE TYPE="本文" X="700" Y="272" WIDTH="14" HEIGHT="19" CONF="0.371" ORDER="31" STRING="十" />
  <LINE TYPE="本文" X="652" Y="272" WIDTH="15" HEIGHT="21" CONF="0.431" ORDER="32" STRING="章" />
  <LINE TYPE="本文" X="627" Y="272" WIDTH="16" HEIGHT="22" CONF="0.412" ORDER="33" STRING="行" />
  <LINE TYPE="本文" X="602" Y="272" WIDTH="15" HEIGHT="22" CONF="0.450" ORDER="34" STRING="附" />
  <LINE TYPE="本文" X="578" Y="272" WIDTH="16" HEIGHT="22" CONF="0.412" ORDER="35" STRING="天" />
  <LINE TYPE="本文" X="554" Y="273" WIDTH="15" HEIGHT="21" CONF="0.473" ORDER="36" STRING="井" />
  <LINE TYPE="本文" X="530" Y="274" WIDTH="16" HEIGHT="20" CONF="0.425" ORDER="37" STRING="直" />
  <LINE TYPE="本文" X="508" Y="275" WIDTH="14" HEIGHT="19" CONF="0.500" ORDER="38" STRING="段" />
  <LINE TYPE="本文" X="487" Y="275" WIDTH="14" HEIGHT="18" CONF="0.485" ORDER="39" STRING="の" />
  <LINE TYPE="本文" X="465" Y="274" WIDTH="17" HEIGHT="20" CONF="0.454" ORDER="40" STRING="事" />
  <LINE TYPE="本文" X="901" Y="342" WIDTH="34" HEIGHT="976" CONF="0.887" ORDER="41" STRING="を付けて考へて見るがまい。此相塲、又々一兩日の内に、八十五六錢から九十錢一二錢位迄通ふ者" />
  <LINE TYPE="本文" X="858" Y="341" WIDTH="35" HEIGHT="975" CONF="0.899" ORDER="42" STRING="であるけれども、九十五錢とは引立勢ひなく、クラリと、又七十錢臺に下るものであるから、此處" />
  <LINE TYPE="本文" X="814" Y="328" WIDTH="36" HEIGHT="1006" CONF="0.896" ORDER="43" STRING="を賣るがよい、急に九十五銭の高直を九十一二錢迄見せた米であるから、七拾銭盤から六十銭五十" />
  <LINE TYPE="本文" X="772" Y="340" WIDTH="34" HEIGHT="984" CONF="0.900" ORDER="44" STRING="錢臺となつても、人気が高直覺へて、買墓へが多いから、五十錢臺へ下る時には、又々七八十錢臺" />
  <LINE TYPE="本文" X="729" Y="343" WIDTH="34" HEIGHT="971" CONF="0.910" ORDER="45" STRING="へ引上げる者であるけれども、自然と其買物が薄らひで、三四十錢二十錢迄も下げる者であるから、" />
  <LINE TYPE="本文" X="685" Y="335" WIDTH="35" HEIGHT="997" CONF="0.902" ORDER="46" STRING="此時、宜しく各地との直鞘、正米との比較等を考へ合せて利喰すべきである。此相塲は、定めて又" />
  <LINE TYPE="本文" X="641" Y="343" WIDTH="36" HEIGHT="986" CONF="0.896" ORDER="47" STRING="々七八十錢臺へ上るであらう、是を大通ひと稱へるのである。併し、是は一ト天井直段後の大通ひ" />
  <LINE TYPE="本文" X="599" Y="344" WIDTH="34" HEIGHT="982" CONF="0.901" ORDER="48" STRING="と云ふ者であつて、眞正の天井でないから、其次の月に、此九十五錢の月節、即ち最高直段を拔ひ" />
  <LINE TYPE="本文" X="554" Y="334" WIDTH="37" HEIGHT="1004" CONF="0.902" ORDER="49" STRING="て圓臺に押上げたならば、油斷なく買入れるがよい。そして、又次の月ドダ内の七八十錢位で上げ" />
  <LINE TYPE="本文" X="512" Y="343" WIDTH="36" HEIGHT="994" CONF="0.875" ORDER="50" STRING="留つたならば、ドシ〳〵賣込んで宜しい。是は、余の考へた三位傳の内であると。(右解釋の直段は、" />
  <LINE TYPE="本文" X="467" Y="338" WIDTH="34" HEIGHT="692" CONF="0.886" ORDER="51" STRING="説明の便宜上、假りに設けたのであるから、拘泥してはならない。)" />
  <LINE TYPE="本文" X="399" Y="500" WIDTH="34" HEIGHT="385" CONF="0.864" ORDER="52" STRING="第十一章行附天井直段の事" />
  <LINE TYPE="本文" X="338" Y="329" WIDTH="35" HEIGHT="1007" CONF="0.872" ORDER="53" STRING="一天井行附直段と云ふは、數月の内高下あり、段々五六拾俵も引上げ、其後可上とも可下とも知れ" />
  <LINE TYPE="本文" X="293" Y="328" WIDTH="36" HEIGHT="1004" CONF="0.813" ORDER="54" STRING="ぬ樣になり、又毎日十俵宛も必至〳〵と引上げ、賣買共に連れ落になり、大騒出る節、上留り年中行" />
  <LINE TYPE="本文" X="264" Y="1120" WIDTH="22" HEIGHT="37" CONF="0.327" ORDER="55" STRING="二三" />
