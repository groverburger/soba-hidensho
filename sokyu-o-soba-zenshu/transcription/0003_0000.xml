<PAGE IMAGENAME="0003_0000.jpg" WIDTH="2048" HEIGHT="1579">
  <LINE TYPE="本文" X="1790" Y="1398" WIDTH="26" HEIGHT="34" CONF="0.372" ORDER="0" STRING="同十二十一日" />
<LINE TYPE="本文" X="890" Y="495" WIDTH="33" HEIGHT="142" CONF="0.746" ORDER="1" STRING="凡例" />
  <LINE TYPE="本文" X="834" Y="343" WIDTH="35" HEIGHT="998" CONF="0.851" ORDER="2" STRING="一本書は翁家の秘襲なる自筆の稿本を原とし坊間の傳寫本を以て校正増補し、且註解を加へて其眞意" />
  <LINE TYPE="本文" X="790" Y="348" WIDTH="35" HEIGHT="991" CONF="0.889" ORDER="3" STRING="を發揮せんとを勉めたり。然れ共註者の不敏なる、恐らくは、翁が眞意の十一を傳ふる能はざらむ" />
  <LINE TYPE="本文" X="747" Y="337" WIDTH="37" HEIGHT="1020" CONF="0.835" ORDER="4" STRING="とを。特に驅引の妙用賣買の調子等に至つては、筆舌の能く盡す所にあらず、讀者、宜しく意を言" />
  <LINE TYPE="本文" X="704" Y="355" WIDTH="25" HEIGHT="145" CONF="0.846" ORDER="5" STRING="外に求むべし。" />
  <LINE TYPE="本文" X="661" Y="323" WIDTH="33" HEIGHT="877" CONF="0.774" ORDER="6" STRING="一本書記する所の月日は、皆大陰暦なり、又當地とあるは、荘内地方のとゝ知るべし。" />
  <LINE TYPE="本文" X="617" Y="321" WIDTH="37" HEIGHT="1047" CONF="0.878" ORDER="7" STRING="一本書の原理は、何れの地に於ても應用するとを得れども、翁は、立論の基礎を莊内地方に置きたる" />
  <LINE TYPE="本文" X="574" Y="343" WIDTH="37" HEIGHT="1010" CONF="0.871" ORDER="8" STRING="が故に、讀者本書の意味を明瞭に解するには。先づ莊内地方米商の慣習を知了するの必要あり、是一" />
  <LINE TYPE="本文" X="530" Y="346" WIDTH="31" HEIGHT="540" CONF="0.876" ORDER="9" STRING="特に、卷頭に酒田舊米會所の慣習を掲録せる所以也。" />
  <LINE TYPE="本文" X="485" Y="336" WIDTH="39" HEIGHT="1040" CONF="0.872" ORDER="10" STRING="一期米駈引の妙用を悟らむと欲せば、幾遍となく本書を繰返し精讀するとを要す。然らば、自然に相當" />
  <LINE TYPE="本文" X="444" Y="342" WIDTH="36" HEIGHT="1026" CONF="0.859" ORDER="11" STRING="塲の強弱を判別し、駈引の妙用に通することを得ん。特に賣買を仕掛け居る時に臨みては决して締み。" />
  <LINE TYPE="本文" X="400" Y="348" WIDTH="31" HEIGHT="655" CONF="0.877" ORDER="12" STRING="讀を怠る可からず、是れ相塲に對する注意を忽にせざる爲なり。" />
  <LINE TYPE="本文" X="341" Y="941" WIDTH="30" HEIGHT="318" CONF="0.702" ORDER="13" STRING="校註者復識" />
  </PAGE>

</OCRDATASET>