  <LINE TYPE="本文" X="1810" Y="336" WIDTH="24" HEIGHT="1086" CONF="0.390" ORDER="0" STRING="…………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………………" />
  <LINE TYPE="本文" X="1744" Y="1087" WIDTH="24" HEIGHT="43" CONF="0.436" ORDER="1" STRING="十六" />
  <LINE TYPE="本文" X="1700" Y="317" WIDTH="31" HEIGHT="977" CONF="0.773" ORDER="2" STRING="採れるとか、又採れないとか云事計りを考へて商を仕かけ、或は、賣買の駈引をするのは間違つて" />
  <LINE TYPE="本文" X="1655" Y="319" WIDTH="31" HEIGHT="985" CONF="0.891" ORDER="3" STRING="居る。是は、相場の大勢につかないで、相塲に逆ふと云者である。米價の高低は、極つて變ずる者" />
  <LINE TYPE="本文" X="1612" Y="320" WIDTH="31" HEIGHT="986" CONF="0.876" ORDER="4" STRING="であるから、算盤づく計りては行かない者で。極意は、天井と底と、人氣の滿欠に意を注ぐが肝腎" />
  <LINE TYPE="本文" X="1575" Y="320" WIDTH="23" HEIGHT="80" CONF="0.743" ORDER="5" STRING="である。" />
  <LINE TYPE="本文" X="1532" Y="245" WIDTH="19" HEIGHT="21" CONF="0.448" ORDER="6" STRING="宗" />
  <LINE TYPE="本文" X="1499" Y="245" WIDTH="18" HEIGHT="20" CONF="0.428" ORDER="7" STRING="久" />
  <LINE TYPE="本文" X="1467" Y="244" WIDTH="17" HEIGHT="20" CONF="0.396" ORDER="8" STRING="翁" />
  <LINE TYPE="本文" X="1436" Y="244" WIDTH="17" HEIGHT="19" CONF="0.360" ORDER="9" STRING="相" />
  <LINE TYPE="本文" X="1402" Y="243" WIDTH="18" HEIGHT="20" CONF="0.377" ORDER="10" STRING="塲" />
  <LINE TYPE="本文" X="1370" Y="244" WIDTH="17" HEIGHT="20" CONF="0.415" ORDER="11" STRING="全" />
  <LINE TYPE="本文" X="1337" Y="242" WIDTH="18" HEIGHT="21" CONF="0.436" ORDER="12" STRING="集" />
  <LINE TYPE="本文" X="1305" Y="242" WIDTH="17" HEIGHT="21" CONF="0.378" ORDER="13" STRING="上" />
  <LINE TYPE="本文" X="1515" Y="406" WIDTH="28" HEIGHT="47" CONF="0.365" ORDER="14" STRING="○" />
  <LINE TYPE="本文" X="1500" Y="466" WIDTH="32" HEIGHT="507" CONF="0.834" ORDER="16" STRING="第六十五章米商の秘傳氣を轉ずる事" />
  <LINE TYPE="本文" X="1438" Y="299" WIDTH="30" HEIGHT="999" CONF="0.866" ORDER="17" STRING="一高下有之其後保合の節、何となく弱く見へ、色々考へ、諸方引合すと雖も強味は見へず。此間に、" />
  <LINE TYPE="本文" X="1394" Y="294" WIDTH="32" HEIGHT="1003" CONF="0.868" ORDER="18" STRING="是非〳〵二三十俵方も引下くべき模樣故、此處にて賣らずんば後れになるべしと、頻りに賣氣進み立" />
  <LINE TYPE="本文" X="1351" Y="293" WIDTH="33" HEIGHT="1007" CONF="0.892" ORDER="19" STRING="候節、氣を轉じ買方に付くべし、是傳也。我至つて弱氣にて買方に付くと、甚だ危くならぬ事なれど" />
  <LINE TYPE="本文" X="1309" Y="291" WIDTH="32" HEIGHT="1007" CONF="0.902" ORDER="20" STRING="も、此書を守り、一分の存意を立てず買入るゝ時は、極めて利運也。是非上ぐべしと、買氣進み立候" />
  <LINE TYPE="本文" X="1265" Y="293" WIDTH="33" HEIGHT="1008" CONF="0.855" ORDER="21" STRING="節も、是又氣を轉じ賣る可し、米商の秘傳也。常々、此心持怠る可からず。我強氣の節は、人も強氣" />
  <LINE TYPE="本文" X="1228" Y="290" WIDTH="25" HEIGHT="311" CONF="0.864" ORDER="22" STRING="と思ふ可し。弱気の節も同じ。" />
  <LINE TYPE="本文" X="1179" Y="304" WIDTH="32" HEIGHT="992" CONF="0.875" ORDER="23" STRING="(釋)本章は、大高下した跡の保合相場の場合に處する、見込の立方を述べた者で、其意は、保合" />
  <LINE TYPE="本文" X="1135" Y="297" WIDTH="33" HEIGHT="1007" CONF="0.898" ORDER="24" STRING="相塲と云ふ者は、人心を陰氣にする者で、そこて諸人も弱氣に傾き、我も亦弱くなる者で、ドウヤ" />
  <LINE TYPE="本文" X="1091" Y="305" WIDTH="33" HEIGHT="992" CONF="0.861" ORDER="25" STRING="ラ間近い内に、二三十丁方も、是非下げる模様に見へるから、茲で賣らなければ賣塲がないと、頻" />
  <LINE TYPE="本文" X="909" Y="303" WIDTH="37" HEIGHT="1005" CONF="0.895" ORDER="26" STRING="りに賣度いことがあるが、こんな場合には、衆人の心も、我心と同様であるから、既に賣る可き丈は" />
  <LINE TYPE="本文" X="866" Y="311" WIDTH="36" HEIGHT="988" CONF="0.896" ORDER="27" STRING="賣て居て、隨て相場も人氣と共に下げる丈は下げて、陰を盡して居る塲合であるから、こんな所を" />
  <LINE TYPE="本文" X="823" Y="313" WIDTH="35" HEIGHT="986" CONF="0.910" ORDER="28" STRING="賣るのは馬鹿の骨頂で、寧ろ人氣の反對に買ふ可きである。我弱氣で、買ふと云ふとは、中々出來" />
  <LINE TYPE="本文" X="778" Y="302" WIDTH="37" HEIGHT="1010" CONF="0.902" ORDER="29" STRING="ない駈引であるが、此時こそ、自分の我意をガラリと捨てゝ、人気反動の機徴を察して買入れる時" />
  <LINE TYPE="本文" X="736" Y="314" WIDTH="35" HEIGHT="994" CONF="0.892" ORDER="30" STRING="は、果して利の付く者である。又、買氣の進む時も、此心得を以て反對に賣る可きである。是は米" />
  <LINE TYPE="本文" X="692" Y="307" WIDTH="31" HEIGHT="659" CONF="0.869" ORDER="31" STRING="商の秘傳で、返す〳〵、變ずる時分の人氣に雷同してはならぬ、" />
  <LINE TYPE="本文" X="625" Y="461" WIDTH="34" HEIGHT="571" CONF="0.884" ORDER="32" STRING="第六十六章買氣をはさみ賣方心得違の事" />
  <LINE TYPE="本文" X="563" Y="299" WIDTH="34" HEIGHT="1003" CONF="0.891" ORDER="33" STRING="一買氣をはさみ賣ると、大に心得違ひ也。假令ば、此米上る可けれども、晦日頃迄には當分強みある" />
  <LINE TYPE="本文" X="520" Y="299" WIDTH="35" HEIGHT="998" CONF="0.896" ORDER="34" STRING="まじく、此處にて少々賣付置き、利足落し、朔日二日頃買過すべしと、賣るとあり、甚だ心得違ひ也。" />
  <LINE TYPE="本文" X="476" Y="292" WIDTH="37" HEIGHT="1011" CONF="0.894" ORDER="35" STRING="決して、下ぐ可く思ふ頃より上る者也。是非下ぐ可しと賣付る時は、景気になれば、尚々其處にて買" />
  <LINE TYPE="本文" X="433" Y="291" WIDTH="36" HEIGHT="1013" CONF="0.898" ORDER="36" STRING="兼、一日二日と過る内、買後れて買入月に却つて賣方になる也。思入の通、月末には少々引下と雖も、" />
  <LINE TYPE="本文" X="389" Y="296" WIDTH="36" HEIGHT="1004" CONF="0.870" ORDER="37" STRING="此米今少々引下く可き間、来月に至り利足落候ても替るとある間敷と、米弱みに見へ候得ば、猶々、" />
  <LINE TYPE="本文" X="346" Y="293" WIDTH="31" HEIGHT="583" CONF="0.847" ORDER="38" STRING="買遅るゝ也。来月上と見定むる時は、唯買塲を待つべし。" />
  <LINE TYPE="本文" X="301" Y="304" WIDTH="37" HEIGHT="1001" CONF="0.842" ORDER="39" STRING="本章は、自分は、大根強氣であり乍ら、目前を掬ふと思つて、賣方してはならぬとの訓戒て" />
  <LINE TYPE="本文" X="274" Y="1092" WIDTH="20" HEIGHT="36" CONF="0.414" ORDER="40" STRING="八七" />
  <LINE TYPE="本文" X="205" Y="314" WIDTH="28" HEIGHT="1111" CONF="0.385" ORDER="41" STRING="一一一一" />
  </PAGE>

