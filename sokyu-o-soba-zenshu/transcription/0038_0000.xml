  <LINE TYPE="本文" X="1428" Y="265" WIDTH="16" HEIGHT="18" CONF="0.414" ORDER="4" STRING="城" />
  <LINE TYPE="本文" X="1396" Y="264" WIDTH="15" HEIGHT="19" CONF="0.393" ORDER="5" STRING="相" />
