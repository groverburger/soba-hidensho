  <LINE TYPE="本文" X="1773" Y="106" WIDTH="29" HEIGHT="1338" CONF="0.395" ORDER="1" STRING="一一一一一一、一、一、、一、一一、一一、一一、一一、一九、一、、一、、一一、一、一一、一、、一一、一、、一一、一、、一九一一九一一、一九一、一九一一一一九一一一九一一、一九、一九、一、一、一九一" />
  <LINE TYPE="本文" X="1493" Y="265" WIDTH="15" HEIGHT="19" CONF="0.379" ORDER="2" STRING="宗" />
