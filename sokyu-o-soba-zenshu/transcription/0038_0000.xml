  <LINE TYPE="本文" X="1662" Y="339" WIDTH="29" HEIGHT="957" CONF="0.774" ORDER="12" STRING="月に持越す場合には、買方は賣方に對し、損盆勘定の時に、一ケ月に何程として利足と云ふ者を" />
  <LINE TYPE="本文" X="1617" Y="329" WIDTH="31" HEIGHT="953" CONF="0.850" ORDER="13" STRING="拂はなければならぬ。其詳しいとは、卷首の酒田米會所の商慣習と云ふ所に、説いて置いた。" />
  <LINE TYPE="本文" X="1574" Y="338" WIDTH="31" HEIGHT="980" CONF="0.878" ORDER="14" STRING="本章は、買方の駈引を述べた者であるが、其意味は、底を買付けて利の乘つた米少し下に逢ふ時は" />
  <LINE TYPE="本文" X="1530" Y="330" WIDTH="32" HEIGHT="997" CONF="0.905" ORDER="15" STRING="先日上げた時利喰したならば、利足を損せずに済んで仕舞つたのに、斯う下げぢやー来月に持越す" />
  <LINE TYPE="本文" X="1487" Y="328" WIDTH="31" HEIGHT="1007" CONF="0.902" ORDER="16" STRING="時は、利足を損さなければならないと、後悔するとある者だが、夫は心得違ひである。底から上げ" />
  <LINE TYPE="本文" X="1444" Y="339" WIDTH="31" HEIGHT="989" CONF="0.884" ORDER="17" STRING="出す米は、十俵位も上げなければ、天井にならない者であるから、少くとも、一ト落即ち三四俵位" />
  <LINE TYPE="本文" X="1402" Y="330" WIDTH="27" HEIGHT="770" CONF="0.868" ORDER="18" STRING="も上げない中は、決して賣てはならぬ。却つて、買重ねてもよい者である。" />
  <LINE TYPE="本文" X="1332" Y="484" WIDTH="31" HEIGHT="570" CONF="0.880" ORDER="19" STRING="第三十五章燈火消えんとして光増心の事" />
  <LINE TYPE="本文" X="1269" Y="319" WIDTH="31" HEIGHT="1005" CONF="0.890" ORDER="20" STRING="一霜月限、天井直段近く、買米有之節、何等の不時申出し、商も不出急上げになるとあり。二三百" />
  <LINE TYPE="本文" X="1227" Y="317" WIDTH="30" HEIGHT="1002" CONF="0.900" ORDER="21" STRING="兩買入ある人も、金高買入ざるを後悔し、殘念に思ひ、少々引下げ候節買入る可く思ふ内に、毎日引" />
  <LINE TYPE="本文" X="1183" Y="313" WIDTH="31" HEIGHT="1011" CONF="0.876" ORDER="22" STRING="上げ落引出て、二三日以前の商も、最早落になる樣になる故、後れたれども半落位は取るべしと思ひ、" />
  <LINE TYPE="本文" X="1139" Y="314" WIDTH="32" HEIGHT="1005" CONF="0.887" ORDER="23" STRING="上げ詰め候米を買重ぬることあり、甚だ宜しからず、愼むべき也。此處買入利を取るとなし。假令、百" />
  <LINE TYPE="本文" X="1096" Y="314" WIDTH="32" HEIGHT="1006" CONF="0.899" ORDER="24" STRING="兩買入ても。初の安買二百兩の利分此爲めに消へ利分なく、却つて不足出る也。此處にて買入るゝ時" />
  <LINE TYPE="本文" X="1054" Y="314" WIDTH="30" HEIGHT="1006" CONF="0.868" ORDER="25" STRING="は、又々、少々引下げ候處にて買重る心に成るなり、又上方相場種々申來るとも、其騒々敷處にて決" />
  <LINE TYPE="本文" X="902" Y="321" WIDTH="31" HEIGHT="999" CONF="0.888" ORDER="26" STRING="して買はざる者也、心得べし。此上げは、陽に登り詰め、此上へ何程上るも知れぬ樣になるなり。是" />
  <LINE TYPE="本文" X="859" Y="303" WIDTH="33" HEIGHT="1025" CONF="0.850" ORDER="27" STRING="燈火消えんとして、光増の心也。是非共、明日利分と見定むると雖も、買はざる者也。此處、米も強" />
  <LINE TYPE="本文" X="816" Y="311" WIDTH="30" HEIGHT="871" CONF="0.834" ORDER="28" STRING="く人気も強く、強氣の人一倍募る處也。此處にて行付天井を見ると肝要也、考ふ可し。" />
  <LINE TYPE="本文" X="773" Y="331" WIDTH="31" HEIGHT="994" CONF="0.867" ORDER="29" STRING="(釋)本章は、天井直段近く、猫子も杓子も強氣の時、我も其渦中に卷き込まれざる用心を述べた" />
  <LINE TYPE="本文" X="730" Y="340" WIDTH="24" HEIGHT="102" CONF="0.881" ORDER="30" STRING="者である。" />
  <LINE TYPE="本文" X="687" Y="335" WIDTH="30" HEIGHT="986" CONF="0.885" ORDER="31" STRING="偖、霜月限、天井直段の時機も近付いて來て、我米に利の乘つて居る時、大した取組も出來ないで、" />
  <LINE TYPE="本文" X="643" Y="334" WIDTH="31" HEIGHT="990" CONF="0.887" ORDER="32" STRING="相塲のみ急に上るとがある。百枚買入ある人も、二百枚も三百枚も仕入れないとを後悔し、残念に" />
  <LINE TYPE="本文" X="600" Y="336" WIDTH="30" HEIGHT="994" CONF="0.901" ORDER="33" STRING="思ふて少し引下げた時に買足そふと思ふて居る内に、毎日幾らかづゝ引上げ、二三日前に買つた商" />
  <LINE TYPE="本文" X="556" Y="338" WIDTH="31" HEIGHT="991" CONF="0.904" ORDER="34" STRING="内も、多分の利が付くから、少し買後れだが、此邊で買つても、未だ少しは取れるだらうと思つて、" />
  <LINE TYPE="本文" X="513" Y="334" WIDTH="31" HEIGHT="990" CONF="0.869" ORDER="35" STRING="最早上詰め、天井際になつて居るも知らないて、買重ねるとある者であるが、併し是は、愼むべき" />
  <LINE TYPE="本文" X="470" Y="336" WIDTH="30" HEIGHT="980" CONF="0.897" ORDER="36" STRING="とてあつて、此んな處を買つては、決して利盆となることがない者である。假令、百枚買つても、" />
  <LINE TYPE="本文" X="427" Y="337" WIDTH="31" HEIGHT="981" CONF="0.907" ORDER="37" STRING="初めの安買二百枚の利は、此高買の爲めに消え失せて、其内相塲が少し下がると、利盆處か、却つ" />
  <LINE TYPE="本文" X="384" Y="334" WIDTH="31" HEIGHT="998" CONF="0.864" ORDER="38" STRING="て損の立つ者である。斯んな處で少しても買ふと、負惜みで、少し下げた處で、又々買ならし度な" />
  <LINE TYPE="本文" X="339" Y="337" WIDTH="32" HEIGHT="987" CONF="0.883" ORDER="39" STRING="る者だ。又斯ふ云ふ塲合に、上方相場の高報、又種々、上の原因を報知して來ると、人氣が引立つ" />
  <LINE TYPE="本文" X="297" Y="339" WIDTH="30" HEIGHT="974" CONF="0.857" ORDER="40" STRING="て騷かしくなる者だが、其騒々敷い處では决して買ふまじき者である。宜く心得て置くが宜しい。" />
  <LINE TYPE="本文" X="262" Y="1112" WIDTH="19" HEIGHT="39" CONF="0.493" ORDER="41" STRING="四七" />
