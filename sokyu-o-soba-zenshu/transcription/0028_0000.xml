  <LINE TYPE="本文" X="1715" Y="1108" WIDTH="20" HEIGHT="37" CONF="0.347" ORDER="10" STRING="二六" />
<LINE TYPE="本文" X="1670" Y="335" WIDTH="31" HEIGHT="979" CONF="0.868" ORDER="11" STRING="何月甲に該当する共急に、百俵から百廿俵位も、甲月に急上げすれば、跡に上なく、夫が天井とな" />
  <LINE TYPE="本文" X="1627" Y="332" WIDTH="31" HEIGHT="981" CONF="0.886" ORDER="12" STRING="つて下に向ふ者である。併し、五六十俵の上げに留まれば、天井直段としては、上げが足りないか" />
  <LINE TYPE="本文" X="1584" Y="323" WIDTH="31" HEIGHT="1001" CONF="0.899" ORDER="13" STRING="ら、丙月丁月と二三ヶ月も引續き上るであらふ。又此外に年塞りと云ふとがある、此繰樣も、本書" />
  <LINE TYPE="本文" X="1540" Y="331" WIDTH="30" HEIGHT="985" CONF="0.876" ORDER="14" STRING="の卷末に述べてあるが、其塞りが、西の方に廻る年は、是亦、八、九、十、十一月頃迄疑なく、上" />
  <LINE TYPE="本文" X="1496" Y="332" WIDTH="31" HEIGHT="981" CONF="0.909" ORDER="15" STRING="る者であるから、六月から、油斷なく買入れて置くが宜しい。尤、此十一月頃に天井を出した後て、" />
  <LINE TYPE="本文" X="1453" Y="323" WIDTH="31" HEIGHT="1000" CONF="0.906" ORDER="16" STRING="三四十俵位も下げて保合つて居る内、其年、又は翌春、三月正月十一月甲に廻る年に廻り合せる時" />
  <LINE TYPE="本文" X="1410" Y="327" WIDTH="31" HEIGHT="984" CONF="0.854" ORDER="17" STRING="には、其時、又々五六十俵位の上げがある者だから、其事を知つて居れば、秋春往來に儲けるとが" />
  <LINE TYPE="本文" X="1367" Y="313" WIDTH="30" HEIGHT="994" CONF="0.874" ORDER="18" STRING="出來るから、豫てより、心得て置くが宜しい。本節は、七月甲に當る年の經驗を述べた者である。" />
  <LINE TYPE="本文" X="1324" Y="312" WIDTH="31" HEIGHT="996" CONF="0.889" ORDER="19" STRING="天井直段の節、初年百俵より百二十俵百六十俵百八十俵位の天井出る共、二年目は、初年より不足、" />
  <LINE TYPE="本文" X="1280" Y="311" WIDTH="31" HEIGHT="1005" CONF="0.861" ORDER="20" STRING="三年目は、尚不足と心得べし。翌春下げ候節も、右に準じ下不足也。上下の月數俵數、共に位付の書" />
  <LINE TYPE="本文" X="1236" Y="311" WIDTH="32" HEIGHT="1002" CONF="0.892" ORDER="21" STRING="にて見知るべし。三位の頭月になりても上からず、却て三四十俵、急に下るとあり、間違と思ふ可か" />
  <LINE TYPE="本文" X="1194" Y="314" WIDTH="31" HEIGHT="999" CONF="0.884" ORDER="22" STRING="らず、丙丁に上ると疑なし。五月、三月、正月三位に廻る時は、新米の的なし。然れども、其年何程" />
  <LINE TYPE="本文" X="1153" Y="304" WIDTH="27" HEIGHT="617" CONF="0.863" ORDER="23" STRING="上作にても、賣方すべからず。三十俵面らならば買ふ可し。" />
  <LINE TYPE="本文" X="1109" Y="321" WIDTH="28" HEIGHT="681" CONF="0.881" ORDER="24" STRING="本節は、天井直段を出す時の割合の概要を説いた者である。" />
  <LINE TYPE="本文" X="1063" Y="329" WIDTH="32" HEIGHT="997" CONF="0.847" ORDER="25" STRING="偖、天井直段を出す時の常の姿を云へば、初の年、百俵乃至百八十俵位の上げあつても、二年目は初" />
  <LINE TYPE="本文" X="907" Y="316" WIDTH="34" HEIGHT="999" CONF="0.876" ORDER="26" STRING="年よりも上の割合不足、三年目は、又二年目より尚一層上げの割合少い者である。翌春の下けも、" />
  <LINE TYPE="本文" X="864" Y="327" WIDTH="35" HEIGHT="995" CONF="0.878" ORDER="27" STRING="此上の割合に準じて、初年、二年、三年と段々下げ不足てある。其證據は、卷末に載せてある、直" />
  <LINE TYPE="本文" X="820" Y="330" WIDTH="30" HEIGHT="554" CONF="0.859" ORDER="28" STRING="段付に明瞭てあるから、繰つて見て大様を知るがよい。" />
  <LINE TYPE="本文" X="776" Y="333" WIDTH="35" HEIGHT="980" CONF="0.909" ORDER="29" STRING="又、三位の頭月なる甲月になつても上らず、却つて三四十俵も逆に下ることあるけれ共、丙月丁月に" />
  <LINE TYPE="本文" X="733" Y="332" WIDTH="35" HEIGHT="988" CONF="0.881" ORDER="30" STRING="は必らず上る者であるから、間違と思はぬがよい。併し、甲の繰合せが、五月か三月か將亦正月に" />
  <LINE TYPE="本文" X="689" Y="321" WIDTH="35" HEIGHT="1013" CONF="0.860" ORDER="31" STRING="廻る時には、相場の見当は付け悪いから、思惑を立てるとは六ケ敷いが、是等の年は、上作でも賣" />
  <LINE TYPE="本文" X="645" Y="325" WIDTH="31" HEIGHT="700" CONF="0.891" ORDER="32" STRING="方しない者である、三十俵臺の米ならば、寧ろ買思惑すべきである。" />
  <LINE TYPE="本文" X="576" Y="481" WIDTH="34" HEIGHT="478" CONF="0.819" ORDER="33" STRING="第十三章冬中天井六月急下げの事" />
  <LINE TYPE="本文" X="492" Y="266" WIDTH="12" HEIGHT="15" CONF="0.386" ORDER="34" STRING="の" />
  <LINE TYPE="本文" X="469" Y="264" WIDTH="16" HEIGHT="18" CONF="0.438" ORDER="35" STRING="事" />
  <LINE TYPE="本文" X="516" Y="314" WIDTH="32" HEIGHT="1015" CONF="0.856" ORDER="36" STRING="一冬中天井直段後の下相塲は、四分半不作年は、翌春迄人氣張詰め下らざる也。船々買急かず、土用" />
  <LINE TYPE="本文" X="471" Y="307" WIDTH="33" HEIGHT="861" CONF="0.817" ORDER="37" STRING="中照込み、田作見事、御藏米出不足、船不足旁、人氣惡敷なり、六月急下になるなり。" />
  <LINE TYPE="本文" X="428" Y="320" WIDTH="32" HEIGHT="795" CONF="0.829" ORDER="38" STRING="本章は、第九章は、第九章の一節と同意で、冬天井の夏下げを説いた者である。" />
  <LINE TYPE="本文" X="386" Y="328" WIDTH="33" HEIGHT="999" CONF="0.851" ORDER="39" STRING="御藏米出不足とは、輸出米の少數を云ふた者で、船不足は、入船不足の意て、茲には、買人の少き" />
  <LINE TYPE="本文" X="343" Y="342" WIDTH="24" HEIGHT="169" CONF="0.886" ORDER="40" STRING="を云ふのである。" />
