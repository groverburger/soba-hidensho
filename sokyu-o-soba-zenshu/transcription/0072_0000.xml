  <LINE TYPE="本文" X="1385" Y="254" WIDTH="16" HEIGHT="19" CONF="0.372" ORDER="5" STRING="全" />
  <LINE TYPE="本文" X="1351" Y="253" WIDTH="18" HEIGHT="19" CONF="0.399" ORDER="6" STRING="集" />
  <LINE TYPE="本文" X="1321" Y="253" WIDTH="15" HEIGHT="18" CONF="0.379" ORDER="7" STRING="下" />
  <LINE TYPE="本文" X="1287" Y="253" WIDTH="15" HEIGHT="17" CONF="0.397" ORDER="8" STRING="卷" />
  <LINE TYPE="本文" X="1757" Y="1108" WIDTH="20" HEIGHT="51" CONF="0.443" ORDER="9" STRING="一一四" />
  <LINE TYPE="本文" X="1714" Y="323" WIDTH="30" HEIGHT="977" CONF="0.798" ORDER="10" STRING="延ばしの高も决して少額ではないのだが、凡べて、上作が二三年續く時は、不足した時の心持を占" />
  <LINE TYPE="本文" X="1668" Y="329" WIDTH="32" HEIGHT="992" CONF="0.867" ORDER="11" STRING="れて、需要者は冠婚喪祭の祝ひ事は勿論、日常の生活に至る迄、悉く米食の傾向を生ずる者で、此" />
  <LINE TYPE="本文" X="1626" Y="327" WIDTH="31" HEIGHT="992" CONF="0.871" ORDER="12" STRING="額も又決して少くはない者である。故に、ケ樣の年柄は、一兩年の内、反對に供給米の欠乏を來す" />
  <LINE TYPE="本文" X="1588" Y="325" WIDTH="25" HEIGHT="483" CONF="0.905" ORDER="13" STRING="もので、隨つて意想外の高直を顯すとがある。" />
  <LINE TYPE="本文" X="1540" Y="328" WIDTH="30" HEIGHT="996" CONF="0.830" ORDER="14" STRING="近來は、内國米不作の時は、外國米の輸入に因て、供給の不足を補ふとが出來るが、夫でも、米價" />
  <LINE TYPE="本文" X="1498" Y="315" WIDTH="29" HEIGHT="864" CONF="0.876" ORDER="15" STRING="は内國不作に比例して上る者であるから、本章を心得て置いて、駈引すべきである。" />
  <LINE TYPE="本文" X="1428" Y="474" WIDTH="31" HEIGHT="595" CONF="0.842" ORDER="16" STRING="第十九章足らぬは餘る餘るは足らぬと申事" />
  <LINE TYPE="本文" X="1365" Y="313" WIDTH="30" HEIGHT="998" CONF="0.865" ORDER="17" STRING="一足らぬ物は餘る、餘る物は足らぬ、と申とあり。但し、多き物は、諸人澤山と心得、油斷して覺悟" />
  <LINE TYPE="本文" X="1321" Y="315" WIDTH="31" HEIGHT="991" CONF="0.886" ORDER="18" STRING="せず、夫故極意不足する也。不足なる物は、人々、油斷なく覺悟して調のへ置く故、極意は餘る也。" />
  <LINE TYPE="本文" X="1278" Y="317" WIDTH="31" HEIGHT="988" CONF="0.881" ORDER="19" STRING="(釋)不作の年は、諸人用心覺悟して、目前に需要なき米迄も買貯へる氣になり、又、買思惑人の" />
  <LINE TYPE="本文" X="1233" Y="321" WIDTH="33" HEIGHT="990" CONF="0.868" ORDER="20" STRING="顯はるゝのみならず、農家の如きは、賣惜んで中々手放さない者で、隨て、市塲に出廻り高不足す" />
  <LINE TYPE="本文" X="1190" Y="324" WIDTH="32" HEIGHT="980" CONF="0.878" ORDER="21" STRING="る者だが、翌春になつて、麥作も好况、順氣立直る時は、そろ〳〵不氣配となつて賣人も顯はれ、" />
  <LINE TYPE="本文" X="1147" Y="322" WIDTH="32" HEIGHT="971" CONF="0.872" ORDER="22" STRING="現米が、市場に出廻り、加之、七八月照込み強く、上作の見込立つ時は、正米一度に出廻つて、一" />
  <LINE TYPE="本文" X="1105" Y="312" WIDTH="30" HEIGHT="938" CONF="0.838" ORDER="23" STRING="時市塲に堆積する者である。尚、本書上卷、第五十五章、六月崩しの項を參照するがよい。" />
  <LINE TYPE="本文" X="896" Y="462" WIDTH="36" HEIGHT="508" CONF="0.846" ORDER="24" STRING="第二十章人の商を羨むべからざる事" />
  <LINE TYPE="本文" X="841" Y="297" WIDTH="24" HEIGHT="328" CONF="0.891" ORDER="25" STRING="一人の商を、羨敷思ふ可からず。" />
  <LINE TYPE="本文" X="789" Y="305" WIDTH="34" HEIGHT="991" CONF="0.843" ORDER="26" STRING="しはしし今、無と思ふ時は、其時の相場の位を辨へず、唯羨ましく思ふ心計りにてする故、手違ひになる也。" />
  <LINE TYPE="本文" X="749" Y="301" WIDTH="30" HEIGHT="809" CONF="0.870" ORDER="27" STRING="八木虎之卷に曰く、羨みの賣買は愼むべき者也と、本章の意味である。" />
  <LINE TYPE="本文" X="678" Y="460" WIDTH="32" HEIGHT="439" CONF="0.886" ORDER="28" STRING="第二十一章腹立売買不可致事" />
  <LINE TYPE="本文" X="619" Y="297" WIDTH="28" HEIGHT="557" CONF="0.870" ORDER="29" STRING="一腹立賣、腹立買、決してすべからず、大に愼むべし。" />
  <LINE TYPE="本文" X="571" Y="308" WIDTH="33" HEIGHT="996" CONF="0.893" ORDER="30" STRING="(釋)相塲の見込を立てるには、理想的に據るべき者で、決して情的に亘てはならぬと云とは、前" />
  <LINE TYPE="本文" X="527" Y="305" WIDTH="35" HEIGHT="1011" CONF="0.874" ORDER="31" STRING="章にも、屡〻説て置たが、此人の商を羨ましく思ふて賣買をすると、亦自分の商が、餘り不手合續一" />
  <LINE TYPE="本文" X="485" Y="312" WIDTH="32" HEIGHT="992" CONF="0.874" ORDER="32" STRING="きの為め、腹立の餘り賣買するなんどは、皆相塲の見込を立てるでなくつて、一時の感情に走つ" />
  <LINE TYPE="本文" X="447" Y="310" WIDTH="27" HEIGHT="485" CONF="0.862" ORDER="33" STRING="賣買するのであるから、大に愼むべきとである。" />
  <LINE TYPE="本文" X="372" Y="456" WIDTH="34" HEIGHT="718" CONF="0.834" ORDER="34" STRING="第二十二章天井直段底直段三年続き夫より變ずる事" />
  <LINE TYPE="本文" X="319" Y="314" WIDTH="29" HEIGHT="666" CONF="0.800" ORDER="35" STRING="一天井直段、底直段、三ケ年續き、夫より變ずるもの也、疑なし。" />
  <LINE TYPE="本文" X="276" Y="1089" WIDTH="21" HEIGHT="58" CONF="0.424" ORDER="36" STRING="一一五" />
