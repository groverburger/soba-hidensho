<PAGE IMAGENAME="page_00020.jpg" WIDTH="1525" HEIGHT="1024">
  <LINE TYPE="本文" X="1291" Y="126" WIDTH="43" HEIGHT="787" CONF="0.886" ORDER="0" STRING="玉ふ理は多きを売て安をかふ米商内の大秘密なり" />
  <LINE TYPE="本文" X="1239" Y="121" WIDTH="39" HEIGHT="801" CONF="0.882" ORDER="1" STRING="一三刻の音下にむかふ商内はかねの王主でるいづみとはしと" />
  <LINE TYPE="本文" X="1186" Y="276" WIDTH="36" HEIGHT="458" CONF="0.757" ORDER="2" STRING="一三割高下驚やらずむかふべし" />
  <LINE TYPE="本文" X="1198" Y="721" WIDTH="23" HEIGHT="61" CONF="0.317" ORDER="3" STRING="天明本" />
  <LINE TYPE="本文" X="1132" Y="119" WIDTH="36" HEIGHT="794" CONF="0.873" ORDER="4" STRING="二刻から三刻当下のある時はいつでも米にむかふ理としれ" />
  <LINE TYPE="本文" X="1073" Y="281" WIDTH="38" HEIGHT="317" CONF="0.805" ORDER="5" STRING="損商内不応ならすべし" />
  <LINE TYPE="本文" X="1016" Y="111" WIDTH="40" HEIGHT="806" CONF="0.872" ORDER="6" STRING="一桶商力も平商ゆもみな釣のゑを喰せておいて釣等ぐるなり" />
  <LINE TYPE="本文" X="961" Y="115" WIDTH="38" HEIGHT="795" CONF="0.907" ORDER="7" STRING="三割の音了に徳は転変し損はならすが秘密なりけり" />
  <LINE TYPE="本文" X="906" Y="110" WIDTH="38" HEIGHT="807" CONF="0.783" ORDER="8" STRING="万人が万ながら強気ならたわけになりて米を売べし" />
  <LINE TYPE="本文" X="856" Y="277" WIDTH="38" HEIGHT="404" CONF="0.839" ORDER="9" STRING="米大崩大変不可驚可買天明本" />
  <LINE TYPE="本文" X="801" Y="112" WIDTH="38" HEIGHT="805" CONF="0.851" ORDER="10" STRING="野も山も皆いてめんに弱気ならあほうになりて米を買べし" />
  <LINE TYPE="本文" X="696" Y="106" WIDTH="43" HEIGHT="808" CONF="0.791" ORDER="11" STRING="分別にも思案もいらぬ子ひ有は人捨こる米くつれなり" />
  <LINE TYPE="本文" X="689" Y="513" WIDTH="19" HEIGHT="110" CONF="0.310" ORDER="12" STRING="◯五日通半ヨメス" />
<LINE TYPE="本文" X="646" Y="117" WIDTH="44" HEIGHT="790" CONF="0.892" ORDER="13" STRING="いつとても買落城の弱とらげこはことこうを買みごらいこゝ" />
  <LINE TYPE="本文" X="592" Y="115" WIDTH="43" HEIGHT="799" CONF="0.874" ORDER="14" STRING="いつとても売落城の音とうげこはいとこらを売がごくいて" />
  <LINE TYPE="本文" X="538" Y="117" WIDTH="37" HEIGHT="534" CONF="0.730" ORDER="15" STRING="豊卑のくずるゝ米は買みよし尚き" />
  <LINE TYPE="本文" X="564" Y="653" WIDTH="23" HEIGHT="273" CONF="0.784" ORDER="16" STRING="をまはて立耳はられ" />
  <LINE TYPE="本文" X="543" Y="654" WIDTH="23" HEIGHT="272" CONF="0.796" ORDER="17" STRING="どころをまはてうるべし" />
  <LINE TYPE="本文" X="478" Y="117" WIDTH="41" HEIGHT="799" CONF="0.896" ORDER="18" STRING="米やすく人気の弱き日は買て人気の強き書き日そこる" />
  <LINE TYPE="本文" X="419" Y="115" WIDTH="49" HEIGHT="798" CONF="0.874" ORDER="19" STRING="一只こめは人気の弱気日は買て人気の強気るにとうるべし" />
  <LINE TYPE="本文" X="365" Y="114" WIDTH="47" HEIGHT="800" CONF="0.863" ORDER="20" STRING="一腰は春二刻音下にむかふべし夏は三刻に花にむかにむかに" />
  <LINE TYPE="本文" X="312" Y="116" WIDTH="43" HEIGHT="802" CONF="0.880" ORDER="21" STRING="千人が千人ながら弱けるはかへ万人強き日にそうるべし" />
  <LINE TYPE="本文" X="257" Y="238" WIDTH="39" HEIGHT="267" CONF="0.759" ORDER="22" STRING="三俵鞘直照可レ逆" />
  <LINE TYPE="本文" X="280" Y="511" WIDTH="21" HEIGHT="62" CONF="0.525" ORDER="23" STRING="天明本" />
  <LINE TYPE="本文" X="279" Y="581" WIDTH="24" HEIGHT="296" CONF="0.765" ORDER="24" STRING="二十一日夜十者曰夜生者曰此事" />
  <LINE TYPE="本文" X="258" Y="583" WIDTH="26" HEIGHT="291" CONF="0.798" ORDER="25" STRING="一世後を法とする故三倍は一刻半" />
  <LINE TYPE="本文" X="201" Y="112" WIDTH="46" HEIGHT="804" CONF="0.813" ORDER="26" STRING="上流理とな人ごとに随て医士さやにものにはこの種まひ申" />
