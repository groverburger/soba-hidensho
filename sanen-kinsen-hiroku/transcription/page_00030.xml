  <LINE TYPE="本文" X="1291" Y="126" WIDTH="39" HEIGHT="268" CONF="0.808" ORDER="0" STRING="の害合ありくるべし" />
  <LINE TYPE="本文" X="1237" Y="112" WIDTH="41" HEIGHT="799" CONF="0.839" ORDER="1" STRING="世の中積のこと弱気に八分に十八里にては強気には" />
  <LINE TYPE="本文" X="1184" Y="111" WIDTH="39" HEIGHT="801" CONF="0.830" ORDER="2" STRING="書分誰とつもる是こがひに勝負なしの中黒り続なる" />
  <LINE TYPE="本文" X="1128" Y="112" WIDTH="42" HEIGHT="801" CONF="0.874" ORDER="3" STRING="べし右強気の功かくの如しさて植はけより早魃風" />
  <LINE TYPE="本文" X="1074" Y="118" WIDTH="38" HEIGHT="788" CONF="0.892" ORDER="4" STRING="局の天災もなく十分の世の中といふは百年に三箇年な" />
  <LINE TYPE="本文" X="1017" Y="116" WIDTH="38" HEIGHT="791" CONF="0.877" ORDER="5" STRING="らではなるべからず我国豊卑なりとても東西南北の国" />
  <LINE TYPE="本文" X="959" Y="116" WIDTH="40" HEIGHT="790" CONF="0.916" ORDER="6" STRING="は吹こたる国もあるべし前一箇目の豊平を見て日本" />
  <LINE TYPE="本文" X="903" Y="111" WIDTH="42" HEIGHT="806" CONF="0.897" ORDER="7" STRING="〽国中よかるべしとかならず〳〵思ふへにらず惣じて下直" />
  <LINE TYPE="本文" X="853" Y="116" WIDTH="41" HEIGHT="796" CONF="0.882" ORDER="8" STRING="なる国よりさきへあがる物なり老ふべし買方にはすき" />
  <LINE TYPE="本文" X="798" Y="115" WIDTH="40" HEIGHT="796" CONF="0.874" ORDER="9" STRING="ならし物などを買あげて米をあくる理もあたが" />
  <LINE TYPE="本文" X="691" Y="92" WIDTH="48" HEIGHT="823" CONF="0.866" ORDER="10" STRING="うりには天性の理をいた広あり外に一理もなし買方に" />
  <LINE TYPE="本文" X="639" Y="108" WIDTH="37" HEIGHT="459" CONF="0.859" ORDER="11" STRING="一刻の強みあること能々差ふべし" />
  <LINE TYPE="本文" X="588" Y="266" WIDTH="41" HEIGHT="177" CONF="0.855" ORDER="12" STRING="弱気の功" />
  <LINE TYPE="本文" X="533" Y="107" WIDTH="42" HEIGHT="793" CONF="0.604" ORDER="14" STRING="一大高直段の耳々□酒など御目あまいは" />
  <LINE TYPE="本文" X="471" Y="110" WIDTH="46" HEIGHT="802" CONF="0.833" ORDER="15" STRING="一事仰出シのあるべし其外□また町中御勘門など仰" />
  <LINE TYPE="本文" X="411" Y="114" WIDTH="40" HEIGHT="398" CONF="0.837" ORDER="16" STRING="一出のあるべし是また老ふべし" />
  <LINE TYPE="本文" X="354" Y="111" WIDTH="50" HEIGHT="798" CONF="0.879" ORDER="17" STRING="或は吹もせぬ風を吹たりといひすこしの破損も火分のや" />
  <LINE TYPE="本文" X="302" Y="108" WIDTH="48" HEIGHT="801" CONF="0.878" ORDER="18" STRING="へ北にいつはり買〆などいたす年も日本は神国にて正通" />
  <LINE TYPE="本文" X="244" Y="111" WIDTH="55" HEIGHT="797" CONF="0.861" ORDER="19" STRING="一をもとする団故天性の天よりもあるべし強気の風雨" />
  <LINE TYPE="本文" X="191" Y="111" WIDTH="54" HEIGHT="796" CONF="0.834" ORDER="20" STRING="のいひたり尤なれば船に船に船に船に気を見てほし候" />
