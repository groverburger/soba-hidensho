<PAGE IMAGENAME="page_00032.jpg" WIDTH="1525" HEIGHT="1024">
  <LINE TYPE="本文" X="1272" Y="111" WIDTH="42" HEIGHT="805" CONF="0.863" ORDER="0" STRING="今の世まか仰して対して遅れけれけれを見ずに歎の前はこまに葉文" />
  <LINE TYPE="本文" X="1223" Y="111" WIDTH="38" HEIGHT="802" CONF="0.895" ORDER="1" STRING="索の坂やまり、へるも見えてまつときはなしに事あやまりおほきを法に" />
  <LINE TYPE="本文" X="1170" Y="108" WIDTH="39" HEIGHT="806" CONF="0.898" ORDER="2" STRING="左てと春買にかくる時は左とへにいふ一歩千里のたがひとなりたすけと" />
  <LINE TYPE="本文" X="1115" Y="106" WIDTH="39" HEIGHT="810" CONF="0.882" ORDER="3" STRING="是ならずしてかへりておほきなる木やまちとなるべし玉づれ四五箇年" />
  <LINE TYPE="本文" X="1053" Y="113" WIDTH="46" HEIGHT="795" CONF="0.875" ORDER="4" STRING="娘なこまり人々の写してもたるゝ本どもあま老かりみけ”ひきかへ差へく" />
  <LINE TYPE="本文" X="999" Y="111" WIDTH="41" HEIGHT="802" CONF="0.892" ORDER="5" STRING="らへみよしとおもはなく方をあげて出生とはならぬされとかく申おの" />
  <LINE TYPE="本文" X="942" Y="106" WIDTH="42" HEIGHT="809" CONF="0.878" ORDER="6" STRING="逢此道にいりそめてより木まこのとしをつまされは猶牛田大介も" />
  <LINE TYPE="本文" X="889" Y="115" WIDTH="40" HEIGHT="794" CONF="0.889" ORDER="7" STRING="とえらまれこまにたがひたるもあらむかとおそるゝになむ具眼の人こそ" />
  <LINE TYPE="本文" X="842" Y="116" WIDTH="34" HEIGHT="792" CONF="0.864" ORDER="8" STRING="もしさるものば公な六もあらはたがしき方に山を通しあらんめてみかし" />
  <LINE TYPE="本文" X="794" Y="206" WIDTH="26" HEIGHT="184" CONF="0.661" ORDER="9" STRING="嘉永四年五月三日" />
  <LINE TYPE="本文" X="789" Y="576" WIDTH="40" HEIGHT="181" CONF="0.564" ORDER="10" STRING="鳴川繁楽" />
