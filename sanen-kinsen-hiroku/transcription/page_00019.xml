<PAGE IMAGENAME="page_00019.jpg" WIDTH="1525" HEIGHT="1024">
  <LINE TYPE="本文" X="1278" Y="275" WIDTH="35" HEIGHT="567" CONF="0.685" ORDER="0" STRING="二十八首桂正者曰仁ハ四ナリ時節午待ナリイナカスナリ" />
<LINE TYPE="本文" X="1222" Y="117" WIDTH="44" HEIGHT="795" CONF="0.869" ORDER="1" STRING="一売買をせがず答がず侍とくの乘まで待も仁なり" />
  <LINE TYPE="本文" X="1170" Y="119" WIDTH="38" HEIGHT="789" CONF="0.904" ORDER="2" STRING="只せくるせく商力に徳はなし五分安を買五分高をうれ" />
  <LINE TYPE="本文" X="1116" Y="114" WIDTH="40" HEIGHT="797" CONF="0.915" ORDER="3" STRING="売買をせけはせらほど損をするとんと抔で手をかへて見よ" />
  <LINE TYPE="本文" X="1059" Y="114" WIDTH="40" HEIGHT="802" CONF="0.909" ORDER="4" STRING="一亥年の米のきれめの音などれ待てうるのが仁のとくなり" />
  <LINE TYPE="本文" X="1004" Y="119" WIDTH="36" HEIGHT="790" CONF="0.899" ORDER="5" STRING="たゞせらに百俵あげて百俵さげたためしがおほき事なり" />
  <LINE TYPE="本文" X="949" Y="111" WIDTH="37" HEIGHT="801" CONF="0.910" ORDER="6" STRING="買せさをせぬか強気の秘密なり筋でも出きるを聞つて買" />
  <LINE TYPE="本文" X="895" Y="111" WIDTH="39" HEIGHT="799" CONF="0.902" ORDER="7" STRING="売せきをせぬか弱気の秘密なりいつでも有もるをまつて売" />
  <LINE TYPE="本文" X="844" Y="111" WIDTH="37" HEIGHT="807" CONF="0.885" ORDER="8" STRING="三年にも二年にもいらぬ安直段せかずにまつがだいこみつなり" />
  <LINE TYPE="本文" X="794" Y="116" WIDTH="34" HEIGHT="794" CONF="0.884" ORDER="9" STRING="一平もいらぬ時節を待がよしこかせとゆえにかららすをふむ" />
  <LINE TYPE="本文" X="684" Y="113" WIDTH="46" HEIGHT="800" CONF="0.882" ORDER="10" STRING="下流理にも時いたられば下はまじ買ぜきするは大たわけなり" />
  <LINE TYPE="本文" X="632" Y="109" WIDTH="46" HEIGHT="807" CONF="0.895" ORDER="11" STRING="一土海理にも時節がこねは上らぬぞ世を買をして悔むまじきぞ" />
  <LINE TYPE="本文" X="578" Y="109" WIDTH="50" HEIGHT="805" CONF="0.888" ORDER="12" STRING="せ候故に安きをうりてあたまから書きをかにてかららすを踏" />
  <LINE TYPE="本文" X="523" Y="109" WIDTH="50" HEIGHT="803" CONF="0.914" ORDER="13" STRING="上るべき気がつきぬればおのづからくごるところか天性としれ" />
  <LINE TYPE="本文" X="468" Y="108" WIDTH="46" HEIGHT="803" CONF="0.885" ORDER="14" STRING="一下るほどくごれは弱気の気もつきて上海ところか天性としれ" />
  <LINE TYPE="本文" X="404" Y="66" WIDTH="50" HEIGHT="845" CONF="0.836" ORDER="15" STRING="○風ふかぬ二百廿日の安直段定式として半はうけてころ" />
  <LINE TYPE="本文" X="349" Y="102" WIDTH="48" HEIGHT="809" CONF="0.870" ORDER="16" STRING="万人別あきれはてたる直がおれ候そそれ前高くりの毘なりけり" />
  <LINE TYPE="本文" X="297" Y="82" WIDTH="45" HEIGHT="830" CONF="0.880" ORDER="17" STRING="○雨風の日をまはうけて米は売日和をまさて米は買べし" />
  <LINE TYPE="本文" X="243" Y="107" WIDTH="47" HEIGHT="802" CONF="0.879" ORDER="18" STRING="順徳の智のみなもなは遂小第そのみなもことまつ仁にあり" />
  <LINE TYPE="本文" X="193" Y="249" WIDTH="35" HEIGHT="571" CONF="0.716" ORDER="19" STRING="勇二十六日辛子ナリストナリストナリ平スナリ" />
  </PAGE>

