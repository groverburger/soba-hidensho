  <LINE TYPE="本文" X="349" Y="100" WIDTH="42" HEIGHT="814" CONF="0.843" ORDER="17" STRING="庚申より十一日の庚午より去間獄丁丑の日間日なり" />
  <LINE TYPE="本文" X="299" Y="444" WIDTH="37" HEIGHT="455" CONF="0.347" ORDER="18" STRING="なり以上十五日の間は風吹ぬものな" />
