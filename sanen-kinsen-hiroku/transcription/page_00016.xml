  <LINE TYPE="本文" X="1054" Y="254" WIDTH="41" HEIGHT="363" CONF="0.873" ORDER="5" STRING="中豊作二箇年" />
  <LINE TYPE="本文" X="1004" Y="309" WIDTH="36" HEIGHT="244" CONF="0.861" ORDER="6" STRING="豊作と同断" />
  <LINE TYPE="本文" X="942" Y="101" WIDTH="43" HEIGHT="793" CONF="0.765" ORDER="7" STRING="戊午壬辰●摂正者日以上大周六十年也" />
  <LINE TYPE="本文" X="892" Y="119" WIDTH="38" HEIGHT="666" CONF="0.863" ORDER="8" STRING="右にあたるとしは豊平といへども中分の耳なり" />
  <LINE TYPE="本文" X="840" Y="209" WIDTH="42" HEIGHT="406" CONF="0.848" ORDER="9" STRING="○大潮小汐の考周" />
  <LINE TYPE="本文" X="784" Y="108" WIDTH="42" HEIGHT="793" CONF="0.851" ORDER="10" STRING="小しほとは六七八と九と十と二十一二と三四五としれ" />
  <LINE TYPE="本文" X="677" Y="98" WIDTH="48" HEIGHT="811" CONF="0.859" ORDER="11" STRING="一右の外皆大潮なり小汐の三日間大谷の日なり大風ふき" />
  <LINE TYPE="本文" X="628" Y="98" WIDTH="49" HEIGHT="810" CONF="0.858" ORDER="12" STRING="いだすなり風の吹出しはさししほに吹出し満汐にやむ" />
