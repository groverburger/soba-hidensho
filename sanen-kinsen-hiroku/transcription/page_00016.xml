  <LINE TYPE="本文" X="1274" Y="106" WIDTH="47" HEIGHT="804" CONF="0.867" ORDER="0" STRING="戊申乙卯丙辰丁己巳未庚申癸亥" />
  <LINE TYPE="本文" X="1217" Y="107" WIDTH="46" HEIGHT="804" CONF="0.896" ORDER="1" STRING="一右にあたるとしは勝負鬱発の変気もならは翌年" />
