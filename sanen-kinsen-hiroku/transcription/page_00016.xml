  <LINE TYPE="本文" X="515" Y="98" WIDTH="44" HEIGHT="812" CONF="0.843" ORDER="14" STRING="十五日晦日の三ほは六ツに満夜ひるともに九ツにひく" />
  <LINE TYPE="本文" X="461" Y="99" WIDTH="46" HEIGHT="817" CONF="0.856" ORDER="15" STRING="〽さししほは日々に四分づとおほく湯いくも四分づとおそくいく也" />
