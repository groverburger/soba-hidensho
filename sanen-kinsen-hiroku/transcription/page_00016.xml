  <LINE TYPE="本文" X="238" Y="111" WIDTH="45" HEIGHT="795" CONF="0.876" ORDER="22" STRING="り故に推にいると海上に船を乗り出し申なり万一にけ" />
  <LINE TYPE="本文" X="188" Y="119" WIDTH="42" HEIGHT="690" CONF="0.848" ORDER="23" STRING="は間になり、それも百年のうちの一年と考へしるべし" />
