<PAGE IMAGENAME="page_00009.jpg" WIDTH="1525" HEIGHT="1024">
  <LINE TYPE="本文" X="1270" Y="114" WIDTH="44" HEIGHT="797" CONF="0.827" ORDER="0" STRING="公にても三割さげは米くづれ万天元のかひ旬々知れ" />
  <LINE TYPE="本文" X="1218" Y="222" WIDTH="37" HEIGHT="689" CONF="0.694" ORDER="1" STRING="一中の飲米は日々に二万俵一箇月には六十万俵なり" />
  <LINE TYPE="本文" X="1163" Y="116" WIDTH="41" HEIGHT="799" CONF="0.756" ORDER="2" STRING="京大阪場ふし見の飲米は二箇月には十五万余" />
  <LINE TYPE="本文" X="1109" Y="117" WIDTH="43" HEIGHT="795" CONF="0.877" ORDER="3" STRING="ふところに金をたやさぬ覚悟せよ金は米釣しほと知るべし" />
  <LINE TYPE="本文" X="1055" Y="115" WIDTH="41" HEIGHT="791" CONF="0.883" ORDER="4" STRING="文珠でも備へのこゝらぬ商内は宣下の変別あれどやぶは" />
  <LINE TYPE="本文" X="997" Y="111" WIDTH="39" HEIGHT="800" CONF="0.855" ORDER="5" STRING="一売買はいはさの備へも同じこと米等きなひの軍兵はかね" />
  <LINE TYPE="本文" X="939" Y="237" WIDTH="41" HEIGHT="261" CONF="0.529" ORDER="6" STRING="○十五禁言ナ" />
  <LINE TYPE="本文" X="960" Y="486" WIDTH="19" HEIGHT="69" CONF="0.596" ORDER="7" STRING="十五首" />
  <LINE TYPE="本文" X="945" Y="554" WIDTH="21" HEIGHT="60" CONF="0.485" ORDER="8" STRING="十四" />
<LINE TYPE="本文" X="886" Y="115" WIDTH="39" HEIGHT="793" CONF="0.892" ORDER="9" STRING="侍へなき商力ならはいつれても損徳なしに商内禁制" />
  <LINE TYPE="本文" X="835" Y="113" WIDTH="40" HEIGHT="796" CONF="0.892" ORDER="10" STRING="大法が秋冬五月はた禁制春六七月はかいはきむぜい" />
  <LINE TYPE="本文" X="783" Y="114" WIDTH="41" HEIGHT="794" CONF="0.859" ORDER="11" STRING="豊早は万人気弱く我よわしあきにまりてうりは禁制" />
  <LINE TYPE="本文" X="681" Y="114" WIDTH="45" HEIGHT="792" CONF="0.871" ORDER="12" STRING="鼻は子気強く亦強し多きにありて買は禁制" />
  <LINE TYPE="本文" X="628" Y="108" WIDTH="49" HEIGHT="801" CONF="0.892" ORDER="13" STRING="一弱気理世に現れおれは皆弱気安きによつて場は禁制" />
  <LINE TYPE="本文" X="572" Y="109" WIDTH="48" HEIGHT="798" CONF="0.913" ORDER="14" STRING="強変が現れ出れ婆皆強気咲きにまへてかひは葉刺" />
  <LINE TYPE="本文" X="523" Y="108" WIDTH="41" HEIGHT="802" CONF="0.909" ORDER="15" STRING="あがりあし見ばかく見ゆる米ならは年は強みも四は禁制" />
  <LINE TYPE="本文" X="465" Y="108" WIDTH="43" HEIGHT="797" CONF="0.899" ORDER="16" STRING="さげる理と手にとるやうに思ふるも秋植のうへの湊して禁制" />
  <LINE TYPE="本文" X="408" Y="116" WIDTH="45" HEIGHT="786" CONF="0.904" ORDER="17" STRING="五月米人気弱くて直は上る早々強けまで売は禁制" />
  <LINE TYPE="本文" X="354" Y="111" WIDTH="43" HEIGHT="799" CONF="0.895" ORDER="18" STRING="さが理とたりしく思に米にても四五月頃のはこる葉刻" />
  <LINE TYPE="本文" X="297" Y="111" WIDTH="46" HEIGHT="799" CONF="0.896" ORDER="19" STRING="天性の説は水無月に出るとしれ米に随ひ平来禁制" />
  <LINE TYPE="本文" X="243" Y="112" WIDTH="46" HEIGHT="796" CONF="0.886" ORDER="20" STRING="洪水を大風ふきの飛等なりはいつのとしでも買は禁制" />
  <LINE TYPE="本文" X="186" Y="115" WIDTH="50" HEIGHT="793" CONF="0.873" ORDER="21" STRING="米はづれ買落紙の土みせげは気そまつくとも端は禁制" />
