  <LINE TYPE="本文" X="1074" Y="101" WIDTH="37" HEIGHT="373" CONF="0.758" ORDER="4" STRING="天地陰陽の気をうけ" />
  <LINE TYPE="本文" X="1071" Y="470" WIDTH="21" HEIGHT="60" CONF="0.655" ORDER="5" STRING="士略" />
<LINE TYPE="本文" X="1093" Y="468" WIDTH="22" HEIGHT="114" CONF="0.702" ORDER="6" STRING="四民工商" />
  <LINE TYPE="本文" X="1078" Y="580" WIDTH="34" HEIGHT="328" CONF="0.763" ORDER="7" STRING="を申しなふ天下才" />
  <LINE TYPE="本文" X="1011" Y="120" WIDTH="47" HEIGHT="795" CONF="0.860" ORDER="8" STRING="一の宝なり三猿とは見猿聞猿言猿の三なり眼に" />
  <LINE TYPE="本文" X="955" Y="118" WIDTH="46" HEIGHT="798" CONF="0.885" ORDER="9" STRING="一強変を見て心に強変を測に沈むことなかれ只心" />
  <LINE TYPE="本文" X="902" Y="118" WIDTH="44" HEIGHT="802" CONF="0.878" ORDER="10" STRING="に可含売耳に弱変を聞て心に弱変の渕に沈むこと" />
  <LINE TYPE="本文" X="852" Y="125" WIDTH="42" HEIGHT="790" CONF="0.876" ORDER="11" STRING="となかれ只心に可含買強変を見聞とも人にかたること" />
  <LINE TYPE="本文" X="797" Y="116" WIDTH="46" HEIGHT="810" CONF="0.856" ORDER="12" STRING="となかれ言は人の心と迷はす是三猿の秘密なり金" />
  <LINE TYPE="本文" X="695" Y="119" WIDTH="35" HEIGHT="379" CONF="0.864" ORDER="13" STRING="泉録とは此書の号なり" />
  <LINE TYPE="本文" X="644" Y="167" WIDTH="42" HEIGHT="704" CONF="0.851" ORDER="14" STRING="一高安の理は空理にて眼に見えずかげも形も無物が躰" />
  <LINE TYPE="本文" X="585" Y="116" WIDTH="44" HEIGHT="802" CONF="0.865" ORDER="15" STRING="上の句の心を考ふなに法をもて上るともいつさがることも" />
  <LINE TYPE="本文" X="530" Y="115" WIDTH="44" HEIGHT="803" CONF="0.893" ORDER="16" STRING="一定までざるが空理なり空理と見れば千年に一度もらり" />
  <LINE TYPE="本文" X="472" Y="118" WIDTH="45" HEIGHT="801" CONF="0.884" ORDER="17" STRING="買する時節となしまた下の句の心を差ふるにかげも形" />
  <LINE TYPE="本文" X="418" Y="119" WIDTH="45" HEIGHT="800" CONF="0.887" ORDER="18" STRING="も無物が体とあり鯡あれは定式あり定式あさる売買あ" />
  <LINE TYPE="本文" X="362" Y="120" WIDTH="44" HEIGHT="796" CONF="0.902" ORDER="19" STRING="り仏道の定式は五戒儒道の定式も五常神道の定" />
  <LINE TYPE="本文" X="309" Y="124" WIDTH="42" HEIGHT="787" CONF="0.905" ORDER="20" STRING="式は智仁勇の三徳みなされ〳〵定式あり●こか申す" />
